gomodel:5970219a00000711
        a                 owl:Ontology ;
        rdfs:comment      "While it's true that the apical PM urothelial plaque is part of 'apical PM', not really keen on getting both CC annots for Upk3a & Upk3b, perhaps it would be better to make the 'occurs in' relationships to the cell type term instead of to 'apical plasma membrane'" , "J:226950" , "trying to indicate that Exoc5 is involved in localization of uroplakin 3's to 'apical side of plasma membrane', but we don't have a localization term specifically to apical PM" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-5501-853X" , "https://orcid.org/0000-0001-7476-6306" ;
        dc:date           "2017-08-24" ;
        dc:title          "PMID:26046524-KRC Exoc5 (Sec10)" ;
        pav:providedBy    "http://informatics.jax.org" ;
        oboInOwl:id       "gomodel:5970219a00000711" ;
        biolink:in_taxon  obo:NCBITaxon_10090 .

