<http://identifiers.org/mgi/MGI:2140882> a owl:Class .

<http://model.geneontology.org/5970219a00000711> a owl:Ontology ;
    ns2:modelstate "production"^^xsd:string ;
    dc:contributor "https://orcid.org/0000-0001-5501-853X"^^xsd:string,
        "https://orcid.org/0000-0001-7476-6306"^^xsd:string ;
    dc:date "2017-08-24"^^xsd:string ;
    dc:title "PMID:26046524-KRC Exoc5 (Sec10)"^^xsd:string ;
    ns3:providedBy "http://informatics.jax.org"^^xsd:string ;
    ns5:id "gomodel:5970219a00000711"^^xsd:string ;
    rdfs:comment "J:226950"^^xsd:string,
        "While it's true that the apical PM urothelial plaque is part of 'apical PM', not really keen on getting both CC annots for Upk3a & Upk3b, perhaps it would be better to make the 'occurs in' relationships to the cell type term instead of to 'apical plasma membrane'"^^xsd:string,
        "trying to indicate that Exoc5 is involved in localization of uroplakin 3's to 'apical side of plasma membrane', but we don't have a localization term specifically to apical PM"^^xsd:string ;
    ns6:in_taxon ns4:NCBITaxon_10090 .

