[ a                      owl:Axiom ;
  rdfs:comment           "Author_statement: \"Interestingly, however, the amplitude of AVA's activity inversely correlates with the worm's velocity immediately post stimulus (Pearsons correlation coefficient R = −0.83), irrespective of stimulus Figure ​Figure4A.4A. Thus our data indicate that AVA's activity directly correlates with the worm's velocity and not with whether ALM, AVM or both are stimulated.\"" ;
  lego:evidence          :6168d1e000000535 ;
  dc:contributor         "https://orcid.org/0000-0002-8151-7479" ;
  dc:date                "2021-10-19" ;
  pav:providedBy         "http://www.wormbase.org" ;
  owl:annotatedProperty  obo:RO_0002327 ;
  owl:annotatedSource    :6168d1e000000496 ;
  owl:annotatedTarget    :6168d1e000000523
] .

