gomodel:SYNGO_3078  a     owl:Ontology ;
        rdfs:comment      "Rationale: From Results section:\n\"Closer inspection revealed PAR1b distribution in dendritic shafts and concentration in dendritic spines, which contained the postsynaptic marker PSD95 (Fig. 1D, arrows). These subcellular PAR1b signals were also confirmed by PAR1b monoclonal antibody (data not shown). These results revealed PAR1b expression in dendritic shafts and spines.\". Experimental description: From M&M section:\n\"Primary hippocampal neuronal cultures were established from ICR mouse embryonic hippocampal tissue (embryonic day 16) of either sex.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-6893-6177" , "https://orcid.org/0000-0002-5265-6306" ;
        dc:date           "2018-04-09" ;
        dc:title          "SYNGO_CC_3078" ;
        pav:providedBy    "https://syngo.vu.nl" ;
