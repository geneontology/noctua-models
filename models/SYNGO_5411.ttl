gomodel:SYNGO_5411  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 5a: \"In cultured hippocampal neurons transfected with an N-terminal GFP-tagged phactr construct, subcellular distribution was throughout cell bodies and dendrites, with apparent enrichment in dendritic spines. Phactr-1 was found in the perinuclear region but was absent from cell nuclei.\"\n\nFigure 5b: \"Subcellular fractionation of rat brain homogenate supported the observation that phactr-1 may be localized at synapses because the protein was found to be present in postsynaptic density (PSD) fractions.\". Experimental description: we annotate against rat species, as this is the endogenous protein observed in Figure 5: \"Subcellular fractionation of rat brain homogenate supported the observation that phactr-1 may be localized at synapses because the protein was found to be present in postsynaptic density (PSD) fractions\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2023-03-15" ;
        dc:title          "SYNGO_CC_5411" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

