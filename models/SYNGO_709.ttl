        a       owl:Class .

gomodel:SYNGO_709  a      owl:Ontology ;
        rdfs:comment      "Rationale: NCS-1 is found in dendritic shafts and spines. Pre-immbedding immunolabeling of NCS-1 in striatum brain slices from rat. The NCS-1 signal was enhanced by a DAB reaction. No KO control or antibody verifications. The images show labeling for NCS-1 in spines and dendritic shafts. No quantifications. DAB signal may diffuse to a rather large distance from the primary antibody, making the spatial resolution of such information difficult to interpret, hence the annotation to 'postsynaptic cytosol' .. Experimental description: Three adult Wistar rats and two adult rhesus monkeys (Macaca mulatta) of both\nsexes were perfused, and brain tissue was prepared as described." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-0755-5899" , "https://orcid.org/0000-0001-7351-8706" , "https://orcid.org/0000-0003-0938-8534" , "https://orcid.org/0000-0003-3185-5709" ;
        dc:date           "2017-08-16" ;
        dc:title          "SYNGO_CC_709" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

