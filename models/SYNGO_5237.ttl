obo:GO_0003674  a  owl:Class .

gomodel:SYNGO_5237  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 4-7: immunogold EM of rat striatum tissue showed Striatin (STRN) was localized to dendrites, dendritic spines and (to a lesser extend) PSD.\n\nAuthors comment on non-postsynaptic localization:\n\"In agreement with previous observations by Castets et al.,[PMID:8769426] axonal processes and terminals, as well as myelinated fibres bundles, were devoid of striatin immunolabelling. So were glial cells, pericytes and endothelial capillary cells.\". Experimental description: M&M: \"All experiments were carried out on adult female Wistar rats (220-240 g; Iffa-Credo) kept under standard laboratory conditions\"\n\nantibody:\n\"rabbit anti-striatin antibody (1-3 μg/ml of affinity-purified antibodies directed against peptide II, corresponding to amino acids 191-205), previously characterized by Castets et al.,[3]\" PMID:8769426" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2023-03-08" ;
        dc:title          "SYNGO_CC_5237" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

