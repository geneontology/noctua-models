:R-HSA-9613354  a           obo:GO_0061724 , owl:NamedIndividual ;
        rdfs:comment        "Triglycerides stored in lipid droplets are hydrolysed under nutrient starvation to release fatty acids for energy. The content of lipid droplets may vary but they are all coated with a protective protein called perilipin. When this protein is degraded, lipid droplets associate with autophagic components and breakdown into fatty acids (Ward C et al. 2016, Schulze R J et al. 2017). This process is termed as lipophagy (Singh R et al. 2009)." ;
        rdfs:label          "Lipophagy" ;
        dc:contributor      "GOC:reactome_curators" , "Authored: Varusai, Thawfeek, 2019-02-21" , "Edited: Varusai, Thawfeek, 2019-11-08" , "Reviewed: Metzakopian, Emmanouil, 2019-02-22" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-9613354" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-9663891/R-HSA-9663891> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

