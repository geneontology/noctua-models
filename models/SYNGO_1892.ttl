obo:GO_0003674  a  owl:Class .

gomodel:SYNGO_1892  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 3A. (A) Analysis of protein phosphatases PP1, PP2A and Anp32e / Cpd1 was performed by Western blotting assays in homogenates and synaptic fractions at P7, P12 and P17. The homogenate and the synaptic fraction contain similar amounts of PP2Ac or PP1c catalytic subunits at all stages studied.\n\nSubcellular fractionation was performed from adult murine brains and cerebella.\n\n13/11/2017 Pim\n- Auhtors use the term PP2A, and show the localization of this protein complex with a PP2Ac antibody.\n- Authors also show localization to dendrites via IF (Fig.6). Experimental description: Wild-type C57BL / 6J (Rora+ / Rora+), from Jackson Laboratories (Bar Harbor, ME, USA)\nP7, P12, P17" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-1190-4481" , "https://orcid.org/0000-0002-4419-210X" , "https://orcid.org/0000-0002-2094-7491" , "https://orcid.org/0000-0002-9848-0262" ;
        dc:date           "2017-11-13" ;
        dc:title          "SYNGO_CC_1892" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

