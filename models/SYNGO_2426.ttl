gomodel:SYNGO_2426  a     owl:Ontology ;
        rdfs:comment      "Rationale: Pharmacological inhibition results in changes in spontaneous miniature excitatory and inhibitory events. This is indicative of a presynaptic effect. Numerous drugs were used to narrow the interpretation implying mGlur8. Experimental description: Methods:\nBriefly, female and male Wistar rats (1-2 months old) were anaesthetized with isofluorane and decapitated." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-5648-066X" , "https://orcid.org/0000-0001-7480-0826" , "https://orcid.org/0000-0003-4022-8707" , "https://orcid.org/0000-0002-1212-5623" , "https://orcid.org/0000-0003-2533-9548" ;
        dc:date           "2018-03-19" ;
        dc:title          "SYNGO_BP_2426" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

