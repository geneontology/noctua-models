gomodel:SYNGO_687  a      owl:Ontology ;
        rdfs:comment      "Rationale: Authors found CHMP4B present in synaptoneurosomal fractions from rat cortical lysates and highly enriched in PSDI fractions. PSDI fractions are the insoluble material obtained by treating synaptoneuronamal fractions with Triton X100. Unlike PSD95, CHMP4B was solubilized after treatment of this fraction with more stringent detergents, suggesting that it is a peripherally attached PSD protein.. Experimental description: From M&M:\nPregnant Oncins France souche A (OFA; a substrain of Sprague Dawley) rats (Charles River) were used for primary neuron cultures, and 2-month-old OFA rats of both sexes were used for biochemical analysis of brain tissue.\n\n14/6/2017 Pim:\nIn rat no reviewed sequences exist and protein names \"Chmp4bl1\" and \"Chmp4b\" are filed under a single non-reviewed sequence." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0575-6950" , "https://orcid.org/0000-0002-1585-539X" ;
        dc:date           "2017-08-10" ;
        dc:title          "SYNGO_CC_687" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

pav:providedBy  a  owl:AnnotationProperty .

