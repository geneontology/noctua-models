obo:GO_0098793  a  owl:Class .

gomodel:SYNGO_706  a      owl:Ontology ;
        rdfs:comment      "Rationale: An antibody against synaptojanin 1 (then called p145) was used for immunofluorescence in frozen sections of rat brain. Synaptojanin was localized to presynaptic nerve terminals based on co-localization with synapsin. The GO term cytosol was selected because at this level it is not possible to define better localization.. Experimental description: from legend to Fig. 5, \"Localization of p145 and synapsin I by double immunofluorescence in frozen sections of rat brain\"." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-7806-5662" ;
        dc:date           "2017-08-14" ;
        dc:title          "SYNGO_CC_706" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

