gomodel:SYNGO_248  a      owl:Ontology ;
        rdfs:comment      "Rationale: Fig.2: colocalization of ADAM10 with PSD-95 asnd Shank, not with synaptophysin.\nFig.4-5: ADAM10 translocates into dendritic spine upon NMDA-R activation.\n\nNote: ADAM10 has TM domain, but exeriments do not show membrane localization. Therefore, only **postsynapse** annotation is made.. Experimental description: Experiments with cultured neurons are from **rat**. These experiments are featured in Fig.2,4, and 5.\n\nliteral M&M:\n\"CELL CULTURES AND TRANSFECTION.\nHippocampal neuronal cultures were prepared from embryonic day 18 (E18) to E19 rat hippocampi as described previously.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-2949-9725" , "https://orcid.org/0000-0003-0662-9523" ;
        dc:date           "2017-11-08" ;
        dc:title          "SYNGO_CC_248" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

