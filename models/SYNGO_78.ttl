obo:GO_0003674  a  owl:Class .

gomodel:SYNGO_78  a       owl:Ontology ;
        rdfs:comment      "Rationale: This study provides some evidence that PLD1 is present at the synapse. PLD1b was detected in the PM fraction of subcellular fractionation from synaptosomes (figure 1A). No controls for the fractionation were provided, which makes it hard to tell what the fractions really contain.\n\nThe antibody does not show cross-reactivity with PLD2 in HEK cell lysates (figure 2).\n\nThe study also includes some confocal microscopy on cultured neurons, but this is of unsufficient quality for annotation.. Experimental description: Synaptosomes prepared from rat brain according to Huttner\net al.(16)." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-7620-2704" , "https://orcid.org/0000-0002-1558-1958" ;
        dc:date           "2017-11-22" ;
        dc:title          "SYNGO_CC_78" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

