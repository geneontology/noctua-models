gomodel:ev_w_id_CHORISMATE-SYNTHASE-RXN_BFO_0000066_reaction_CHORISMATE-SYNTHASE-RXN_location_lociGO_0005829_SGD_PWY_YeastPathways_ARO-PWY-1
        a                   owl:NamedIndividual , obo:ECO_0000245 ;
        lego:evidence-with  "SGD_PWY:ARO-PWY-1" ;
        dc:contributor      "GOC:sgd_curators" ;
