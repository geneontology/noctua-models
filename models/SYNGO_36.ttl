gomodel:SYNGO_36  a       owl:Ontology ;
        rdfs:comment      "Rationale: Ultrastructural localization of immunoreactivities of alpha- and beta-SNAP visualized with nanogold-silver enhancing technique shows immunoreactivity on synaptic vesicles in Neuromuscular junction. In basket cell terminals in the cerebellum, immunoreactivity was localized on presynaptic plasma membranes. In mossy fiber terminals in the cerebellum, immunoreactivity mainly distributed on presynaptic plasma membranes near postsynaptic densities. Table 1 summarises their findings: alpha-SNAP is mainly localised in presyanpses on membranes and vesicles but is also present at extra-synaptic sites.. Experimental description: M&M: Rats (from either Charles River Japan, Yokohama, Japan or Japan SLC, Hamamatsu, Japan)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9900-4233" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2018-07-26" ;
        dc:title          "SYNGO_CC_36" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

