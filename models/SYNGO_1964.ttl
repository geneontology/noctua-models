gomodel:SYNGO_1964  a     owl:Ontology ;
        rdfs:comment      "Rationale: This paper shows the ultrastructural localization of drebrin A primarily in dendritic spines, as visualized by horseradish peroxidase/diaminobenzidine (HRP/DAB) staining (Figure 1). The localization was highest in the spine cytoplasm (~56%), with smaller fractions in or at the PSD (~25%), and at the plasma membrane (~15%) (Figure 3).. Experimental description: from M&M: \"C57BL mice were purchased from Charles River (Tsukuba, Japan) and bred and housed\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-6153-3586" , "https://orcid.org/0000-0002-2666-0758" ;
        dc:date           "2017-11-23" ;
        dc:title          "SYNGO_CC_1964" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

