obo:UBERON_0002435  a  owl:Class .

dc:contributor  a  owl:AnnotationProperty .

gomodel:SYNGO_5014  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 2: Electron micrographs show immunolabeling for Gβ5 (GNB5) at the synapse in mouse striatum and hippocampus while labeling was abolished in knockout controls.\n\n\"In striatum (A-C), and hippocampus (D-F) immunoparticles for Gβ5 were detected postsynaptically along the somatic plasma membrane (arrows), and intracellular sites (crossed arrows) of dendritic shafts (Den) and dendritic spines (s). In addition, immunoparticles for Gβ5 were detected at presynaptic sites, along the extrasynaptic plasma membrane (arrowheads) of axon terminals (at) establishing excitatory synapses with dendritic shafts or dendritic spines (s). Immunoreactivity for Gβ5 was completely absent in Gβ5-/-samples\". Experimental description: M&M: \"The Gβ5-/-mice were generated previously and were back-crossed with C57/Bl6 mice for six generations\"\n\nantibody:\n\"We would like to thank Dr. Ching-Kang Jason Chen (VCU) for providing Gβ5-/-mouse line and Dr. William Simonds (NIH) for the generous gift of anti-Gβ5 antibodies\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2023-02-18" ;
        dc:title          "SYNGO_CC_5014" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

