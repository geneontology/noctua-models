gomodel:ev_w_id_R-HSA-1912372_RO_0002411_R-HSA-1912355_Reactome_R-HSA-1912420_R-HSA-1912355_enabled_by_UniProt_Q8NES3_R-HSA-1912355_controller
        a               owl:NamedIndividual , obo:ECO_0000313 ;
        dc:contributor  "GOC:reactome_curators" ;
