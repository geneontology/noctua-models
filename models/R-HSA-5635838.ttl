<http://model.geneontology.org/ev_w_id_R-HSA-5632672_RO_0002233_R-ALL-5632460_cilium_Reactome_R-HSA-5632672>
        a       <http://purl.obolibrary.org/obo/ECO_0000313> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
