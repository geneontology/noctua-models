<http://model.geneontology.org/ev_w_id_R-HSA-5632672_BFO_0000050_R-HSA-5635838/R-HSA-5635838_Reactome_R-HSA-5635838>
        a               owl:NamedIndividual , obo:ECO_0000313 ;
        dc:contributor  "GOC:reactome_curators" ;
