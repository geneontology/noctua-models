obo:ECO_0006063  a  owl:Class .

pav:providedBy  a  owl:AnnotationProperty .

gomodel:SYNGO_5432  a     owl:Ontology ;
        rdfs:comment      "Rationale: - KIF1A directly interacts with CaM and with the scaffolds liprin-α and TANC2.\n- KIF1A is regulated by a Ca2+/CaM-dependent mechanism, which allows for DCV loading.\n- Liprin-α and TANC2 are static PSD proteins that are not part of the KIF1A-DCV complex.\n- KIF1A-driven DCVs are recruited to dendritic spines by liprin-α and TANC2.\n\n\"We showed that calcium, acting via CaM, enhances KIF1A binding to DCVs and increases vesicle motility. In contrast, liprin-α and TANC2 are not part of the KIF1A-cargo complex but capture DCVs at dendritic spines.\". Experimental description: M&M: \"Female pregnant Wister rats were obtained from Janvier Laboratories. Hippocampal neurons were obtained from embryos of both genders at the embryonic day 18 (E18) stage of development.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2023-03-16" ;
        dc:title          "SYNGO_BP_5432" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

