obo:UBERON_0001950  a  owl:Class .

gomodel:SYNGO_2522  a     owl:Ontology ;
        rdfs:comment      "Rationale: This study shows that DRD2 modulates synaptic transmission via postsynaptic modulation of cell excitability via modulation of NMDARs and AMPARs.\n\nNote: the high level term 'postsynaptic modulation of chemical synaptic transmission (GO:0099170)' was selected because the underlying mechanism of increased NTR responses is not explained. Beware: the term 'regulation of postsynaptic neurotransmitter receptor activity (GO:0098962)' was note selected because reserved for proteins that modulate the intrinsic channel properties of NTRs.. Experimental description: \"Male Sprague Dawley rats (Charles River Laboratories, Wilmington, MA) were maintained on a 12 hr...\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0003-0593-3443" ;
        dc:date           "2018-02-14" ;
        dc:title          "SYNGO_BP_2522" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

