:R-HSA-169911  a            owl:NamedIndividual , obo:GO_0042981 ;
        rdfs:comment        "A regulated balance between cell survival and apoptosis is essential for normal development and homeostasis of multicellular organisms (see Matsuzawa, 2001). Defects in control of this balance may contribute to autoimmune disease, neurodegeneration and cancer. Protein ubiquitination and degradation is one of the major mechanisms that regulate apoptotic cell death (reviewed in Yang and Yu 2003)." ;
        rdfs:label          "Regulation of Apoptosis" ;
        dc:contributor      "Authored: Jakobi, R, 2008-02-05 11:04:14" , "Edited: Matthews, L, 2008-02-12 16:13:24" , "GOC:reactome_curators" , "Reviewed: Chang, E, 2008-05-21 00:05:41" , "Edited: Matthews, L, 2008-06-12 00:23:53" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-169911" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-109581/R-HSA-109581> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

