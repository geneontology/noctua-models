gomodel:SYNGO_1062  a     owl:Ontology ;
        rdfs:comment      "Rationale: In this study authors generated antisera against calcineurin A alpha by immunizing a rabbit and used it to detect calcineurin A alpha in different subcellular fractions prepared from rat brain. Though data showing the relative amounts of calcineurin A alpha in the different fractions is only presented in a table format and blots are not shown, authors claim that Calcineurin A alpha is enriched in the P2C fraction containing synaptosomes, and when this fraction was lysed, 80% of the protein was recovered in the soluble fraction, which suggest that calcineurin A alpha is most abundant in the synaptic cytosol.. Experimental description: \"For quantitative determination of the isoforms in tissue\nhomogenates from various regions of the rat brain and in aliquots of subcellular fractions, male Wistar rats (weighing 150-200 g) were decapitated, and brains were quickly removed.\"\n\nThe antisera was prepared against the rat Calcineurin A alpha sequence as described in Ito et al., 1989." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0575-6950" , "https://orcid.org/0000-0002-1585-539X" ;
        dc:date           "2017-08-11" ;
        dc:title          "SYNGO_CC_1062" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

pav:providedBy  a  owl:AnnotationProperty .

