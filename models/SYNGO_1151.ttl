obo:GO_0099171  a  owl:Class .

gomodel:SYNGO_1151  a     owl:Ontology ;
        rdfs:comment      "Rationale: The adenosine A2B receptor is a G-protein coupled receptor that is involved in the modulation of synaptic transmission. Application of the A2B agonist BAY 60-6583 did not modify basal synaptic transmission (Fig. 1c), but caused a decrease in the paired-pulse ratio in the Schaffer collateral - commissural pathway in the hippocampus (Fig. 1d). This effect was blocked by co-application of the \"AB antagonist MRS1754 (Fig. 1e) and in A2B-KO mice (Fig. 1f).. Experimental description: Male C57/BL6 mice (10-12 weeks old) were obtained from Charles River (Barcelona, Spain) and A2BR-KO mice (Belikoff et al., 2011) were kindly donated" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-7351-8706" , "https://orcid.org/0000-0002-0755-5899" , "https://orcid.org/0000-0003-3185-5709" , "https://orcid.org/0000-0003-0938-8534" ;
        dc:date           "2018-05-29" ;
        dc:title          "SYNGO_BP_1151" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

