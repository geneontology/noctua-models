:R-HSA-70921  a             obo:GO_0006548 , owl:NamedIndividual ;
        rdfs:comment        "The major pathway of histidine catabolism, annotated here, proceeds in four steps to yield glutamate and, in the process, convert one molecule of tetrahydrofolate to 5-formiminotetrahydrofolate (Morris et al. 1972). Histidine can also be decarboxylated to form histamine. Histidine can also be used to form carnosine (beta-alanyl-L-histidine), an abundant dipeptide in skeletal muscle and brain of most vertebrates." ;
        rdfs:label          "Histidine catabolism" ;
        dc:contributor      "Edited: D'Eustachio, P, 2003-06-24 00:00:00" , "Reviewed: D'Eustachio, Peter, 2025-11-07" , "Authored: D'Eustachio, P, 2003-06-24 00:00:00" , "Reviewed: D'Eustachio, Peter, 2026-02-25" , "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-70921" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-71291/R-HSA-71291> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

