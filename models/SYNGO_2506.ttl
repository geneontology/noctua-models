gomodel:SYNGO_2506  a     owl:Ontology ;
        rdfs:comment      "Rationale: background: in glutamatergic synapses of medium spiny neurons that express the DRD1 (DR1-MSN) dopamine application within a critical period after synaptic stimulation is able to induce spine morphology changes. The effect is shown to be DRD1 dependent in two ways:\n\n1. The authors state that the MSN neurons mainly express the DRD1 receptor\n2. The effect on spine morphology is shown to be mediated by D1 and not the D2 receptor using pharmacological tools (SCH23390, a claimed selective D1 antagonist).. Experimental description: \"Acute coronal slices of nucleus accumbens (280 um) were obtained from 5- to 7-\nweek-old mice that were injected with AAV...\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2018-02-14" ;
        dc:title          "SYNGO_BP_2506" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

