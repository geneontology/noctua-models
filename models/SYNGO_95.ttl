gomodel:SYNGO_95  a       owl:Ontology ;
        rdfs:comment      "Rationale: Using an isoform-specific antibody and immuno electron microscopy, it is demonstrated that PKC epsilon is present in the presynaptic terminal. The antibody shows no cross reactivity for other PKCs on western blot, but No knockout control is provided.\n\n5/4/2017 Pim\n- The cytosolic localization in the synaptic terminal is inferred from the known activity cycle of PKC.. Experimental description: Frontal sections of the rat brain were prepared and stained as described 27." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-7620-2704" , "https://orcid.org/0000-0002-1558-1958" ;
        dc:date           "2017-04-05" ;
        dc:title          "SYNGO_CC_95" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

