obo:GO_0098978  a  owl:Class .

gomodel:SYNGO_2289  a     owl:Ontology ;
        rdfs:comment      "Rationale: This paper utilizes the Calbindin knockout mouse and directly addresses it role in Ca2+ binding and buffering. Using Calcium Green-1 fluorescence it establishes that calbindin deficient Purkinje cell dendrites have an elevated Ca2+ in response to climbing fibre synaptic inputs. The somatic resting levels of Ca2+ remain unchanged in the wild type showing a selective role to synaptic Ca2+ buffering.\n\n24/01/2018 Pim\n- Calbindin is a known Ca2+-binding protein that has 5 EF-hands.. Experimental description: Materials and Methods Calbindin genomic clones were isolated from a 129sv library (Stratagene) using mouse calbindin cDNA.............." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-0755-5899" , "https://orcid.org/0000-0003-3185-5709" , "https://orcid.org/0000-0001-7351-8706" , "https://orcid.org/0000-0003-0938-8534" ;
        dc:date           "2018-01-24" ;
        dc:title          "SYNGO_MF_2289" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

