:R-HSA-433137  a            obo:GO_0008150 , owl:NamedIndividual ;
        rdfs:comment        "Five human SLC13 genes encode sodium-coupled sulphate, di- and tri-carboxylate transporters located on the plasma membrane. Two transporters (NaS1 and NaS2) co-transport sulphate with sodium. The other members (NaDC1, NaDC3, and NaCT) co-transport sodium with di- and tri-carboxylates such as succinate, citrate and alpha-ketoglutarate (Pajor AM, 2006)." ;
        rdfs:label          "Sodium-coupled sulphate, di- and tri-carboxylate transporters" ;
        dc:contributor      "Edited: Jassal, Bijay, 2009-08-21" , "Authored: Jassal, Bijay, 2009-08-21" , "Reviewed: He, Lei, 2009-11-12" , "Reviewed: D'Eustachio, Peter, 2025-08-12" , "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-433137" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-9958790/R-HSA-9958790> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

