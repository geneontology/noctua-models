obo:ECO_0006067  a  owl:Class .

gomodel:SYNGO_1374  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig3 shows that ARF1 depletion results in reduced F-actin (Fig3A) and reduced F-actin dynamic (Fig3D/E) in spines of rat hippocampal neurons, indicating that ARF1 regulates actin polymerisation in the spine. This phenotype can be rescued by reintroducing ARF1 indicating that it is specific.. Experimental description: M&M: \"Rat embryonic hippocampal neuronal cultures were prepared from E18\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0001-5259-4945" ;
        dc:date           "2017-10-25" ;
        dc:title          "SYNGO_BP_1374" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

