gomodel:SYNGO_1343  a     owl:Ontology ;
        rdfs:comment      "Rationale: Puralpha and PSD-95 co-localised in mature hippocampal neurons DIV15.\n\n24/9/2017 Pim\n- Literal: \"Puralpha immunoreactivity exhibited a granular staining pattern along dendrites (Figure 1A). About one-third of Puralpha granules were colocalized with PSD-95 (Figure 1, A and E). This suggests that some of the Puralpha-positive RNA granules are localized in postsynaptic spines, given that they are specifically localized to dendrites but not axons\". Experimental description: E16 ICR mice" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2094-7491" , "https://orcid.org/0000-0002-9848-0262" , "https://orcid.org/0000-0002-1190-4481" , "https://orcid.org/0000-0002-4419-210X" ;
        dc:date           "2017-09-24" ;
        dc:title          "SYNGO_CC_1343" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

