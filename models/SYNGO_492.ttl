gomodel:SYNGO_492  a      owl:Ontology ;
        rdfs:comment      "Rationale: Knockdown of endogenous MECP2 by MECP2 ShRNAi in rat hippocampal slice cultures (P7-P10) causes a reduction in the density of mature dendritic spines, dendritic nodes, total dendritic length and dendritic intersections at 4 days post transfection.\n\nMECP2 role for proper spine maturation is furthermore demonstrated in Fig. 2: Overexpression of RTT-associated MECP2 mutation causes persistent reduction in dendritic spine density in hippocampal pyramidal neurons.. Experimental description: Sprague-Dawley rats.\n\n29/5/2017 Pim\nspecies of over expressed MECP2 protein is not relevant for species selection." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-1190-4481" , "https://orcid.org/0000-0002-9848-0262" , "https://orcid.org/0000-0002-4419-210X" , "https://orcid.org/0000-0002-2094-7491" ;
        dc:date           "2017-05-30" ;
        dc:title          "SYNGO_BP_492" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

