gomodel:SYNGO_2404  a     owl:Ontology ;
        rdfs:comment      "Rationale: Post-tetanic potentiation (PTP) at the TA-CA1 synapses was impaired in netrin-G1-KO.\nfEPSP potentiation by PDBu (a PKC activator; 0.4 μm) was reduced at TA-CA1 synapses in netrin-G1-KO.\nLTP induced by TBuS (an LTP-stimulation protocol) at the TA-CA1 synapses was attenuated in netrin-G1-KO.\nSynaptic potentiation following consecutive four TBuS trains was decreased in netrin-G1-KO.. Experimental description: Materials and Methods\nElectrophysiology.\nMice were deeply anesthetized with halothane (Takeda) and killed by decapitation." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-6194-9648" , "https://orcid.org/0000-0001-5518-6584" ;
        dc:date           "2018-02-07" ;
        dc:title          "SYNGO_BP_2404" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

