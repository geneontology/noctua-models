obo:ECO_0007719  a  owl:Class .

<http://identifiers.org/mgi/MGI:1921270>
        a       owl:Class .

gomodel:SYNGO_5558  a     owl:Ontology ;
        rdfs:comment      "Rationale: Cultured hippocampal neurons were immunostained for endogenous CPNE4, pre-synaptic marker protein synaptophysin (SYP) and postsynaptic marker PSD95 (DLG4). Confocal microscopy confirmed synaptic localization for CPNE4 by partial co-localization with both marker proteins. The data does not support a more specific annotation to either pre- or post-synaptic compartments.\n\n---\n\nThe experimental data annotated here will be included in an upcoming manuscript (by the SynGO consortium) that describes the SynGO 1.2 update, when a PMID is available this annotation will be updated with the respective reference.. Experimental description: Microscopy experiments were performed in cultured hippocampal mouse neurons.\n\nantibody: Abcam, Ab237627, Rabbit, poly" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2023-11-28" ;
        dc:title          "SYNGO_CC_5558" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

