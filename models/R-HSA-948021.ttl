dc:source  a    owl:AnnotationProperty .

:R-HSA-948021  a            obo:GO_0008150 , owl:NamedIndividual ;
        rdfs:comment        "At least two mechanisms of transport of proteins from the ER to the Golgi have been described. One is a general flow requiring no export signals (Wieland et al, 1987; Martinez-Menarguez et al, 1999). The other is mediated by LMAN1/MCFD2, mannose-binding lectins that recognize a glycan signal (Zhang B et al, 2003)." ;
        rdfs:label          "Transport to the Golgi and subsequent modification" ;
        dc:contributor      "GOC:reactome_curators" , "Authored: Dall'Olio, GM, 2009-11-10" , "Edited: Jassal, B, 2010-09-15" , "Reviewed: Gagneux, P, 2010-11-18" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-948021" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-446203/R-HSA-446203> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

