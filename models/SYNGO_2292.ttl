obo:ECO_0001225  a  owl:Class .

gomodel:SYNGO_2292  a     owl:Ontology ;
        rdfs:comment      "Rationale: This paper shows that synaptic transmission is the same in wild type and P2X-3 receptor knockout mice (Figure 2A). However using stimulation protocols that bring about long term depression in the CA1 (Figure 3C) and CA3 (Figure 4C) and dentate gyrus (Figure 4D) there is a loss of this synaptic plasticity in the P2X3 knockout mice.. Experimental description: Material and Methods: Young adult (3-6 month) P2X3 receptor knockout (P2x3KO) mice and wild-type littermate...................." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-3185-5709" , "https://orcid.org/0000-0001-7351-8706" , "https://orcid.org/0000-0003-0938-8534" , "https://orcid.org/0000-0002-0755-5899" ;
        dc:date           "2018-02-09" ;
        dc:title          "SYNGO_BP_2292" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

