lego:evidence  a  owl:AnnotationProperty .

gomodel:SYNGO_2529  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.1: \"Activation of D4 receptors reversibly reduced NMDA receptor currents in acutely dissociated PFC pyramidal neurons. \"\n\nFig.2: \"Activation of D4 receptors reduced the amplitude of NMDAR-mediated EPSCs in PFC slices but did not change the paired-pulse ratio of NMDAR EPSCs.\"\n\nFig.6: \"Activation of D4 receptors reduced the NMDAR surface expression and increased the NMDAR internalization in a CaMKII-dependent manner. \". Experimental description: \" Briefly, PFC was dissected from 18 d rat embryos, \"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2018-02-15" ;
        dc:title          "SYNGO_BP_2529" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

