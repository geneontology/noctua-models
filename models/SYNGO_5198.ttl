obo:GO_0014069  a  owl:Class .

gomodel:SYNGO_5198  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 1: Reduced Cdk5 activity via p35 knockout promoted PSD95 (DLG4) ubiquitination.\n\nFigure 2: Reduced Cdk5 activity via p35 knockout increased interaction and colocalization of Mdm2 with PSD95. In p35 knockout mice, the amount of Mdm2 obtained through PSD95 pulldown is increased as compared to wildtype. Confocal imaging of immunofluorescence labeling for Mdm2 and PSD95 showed increased co-localization in cultured hippocampal neurons upon treatment with roscovitine (Cdk5 inhibitor).. Experimental description: M&M: \"Dissociated hippocampal cultures were prepared from E17-E18 rat brains as described previously (Zhang et al., 2008).\"\n\nantibody:\nMdm2 mouse monoclonal (Millipore)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2023-03-01" ;
        dc:title          "SYNGO_CC_5198" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

