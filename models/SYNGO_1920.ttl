gomodel:SYNGO_1920  a     owl:Ontology ;
        rdfs:comment      "Rationale: 17/11/2017 Pim\nFig.5: \"RhoGAP2 increases the number of synapses and the accumulation of endogenous synaptic proteins.\"\nFig.6: \"The IL1RAPL1/PTPδ complex recruits RhoGAP2 to synapses.\"\nFig.7: \"Dendritic spine number and morphology of hippocampal neurons are regulated by RhoGAP2.\". Experimental description: RhoGDI 2 was over-expressed in rat hippocampal neurons\n\nLiteral form M&M\n\"Cell culture, transfection, staining and quantification\nof primary rat hippocampal neurons\nLow-density hippocampal neuronal cultures were prepared from E18-E19 rat hippocampi as previously described with minor modifications\"\n\n7/6/2017 Pim\n- Species of the over-expressed protein is traced back to **human** species via mRNA accession number AF284435 in PMID:20096586. literal: \"Original, full-length cDNA construct of IL1RAPL1 was obtained by J. Sims (Amgen) (AF284435, aa 1-696). \"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-2949-9725" , "https://orcid.org/0000-0003-0662-9523" ;
        dc:date           "2018-01-26" ;
        dc:title          "SYNGO_BP_1920" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_9606" .

