gomodel:SYNGO_1009  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig 7 shows typical examples where Sept3 is colocalises with presynaptic marker synaptophysin and dynamin I. Fig 8 shows immunolocalization of Sept3 to presynaptic terminals by immuno-EM with very little signal on postsynaptic locations, suggesting that Sept3 is located specifically to the presynaptic compartment. However, no quantification is presented.. Experimental description: M&M: \"Rat embryonic hippocampal cell cultures were prepared from hippocampi of 18-day-old fetal rat brains. \"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0001-5259-4945" ;
        dc:date           "2017-08-07" ;
        dc:title          "SYNGO_CC_1009" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

