gomodel:SYNGO_1876  a     owl:Ontology ;
        rdfs:comment      "Rationale: The authors isolated hPSD from neocortical biopsies of nine adults (Supplementary Table 1 and Supplementary Fig. 1a) and performed proteomic profiling using LC-MS/MS to comprehensively identify a total of 1,461 proteins (total hPSD), 748 of which were detected in all three replicates (consensus hPSD, used for all subsequent analysis, except where explicitly stated otherwise; Supplementary Table 2).. Experimental description: Subspecies, age or other: not specified." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4419-210X" , "https://orcid.org/0000-0002-9848-0262" , "https://orcid.org/0000-0002-1190-4481" , "https://orcid.org/0000-0002-2094-7491" ;
        dc:date           "2018-02-08" ;
        dc:title          "SYNGO_CC_1876" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_9606" .

