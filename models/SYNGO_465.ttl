obo:GO_0003674  a  owl:Class .

gomodel:SYNGO_465  a      owl:Ontology ;
        rdfs:comment      "Rationale: Fig. 2A Immuno EM detects the protein in dendrites and at PSDs.\n\nFig. 2C supports the EM findings by subcellular fractionations or rat adult brain: the protein is strongly enriched in the PSD fraction.\n\nFig. 2B Further confirms Abi-1 presence at synapses in immunofluorescence on hippocampal rats primary culture at DIV21. Abi-1 colocalizes with markers for excitatory synapses (ProSAP2/Shank3).. Experimental description: Fig.2A rat brain\nFig.2B rat hippocampal primary neurons\nFig.2C rat brain / rat hippocampal primary neurons" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-1190-4481" , "https://orcid.org/0000-0002-2094-7491" , "https://orcid.org/0000-0002-9848-0262" , "https://orcid.org/0000-0002-4419-210X" ;
        dc:date           "2017-09-25" ;
        dc:title          "SYNGO_CC_465" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

