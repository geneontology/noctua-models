gomodel:SYNGO_100  a      owl:Ontology ;
        rdfs:comment      "Rationale: Using an inhibitory peptide (eV1-2) that is reportedly specific for PKC epsilon, it is shown that PKC epsilon regulates acetylcholine release at the NMJ. eV1-2 displays a dose-dependent reduction in the potentiation of ACh release induced by the phorbol ester PMA.. Experimental description: Diaphragm muscles of young adult male Sprague-Dawley rats (30-40 days; Criffa, Barcelona, Spain) were used to perform stimulation experiments, Western blotting and electrophysiological experiments." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-7620-2704" , "https://orcid.org/0000-0002-1558-1958" ;
        dc:date           "2018-03-19" ;
        dc:title          "SYNGO_BP_100" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

