gomodel:SYNGO_2090  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.1: \"Syt-IV is targeted to BDNF-containing vesicles\"\nFig.2: \"Activity-induced syt-IV and BDNF colocalize and traffic together\"\n\nFig.7: \"Syt-IV modulates presynaptic function via regulation of post-synaptic BDNF release\"\nNote, postsynaptic release dependent on SYT4. Tested using soluble TrkB (the BDNF receptor) to scavenge released BDNF.\n\nFig.8: \"Syt-IV knockouts have enhanced LTP due to excess BDNF release\". Experimental description: \"Hippocampi were isolated from P1-3 mice or E18-19 rats and plated at 25,000-50,000 cells/cm2 on poly-lysine\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2094-7491" , "https://orcid.org/0000-0002-4419-210X" , "https://orcid.org/0000-0002-1190-4481" , "https://orcid.org/0000-0002-9848-0262" ;
        dc:date           "2018-07-03" ;
        dc:title          "SYNGO_BP_2090" ;
        pav:providedBy    "https://syngo.vu.nl" ;
