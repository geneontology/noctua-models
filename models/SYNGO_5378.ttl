obo:BFO_0000050  a  owl:ObjectProperty .

gomodel:SYNGO_5378  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 1D: immunofluorescence imaging of overexpressed CAP1-GFP in cultured hippocampal neurons showed localization to dendritic spines.\n\nFigure 1H-L: STED super-resolution imaging showed endogenous CAP1 was localized througout both pre- and post-synapse.\n\n\"Hippocampal neurons from brain-specific CAP1-KO mice were exploited for control experiments [61], which proved specificity of the antibody (Fig. S1E).\". Experimental description: \"Generation of CAP1flx/flx and Cfl1flx/flx mice has been described before\"\n\"Primary hippocampal neurons from embryonic day 18.5 (E18.5) mice were prepared as previously described\"\n\nantibody:\nanti-CAP1 (Proteintech, 16231-1-AP)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2023-03-13" ;
        dc:title          "SYNGO_CC_5378" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

