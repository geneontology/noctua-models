obo:GO_0016082  a  owl:Class .

gomodel:SYNGO_558  a      owl:Ontology ;
        rdfs:comment      "Rationale: The splice variant CAPS2b can fully rescue deficits in synaptic transmission (evoked release, readiliy-releasable pool) in isolated, autaptic CAPS-1/2 double KO neurons.\n\nMoreover, the data indicates that the priming function of CAPS2 lies in the N-terminal part of the protein (Splice variant CAPS2e, lacking the C-terminal MUN domain) can still (at least partially) rescue deficits in the readily-releasable pool size.. Experimental description: We cloned the mouse cDNAs of all CAPS2 splice variants as IRES-eGFP constructs into a Semliki Forest virus vector (pSFV1)...\nCAPS1/CAPS2-deficient (DKO) mice (Jockusch et al., 2007) from days e18 and e19..." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-3185-5709" , "https://orcid.org/0000-0002-0755-5899" , "https://orcid.org/0000-0003-0938-8534" , "https://orcid.org/0000-0001-7351-8706" ;
        dc:date           "2017-05-31" ;
        dc:title          "SYNGO_BP_558" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

