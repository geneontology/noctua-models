gomodel:SYNGO_1701  a     owl:Ontology ;
        rdfs:comment      "Rationale: The authors performed conventional confocal microscopy using antibodies against endophilin 1. They demonstrate colocalization of endophilin 1 with the presynaptic marker synaptophysin in both cultured rat hippocampal neurons (figure 7) and rat brain sections (figure 8) (deep cerebellar nuclei, CA1 region and CA3 region). Experimental description: From the experimental procedures, \"Double immunofluorescence experiments with rat brain sections and cultured hippocampal neurons..\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-7806-5662" ;
        dc:date           "2017-12-06" ;
        dc:title          "SYNGO_CC_1701" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

