        a               owl:NamedIndividual , obo:ECO_0000313 ;
        dc:contributor  "GOC:reactome_curators" ;
        dc:date         "2026-06-29" ;
        dc:source       "Reactome:R-HSA-9909649" ;
        pav:providedBy  "https://reactome.org" .

:R-HSA-9909649  a           obo:GO_0008150 , owl:NamedIndividual ;
        rdfs:comment        "The transcriptional regulation of CD274 (PD-L1/ programmed death-ligand 1) plays a critical role in the regulation of normal T cell function in normal physiological condition where it provides immune homeostasis. The expression of PD-L1 is tightly controlled by various transcription factors and signalling pathways, which respond to both intrinsic cellular signals and extrinsic environmental perturbations. PD-L1 is regulated transcriptionally by multiple mechanism like epigenetic modifications (EZH2, DNMTs, MLLs), transcription factors (STAT3. STAT1, IRF1, MYC, HIF and ither) which get activated in response to multiple upstream signalling pathways. The transcriptional regulation of PD-L1 is a complex interplay of oncogenic signalling pathways, cytokine responses, epigenetic modifications, specific transcription factors, the tumour microenvironment, and non-coding RNAs. This multifaceted regulation ensures that PD-L1 expression can be finely tuned to promote immunotolerance in normal condition as well as immune evasion in cancer, making it a critical target for cancer immunotherapy (Zhou et al.,2023, Cha et al.,2019, Yamaguchi et al.,2022, Ju et al.,2020)" ;
        rdfs:label          "Regulation of PD-L1(CD274) transcription" ;
        dc:contributor      "Reviewed: Hung, Mien-Chie, Yamaguchi, Hirohito, 2025-08-26" , "Authored: Hung, Mien-Chie, Yamaguchi, Hirohito, 2025-08-26" , "Edited: Gillespie, Marc E, 2025-08-08" , "GOC:reactome_curators" , "Authored: Tiwari, Krishna, 2024-11-05" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-9909649" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-9909648/R-HSA-9909648> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

