gomodel:SYNGO_4094  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig 2A-B: Immunocytochemical study demonstrates colocalization (~90%) of endogenous SALM1 (green) with postsynaptic excitatory synapse marker Homer (red).\nFigC: Higher magnification indicates SALM1 puncta partially overlapping with postsynaptic Homer puncta.\nFig D-E: Electron micrographs showing subsynaptic localization of endogenous SALM1 in mouse hippocampal brain slices. SALM1 immunogold particles are detected in postsynapses (indicated by cyan and blue arrows) and were less abundantly detected in postsynaptic terminals (~40%).. Experimental description: Wild-type E18 mouse embryos were obtained by cesarean section of pregnant female C57/Bl6 mice." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0003-2916-7616" ;
        dc:date           "2021-01-19" ;
        dc:title          "SYNGO_CC_4094" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

