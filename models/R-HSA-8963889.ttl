<http://model.geneontology.org/ev_w_id_R-HSA-5694109_RO_0002234_R-ALL-422024_extracellular_region_Reactome_R-HSA-5694109>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/ECO_0000313> ;
