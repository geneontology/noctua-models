:R-HSA-1855184  a           obo:GO_0033271 , owl:NamedIndividual ;
        rdfs:comment        "Inositol phosphates IP4, IP5, and IP6 are exported from the cytosol to the endoplasmic reticulum (ER) lumen (Caffrey et al. 1999, Chi et al. 1999). The molecular details of these transport processes remain uncertain. They are represented here as myo-inositol transmembrane transport enabled by an unknown transporter protein associated with the ER membrane." ;
        rdfs:label          "IPs transport between cytosol and ER lumen" ;
        dc:contributor      "Authored: Williams, MG, 2011-10-28" , "Edited: Williams, MG, 2011-10-28" , "GOC:reactome_curators" , "Reviewed: Wundenberg, Torsten, 2012-11-06" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-1855184" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-1483249/R-HSA-1483249> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

