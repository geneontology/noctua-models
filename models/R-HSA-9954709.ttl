<http://model.geneontology.org/REACTO_R-HSA-9907949_R-HSA-9908170_R-HSA-9949676_component>
        a       <http://purl.obolibrary.org/obo/GO_0032991> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
