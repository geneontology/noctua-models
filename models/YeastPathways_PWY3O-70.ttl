:YeastPathways_PWY3O-70
        a                   obo:GO_0000271 , owl:NamedIndividual ;
        rdfs:comment        "Chitosan, a beta-1,4 -D-glucosamine homopolymer, is a component of the yeast spore wall (ascospore) and is produced by the deacetylation of nascent chains of chitin, a beta-1,4-N-acetyl-D- glucosamine homopolymer. The CDA1 and CDA2 genes, expressed specifically during sporulation, account for the total chitin deacetylase activity in S. cerevisiae (|CITS:[8940152]|)." ;
        rdfs:label          "chitosan biosynthesis" ;
        layout:x            "284" ;
        layout:y            "68" ;
        dc:contributor      "GOC:sgd_curators" , "https://orcid.org/0000-0001-6787-2901" ;
        dc:date             "2023-11-30" ;
        pav:providedBy      "http://www.yeastgenome.org" ;
        oboInOwl:hasDbXref  "YeastPathways_PWY3O-70" ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

