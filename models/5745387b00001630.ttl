skos:note  a    owl:AnnotationProperty .

[ a                      owl:Axiom ;
  rdfs:comment           "ES: We found that gfp expression driven under only 165 bp of the regulatory sequence of srh-234 (srh-234p::gfp) is strongly expressed in ADL in fed animals (Figure 1A, upper panel), but when animals were starved for long-periods of time (>6 hours), srh-234p::gfp was significantly downregulated (Figure 1A, lower panel). Similar results were found for another independent integrated transgenic array of srh-234p::gfp (oyIs57) (Table S2)." ;
  lego:evidence          :5745387b00001646 ;
  dc:contributor         "https://orcid.org/0000-0002-1706-4196" ;
  dc:date                "2016-08-05" ;
  owl:annotatedProperty  obo:BFO_0000050 ;
  owl:annotatedSource    :5745387b00001645 ;
  owl:annotatedTarget    :5745387b00001642
] .

