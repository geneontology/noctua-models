[] a owl:Axiom ;
    ns2:evidence <http://model.geneontology.org/5745387b00001630/5745387b00001646> ;
    dc:contributor "https://orcid.org/0000-0002-1706-4196"^^xsd:string ;
    dc:date "2016-08-05"^^xsd:string ;
    rdfs:comment "ES: We found that gfp expression driven under only 165 bp of the regulatory sequence of srh-234 (srh-234p::gfp) is strongly expressed in ADL in fed animals (Figure 1A, upper panel), but when animals were starved for long-periods of time (>6 hours), srh-234p::gfp was significantly downregulated (Figure 1A, lower panel). Similar results were found for another independent integrated transgenic array of srh-234p::gfp (oyIs57) (Table S2)."^^xsd:string ;
    owl:annotatedProperty ns3:BFO_0000066 ;
    owl:annotatedSource <http://model.geneontology.org/5745387b00001630/5745387b00001634> ;
    owl:annotatedTarget <http://model.geneontology.org/5745387b00001630/5745387b00001642> .

[] a owl:Axiom ;
    ns2:evidence <http://model.geneontology.org/5745387b00001630/5745387b00001641> ;
    dc:contributor "https://orcid.org/0000-0002-1706-4196"^^xsd:string ;
    dc:date "2016-08-04"^^xsd:string ;
    owl:annotatedProperty ns3:BFO_0000066 ;
    owl:annotatedSource <http://model.geneontology.org/5745387b00001630/5745387b00001634> ;
    owl:annotatedTarget <http://model.geneontology.org/5745387b00001630/5745387b00001640> .

[] a owl:Axiom ;
    dc:contributor "https://orcid.org/0000-0002-1706-4196"^^xsd:string ;
    dc:date "2016-08-05"^^xsd:string ;
    owl:annotatedProperty ns3:BFO_0000066 ;
    owl:annotatedSource <http://model.geneontology.org/5745387b00001630/5745387b00001644> ;
    owl:annotatedTarget <http://model.geneontology.org/5745387b00001630/5745387b00001645> .

[] a owl:Axiom ;
    ns2:evidence <http://model.geneontology.org/5745387b00001630/5745387b00001647> ;
    dc:contributor "https://orcid.org/0000-0002-1706-4196"^^xsd:string ;
    dc:date "2023-03-16"^^xsd:string ;
    rdfs:comment "Automated change 2023-03-16: RO:0002213 replaced by RO:0002407",
        "ES:  Of the 18 bHLH genes examined, we found that hlh-2, hlh-3 and mxl-3 mutants strongly reduced but did not abolish srh-234p::gfp expression levels in ADL during well-fed conditions, while hlh-6 and hlh-10 mutants and hlh-4(RNAi) treated animals reduced srh-234p::gfp expression (Figs 3A, 3C and S2). "^^xsd:string ;
    owl:annotatedProperty ns3:RO_0002407 ;
    owl:annotatedSource <http://model.geneontology.org/5745387b00001630/5745387b00001634> ;
    owl:annotatedTarget <http://model.geneontology.org/5745387b00001630/5745387b00001644> .

