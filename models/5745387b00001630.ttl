    owl:annotatedTarget "hlh-2 Cele"^^xsd:string .

[] a owl:Axiom ;
    ns2:evidence <http://model.geneontology.org/5745387b00001630/5745387b00001643> ;
    dc:contributor "https://orcid.org/0000-0002-1706-4196"^^xsd:string ;
    dc:date "2016-08-05"^^xsd:string ;
    rdfs:comment "ES: Using hlh-2::GFP reporter strains (see below) and DiI staining, three of the bilateral pairs of neurons have been identified, with the generous help of Cori Bargmann, as ADL (L and R) and ASH (L and R) and RIC (L and R)."^^xsd:string ;
    owl:annotatedProperty ns3:BFO_0000066 ;
    owl:annotatedSource <http://model.geneontology.org/5745387b00001630/5745387b00001634> ;
    owl:annotatedTarget <http://model.geneontology.org/5745387b00001630/5745387b00001642> .

