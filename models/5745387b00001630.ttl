[ a                      owl:Axiom ;
  rdfs:comment           "ES:  Of the 18 bHLH genes examined, we found that hlh-2, hlh-3 and mxl-3 mutants strongly reduced but did not abolish srh-234p::gfp expression levels in ADL during well-fed conditions, while hlh-6 and hlh-10 mutants and hlh-4(RNAi) treated animals reduced srh-234p::gfp expression (Figs 3A, 3C and S2). " , "Automated change 2023-03-16: RO:0002213 replaced by RO:0002407" ;
  lego:evidence          :5745387b00001647 ;
  dc:contributor         "https://orcid.org/0000-0002-1706-4196" ;
  dc:date                "2023-03-16" ;
  owl:annotatedProperty  obo:RO_0002407 ;
  owl:annotatedSource    :5745387b00001634 ;
  owl:annotatedTarget    :5745387b00001644
] .

