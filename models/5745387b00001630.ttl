[] a owl:Axiom ;
    ns2:evidence <http://model.geneontology.org/5745387b00001630/5745387b00001635> ;
    dc:contributor "https://orcid.org/0000-0002-1706-4196"^^xsd:string ;
    dc:date "2016-08-04"^^xsd:string ;
