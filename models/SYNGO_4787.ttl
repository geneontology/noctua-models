gomodel:SYNGO_4787  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 2B: Prickle2 was enriched in PSD biochemical fractions from homogenates of rat brain.\n\nFigure 3A: Confocal imaging showed Prickle2 co-localizes with PSD95 in cultured rat hippocampal neurons.\n\nFigure 4D: Post-embedding immunogold electron microscopy showed postsynaptic density localization of Prickle2 in mouse brain.\n\nFurther evidence for PSD localization comes from PPI assays that show PSD95 (DLG4) interaction.. Experimental description: Figure 4: \"Immunohistochemical distribution and postsynaptic localization of Pk2 in mouse brain.\". We here annotate against species used in this immunogold assay." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2022-08-30" ;
        dc:title          "SYNGO_CC_4787" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

