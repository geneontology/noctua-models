obo:ECO_0000279  a  owl:Class .

gomodel:SYNGO_5587  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig. 2. Gα13 proteins are required for GABA-B receptor-induced JNK phosphorylation.\n\nFig. 3. Activation of the GABA-B receptor leads to Gα13 protein activation.\n\nFig. 5. GABA-B receptor increases PSD95 phosphorylation and synaptic accumulation.\n\nFigure S5: Gα13 but not ERK1/2 is involved in GABA-B receptor-mediated PSD95 phosphorylation and dendrite accumulation in cerebellar granule neurons (CGNs).\n\nFig. 6. Gα13 -JNK is involved in GABA-B receptor-mediated neuronal protection.. Experimental description: M&M:\n\"Briefly, 7-day-old KunMing mice pups obtained from ...\"\n\"To generate a construct encoding the C-terminal Gα13 (amino acids 322 to 378), short complimentary oligonucleotides encoding the peptide sequences were obtained from the Gα13 cDNA, which was generously donated by P. Rondard (Institut de Génomique Fonctionnelle, France).\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" ;
        dc:date           "2023-11-29" ;
        dc:title          "SYNGO_BP_5587" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

