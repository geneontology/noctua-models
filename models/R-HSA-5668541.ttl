<http://model.geneontology.org/ev_w_id_REACTO_R-HSA-9908170_R-HSA-9908177_R-HSA-5668520_component_BFO_0000051_UniProtKB_Q16186_R-HSA-9908170_R-HSA-5668520_component_Reactome_R-HSA-9908170>
        a       <http://purl.obolibrary.org/obo/ECO_0000313> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
        <http://purl.org/dc/elements/1.1/contributor>
