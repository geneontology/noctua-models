obo:IAO_0000115  a  owl:AnnotationProperty .

gomodel:5e72450500001424
        a                 owl:Ontology ;
        rdfs:comment      "idea is to use causal relationships between activities, not processes, except in the case of an \"activity regulating process\" like translation, to specify the mechanism, when known. The biological program this is part of, is a negative regulation of the VEGF pathway program, so we will represent this by making the activity part of the process. We need to work on the annotations that are being made from this. In particular, it should not try to infer regulation of BP terms from regulates relations and the BP (i.e. there should not be a \"positive regulation of receptor binding\" annotation inferred)." , "Pascale 2026-02-26 Improved model to remove old relations." ;
        lego:modelstate   "development" ;
        dc:contributor    "https://orcid.org/0000-0002-1706-4196" , "https://orcid.org/0000-0002-9074-3507" , "https://orcid.org/0000-0003-1813-6857" ;
        dc:date           "2026-02-26" ;
        dc:title          "miRNA example PT" ;
        pav:providedBy    "http://www.wormbase.org" , "http://geneontology.org" ;
        owl:versionIRI    gomodel:5e72450500001424 ;
        biolink:in_taxon  obo:NCBITaxon_9606 .

