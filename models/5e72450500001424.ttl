<http://model.geneontology.org/5e72450500001424> a owl:Ontology ;
    ns3:modelstate "development"^^xsd:string ;
    dc:contributor "https://orcid.org/0000-0002-1706-4196"^^xsd:string,
        "https://orcid.org/0000-0002-9074-3507"^^xsd:string,
        "https://orcid.org/0000-0003-1813-6857"^^xsd:string ;
    dc:date "2020-05-06"^^xsd:string ;
    dc:title "miRNA example PT"^^xsd:string ;
    ns1:providedBy "http://geneontology.org"^^xsd:string,
        "http://www.wormbase.org"^^xsd:string ;
    rdfs:comment "idea is to use causal relationships between activities, not processes, except in the case of an \"activity regulating process\" like translation, to specify the mechanism, when known. The biological program this is part of, is a negative regulation of the VEGF pathway program, so we will represent this by making the activity part of the process. We need to work on the annotations that are being made from this. In particular, it should not try to infer regulation of BP terms from regulates relations and the BP (i.e. there should not be a \"positive regulation of receptor binding\" annotation inferred)."^^xsd:string ;
    owl:versionIRI <http://model.geneontology.org/5e72450500001424> ;
    ns5:in_taxon ns4:NCBITaxon_9606 .

