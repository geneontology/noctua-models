obo:RO_0002333  a  owl:ObjectProperty .

gomodel:SYNGO_5357  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 3: in biochemical fractions prepared from rat forebrain, Uev1A (UBE2V1) was enriched in PSD fractions.\n\nFigure S3: confocal imaging of immunofluorescence labeling for Uev1A and PSD-95 (DLG4) in cultured hippocampal neurons showed partial co-localization. Further, Uev1A immunoprecipitation in mouse forebrain yields PSD95.\n\n\"In vitro ubiquitination assays using purified proteins showed that TRAF6, in conjunction with Ubc13/Uev1A, effectively delivered the ubiquitin moieties to PSD-95, which did not occur when TRAF6, UbK63, Ubc13, Uev1A, or PSD-95 was omitted from the reaction mix (Fig. 3E).\". Experimental description: M&M: \"high-density (1 × 106) hippocampal neurons were prepared from E18 rat embryos\"\n\nantibody:\nanti-Uev1A (ProSci, 3375)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2023-11-08" ;
        dc:title          "SYNGO_CC_5357" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

