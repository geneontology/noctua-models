gomodel:SYNGO_4004  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 2C: Lasp1 expression was enriched in PSD fractions, PSD-95 was used as a positive control.\nFigure 5A-D: Punctate pattern of Lasp1 immunolabelling overlays with postsynaptic marker, PSD-95.\nFigure 5E: To ensure its localisation on the postsynapse, Lasp1-GFP was transfected into hippocampal neurons and the expression was seen on dendritic spines.\nFigure 6: Preembedding immunoelectron microscopy demonstrate prominent labelling at the postsynaptic compartment.\n\nNote on the antibody used: the paper does not comment on antibody specificity.\n\nTaken together, the SynGO term 'postsynapse' was used.. Experimental description: Hippocampal neuronal cultures were derived from Spague-Dawley rats (18 days of gestation)." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0003-2916-7616" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2020-12-08" ;
        dc:title          "SYNGO_CC_4004" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

