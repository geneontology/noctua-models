<http://model.geneontology.org/R-HSA-2426168> <http://geneontology.org/lego/modelstate> "development" ;
	<http://purl.org/pav/providedBy> "https://reactome.org" ;
	<https://w3id.org/biolink/vocab/in_taxon> <http://purl.obolibrary.org/obo/NCBITaxon_9606> ;
	a <http://www.w3.org/2002/07/owl#Ontology> ;
	<http://www.w3.org/2000/01/rdf-schema#comment> "For logical inference, import the integrated tbox ontology http://purl.obolibrary.org/obo/go/extensions/go-lego-reacto.owl" , "http://www.reactome.org" , "Imported from Reactome: https://reactome.org/content/detail/R-HSA-2426168" ;
	<http://purl.org/dc/elements/1.1/title> "Activation of gene expression by SREBF (SREBP) - imported from: Reactome" ;
	<http://purl.org/dc/elements/1.1/contributor> "GOC:reactome_curators" ;
	<http://purl.org/dc/elements/1.1/date> "2023-06-21" .

<http://model.geneontology.org/R-HSA-2426168/R-HSA-2426168> <http://purl.org/pav/providedBy> "https://reactome.org" ;
	<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "R-HSA-2426168" ;
	<http://www.w3.org/2004/02/skos/core#narrower> <http://model.geneontology.org/R-HSA-1655829/R-HSA-1655829> ;
	a <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/GO_0019216> ;
	<http://www.w3.org/2000/01/rdf-schema#comment> "After transiting to the nucleus SREBPs (SREBP1A/1C/2, SREBFs) bind short sequences, sterol regulatory elements (SREs), in the promoters of target genes (reviewed in Eberle et al. 2004, Weber et al. 2004). SREBPs alone are relatively weak activators of transcription, with SREBP1C being significantly weaker than SREBP1A or SREBP2. In combination with other transcription factors such as SP1 and NF-Y the SREBPs are much stronger activators. SREBP1C seems to more specifically target genes involved in fatty acid synthesis while SREBP2 seems to target genes involved in cholesterol synthesis (Pai et al. 1998)." ;
	<http://www.w3.org/2000/01/rdf-schema#label> "Activation of gene expression by SREBF (SREBP)" ;
	<http://www.w3.org/2004/02/skos/core#note> "org.biopax.paxtools.model.level3.Pathway" ;
	<http://purl.org/dc/elements/1.1/contributor> "GOC:reactome_curators" , "Authored: May, B, 2012-07-26" , "Edited: May, B, 2012-07-26" , "Reviewed: Liang, Guosheng, 2012-08-25" ;
	<http://purl.org/dc/elements/1.1/date> "2023-06-21" .

