lego:evidence  a  owl:AnnotationProperty .

gomodel:SYNGO_2130  a     owl:Ontology ;
        rdfs:comment      "Rationale: \"Figure 5. Selective increase in AChE content in the synaptic cleft after muscle training.\"\n\n\"Conclusion: Overall, our study supports a functional role for the G4 AChE tetramer in the neuromuscular synapse\"\n\n11/12/2017 Pim\n- The authors show that a membrane attached form of AChE is responsible for the increase of ACh-esterase activity in the muscle. The term 'synaptic cleft (GO:0043083)' is selected based on the site of activity of the non-membrane bound variants and the membrane bound variant together.. Experimental description: \"Electron micrographs of cross sections through EDL muscles isolated from control (A) and trained (B) rats, specifically labeled for AChE by the Nanogold-Fas conjugate.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2017-12-11" ;
        dc:title          "SYNGO_CC_2130" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

