gomodel:SYNGO_3979  a     owl:Ontology ;
        rdfs:comment      "Rationale: Using subcellular fraction and immunbloting, Rabaptin-5 is detected in synaptosomal fractions. This was partially validated by the detection of the protein with synaptic vesicle clusters in primary cortical cultures using immuno-electron microscopy.. Experimental description: Materials and Methods: To determine whether GAP-43 and rabaptin-5 localized to synaptic vesicle membrane or plasma membrane, within the synaptosome fraction, adult rat brain was subfractionated exactly as described (Whittaker et al., 1964)." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-5615-1014" ;
        dc:date           "2020-09-25" ;
        dc:title          "SYNGO_CC_3979" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

