gomodel:SYNGO_1668  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fluorescence microscopy of endogenous Dvl1 or over-expressed Dvl1 in hippocampal neurons (Div 9) show appreciable punctate colocalisation with presynaptic markers synapsin-1 and Bassoon along axons.. Experimental description: Materials and Methods \"Basilar pontine nuclei from wild-type, Dvl1 mutant, or Wnt7a-/-;Dvl1-/- mutant mice were dissected from newborn or P1 pups, cut into 100-μm2 explants, and cultured in 16-well LabTeck chamber slides, as previously described\"." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-5615-1014" ;
        dc:date           "2017-11-03" ;
        dc:title          "SYNGO_CC_1668" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

