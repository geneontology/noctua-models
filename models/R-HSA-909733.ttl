dc:contributor  a  owl:AnnotationProperty .

:R-HSA-909733  a            owl:NamedIndividual , obo:GO_0060337 ;
        rdfs:comment        "Type I interferons (IFNs) are composed of various genes including IFN alpha (IFNA), beta (IFNB), omega, epsilon, and kappa. In humans the IFNA genes are composed of more than 13 subfamily genes, whereas there is only one IFNB gene. The large family of IFNA/B proteins all bind to a single receptor which is composed of two distinct chains: IFNAR1 and IFNAR2. The IFNA/B stimulation of the IFNA receptor complex leads to the formation of two transcriptional activator complexes: IFNA-activated-factor (AAF), which is a homodimer of STAT1 and IFN-stimulated gene factor 3 (ISGF3), which comprises STAT1, STAT2 and a member of the IRF family, IRF9/P48. AAF mediates activation of the IRF-1 gene by binding to GAS (IFNG-activated site), whereas ISGF3 activates several IFN-inducible genes including IRF3 and IRF7." ;
        rdfs:label          "Interferon alpha/beta signaling" ;
        dc:contributor      "Edited: Garapati, P V, 2010-07-07" , "GOC:reactome_curators" , "Authored: Garapati, P V, 2010-07-07" , "Reviewed: Abdul-Sater, AA, Schindler, C, 2010-08-17" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-909733" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-913531/R-HSA-913531> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

