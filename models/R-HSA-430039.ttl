obo:GO_0005829  a  owl:Class .

:R-HSA-430039  a            obo:GO_0000288 , owl:NamedIndividual ;
        rdfs:comment        "Degradation of mRNA from 5' to 3' occurs in three steps. First, the mRNA is bound at its 3' end by the Lsm1-7 complex. The bound Lsm1-7 may prevent nucleases from accessing the 3' end. Second, the 7-methylguanosine cap of the mRNA is hydrolyzed by the DCP1-DCP2 complex. Third, the 5' end of the decapped mRNA is attacked by the XRN1 exoribonuclease which digests the remainder of the mRNA from 5' to 3'. These processes may be physically connected by PATL1, the homolog of yeast Pat1, which stably binds the Lsm1-7 complex and interacts with the DCP1-DCP2 decapping complex and the Ccr4-NOT deadenylation complex (Ozgur et al. 2010)." ;
        rdfs:label          "mRNA decay by 5' to 3' exoribonuclease" ;
        dc:contributor      "Edited: May, B, 2009-07-22" , "Authored: May, B, 2009-07-22" , "Reviewed: Wilusz, J, 2009-09-17" , "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-430039" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-429914/R-HSA-429914> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

