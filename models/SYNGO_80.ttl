lego:evidence  a  owl:AnnotationProperty .

gomodel:SYNGO_80  a       owl:Ontology ;
        rdfs:comment      "Rationale: Combination of knock down and pharmacological inhibitions along with function measures of presynaptic calcium influx shows that CDK5 normally constrains the activity of voltage-gated Ca channels.\n\n23/01/2017 Pim\n- Fig.1 KD of CNa has negative effect on SV exocytosis\n- Fig.2 KD/agonist of CDK5 has positive effect on SV exocytosis\n- Fig.2 Effect of CDK5 and CNa is via VGCCs (shown via VGCC inhibition)\n- Fig.3/4/5/6 CNa and CDK5 activities affect presynaptic Ca influx. Experimental description: Hippocampal CA3-CA1 regions were dissected from 1- to 2-d-old Sprague Dawley rats, dissociated, and plated onto poly-ornithine-coated glass for 14-21 d as described previously (Ryan, 1999)." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-5648-066X" , "https://orcid.org/0000-0003-4022-8707" , "https://orcid.org/0000-0001-7480-0826" , "https://orcid.org/0000-0003-2533-9548" , "https://orcid.org/0000-0002-1212-5623" ;
        dc:date           "2018-06-05" ;
        dc:title          "SYNGO_BP_80" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

