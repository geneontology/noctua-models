:R-HSA-9854311  a           obo:GO_0008150 , owl:NamedIndividual ;
        rdfs:comment        "(Citrate-synthase)-lysyl-methyltransferase (CSKMT, METTL12) transfers three methyl groups from S-adenosylmethionine (SAM) to lysine-395 of citrate synthase (CS). The expression of CSKMT is low or absent in many normal organ tissues, but the trimethylated form is predominant in most cell lines tested. The modification is evolutionarily conserved, with contradicting reports on the activity of modified CS, while the effect on the whole CS/ACO2 metabolon was not investigated. Oxalocetate inhibits methyltransferase activity (Malecki et al., 2017; Rhein et al., 2017; reviewed in Qi et al., 2023)." ;
        rdfs:label          "Maturation of TCA enzymes and regulation of TCA cycle" ;
        dc:contributor      "Reviewed: Hill, David P, 2024-02-15" , "Edited: D'Eustachio, Peter, 2024-02-15" , "Edited: Stephan, Ralf, 2024-05-21" , "GOC:reactome_curators" , "Authored: Stephan, Ralf, 2023-11-25" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-9854311" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-71403/R-HSA-71403> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

