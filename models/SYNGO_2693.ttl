gomodel:SYNGO_2693  a     owl:Ontology ;
        rdfs:comment      "Rationale: GluD1 is shown to primarily localize to the postsynaptic density of excitatory synapses in CA1 neurons of the mouse hippocampus (Figure 8 g, h). Antibodies used for electron microscopy analyses were validated by western blotting using GRID1-/- and did not cross react with GluD2 in HEK cells (Figure 5a,b). Experimental description: western blot: HEK cells; no information on plasmid DNA used, they might be mouse cDNAs for GluD1 and GluD2 because they test antibodies and mRNA probes with them.\n\nElectron microscopy: mouse brain section" , "Automated change 2024-03-14: GO:0099061 replaced by GO:0098839" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-5676-366X" , "https://orcid.org/0000-0001-9783-5183" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_2693" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

