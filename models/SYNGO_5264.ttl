gomodel:SYNGO_5264  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 5: Nedd4-2 (NEDDL) is a ubiquitin E3 ligase that ubiquitinates GluA1 (GRIA1) at lysine-868 and mediate its surface expression in cortical neuron cultures.\n\nFigure 6, 7, 8: three epilepsy-associated missense mutations of Nedd4-2 (S233L, E271A, and H515P) exhibited reduced ability to ubiquitinate GluA1 in vitro. This also affected GluA1 surface expression.. Experimental description: M&M: \"Primary cortical neuron cultures were made from p0-p1 mice as described previously\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2023-03-09" ;
        dc:title          "SYNGO_BP_5264" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

