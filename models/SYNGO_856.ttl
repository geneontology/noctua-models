lego:evidence  a  owl:AnnotationProperty .

gomodel:SYNGO_856  a      owl:Ontology ;
        rdfs:comment      "Rationale: Overexpressed GFP-tagged msec7-1 is localized to presynaptic regions in Xenopus neuromuscular junctions (Fig. 2). Overexpression of msec7-1 causes a translocation of ARF6 from endosomal compartments to the plasma membrane in HEK293 cells (Fig. 1). mSec7-1 contains a pleckstrin-homology domain, which mediates an enhancement of the GEF activity by its binding to PIP2.. Experimental description: - Fig.1 Expression vectors for full length rat msec7-1 were generated...\n- Fig. 2 Synaptic localization shown with Xenopus cell culture that overexpresses rat mSec." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-3185-5709" , "https://orcid.org/0000-0002-0755-5899" , "https://orcid.org/0000-0001-7351-8706" , "https://orcid.org/0000-0003-0938-8534" ;
        dc:date           "2017-08-22" ;
        dc:title          "SYNGO_CC_856" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

