obo:GO_0140251  a  owl:Class .

gomodel:SYNGO_2770  a     owl:Ontology ;
        rdfs:comment      "Rationale: Plekhg5 is a GEF that regulates the activity of Rab26 (Fig 7). In axons, loss of Plekhg5 led to a reduction in autophagosome density that could be elevated by expression of Rab26QL. Additionally, loss of the GEF also increases levels of the synaptic vesicle markers (synaptophysin 1, synaptobrevin 1, synaptotagmin 1 and synapsin 1). This is indicative that Rab26 and its GEF is involved in the degradation of synaptic vesicle proteins via autophagy.\n\nUniprot: has lipid anchor. Experimental description: - \"To generate Plekhg5-deficient mice....\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-5615-1014" ;
        dc:date           "2018-04-30" ;
        dc:title          "SYNGO_BP_2770" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

