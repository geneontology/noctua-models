gomodel:SYNGO_1169  a     owl:Ontology ;
        rdfs:comment      "Rationale: Colocalisation of recycling SVs labelled by synaptotagmin and Rab5(Q79L) in neurons indicates that SV endocytosis goes through a Rab5-containing endosomal compartment.. Experimental description: Materials and Methods \"All constructs were generated from rat (Rattus norvegicus) sequences. Hippocampal cultures were prepared as described (11) and were transfected between 7 and 11 d in vitro (DIV) with the various pHluorin constructs using NeuroMag paramagnetic beads (Oz bi-osciences) according to the supplier's protocol.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-5615-1014" ;
        dc:date           "2018-05-11" ;
        dc:title          "SYNGO_BP_1169" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

