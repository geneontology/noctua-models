gomodel:SYNGO_304  a      owl:Ontology ;
        rdfs:comment      "Rationale: Immunofluorescence with antibodies directed against GLUT4 were co-localized with a bona fide presynaptically localized protein, synapsin I. Furthermore genetic ablation of GLUT4 by shRNA-mediated KD eliminates the antibody staining, validating the specificity of the immunocytochemistry. Experimental description: Hippocampal CA1-CA3 neurons were isolated from 1- to 3-day-old rats of mixed gender" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-5648-066X" , "https://orcid.org/0000-0003-2533-9548" , "https://orcid.org/0000-0001-7480-0826" , "https://orcid.org/0000-0003-4022-8707" , "https://orcid.org/0000-0002-1212-5623" ;
        dc:date           "2017-03-14" ;
        dc:title          "SYNGO_CC_304" ;
        pav:providedBy    "https://syngo.vu.nl" ;
