obo:RO_0002629  a  owl:ObjectProperty .

:R-HSA-5607763  a           owl:NamedIndividual , obo:GO_0008150 ;
        rdfs:comment        "CLEC7A (Dectin-1) signals through the classic calcineurin/NFAT pathway through Syk activation phospholipase C-gamma 2 (PLCG2) leading to increased soluble IP3 (inositol trisphosphate). IP3 is able to bind endoplasmic Ca2+ channels, resulting in an influx of Ca2+ into the cytoplasm. This increase in calcium concentration induces calcineurin activation and consequently, dephosphorylation of NFAT and its translocation into the nucleus, triggering gene transcription and extracellular release of Interleukin-2 (Plato et al. 2013, Goodridge et al. 2007, Mourao-Sa et al. 2011)." ;
        rdfs:label          "CLEC7A (Dectin-1) induces NFAT activation" ;
        dc:contributor      "Reviewed: Geijtenbeek, Teunis B H, 2014-09-02" , "GOC:reactome_curators" , "Edited: Garapati, P V, 2014-07-14" , "Authored: Garapati, P V, 2014-07-14" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-5607763" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-5607764/R-HSA-5607764> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

