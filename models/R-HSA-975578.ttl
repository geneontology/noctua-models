obo:BFO_0000050  a  owl:ObjectProperty .

:R-HSA-975578  a            obo:GO_0008150 , owl:NamedIndividual ;
        rdfs:comment        "If MAN2 acts before MGAT3, the pathway progresses to complex N-glycans, because MAN2 is not able to operate on bisected oligosaccharides (11421343, page 5). The expression of MAN2 over MGAT3 in a tissue can regulate the synthesis of hybrid or complex N-glycans." ;
        rdfs:label          "Reactions specific to the complex N-glycan synthesis pathway" ;
