lego:evidence  a  owl:AnnotationProperty .

:R-HSA-9620244  a           obo:GO_0007268 , owl:NamedIndividual ;
        rdfs:comment        "In long-term potentiation (LTP), involved in learning and memory, a brief period of synaptic activity induces a lasting increase in the strength of the synapse. LTP is initiated by NMDA receptor-mediated activation of calcium/calmodulin-dependent protein kinase II (CaMKII), followed by binding of CaMKII to the NMDA receptor and CaMKII-mediated phosphorylation of AMPA receptor subunits (reviewed by Lisman et al. 2012 and Luscher and Malenka 2012)." ;
        rdfs:label          "Long-term potentiation" ;
        dc:contributor      "GOC:reactome_curators" , "Edited: Orlic-Milacic, Marija, 2018-11-07" , "Reviewed: Yi, Feng, 2018-11-02" , "Authored: Orlic-Milacic, Marija, 2018-10-10" , "Reviewed: Hansen, Kasper B, 2018-11-02" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-9620244" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-438064/R-HSA-438064> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

