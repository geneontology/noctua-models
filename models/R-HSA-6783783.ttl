<http://model.geneontology.org/ev_w_id_REACTO_R-HSA-6784367_R-HSA-6784348_R-HSA-6784324_component_BFO_0000051_UniProtKB_P23458_R-HSA-6784367_R-HSA-6784324_component_Reactome_R-HSA-6783783>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/ECO_0000313> ;
        <http://purl.org/dc/elements/1.1/contributor>
                "GOC:reactome_curators" ;
        <http://purl.org/dc/elements/1.1/date>
                "2026-04-09" ;
