gomodel:SYNGO_2601  a     owl:Ontology ;
        rdfs:comment      "Rationale: GPC6 is sufficient to increase surface clustering of GluA1 AMPA receptors and to induce structural synapse formation.\n\n21/2/2018 Pim\n- GPC6 is a protein secreted by astrocytes.. Experimental description: Methods\nPurification and culture of RGCs and astrocytes\nRGCs were purified by sequential immunopanning to greater than 99% purity from P5-P7 Sprague-Dawley rats." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-6194-9648" , "https://orcid.org/0000-0001-5518-6584" ;
        dc:date           "2018-03-05" ;
        dc:title          "SYNGO_BP_2601" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

