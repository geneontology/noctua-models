gomodel:SYNGO_2409  a     owl:Ontology ;
        rdfs:comment      "Rationale: Enhanced synapse formation by overexpression of PTPRT.\nLoss of synapses by knockdown of PTPRT.\nKnockdown of PTPRT in cultured neurons (DIV 13-16) decreased the frequency, but not amplitude of mEPSCs.. Experimental description: Materials and methods\nCell culture and transfection\nPrimary hippocampal neuronal cultures were as described earlier (Lee et al, 2003)\nNeuron Culture, Transfection, and Immunostaining-Primary hippocampal neuronal cultures were prepared from rat embryonic brain (embryonic day 18)\n\nDNA constructs\nFull-length human PTPRT (NM_133170, aa 1-1460; from a human brain cDNA library; Clontech) was subcloned into GW1-CMV." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-6194-9648" , "https://orcid.org/0000-0001-5518-6584" ;
        dc:date           "2018-02-07" ;
        dc:title          "SYNGO_BP_2409" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

