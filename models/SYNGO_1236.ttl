gomodel:SYNGO_1236  a     owl:Ontology ;
        rdfs:comment      "Automated change 2024-03-14: GO:0030285 replaced by GO:0030672" , "Rationale: SV2C identified in purified SV fraction (Table I).\n\n19/01/2021 Dnyanada: PMID: 31959215 added to this annotation uses immunoEM data to demonstrate localisation of SV2 to synaptic vesicles. The anti-SV2 antibody used in the study is not isoform-specific and was added to the additional literature field for all SV2 CC annotations.. Experimental description: Result section, First sentence: To isolate docking complexes from RAT brain, we first prepared synaptosomes and subjected them to limited proteolysis to dissociate pre- and postsynaptic membranes" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9900-4233" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2024-03-14" ;
