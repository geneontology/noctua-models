	a <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/GO_0034602> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "alpha-ketoglutarate + CoASH + NAD+ => succinyl-CoA + CO2 + NADH + H+" ;
	<http://www.w3.org/2004/02/skos/core#exactMatch> <http://www.reactome.org/biopax/84/48887#BiochemicalReaction12850> ;
