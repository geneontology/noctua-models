gomodel:SYNGO_1082  a     owl:Ontology ;
        rdfs:comment      "Automated change 2024-03-14: GO:0099055 replaced by GO:0045211" , "Rationale: Pre-embedding immuno-peroxidase labelling for electron microscopy indicates the presence of Alpha2A Adrenergic receptor (Alpha2A-AR) immunoreactivity in some dendrites and spines in the hippocampus (Fig. 3, 4, 6, 8, 9). Immunoreactive postsynapses were \"exclusively asymmetric contacts\". Alpha2A-AR immunoreactivity was often intense at the postsynaptic density and perisynaptic region (figure legend Fig. 3).\n\nPreabsorption of the antibody with the peptide completely abolishes immunostaining (Fig. 1C).. Experimental description: Fourteen adult male Sprague-Dawley rats (250-300 g;Hilltop Labs, Scottdale, PA) were used in the study." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-3185-5709" , "https://orcid.org/0000-0003-0938-8534" , "https://orcid.org/0000-0001-7351-8706" , "https://orcid.org/0000-0002-0755-5899" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_1082" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .
