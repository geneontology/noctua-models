gomodel:SYNGO_5529  a     owl:Ontology ;
        rdfs:comment      "Automated change 2024-03-14: GO:0099055 replaced by GO:0045211" , "Rationale: Figure 4B: OLFM1 pulldowns yield AMPARs and SE6L1 (SEZ6L) as strong interactors.\n\nFigure S10: Confocal fluorescence imaging showed SE6L1 localized to postsynaptic membranes in the hippocampal CA1 region by virtue of partial co-localization with the mostly spine-restricted Nrn1 (SE6L1 was homogenously distributed along the dendrite).. Experimental description: the hippocampal CA1 pyramidal cells used for confocal were obtained from mice. Intact tissue was used for confocal imaging. M&M;\n\"Staining\nAfter fixation, slices were incubated overnight at 4°C in a 0.1 M PB buffer containing 0.1% Triton X-100 and 6% normal goat serum or normal donkey serum with antibodies.\"\n\nantibody;\nsheep anti-SEZ6L (R&D System AF-4804)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_5529" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

