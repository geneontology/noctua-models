obo:GO_0099171  a  owl:Class .

gomodel:SYNGO_871  a      owl:Ontology ;
        rdfs:comment      "Rationale: Mint2 likely functions redundantly with Mint1 in excitatory neurons to regulate presynaptic release at excitatory synapses.\nFig. 5 shows that Mint1/2 DKO mice but not single Mint1 KO mice exhibit reduced basal excitatory synaptic strength and a decrease in neurotransmitter release probability at excitatory synapses.\nFig. 6 shows that release probability is normal at inhibitory synapses of Mint1/2 DKO mice.\nFig. 7 shows that Mint1/2 DKO mice have reduced mEPSC frequency.. Experimental description: Mint1/2 double KO mice were studied." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0912-1514" , "https://orcid.org/0000-0002-3670-7863" ;
        dc:date           "2018-06-07" ;
        dc:title          "SYNGO_BP_871" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

