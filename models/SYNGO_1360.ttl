obo:GO_0030163  a  owl:Class .

gomodel:SYNGO_1360  a     owl:Ontology ;
        rdfs:comment      "Rationale: Stimulation of synaptosomes by high potassium (K), induces release of radiolabelled proline. These data indicate depolarization-induced proline release from SVs. The L-proline transporter is expressed in synaptic vesicles (see linked reference annotation). Therefore these data indicate a function of L-proline in transporting proline into SVs.. Experimental description: Male Wistar (WAG) rats weighing 180-220 g were de- capitated, and visual cortex slices" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-7351-8706" , "https://orcid.org/0000-0003-3185-5709" , "https://orcid.org/0000-0002-0755-5899" , "https://orcid.org/0000-0003-0938-8534" ;
        dc:date           "2018-05-29" ;
        dc:title          "SYNGO_BP_1360" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

