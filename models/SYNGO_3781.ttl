gomodel:SYNGO_3781  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.3: \"Glycinergic synapses are disrupted in nbea mutants\"\n\nFig.4: \"Electrical and chemical synaptic scaffolds are disrupted in nbea mutants\"\n\nFig.6: \"Neurobeachin is necessary and sufficient in the postsynaptic neuron for electrical and chemical synapse formation\"\n- \"We found that Nbea was also sufficient in the postsynaptic neuron (be it CoLo or M), but not in the presynaptic neuron, to rescue GlyR localization\"\n- \"Taken together we conclude that Nbea is both necessary and sufficient within the postsynaptic neuron for electrical and chemical synapse formation.\"\n\n- synapse organization. Experimental description: - \"In a forward genetic screen in zebrafish we identified a mutation in neurobeachin (nbea)...\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0003-0593-3443" ;
        dc:date           "2023-03-17" ;
        dc:title          "SYNGO_BP_3781" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_7955" .

