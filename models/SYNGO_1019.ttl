gomodel:SYNGO_1019  a     owl:Ontology ;
        rdfs:comment      "Rationale: The results in Fig. 6C,D show that SynCAM 1 is required so that the postsynaptic protein Farp1 can regulate presynaptic active zone composition. Specifically, elevating Farp1 selectively in postsynaptic neurons increases the intensity of staining for the active zone marker Bassoon in presynaptic neurons that form inputs onto these neurons, and this Farp1-dependent increase in Bassoon intensity does not occur when SynCAM 1 is knocked-out.. Experimental description: The authors used a construct cloned from a mouse library, see SynGO entry 1018" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0912-1514" , "https://orcid.org/0000-0002-3670-7863" ;
        dc:date           "2017-11-01" ;
        dc:title          "SYNGO_BP_1019" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

