[ a                      owl:Axiom ;
  rdfs:comment           "Both AKT-1, AKT-2, and SGK-1 purified from a wild-type background phosphorylated DAF-16 (Figure 4A). In contrast, all three kinases purified\nfrom a pdk-1 mutant background were not able to phosphorylate DAF-16 (Figure 4A). This demonstrates that functional PDK-1 is required to activate AKT-1, AKT-2, and SGK-1 in vivo." ;
  lego:evidence          :568b0f9600000499 ;
  dc:contributor         "https://orcid.org/0000-0002-1706-4196" ;
  dc:date                "2016-01-28" ;
  owl:annotatedProperty  obo:RO_0002333 ;
  owl:annotatedSource    :5667fdd400000706 ;
  owl:annotatedTarget    :568b0f9600000498
] .

<http://identifiers.org/wormbase/WBGene00004932>
