[ a                      owl:Axiom ;
  rdfs:comment           "Thus, the expression pattern and localization of SGK-1 closely resembles that of PDK-1 (Paradis et al., 1999), but is distinct from the cellular localization of AKT-1::GFP and AKT-2::GFP, which preferentially stain the cytoplasmic membrane (Paradis and Ruvkun, 1998; our unpublished data)." ;
  lego:evidence          :568b0f9600000508 ;
  dc:contributor         "https://orcid.org/0000-0002-1706-4196" ;
  dc:date                "2016-01-28" ;
  owl:annotatedProperty  obo:BFO_0000066 ;
