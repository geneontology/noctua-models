:R-HSA-5654732  a           owl:NamedIndividual , obo:GO_0008150 ;
        rdfs:comment        "Once activated, the FGFR signaling pathway is regulated by numerous negative feedback mechanisms. These include downregulation of receptors through CBL-mediated ubiquitination and endocytosis, ERK-mediated inhibition of FRS2-tyrosine phosphorylation and the attenuation of ERK signaling through the action of dual-specificity phosphatases, IL17RD/SEF, Sprouty and Spred proteins. A number of these inhibitors are themselves transcriptional targets of the activated FGFR pathway." ;
        rdfs:label          "Negative regulation of FGFR3 signaling" ;
        dc:contributor      "Authored: Rothfels, K, 2011-08-15" , "Reviewed: Gotoh, N, 2011-08-26" , "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-5654732" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-5654741/R-HSA-5654741> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

