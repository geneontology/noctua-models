lego:evidence  a  owl:AnnotationProperty .

gomodel:SYNGO_4550  a     owl:Ontology ;
        rdfs:comment      "Rationale: Activity-dependent structural plasticity of dendritic spines is regulated by CD44. Chemical LTP (cLTP) induces massive increase of spine head size. This is suppressed by shRNA-mediated knockdown of CD44 (Fig. 5). The activity-dependent regulation of spine shape may be mediated by differential regulation of small actin cytoskeleton-regulating GTPases RhoA, Rac1, and Cdc42 as shown in a FRET-based assay (Fig. 6).. Experimental description: Primary rat hippocampal cultures were prepared from P0 rat brains as described previously ... (p. 4063/ Cell cultures)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9681-3318" , "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-9880-1214" , "https://orcid.org/0000-0002-0269-0311" ;
        dc:date           "2023-01-29" ;
        dc:title          "SYNGO_BP_4550" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

