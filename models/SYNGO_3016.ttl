obo:GO_0003674  a  owl:Class .

gomodel:SYNGO_3016  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.3: \"CPEB Localizes to Synapses in Hippocampal Neurons In Vitro\"\n- \"CPEB immunoreactivity displays a similar distribution to that of synapses on this neuron. A higher magnification of a dendrite taken from two different neurons demonstrates CPEB colocalization with synapses (arrows). Some synapses have little or no CPEB colocalization (small arrowheads).\"\n- \"CPEB is enriched in the postsynaptic density\". Experimental description: - \"Low-density cultures of rat hippocampal neurons were made as previously described...\"\n- \"Postsynaptic density fractions were prepared from adult rat brain ...\"\n\nNote: The paper just mentions 'CPEB'. Based on blast analysis of the qPCR primer sequence 'TCAAGCCTTCGCATTTCCCCTCC' I could conclude that the authors studied CPEB-1." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2018-03-27" ;
        dc:title          "SYNGO_CC_3016" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

