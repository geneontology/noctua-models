obo:BFO_0000050  a  owl:ObjectProperty .

gomodel:SYNGO_5045  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 1d: GFP-ARHGAP12 was localized to dendritic spines of rat hippocampal CA1 pyramidal neurons.\n\nFigure 1e: double immunofluorescence labeling of ARHGAP12 and PSD-95 (DLG4) in hippocampi sections from a P20 rat showed partial co-localization.. Experimental description: M&M: \"Rats were used at E18 or postnatal day 6 (P6) for primary neuronal cultures or organotypic hippocampal slices, respectively\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2514-0216" ;
