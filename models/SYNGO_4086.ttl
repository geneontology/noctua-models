gomodel:SYNGO_4086  a     owl:Ontology ;
        rdfs:comment      "Rationale: Hippocampal neurons of ROCK2 heterozygous mice showed reduced spine density accompanied by increased spine width and length. The density of excitatory synapses were also reduced. The mutant neurons also show reductions in mEPSC frequencies and amplitudes with depressed input/output curves. Impairments in spatial learning and memory and in fear conditioning paradigms were also observed.. Experimental description: Materials and Methods \"The Rock1+/- and Rock2+/- mice were gifted from Dr. Robert W. Caldwell of Augusta University\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-5615-1014" ;
        dc:date           "2020-09-25" ;
        dc:title          "SYNGO_BP_4086" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

