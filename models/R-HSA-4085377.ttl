:R-HSA-4085377  a           obo:GO_0008150 , owl:NamedIndividual ;
        rdfs:comment        "SUMOylation processes themselves can be controlled by SUMOylation (reviewed in Wilkinson and Henley 2010). The SUMO E3 ligases PIAS4, RANBP2, and TOPORS are SUMOylated, as is the single SUMO E2 enzyme, UBE2I (UBC9). SUMOylation affects the subcellular location of PIAS4 and TOPORS and affects the activity of PIAS4 and UBE2I." ;
        rdfs:label          "SUMOylation of SUMOylation proteins" ;
        dc:contributor      "Reviewed: Niskanen, Einari, 2018-08-08" , "Edited: May, B, 2013-08-03" , "Reviewed: Niskanen, Einari, 2018-05-09" , "GOC:reactome_curators" , "Authored: May, B, 2013-08-03" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-4085377" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-3108232/R-HSA-3108232> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

