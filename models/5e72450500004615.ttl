[ a                      owl:Axiom ;
  rdfs:comment           "Mild alterations in gene expression of GAG\nsynthesizing enzymes and core proteins" , "increased expression of the GPI-anchored glypicans (Gpc), Gpc2, Gpc3 and Gpc6 in Ext1gt/gt chondrocytes. the\nsmall leucin-rich proteoglycan decorin (Dcn) was\nreduced, while the expression of biglycan (Bgn)\nwas elevated. Importantly, the expression of aggrecan (Acan) the major PG of the interterritorial ECM,\nwas increased, accompanied by an increased\nexpression of the hyaluronan binding link protein\n(Hpln1)" ;
  lego:evidence          :5e72450500004640 ;
  dc:contributor         "https://orcid.org/0000-0003-3394-9805" ;
  dc:date                "2020-05-19" ;
  pav:providedBy         "http://informatics.jax.org" ;
  owl:annotatedProperty  obo:RO_0002418 ;
  owl:annotatedSource    :5e72450500004620 ;
  owl:annotatedTarget    :5e72450500004638
] .

