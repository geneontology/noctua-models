:R-HSA-8851907  a           owl:NamedIndividual , obo:GO_0008150 ;
        rdfs:comment        "MET binds and phosphorylates the adapter protein GAB1, thus creating a docking site for the regulatory subunit PIK3R1 of the PI3K complex. Recruitment of PI3K to MET-bound phosphorylated GAB1 results in PI3K activation, production of PIP3, and stimulation of downstream AKT signaling (Rodrigues et al. 2000, Schaeper et al. 2000)." ;
        rdfs:label          "MET activates PI3K/AKT signaling" ;
        dc:contributor      "Edited: Orlic-Milacic, Marija, 2016-06-14" , "Reviewed: Heynen, Guustaaf, 2016-07-11" , "Authored: Orlic-Milacic, Marija, 2016-06-14" , "GOC:reactome_curators" , "Reviewed: Birchmeier, Walter, 2016-07-11" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-8851907" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-6806834/R-HSA-6806834> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

