<http://model.geneontology.org/ev_w_id_REACTO_R-HSA-1369125_R-HSA-1369095_R-HSA-1671691_component_BFO_0000051_REACTO_R-HSA-1977945_R-HSA-1369125_R-HSA-1671691_component_Reactome_R-HSA-1369125>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/ECO_0000313> ;
