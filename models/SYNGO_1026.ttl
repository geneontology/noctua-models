gomodel:SYNGO_1026  a     owl:Ontology ;
        rdfs:comment      "Rationale: CDCrel-1 (SEPT5) in axon terminals in thalamus (Fig4C) and globus pallidus (Fig4D). They claim in Fig4D that it are mainly GABA terminals, identified by the DAB stain with SEPT5 in gold label, but the DAB stain is not that clear. No quantification of the immuno-EM labeling is offered.. Experimental description: M&M \"We used preembedding immunoperoxidase and immunogold labeling methods. Mouse brains were fixed with PB\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0001-5259-4945" ;
        dc:date           "2017-08-07" ;
        dc:title          "SYNGO_CC_1026" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

