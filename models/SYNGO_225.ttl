gomodel:SYNGO_225  a      owl:Ontology ;
        rdfs:comment      "Rationale: CTTNBP2 regulates dendritic spine morphology and synaptic activity (Fig 4) by stabilizing the actin actin-binding protein cortactin (CTTN; SynGO ID 223) at synapses (Fig 5 and 7).. Experimental description: - overexpression constructs (myc tagged CTTNBP2 mutatnts) were generated from mouse cDNAs (see Table 1)\n- species of miRNA KD effect is **rat** (rat tissues)\n\n9/3/2017 Pim:\n-species of cultured neurons (Fig.4,6,7) is **rat**.\n-Final annotation made against **rat**" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-6153-3586" , "https://orcid.org/0000-0002-2666-0758" ;
        dc:date           "2017-03-28" ;
        dc:title          "SYNGO_BP_225" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

