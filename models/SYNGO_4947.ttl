lego:evidence  a  owl:AnnotationProperty .

gomodel:SYNGO_4947  a     owl:Ontology ;
        rdfs:comment      "Rationale: PODXL is required for correct synaptogenesis in the hippocampus (Fig. 6). Confocal imaging of mouse hippocampal cultured neurons and electron microscopy imaging of both tissue slice and cultures showed a 23~28% decreased density of synaptic contacts.. Experimental description: Result section text related to Figure 6; \"podxl-deficient mice do not survive after birth, therefore to ascertain whether decreased synaptogenesis is transient or persistent, we prepared organotypic hippocampal slices from E18 embryos that were cultured for 7 DIV.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2023-01-29" ;
        dc:title          "SYNGO_BP_4947" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

