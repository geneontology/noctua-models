<http://model.geneontology.org/reaction_R-HSA-9013978_location_lociGO_0010008>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/GO_0010008> ;
        <http://purl.org/dc/elements/1.1/contributor>
                "GOC:reactome_curators" ;
        <http://purl.org/dc/elements/1.1/date>
                "2026-04-08" ;
