gomodel:SYNGO_1072  a     owl:Ontology ;
        rdfs:comment      "Rationale: The study uses subcellular fractionation to show the predicted cytoplasmic Ca2+ binding protein shows pool of membrane associated protein. This is distributed in a Ca2+ dependent fashion to synaptic and synaptic vesicle membranes. This observed when Calretinin immunoreactivity in fractions is probed by western blotting and radioimmunoassy.. Experimental description: Material and Methods: \"Sub-cellular fractions were prepared from the cerebellum of male rats." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0938-8534" , "https://orcid.org/0000-0003-3185-5709" , "https://orcid.org/0000-0001-7351-8706" , "https://orcid.org/0000-0002-0755-5899" ;
        dc:date           "2018-10-19" ;
        dc:title          "SYNGO_CC_1072" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

