gomodel:SYNGO_2967  a     owl:Ontology ;
        rdfs:comment      "Rationale: Conclusion: CTNND2; NPRAP is a protein that structurally couples AMPARs to cadherins via the GRIP1 (possibly GRIP2) proteins.\n\nFig.1: \"Formation of GluR2-ABP/GRIP-NPRAP-cadherin complexes in vitro and in vivo.\"\n\nFig.5: \"PSD enrichment and interaction of endogenous NPRAP with N-cadherin and the scaffolding proteins ABP, GRIP, and PSD-95 in brain and synaptosomal fractions.\"\n\nFig.6: \"Exogenous NPRAP recruits ABP to spines of cultured neurons dependent on the PDZ binding site\"\n\nFig.7: \"Dominant-negative NPRAP constructs decrease cell surface endogenous AMPAR\". Experimental description: - \"Rat hippocampal neurons in low-density culture ...\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0003-0593-3443" ;
        dc:date           "2018-05-30" ;
        dc:title          "SYNGO_MF_2967" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

