:R-HSA-9013106  a           obo:GO_0008150 , owl:NamedIndividual ;
        rdfs:comment        "This pathway catalogues RHOC guanine nucleotide exchange factors (GEFs), GTPase activator proteins (GAPs), GDP dissociation inhibitors (GDIs) and RHOC effectors. RHOC belongs to the RHOA subfamily of RHO GTPases and shares 85% sequence identity with RHOA and RHOB (Wheeler and Ridley 2004). Like RHOA and RHOB, RHOC regulates the cytoskeleton and is involved in cell adhesion and migration (Guan et al. 2018). RHOC contributes to invasiveness and metastatic potential of cancer cells (Bravo-Cordero et al. 2014; Guan et al. 2018; Thomas et al. 2019)." ;
        rdfs:label          "RHOC GTPase cycle" ;
        dc:contributor      "Edited: Orlic-Milacic, Marija, 2021-02-25" , "GOC:reactome_curators" , "Authored: Orlic-Milacic, Marija, 2020-07-14" , "Reviewed: Fort, Philippe, 2021-02-05" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-9013106" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-9012999/R-HSA-9012999> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

