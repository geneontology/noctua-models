gomodel:SYNGO_5335  a     owl:Ontology ;
        rdfs:comment      "Rationale: \"We injected lentiviral vectors into the CA1 region of P0 rat pups and imaged P14 secondary apical CA1 dendrites in SR on a structured illumination microscope followed by analysis of dendritic spine density. FLRT2 KD caused a strong, 47.3% decrease in dendritic spine density compared to dendrites from CA1 neurons infected with control lentivirus (Figures 5A and 5B). ... Spine shape was not detectably altered in any of the KD conditions (Figure S6A)\". Experimental description: Results: \"We injected lentiviral vectors into the CA1 region of P0 rat pups ...\"\n\nshRNA targeting sequence: FLRT2: GATCCAACTTTCCATCCAC" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2023-03-12" ;
        dc:title          "SYNGO_BP_5335" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

