gomodel:SYNGO_201  a      owl:Ontology ;
        rdfs:comment      "Rationale: Flotillin-1 co-localizes with markers of excitatory synapses (VGLUT1, GluN1) but not with GABAergic markers (GAD65). Currently it cannot decided if the protein is localized pre- or postsynaptic.. Experimental description: hippocampi were dissected from embryonic day 18 Sprague-Dawley rats" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-0269-0311" , "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-9880-1214" , "https://orcid.org/0000-0002-9681-3318" ;
