gomodel:ev_w_id_R-HSA-9036987_RO_0002411_R-HSA-9034053_Reactome_R-HSA-9033807
        a               owl:NamedIndividual , obo:ECO_0000313 ;
        dc:contributor  "GOC:reactome_curators" ;
