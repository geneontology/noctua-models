gomodel:SYNGO_2158  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig4. vamp2+vamp7+ap3 co-localize in mouse primary neocortical neurons. Antibody against delta subunit of the AP-3 adaptor complex (SA4).\n\nNote: the AP-3 complex location is used as a marker of the endosomal compartment. The study details the co-localization of synaptic vesicle proteins and AP-3 to show that the endosomal compartment is in fact present in the presynapse.. Experimental description: \"Synaptic vesicle and lysosomal AP-3 cargoes colocalization in mouse primary neocortical neurons...\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-7806-5662" ;
        dc:date           "2018-02-14" ;
        dc:title          "SYNGO_CC_2158" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

