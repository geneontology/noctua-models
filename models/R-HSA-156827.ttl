obo:GO_0008150  a  owl:Class .

obo:RO_0002234  a  owl:ObjectProperty .

:R-HSA-156827  a            owl:NamedIndividual , obo:GO_0008150 ;
        rdfs:comment        "While circularization of mRNA during translation initiation is thought to contribute to an increase in the efficiency of translation, it also appears to provide a mechanism for translational silencing. This might be achieved by bringing inhibitory 3' UTR-binding proteins into a position in which they interfere either with the function of the translation initiation complex or with the assembly of the ribosome (Mazumder et al 2001). Translational silencing of Ceruloplasmin (Cp) occurs 16 hrs after its induction by INF-gamma (Mazumder et al., 1997). Although the mechanism by which silencing occurs has not yet been determined, this process is mediated by the L13a subunit of the 60s ribosome and thought to require circularization of the Cp mRNA (Sampath et al., 2003; Mazumder et al., 2001; Mazumder et al., 2003). Between 14 and 16 hrs after INF gamma induction, the L13a subunit of the 60s ribosome is phosphorylated and released from the 60s subunit. Phosphorylated L13a then associates with the GAIT element in the 3' UTR of the Cp mRNA inhibiting its translation." ;
        rdfs:label          "L13a-mediated translational silencing of Ceruloplasmin expression" ;
        dc:contributor      "GOC:reactome_curators" , "Authored: Matthews, L, 2004-12-13 00:49:48" , "Edited: Matthews, L, 0000-00-00 00:00:00" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-156827" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-72613/R-HSA-72613> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

