obo:BFO_0000050  a  owl:ObjectProperty .

gomodel:SYNGO_5516  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 6:\n\"Immunoelectron microscopic localization of testican. Testican localization in the postsynaptic portion of synapses present in the stratum lucidum of the hippocampus (a, b), cortex (c, d), and molecular layer of the cerebellum (e) of a 21-day-old mouse brain after incubation with PTC9 antiserum (1:500).\n\nThe labeling (open arrows) is strong on the postsynaptic (Po) density and faint in the immediate cytoplasmic fluid. No labeling is present in the synaptic cleft. The corresponding presynaptic areas (Pr), clearly identified by the presence of synaptic vesicles, are also negative; not all the postsynaptic densities are immunostained.\". Experimental description: Figure 6: \"Testican localization in the postsynaptic portion of synapses present in the stratum lucidum of the hippocampus (a, b), cortex (c, d), and molecular layer of the cerebellum (e) of a 21-day-old mouse brain after incubation with PTC9 antiserum (1:500).\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2023-11-02" ;
        dc:title          "SYNGO_CC_5516" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

