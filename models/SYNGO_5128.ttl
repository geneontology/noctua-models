gomodel:SYNGO_5128  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 1a: CC2D1A (aka. Freud-1) protein expression in hippocampal CA1 tissue was lowest at E18 and postnatal day 1 as compared to young and adult mice.\n\nFigure 1b: biochemical fractions showed CC2D1A was present at both pre- and post-synapse.\n\nFigure 6: Effects of Cc2d1a deletion on expression of AMPAR and NMDAR subunits, mEPSCs, and evoked NMDAR-mediated EPSCs in the hippocampal CA1 region.. Experimental description: Results, Figure 1 legend: \"Representative immunoblotting analysis showing the subcellular localization of CC2D1A in P35 mouse hippocampal CA1 lysates\"\n\nantibody:\nCC2D1A (1:1000; Proteintech, catalog #16816-1-AP, RRID:AB_2275394)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2023-02-25" ;
        dc:title          "SYNGO_CC_5128" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

