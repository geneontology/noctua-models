gomodel:SYNGO_47  a       owl:Ontology ;
        rdfs:comment      "Rationale: Immunoblotting of subcellular fractions and highly purified synaptic vesicles using specific antibodies against RAB3A indicate presence of Rab3A in synaptic vesicles.\n\nUniprot: has lipid anchor. Experimental description: \"For generation of N-terminally hexahistidine-tagged expression constructs, mouse Rab3A (primers 1236, CGGGATCCGCTTCCGCCACAGACTCTCGC, and 1209, TCAGCAGGCACAATCCTGATGAGG), Rab3B (primers 931, CATATGGCTTCAGTGACTGATGGTAAGACTGG and 932,GAATTCTGCTGCAGCAGAGGTGGGG),and Rab 3C (primers 1238, GGATCCGCCTCTGCACAAGATGCCAGG, and 1213, TTAGCAGCCACAGTTGGGCTGTGG) were cloned by PCR from mouse brain cDNA as template.\"" , "Automated change 2024-03-14: GO:0098993 replaced by GO:0030672" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-5615-1014" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_47" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

