gomodel:SYNGO_5288  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 13b, c: immunofluorescence imaging of cultured hippocampal neurons showed overexpressed SRGAP3 was enriched in dendritic spines at a ratio of 1.32 compared to diffuse GFP with a ratio of 0.99.. Experimental description: M&M: \"Briefly, the hippocampi of embryonal day 17 Wistar rat fetuses of either sex were dissected and brains obtained.\"\n\nWild-type mCherry-tagged α-actinin 4 (ACTN4)\n\"Briefly, entry clones [clone-IDs: 100011237 (ACTN4) and 100069053 (SrGAP3)] from the human ORFeome collaboration library were transferred into mCherry-tagged mammalian expression destination vectors using standard LR Gateway cloning.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2023-03-09" ;
        dc:title          "SYNGO_CC_5288" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_9606" .

