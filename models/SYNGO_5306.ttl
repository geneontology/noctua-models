gomodel:SYNGO_5306  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 3e-j: immunofluorescence imaging of FGF7 in cultured hippocampal neurons showed co-localization with inhibitory postsynapse marker protein Gephyrin (GPHN). Same results for both overexpressed FGF7-DsRed and endogenous FGF7. FGF7 did not colocalize with excitatory synapse marker proteins.. Experimental description: M&M: \"Dissociated hippocampal cultures were prepared from E16.5-P0 WT, FGF22KO and FGF7KO mice as previously described\"\n\nantibody:\nanti-FGF7 (1:100; Santa Cruz, H-73 and C-19)\n\nplasmid:\n\"Expression plasmids for FGF22-EGFP and FGF7-DsRed were generated by subcloning the full-length mouse fgf22 or fgf7 cDNA (minus the stop codon) into the NheI-XhoI or EcoRI-ApaI sites of pEGFP-N1 or pDsRed2-N1 (Clontech) in frame.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2023-03-11" ;
        dc:title          "SYNGO_CC_5306" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

