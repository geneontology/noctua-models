gomodel:SYNGO_2455  a     owl:Ontology ;
        rdfs:comment      "Rationale: SALM5 interacts with LAR in cell aggregation assays.\nSALM5 directly interacts with LAR.\nSoluble LAR inhibits SALM5-dependent synapsin I clustering.. Experimental description: Materials and Methods\nMixed-culture assay\nprimary hippocampal neuron cultures at DIV 9/10 prepared from E18-19 rat hippocampi were cocultured with HEK293T cells.\n\nDNA constructs and antibodies\nFor Myc tagging of SALMs, the epitope was inserted between aa 16 and 17 of mouse SALM3 and aa 19 and 20 of mouse SALM5, respectively, in pGW1 (British Biotechnology)." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-6194-9648" , "https://orcid.org/0000-0001-5518-6584" ;
        dc:date           "2018-02-21" ;
        dc:title          "SYNGO_BP_2455" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

