gomodel:SYNGO_167  a      owl:Ontology ;
        rdfs:comment      "Rationale: Using immuno electron microscopy (figure 3), it is shown that calcineurin gamma (PPP3CC) is present in the presynaptic cytosol. The antibody used is costum made, and was tested with RNA knockdown (Figure 4).. Experimental description: vibratome sections of 4% paraformaldehyde and 0.1% glutaraldehyde perfusion-fixed mouse hippocampi were immunostained using rabbit anti-mouse CNA antiserum overnight at room temperature." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-7620-2704" , "https://orcid.org/0000-0002-1558-1958" ;
        dc:date           "2017-08-31" ;
        dc:title          "SYNGO_CC_167" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

