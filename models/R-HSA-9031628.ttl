:R-HSA-9031628  a           obo:GO_0008150 , owl:NamedIndividual ;
        rdfs:comment        "NGF stimulation induces expression of a wide array of transcriptional targets. In rat PC12 cells, a common model for NGF signaling, stimulation with NGF causes cells to exit the cell cycle and undergo a differentiation program leading to neurite outgrowth. This program is driven by the expression of immediate early genes (IEGs), which frequently encode transcription factors regulating the activity of NGF-specific delayed response genes (reviewed in Sheng and Greenberg, 1990; Flavell and Grennberg, 2008; Santiago and Bashaw, 2014)." ;
        rdfs:label          "NGF-stimulated transcription" ;
        dc:contributor      "Reviewed: Aletta, John M, 2020-01-17" , "Edited: Rothfels, Karen, 2020-02-24" , "GOC:reactome_curators" , "Authored: Rothfels, Karen, 2019-08-16" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-9031628" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-198725/R-HSA-198725> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

