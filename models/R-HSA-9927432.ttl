<http://model.geneontology.org/ev_w_id_R-HSA-9925879_RO_0012002_UniProt_P15514_R-HSA-9925879_controller_Reactome_R-HSA-9927432>
        a       <http://purl.obolibrary.org/obo/ECO_0000363> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
