<http://model.geneontology.org/ev_w_id_R-HSA-9925879_RO_0002234_R-HSA-9925876_R-HSA-9925879_Reactome_R-HSA-9925879>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/ECO_0000313> ;
