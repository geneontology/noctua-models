gomodel:SYNGO_1602  a     owl:Ontology ;
        rdfs:comment      "Rationale: Immunohistochemistry on primary neurons from P2 hippocampus (DIV14-DIV21) from wild-type or Abi2-/- mice shows localization of Abi2 at dendritic spines.\n\nFurthermore analysis of dendritic spines in pyramidal neurons of neocortexes and CA1 regions of the hippocampus shows that loss of Abi2 results in aberrant spine morphology and density.. Experimental description: C57BL/6 mice" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9848-0262" , "https://orcid.org/0000-0002-4419-210X" , "https://orcid.org/0000-0002-1190-4481" , "https://orcid.org/0000-0002-2094-7491" ;
        dc:date           "2018-05-31" ;
        dc:title          "SYNGO_BP_1602" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

