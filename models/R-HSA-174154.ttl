dc:date  a      owl:AnnotationProperty .

:R-HSA-174154  a            obo:GO_0031145 , owl:NamedIndividual ;
        rdfs:comment        "The separation of sister chromatids in anaphase requires the destruction of the anaphase inhibitor, securin. Securin associates with and inactivates the protease, separase. Separase cleaves the cohesin subunit, Scc1 that is responsible for the cohesion of sister chromatids (reviewed in Nasmyth et al., 2000). Securin destruction begins at metaphase after the mitotic spindle checkpoint has been satisfied (Hagting et al., 2002)." ;
        rdfs:label          "APC/C:Cdc20 mediated degradation of Securin" ;
        dc:contributor      "Edited: Matthews, L, 2006-01-30 00:00:00" , "Authored: Lorca, T, Castro, A, 2006-01-26 00:00:00" , "Reviewed: Peters, JM, 2006-03-27 22:55:09" , "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-174154" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-176409/R-HSA-176409> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

