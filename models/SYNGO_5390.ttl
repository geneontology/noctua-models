gomodel:SYNGO_5390  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 1-3: using a specific blocker (JTE-013) for the sphingosine-1-phosphate receptor 2 (S1PR2) affects dendritic spine development in CA3 pyramidal neurons. Confocal imaging after application showed spine density and morphology was significantly affected. This was confirmed by FRAP of eGFP-actin in spines.. Experimental description: M&M: \"Hippocampal organotypic cultures were prepared from postnatal day 5 (P5) C57Bl/6 mice of either sex as previously described (Stoppini et al., 1991; Michaelsen-Preusse et al., 2014).\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2023-03-15" ;
        dc:title          "SYNGO_BP_5390" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

