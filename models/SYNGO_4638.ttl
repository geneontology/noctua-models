gomodel:SYNGO_4638  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 3. immunogold labeling of Vps52 in mouse CA1 hippocampal pyramidal cells.\n\n\"Immunoreactive metal particles for Vps52 were distributed in various compartments including the cell body, dendrite, dendritic spine, axon, and nerve terminal (Fig. 3A-F). Quantitative analysis revealed that the highest density of immunoreactive particles was detected in the dendrite and cell body with approximately twofold higher density than that in the dendritic spine, axon, and nerve terminal\". Experimental description: \"C57BL/6 mice were used for immunoprecipitation, immunoblotting, and immunohistochemical analyses, and pregnant ICR mice were used for hippocampal primary culture\"\n\n\"rabbit anti-Vps52 IgG (1.0 μg/ml, Cat. No. HPA042667, Atlas Antibodies AB, Bromma, Sweden), which had been raised against the recombinant protein corresponding to amino acids 56-154 of mouse Vps52 (GeneBank accession no. NM_172620).\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2022-05-07" ;
        dc:title          "SYNGO_CC_4638" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

