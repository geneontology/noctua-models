obo:RO_0002333  a  owl:ObjectProperty .

:R-HSA-75815  a             owl:NamedIndividual , obo:GO_0043161 ;
        rdfs:comment        "Cyclin D turnover is regulated by ubiquitination and proteasomal degradation which are positively regulated by cyclin D phosphorylation on threonine-286 (Diehl et al., 1997).<p>After the Cyclin D serves the role of mediating reactions by Cdk4 and Cdk6, it is shuttled to the cytoplasm and degraded in a ubiquitin-dependent manner. Whether Cdk4 and Cdk6 are truly redundant is a topic still under investigation, although both the kinases are required for normal cell cycle progression.<p>Destruction of the D type cyclins accompanies the end of the G1 phase, and the E type cyclins are involved in transition of the cell from G1 to S phase." ;
        rdfs:label          "Ubiquitin-dependent degradation of Cyclin D" ;
        dc:contributor      "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-75815" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-69242/R-HSA-69242> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

