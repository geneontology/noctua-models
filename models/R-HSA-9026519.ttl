:R-HSA-9026519  a           owl:NamedIndividual , obo:GO_0046579 ;
        rdfs:comment        "Activation of the neurotrophin receptor NTRK2 (TRKB) by BDNF or NTF4 triggers downstream RAS signaling. The best studied mechanism for activation of RAS signaling downstream of NTRK2 is through SHC1-mediated recruitment of the GRB2:SOS1 complex, triggering SOS1-mediated guanine nucleotide exchange on RAS and formation of active RAS:GTP complexes (Minichiello et al. 1998, McCarthy and Feinstein 1999, Yuen and Mobley 1999)." ;
        rdfs:label          "Activated NTRK2 signals through RAS" ;
        dc:contributor      "Edited: Orlic-Milacic, Marija, 2018-02-20" , "Reviewed: Castrén, Eero, 2018-02-13" , "Reviewed: Antila, Hanna, 2018-02-13" , "Authored: Orlic-Milacic, Marija, 2018-01-05" , "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-9026519" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-9006115/R-HSA-9006115> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

