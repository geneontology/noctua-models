gomodel:SYNGO_4606  a     owl:Ontology ;
        rdfs:comment      "Rationale: Table 1. Clathrin heavy chain (CLTC) was detected in biochemically enriched PSD fractions by LC-MS/MS.\n\nFigure 3. Immunogold labeling of clathrin heavy chain in the mouse hippocampal CA1 region shows localization at the postsynaptic membrane, to the side of the spine and near the PSD.. Experimental description: \"Animals and Morphine Treatment ... Four-month-old male wild-type C57BL/6JBom mice (20-25 g) ...\"\n\n\"anti-clathrin antibody (1:10, BD Biosciences, San Jose, CA)\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-7806-5662" ;
        dc:date           "2022-06-19" ;
