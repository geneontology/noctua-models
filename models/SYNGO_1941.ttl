gomodel:SYNGO_1941  a     owl:Ontology ;
        rdfs:comment      "Automated change 2026-01-08: GO:0150047 replaced by GO:0099528" , "Rationale: GABAB1-deficient (GABAB1-/-) mice were generated. Using classical electrophysiological techniques together with application of baclofen, a GABA B agonist, authors showed lost of Pre- and Postsynaptic GABAB Responses in GABA B1 -/- mice. This demonstrates that GABAB1 is an essential component of pre- and postsynaptic GABAB receptors.. Experimental description: Horizontal slices containing the hippocampus (300 um thick) were prepared from P12 to P21 mice using standard procedures." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-5648-066X" , "https://orcid.org/0000-0001-7480-0826" , "https://orcid.org/0000-0003-2533-9548" , "https://orcid.org/0000-0003-4022-8707" , "https://orcid.org/0000-0002-1212-5623" ;
        dc:date           "2026-01-08" ;
        dc:title          "SYNGO_MF_1941" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

