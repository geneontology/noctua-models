obo:GO_0006810  a  owl:Class .

gomodel:SYNGO_2197  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.4: \"Myo5a mediates the postendocytic recycling of TrkB-FL but not TrkB.T1\" [shRNA, overexpression]\nFig.7: \"Inhibiting the association between Myo5a and TrkB by TAT-5aExonE55-66 reduces the recycling of TrkB-FL\" [TAT peptide of Myo5a domain --> overexopression]\nFig.8: \"Myo5a mediates the postendocytic recycling of TrkB-FL and contributes to the BDNF-triggered translocation of TrkB-FL into dendritic spines and sustained downstream signaling\" [TAT peptide of Myo5a domain --> overexpression]. Experimental description: Neuronal culture: species of the neuronal culture not stated in the paper.\nOverexpressed proteins: \"Plasmid constructs of rat TrkB-FL, TrkB.T1, TrkB mutant constructs, Myc-Rab11, HA-Rab3a were kept in our laboratory (Zhao et al., 2009; Huang et al., 2013)\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2018-05-29" ;
        dc:title          "SYNGO_BP_2197" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

