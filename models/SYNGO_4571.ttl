gomodel:SYNGO_4571  a     owl:Ontology ;
        rdfs:comment      "Rationale: Authors use a FRET sensor of ERK1/2 activation localized to presynapses and correlate the presence of over-expressed SIPA1L2 with lower fluorescence lifetime of the donor pair, that indirectly indicated ERK activation.\nIn a rescue experiments, restoration of SIPA1L2 rescues the ERK-dependent phosphorylation of Synapsin in sipa1l2-/- cells.. Experimental description: Recombinant DNA used to visualized SIPA1L2 tagged with fluorescent reporters derives from mouse (Suppl. table 1). Recombinant DNA was over expressed in rat hippocampal primary neurons and wt and sipa1l2-/- primary hippocampal neurons." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0575-6950" , "https://orcid.org/0000-0002-1585-539X" ;
        dc:date           "2022-04-29" ;
        dc:title          "SYNGO_BP_4571" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

