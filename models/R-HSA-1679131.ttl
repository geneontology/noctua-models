<http://model.geneontology.org/ev_w_id_R-HSA-1678920_RO_0002234_R-HSA-1678924_R-HSA-1678920_Reactome_R-HSA-1679131>
        a       <http://purl.obolibrary.org/obo/ECO_0000313> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
