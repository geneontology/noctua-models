gomodel:593423e000001008
        a                 owl:Ontology ;
        rdfs:comment      "NOT getting CC annotation out of this " , "only mouse work is with irradiated dorsal epidermis and shows only that this decreases sphingomyelin biosynthesis, not sure how this could be a direct annotation for mouse... maybe fine to just let the mouse protein get annots by ISO with the human annots in this paper??" , "check if CERT isoform specifically -2 form" , "Not sure I'd want to make an annotation to 'sphingomyelin biosynthetic process' for this gene, but it does require that the ER to Golgi ceramide transport occurs, so this is a place where I can see wanting to indicate a relationship WITHOUT making an annotation to the downstream term for Col4a3bp." , "How do I indicate that this function is specifically the -2 form?" , "need manual assertion form of enzyme inhibition evidence" , "J:138570" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9796-7693" , "https://orcid.org/0000-0001-5501-853X" ;
        dc:date           "2026-04-06" ;
        dc:title          "        PMID-18411267-KRC COL4A3BP" ;
        pav:providedBy    "http://informatics.jax.org" ;
        oboInOwl:id       "gomodel:593423e000001008" ;
        biolink:in_taxon  obo:NCBITaxon_9606 .

