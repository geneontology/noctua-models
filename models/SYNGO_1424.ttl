gomodel:SYNGO_1424  a     owl:Ontology ;
        rdfs:comment      "Automated change 2024-03-14: GO:0099055 replaced by GO:0045211" , "Rationale: Detection of nAchRs subunits in sub synaptic fractions of rodent striatal synaptosomes with Western Blot\n\n22/11/2017 Pim\n- The authors mention enrichment of PSD, but I allow annotation to the less specific term postsynaptic membrane to reflect the dirty nature of the preparation.\n- Based on the known transmembrane topology of the protein, the \"integral component of ... membrane\" term was chosen.. Experimental description: The animals used in this work were male Wistar rats (10-14 weeks old) and male C57BL/6 mice (10-12 weeks old) obtained from Charles River (Barcelona, Spain)." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0001-9425-2935" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_1424" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

