gomodel:ev_w_id_R-HSA-203893_RO_0002333_R-HSA-203817_R-HSA-203893_controller_Reactome_R-HSA-203927
        a               owl:NamedIndividual , obo:ECO_0000313 ;
        dc:contributor  "GOC:reactome_curators" ;
