dc:date  a      owl:AnnotationProperty .

gomodel:SYNGO_2483  a     owl:Ontology ;
        rdfs:comment      "Rationale: This paper shows a novel GluR3 dependent mechanism of LTP in the cerebellum. GluR3 is shown to mediate enhanced postsynaptic responses in PF to PC synapses. The enhancement of responses is not mediated by trafficking (more AMPARs in the PSD membrane as shown for the hippocampal CA1-CA3 synapse), but via cAMP dependent change in the single channel concuctance of Glur3 containing receptors. Overall it can be concluded that GluR3 mediates membrane potential changes in the postsynaptic membrane.\n\nFig.2: \"GluA3 Is Required for PF-PC LTP, but Not LTD\"\nFig.3: \"Rising cAMP Levels Produce GluA3-Dependent Postsynaptic Potentiation\"\nFig.4: \"Rising cAMP Levels Produce GluA3-Dependent Synaptic Potentiation without AMPAR Trafficking\"\nFig.5: \"GluA3 Plasticity Occurs through cAMP-Dependent Changes of Single-Channel Conductance and Open Probability\". Experimental description: \"PC-specific GluA3-KO mice were generated by crossing floxed GluA3 mice ...\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2018-02-12" ;
        dc:title          "SYNGO_MF_2483" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

