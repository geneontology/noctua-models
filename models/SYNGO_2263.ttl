gomodel:SYNGO_2263  a     owl:Ontology ;
        rdfs:comment      "Rationale: Background: USP8 is a known deubiquitinase.\n\nFig.3: \"Rapid NMDAR-dependent dephosphorylation and activation USP8\"\nDeubiquitinating enzyme USP8 is activated by NMDAR activation.\nFig.4: \"USP8 regulates synaptic strength\"\nDeubiquitinating enzyme USP8 deubiquitinates AMPARs and regulates synaptic strength.\nFig.5: \"Synaptic activity levels regulate Nedd4-1 and USP8 in opposing fashion\"\nFig.6: \"Nedd4-1 and USP8 are regulators of homeostatic downscaling\". Experimental description: - \"Rat dissociated hippocampal or cortical neurons from postnatal day 1 pups...\"\n- \"Rat USP8-GFP was additionally subcloned...\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2094-7491" , "https://orcid.org/0000-0002-4419-210X" , "https://orcid.org/0000-0002-9848-0262" , "https://orcid.org/0000-0002-1190-4481" ;
        dc:date           "2017-12-18" ;
        dc:title          "SYNGO_BP_2263" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

