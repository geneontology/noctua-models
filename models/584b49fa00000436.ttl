[ a                      owl:Axiom ;
  rdfs:comment           "Supporting evidence statement (PMID:16208361): The wild-type CED-3 zymogen, generated by in vitro translation,\nwas slowly autoprocessed as previously reported9,29 (Fig. 5b, lanes\n1–3). The autoprocessing requires the catalytic residue Cys 358, as the\nmutation C358S abolished CED-3 autoactivation (Fig. 5b, lanes 4\nand 5). This result indicates that the processing of the CED-3\nzymogen is not due to other contaminating protease(s)." ;
  lego:evidence          :5fce9b7300000093 ;
  dc:contributor         "https://orcid.org/0000-0002-1706-4196" ;
  dc:date                "2020-12-14" ;
  pav:providedBy         "http://www.wormbase.org" ;
  owl:annotatedProperty  obo:RO_0002233 ;
  owl:annotatedSource    :5fce9b7300000080 ;
  owl:annotatedTarget    :5fce9b7300000078
] .

