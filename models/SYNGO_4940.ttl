obo:UBERON_0002421  a  owl:Class .

gomodel:SYNGO_4940  a     owl:Ontology ;
        rdfs:comment      "Rationale: \"Forced expression of syndecan-2 in young hippocampal neurons induces the morphological maturation of dendritic spines\" (Fig. 6). \"Cytoplasmic domain of syndecan-2, but not COOH-terminal PDZ binding motif, is required for the targeting of syndecan-2 to dendritic spines\" (Fig. 7).. Experimental description: \"Primary Cultures of Rat Hippocampal Neurons\" (p. 576)" ;
        lego:modelstate   "production" ;
