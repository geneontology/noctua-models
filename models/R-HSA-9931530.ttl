gomodel:ev_w_id_R-HSA-9920673_RO_0002411_R-HSA-9909369_Reactome_R-HSA-9931530
        a               owl:NamedIndividual , obo:ECO_0000313 ;
        dc:contributor  "GOC:reactome_curators" ;
