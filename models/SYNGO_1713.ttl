gomodel:SYNGO_1713  a     owl:Ontology ;
        rdfs:comment      "Rationale: Authors show that SPTBN2; betaIII spectrin is a protein that is localized in the spine neck. Perturbation of SPTBN2; betaIII spectrin results in problems with spine formation (accumulation of postsynaptic marker proteins). Presynaptic components appear to assemble fine.\n\nTogether I interpreted this as that SPTBN2; betaIII spectrin is a structural component of the postsynapse that via this function influences the organization of synapses and synaptic transmission.. Experimental description: Figure legend: \"C, Immunogold EM of III spectrin staining in thin sections of mouse brain. \"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0001-5259-4945" ;
        dc:date           "2018-05-29" ;
        dc:title          "SYNGO_MF_1713" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

