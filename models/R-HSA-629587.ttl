:R-HSA-629587  a            obo:GO_0007268 , owl:NamedIndividual ;
        rdfs:comment        "Nicotinic acetylcholne receptors that have low Ca2+ permeability allow the influx of Na+ which causes depolarization of the membrane initiating voltage dependent responses such as activation of voltage dependent opening of Ca2+ channels and thus eliciting an increase in Ca2+ and downstream signaling. These receptors could be found in both presynaptic and postsynaptic terminals." ;
        rdfs:label          "Highly sodium permeable postsynaptic acetylcholine nicotinic receptors" ;
        dc:contributor      "Reviewed: Restituito, S, 2008-11-27 12:38:49" , "Edited: Gillespie, ME, 2010-05-18" , "Authored: Mahajan, SS, 2010-04-26" , "Reviewed: Wen, Hua, 2020-01-24" , "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-629587" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-622327/R-HSA-622327> , <http://model.geneontology.org/R-HSA-622323/R-HSA-622323> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

