obo:BFO_0000066  a  owl:ObjectProperty .

gomodel:SYNGO_3051  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.2:\n- \" Western blotting of subcellular fractions revealed that both drosha and DGCR8 were present in synaptic fractions and, within synaptosomes, were predominantly associated with PSDs (Fig. 2c).\"\n- \"PSD-95 immunoprecipitates contained drosha and DGCR8 (Fig. 2b). \"\n\nFig.3: \"Immunolocalization of Drosha in adult mouse hippocampus\"\n- \" Drosha was colocalized with PSD95 within the neuropil of the molecular layer, where the apical dendrites of pyramidal neurons are located (Fig. 3a and b).\". Experimental description: - \"Two-month-old male C57Bl/6 mice were employed in this study\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0003-0593-3443" ;
        dc:date           "2018-03-28" ;
        dc:title          "SYNGO_CC_3051" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

