:R-HSA-1307965  a           owl:NamedIndividual , obo:GO_0008150 ;
        rdfs:comment        "FGF21 and FGF19 require betaKlotho for efficient signaling through FGFR1c and FGFR3c. betaKlotho does not interact with 'b' receptor isoforms, and only weakly with FGFR2c. In addition, FGF19, but not FGF21, signals through FGFR4 in a betaKlotho-dependent fashion" ;
        rdfs:label          "betaKlotho-mediated ligand binding" ;
        dc:contributor      "GOC:reactome_curators" , "Authored: Rothfels, K, 2011-08-15" , "Reviewed: Gotoh, N, 2011-08-26" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-1307965" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-190322/R-HSA-190322> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

