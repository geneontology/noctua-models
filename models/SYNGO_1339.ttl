obo:GO_0099528  a  owl:Class .

gomodel:SYNGO_1339  a     owl:Ontology ;
        rdfs:comment      "Automated change 2026-01-08: GO:0150047 replaced by GO:0099528" , "Rationale: Patch clamp recordings of potassium currents evoked by activation of G-protein couples GABAB R's containing subunit 1 expressed in Xenopus Oocytes.\n\nrule: NAS_MFCC-BP\nrationale:\nProtein has G-protein neurotransmitter receptor activity and is localized in the presynaptic membrane (shown with high-resolution technique). The inference to term 'G-protein coupled neurotransmitter receptor activity involved in regulation of presynaptic membrane potential (GO:0150047)' is trivial and non-controversial.\nPinf_CC:\n[Q9Z0U4] SyNGO ID 1251 (PMID:17924569, EM). Experimental description: Expression Constructs for gb1a and gb2 Receptors-The murine gb1a (mgb1a) cDNA was constructed from two expressed sequence tags (IMAGE Consortium clone identification numbers 472408 and 319196), combined by standard PCR methods, and subcloned into the pCINeo (Stratagene) and pcDNA3.1 (Invitrogen) vectors." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0001-9425-2935" ;
        dc:date           "2026-01-08" ;
        dc:title          "SYNGO_MF_1339" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

