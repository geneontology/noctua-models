gomodel:SYNGO_2548  a     owl:Ontology ;
        rdfs:comment      "Rationale: Table.1: \"Rapid effects of extracellularly or intracellularly administered corticosterone on hippocampal CA1 cell mEPSC and mIPSC parameters\"\n- \"Perfusion with the selective MR antagonist spironolactone (100 nm) by itself did not change mEPSC frequency compared to the baseline recording, but prevented the enhancement of mEPSC frequency induced by extracellularly applied corticosterone (Table 1).\"\n\nFig.3: \"Retrograde signalling via CB1 receptors or nitric oxide is not involved in the effect of corticosterone on mEPSC frequency\". Experimental description: \"All experiments, unless stated otherwise, were performed in male C57/Bl6 mice...\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0003-0593-3443" ;
        dc:date           "2018-03-19" ;
        dc:title          "SYNGO_BP_2548" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .
