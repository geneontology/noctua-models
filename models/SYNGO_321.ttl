gomodel:SYNGO_321  a      owl:Ontology ;
        rdfs:comment      "Rationale: Subcellular fractionation from synaptosomes is used to study the localization of adenylyl cyclases. It is shown that adenylyl cyclase 1 is present in the presynaptic as well as the postsynaptic fraction. AC1 was not detected in the fraction containing active zone proteins.\nIn immunohistochemistry in hippocampal slices, AC1 appeared to colocalize with PSD95, which is consistent with a synaptic localization.\n\nThe antibody used against AC1 was verified with a knockout control.. Experimental description: Individual forebrain regions (containing hippocampus and cortex) were freshly isolated from WT, AC1KO and AC8KO male mice killed by CO2 inhalation." , "Automated change 2024-03-14: GO:0099061 replaced by GO:0098839" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-1558-1958" , "https://orcid.org/0000-0002-7620-2704" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_321" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

