obo:GO_0003674  a  owl:Class .

gomodel:SYNGO_4124  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig1A: Immunocytochemistry shows that immunoreaction product of endogenous APPL1 colocalises with postsynaptic marker PSD95 (marked by white arrows). Almost 90% of the PSD95 clusters colocalize with APPL1 in excitatory hippocampal neurons.\n\n\"Postsynapse\" was chosen as the SynGO term, instead of a more specific term due to the lack of relevant evidence.. Experimental description: Low density hippocampal neuronal cultures were prepared and maintained as previously described (Goslin et al., 1998)." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0003-2916-7616" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2021-01-20" ;
        dc:title          "SYNGO_CC_4124" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

