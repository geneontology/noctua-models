obo:GO_0045211  a  owl:Class .

<http://identifiers.org/mgi/MGI:94924>
        a       owl:Class .

gomodel:SYNGO_2512  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.2: \"Expression profiles of dopamine receptors in the striatum\"\n- \"In MSNs, the density of cell membrane-attached metal particles for D1R and D2R was comparably high in the soma, dendritic shaft, and dendritic spines (Fig. 2 A-C). In the neuropil, weak immunolabeling for D1R and D2R was also observed in terminals forming symmetric-but not asymmetric-synapses (Fig. 2C).\"\n\n- Based on the known transmembrane topology of the protein, the \"integral component of ... membrane\" term was chosen.. Experimental description: \"The dorsolateral portion of the striatum in adult male C57BL/6N, NL2-KO (Jackson Laboratory), CAST-KO (43), D1R-KO (44), and D2R-KO (45) mice (1-3 mo of age) was analyzed. \"" , "Automated change 2024-03-14: GO:0099055 replaced by GO:0045211" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0003-0593-3443" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_2512" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

