obo:BFO_0000050  a  owl:ObjectProperty .

gomodel:SYNGO_1068  a     owl:Ontology ;
        rdfs:comment      "Rationale: The work shows CDH-9 immunofluorescence in the proximity of synaptic processes. Transfected expression of a tagged version of the CDH-9 indicates a discrete localization of the recombinantly expressed product outside but close to synaptic cluster. Overall evidence suggest targeted expression. Figure 8 highlights shRNA knock down of the CDH-9 proteins exerts a disruption of synaptic structure supporting synaptic function of the protein as assessed by quantitative morphometric EM.\n\n3/7/2017 Pim\n- Fig.5C shows the homophilic adhesive property of Cadh9. Experimental description: Mouse in utero poration are explicitly mentioned in the methods but the culture method cited in the supplementary indicates rats and methods and figures do not clarify this.\n\n3/2/2017 Pim\n- Overexpressed protein is of mouse species. Literal \"cDNA encoding the predicted full-length cadherin-9 gene described in GenBank NM_009869.1 was amplified from a P7 mouse hippocampal cDNA library.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0938-8534" , "https://orcid.org/0000-0002-0755-5899" , "https://orcid.org/0000-0003-3185-5709" , "https://orcid.org/0000-0001-7351-8706" ;
        dc:date           "2017-09-06" ;
        dc:title          "SYNGO_BP_1068" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

