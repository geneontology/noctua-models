gomodel:SYNGO_5546  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 1e: Immunogold electron microscopy showed FRMPD4 (also termed PDZD10, PDZK10, Preso, Preso1) gold particles enriched in and adjacent to the PSDs in the hippocampus.\n\nFigure 1d: Double immunofluorescent staining with confocal fluorescence microscopy of FRMPD4 and PSD95 (DLG4) showed co-localization at synaptic puncta in cultured hippocampal neurons. No co-localization was observed for GAD65.. Experimental description: mice were used throughout this study. \"Preso1-/- mice were generated as follows.\"\n\n\"Preso1 antibodies were generated in rabbits using the rat Preso1 C terminal 20 aa or 330 aa as antigens. The antibody from 20-aa antigen was used for immunoelectron microscopy (1:100)\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2023-11-11" ;
        dc:title          "SYNGO_CC_5546" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .
