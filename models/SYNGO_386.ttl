gomodel:SYNGO_386  a      owl:Ontology ;
        rdfs:comment      "Rationale: Serial section analysis of electron microscopic images from the hippocampal CA1 showed Cav2.3 to be predominantly presynaptic in the interpeduncular nucleus but mainly expressed postsynaptically in other brain regions. Cav2.3 immunogold particles were observed primarily in the extrasynaptic plasma membrane and occasionally over the presynaptic active zone.\n\nThe following characteristics were used to identify presynaptic terminals: synaptic vesicle accumulation, presence of presynaptic specializations, and rigid alignment of presynaptic membrane to its postsynaptic partner. Synapses were identified based on postsynaptic thickening and electron dense materials in the synaptic cleft.. Experimental description: In this study, 2-3-month-old adult male C57BL/6 mice (n = 10), and age-matched, sex-matched Cav2.3 knock-out (KO) mice (n = 7) and postnatal day 20 rats (n = 2) were used.\n\n25/4/2017 Pim\n- rats only used in Fig.6 not used for this annotation." , "Automated change 2024-03-14: GO:0099056 replaced by GO:0042734" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-2533-9548" , "https://orcid.org/0000-0002-1212-5623" , "https://orcid.org/0000-0002-5648-066X" , "https://orcid.org/0000-0001-7480-0826" , "https://orcid.org/0000-0003-4022-8707" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_386" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

