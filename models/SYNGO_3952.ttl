obo:BFO_0000050  a  owl:ObjectProperty .

gomodel:SYNGO_3952  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig 6 shows that Synaptoporin (SPO) is \"necessary for homeostatic up regulation of mossy-fiber CA3 synapses\". Fig 6D-F show that SPO knock-down prevents the increase of mEPSP amplitude and frequency upon TTX incubation. Also PSD95 intensity does not increase under SPO knock-down conditions like observed in control (Fig 6B). Rescue construct elevates all these parameters also in absence of TTX.. Experimental description: Materials and Methods\"Hippocampal cultures prepared from E19 rat embryos were treated at >21 DIV with vehicle control, TTX (1 μM),...\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0001-5259-4945" ;
        dc:date           "2020-10-07" ;
        dc:title          "SYNGO_BP_3952" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

