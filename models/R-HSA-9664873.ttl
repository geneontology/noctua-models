:R-HSA-9664873  a           owl:NamedIndividual , obo:GO_0000425 ;
        rdfs:comment        "Peroxisomes are cytosolic organelles involved in the catabolism of branched and long-chain fatty acids and in the reduction of reactive oxygen species (ROS). Peroxisomes homeostasis is critical to maintain ROS levels. Consequently, it is important to eliminate dysfunctional peroxisomes. The degradation of peroxisomes by autophagy is known as pexophagy (Katarzyna ZR et al. 2016). Pexophagy can be triggered by a shift in nutrient conditions." ;
        rdfs:label          "Pexophagy" ;
        dc:contributor      "Authored: Varusai, Thawfeek, 2019-10-29" , "GOC:reactome_curators" , "Edited: Varusai, Thawfeek, 2019-10-29" , "Reviewed: Metzakopian, Emmanouil, 2019-10-30" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-9664873" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-9663891/R-HSA-9663891> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

