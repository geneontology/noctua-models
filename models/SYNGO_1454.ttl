gomodel:SYNGO_1454  a     owl:Ontology ;
        rdfs:comment      "Rationale: Abl-interacting protein-1 (ABI-1)/Abi1, is a component of the WAVE complex, that organizes the actin cytoskeleton and promotes vesicle clustering at presynaptic sites. Using a mutant allele of abi-1 in C. elegans, the authors showed defective vesicle clustering at presynaptic sites.. Experimental description: Worms were raised on NGM plates at 20°C using OP50 Escherichia coli as a food source. N2 Bristol was used as the wild-type reference strain." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-7480-0826" , "https://orcid.org/0000-0002-5648-066X" , "https://orcid.org/0000-0003-2533-9548" , "https://orcid.org/0000-0002-1212-5623" , "https://orcid.org/0000-0003-4022-8707" ;
        dc:date           "2017-11-20" ;
        dc:title          "SYNGO_BP_1454" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_6239" .

