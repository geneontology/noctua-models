gomodel:69c59f8a00002601
        a                 owl:Ontology ;
        rdfs:comment      "Note that the positive regulation of cell migration is specifically for MCCs (multiciliated cells) before they intercalate into the epidermis (as evidenced by reduced migration speeds in the MO odf2 knockdown condition). Could not find a biological process term to annotate the disruption of MCC spacing/patterning within the epidermis (also in odf2 MO knockdown)" , "Automated change 2026-05-28: GO:0097711 replaced by GO:1905349" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-5495-4588" ;
        dc:date           "2026-05-28" ;
        dc:title          "Role of odf2.L in Xenopus multiciliated cell development and function" ;
        pav:providedBy    "http://www.xenbase.org" ;
        biolink:in_taxon  obo:NCBITaxon_8355 .

