gomodel:SYNGO_1466  a     owl:Ontology ;
        rdfs:comment      "Rationale: Synapsin I KO mice are viable and show no effect on basal synaptic transmission. Mice lacking synapsin I exhibit a selective increase in paired pulse facilitation, with no major alterations in other synaptic parameters such as long-term potentiation.. Experimental description: M&M: Generationof Murine Synapsin I Null Mutants by Homologous Recombination In ES Cells. tandard procedures were used to record synaptic responses from hippocampal slices prepared from control and mutant mice." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9900-4233" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2017-10-26" ;
        dc:title          "SYNGO_BP_1466" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .
