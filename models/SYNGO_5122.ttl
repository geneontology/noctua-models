obo:GO_0003674  a  owl:Class .

gomodel:SYNGO_5122  a     owl:Ontology ;
        rdfs:comment      "Rationale: - CRMP2 (DPYSL2) promotes the dendritic spine maturation in cultured hippocampal neurons.\n- Dephosphorylation of CRMP2 at Thr514 further promotes the dendritic spine maturation.\n- DeSUMOylation of CRMP2 at Lys374 also promotes the dendritic spine maturation.\n- During this process, SUMOylation of CRMP2 is independent of its phosphorylation.. Experimental description: M&M: \"All the experiments were conducted with 1-day old pups of Sprague-Dawley (SD) rats\"\n\n\"The cDNA fragments encoding CRMP2 and SENP1, were amplified by PCR using the obtained clone of rat CRMP2 (NM_001105717.2) and SENP1 (XM_017595316.1) as templates.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2023-02-25" ;
        dc:title          "SYNGO_BP_5122" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

