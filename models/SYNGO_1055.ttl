obo:RO_0002333  a  owl:ObjectProperty .

gomodel:SYNGO_1055  a     owl:Ontology ;
        rdfs:comment      "Rationale: The data shows the selective association of APP with the sub-fraction derived from brain synaptosomes that harbours plasmamembrane associated vesicles. These fractions when immuno-isolated with a synaptic vesicle antibody elute active zone associated proteins more readily. This synaptic enrichment is reinforced by classic sub-fractionations.. Experimental description: Materials and Methods state Rat and mouse used but data annotated is for fractionation from Mouse tissue." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0938-8534" , "https://orcid.org/0000-0003-3185-5709" , "https://orcid.org/0000-0002-0755-5899" , "https://orcid.org/0000-0001-7351-8706" ;
        dc:date           "2017-08-22" ;
        dc:title          "SYNGO_CC_1055" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

