gomodel:SYNGO_4045  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fzd8 was detected in Liquid chromatography-mass spectrometry results of LDCVs.\nFigure 3B: Post-embedding immunogold (inset) staining against Fzd8 displays localisation on the surface of LDCV.\nFigure 3A and S2D: Fzd8 immunoreaction was present on LDCVs and did not colocalise with SP or CGRP (DCV markers) indicating that LDCVs might have another subset that does not have SP or CGRP.\n\n18/01/2021 Dnyanada: The paper does not provide any information on the specificity of the antibody used.. Experimental description: No mention of mouse strain used ...Authors were contacted for retrieving this information (15/05/2020 Dnyanada, xu.zhang@ion.ac.cn)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-2916-7616" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2021-01-18" ;
        dc:title          "SYNGO_CC_4045" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

