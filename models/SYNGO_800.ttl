gomodel:SYNGO_800  a      owl:Ontology ;
        rdfs:comment      "Rationale: Fig1C: quantitative immuno-EM for endogenous Profilin2. The pfn2 KO mouse was used as control. Quantification shows that profilin 2 is predominantly localised to the postsynaptic spine, with also significant labelling in presynaptic boutons and dendritic spines compared to background labelling in the pfn2 null mice.. Experimental description: Figure 1 Expression and localization of profilin1 and profilin2 in mouse brain." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0001-5259-4945" ;
        dc:date           "2017-08-07" ;
