:R-HSA-5657655  a           owl:NamedIndividual , obo:GO_0006307 ;
        rdfs:comment        "Reactive cellular catabolites can cause DNA damage by 6-O-methylation of guanine. 6-O-methylguanine can pair ambiguously with both C and T, and cause transition mutations. Active reversal of such damage can be facilitated by MGMT, a protein that has 6-O-methylguanine-DNA methyltransferase activity (Mitra and Kaina 1993)." ;
        rdfs:label          "MGMT-mediated DNA damage reversal" ;
        dc:contributor      "GOC:reactome_curators" , "Edited: Orlic-Milacic, Marija, 2014-12-16" , "Reviewed: Joshi-Tope, G, 2004-02-04 16:13:17" , "Authored: Pegg, A, 2004-02-04 15:50:05" , "Edited: Joshi-Tope, G, 2004-02-04 16:13:17" , "Reviewed: Gillespie, Marc E, 2015-02-06" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-5657655" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-73942/R-HSA-73942> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

