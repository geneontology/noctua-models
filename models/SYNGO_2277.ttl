obo:GO_0050804  a  owl:Class .

gomodel:SYNGO_2277  a     owl:Ontology ;
        rdfs:comment      "Rationale: Authors investigate the effect of the AKAP7 deletion in the dentate gyrus region of the hippocampus. To do this, they induced LTP in the MF-CA3 synapse, a presynaptic form of LTP that is known to be dependent on PKA and it is expressed presynaptically. cAMP-induced LTP application was monitored with extracellular field excitatory postsynaptic potential (fEPSP) recordings as well as with whole-cell recordings of NMDA receptor (NMDAR)-mediated excitatory postsynaptic currents (EPSCs) in WT and KO organotypic slices. In both cases, the response in the KO was severely reduced as compared to WT slices.. Experimental description: \"Generation of AKAP7 KO and floxed AKAP7 mouse lines was described previously (Jones et al., 2012). We generated tissue-specific DG-KO animals by crossing Akap7lox/lox to Pomc-Cre+;Akap7+/- animals, which express Cre recombinase primarily in the hypothalamus and dentate gyrus.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0575-6950" , "https://orcid.org/0000-0002-1585-539X" ;
        dc:date           "2018-01-24" ;
        dc:title          "SYNGO_BP_2277" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

