obo:BFO_0000066  a  owl:ObjectProperty .

gomodel:SYNGO_2392a39b0b8c-b9ff-4443-9824-2f970dec0a91
        a               owl:NamedIndividual , obo:ECO_0007695 ;
        dc:contributor  "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0001-5259-4945" ;
