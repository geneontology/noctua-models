obo:ECO_0006042  a  owl:Class .

gomodel:SYNGO_208  a      owl:Ontology ;
        rdfs:comment      "Rationale: Quantitative mass spectrometric analyses (iTRAQ) of synaptic vesicle docking complexes indicate the presence of RAB1A on presynaptic terminals.\n\n22/2/2017 Pim:\n-Presynaptic annotation is based on the proteolytic treatment of synaptosomes [\"Limited Proteolysis Removes Postsynaptic but Not Presynaptic Proteins from Purified Synaptosomes\"]\n-Rab1A is present in these treated synaptosomes, but is not enriched in SVs --> presynapse.. Experimental description: From main text \"To isolate docking complexes from rat brain, we first prepared synaptosomes and subjected them to limited proteolysis to dissociate pre- and postsynaptic membranes\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-5615-1014" ;
        dc:date           "2017-03-21" ;
        dc:title          "SYNGO_CC_208" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

