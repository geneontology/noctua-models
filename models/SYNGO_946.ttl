gomodel:SYNGO_946  a      owl:Ontology ;
        rdfs:comment      "Rationale: Fig 2, 3, 4, 5 Molecular layer Golgi Cell dendrites and dendritic spines were labelled with anti-contactin-1 antibodies in immunoEM of 10-day old and adult mice.\n\nNote that other neuron types exhibit presynaptic labeling (annotation 945), but that at no synapse both pre- and post-synaptic labeling was detected.\n\n12/10/2017 Pim\n- Based on the known lipid anchor of the protein, the \"anchored component of ... membrane\" term was chosen.. Experimental description: Mice 1, 5, and 10 d of age were killed by decapitation or intracardiac perfusion." , "Automated change 2024-03-14: GO:0099025 replaced by GO:0045211" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0912-1514" , "https://orcid.org/0000-0002-3670-7863" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_946" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

