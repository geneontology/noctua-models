obo:ECO_0007719  a  owl:Class .

gomodel:SYNGO_1689  a     owl:Ontology ;
        rdfs:comment      "Automated change 2024-03-14: GO:0099056 replaced by GO:0042734" , "Rationale: Fig4 shows immuno-EM against DVAP-33A in drosophila neuromuscular junction. The gold label can be found on the presynaptic plasma membrane (Fig4A-E) and large vesicles in the presynaptic terminal (Fig4F), the synaptic vesicles remain unstained (Fig4E). DVAP-33A has a transmembrane domain (Fig1C), hence it is likely it is an integral part of these membrane structures.. Experimental description: M&M:\"Pre-embedding immunolabeling was performed on the heads of four Drosophila adults and more than six filleted third instar larvae.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0001-5259-4945" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_1689" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_7227" .

