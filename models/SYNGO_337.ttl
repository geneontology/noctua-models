gomodel:SYNGO_337  a      owl:Ontology ;
        rdfs:comment      "Rationale: Figure 4.\nIRSp53 can be localized to different postsynaptic structures including postsynaptic membrane (associated with the Insulin receptor), the cytosol and cytoskeleton.\nImmunogold-EM localization of IRSp53 in the CA1 stratum radiatum of rat hippocampus. Numerous IRSp53 immunogold particles are associated with postsynaptic structures (A-E). The arrows point to particles that localize within the PSD, and arrowheads point to particles in the spine cytoplasm not associated with the PSD. An example of the association of IRSp53 particles\nwith perforated PSDs is shown (B; white arrowhead).. Experimental description: Rat brain coronal sections (50 um thick). p. 870" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-9681-3318" , "https://orcid.org/0000-0002-9880-1214" , "https://orcid.org/0000-0002-0269-0311" ;
        dc:date           "2017-06-12" ;
        dc:title          "SYNGO_CC_337" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

