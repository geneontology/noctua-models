obo:GO_0003674  a  owl:Class .

gomodel:SYNGO_4548  a     owl:Ontology ;
        rdfs:comment      "Rationale: Cell adhesion molecule (CAM) CD44 shRNA knockdown reduces spine head width and increases spine length. This phenotype can be rescued by overexpression shRNA-resistent CD44 (Fig. 2). CD44 knockdown also causes a reduction of PSD-95 levels in spines relative to dendrites (Fig. 4A,B). The determination of spine shape seems to be mediated by differential regulation of small GTPases RhoA, Rac1, and Cdc42 by CD44 as shown in a FRET-based assay (Fig. 6).. Experimental description: Primary rat hippocampal cultures were prepared from P0 rat brains as described previously ... (p. 4063/ Cell cultures)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-9880-1214" , "https://orcid.org/0000-0002-0269-0311" , "https://orcid.org/0000-0002-9681-3318" ;
        dc:date           "2023-01-29" ;
        dc:title          "SYNGO_BP_4548" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

