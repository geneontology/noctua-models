biolink:in_taxon  a  owl:AnnotationProperty .

:R-HSA-975110  a            obo:GO_0008150 , owl:NamedIndividual ;
        rdfs:comment        "In plasmacytoid dendritic cell induction of type I IFNs critically depends on IFN regulatory factor 7 in TLR7 and 9 signaling (Honda et al 2005). IRF-7, but not IRF3, interacts with MyD88, TRAF6, and IRAKs and translocates to the nucleus upon phosphorylation (Kawai et al 2004; Uematsu et al 2005).<p> TLR7/8 signaling was shown to induce IRF5 activation along with IRF7 [Schoenemeyer et al 2005], while IRF8 [Tsujimura H et al 2004] and IRF1 were reported to be implicated in TLR9 signaling." ;
        rdfs:label          "TRAF6 mediated IRF7 activation in TLR7/8 or 9 signaling" ;
        dc:contributor      "Reviewed: Gillespie, ME, 2010-10-29" , "Authored: Shamovsky, V, 2010-08-25" , "GOC:reactome_curators" , "Edited: Shamovsky, V, 2010-11-15" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-975110" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-975155/R-HSA-975155> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

