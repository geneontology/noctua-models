gomodel:SYNGO_938  a      owl:Ontology ;
        rdfs:comment      "Rationale: This publication provides some evidence that liprin b2 is present at the presynapse.\n\nThe authors prepare synapsomes, and subject these to a series of purification steps to isolate the presynaptic terminal. The preparation is virtually devoid of postsynaptic proteins, making a presynaptic localization of liprin b2 likely.. Experimental description: To isolate docking complexes from rat brain, we first prepared synaptosomes and subjected them to limited proteolysis to dissociate pre- and postsynaptic membranes (Figure 1A)." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-7620-2704" , "https://orcid.org/0000-0002-1558-1958" ;
        dc:date           "2018-01-24" ;
        dc:title          "SYNGO_CC_938" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

