obo:BFO_0000066  a  owl:ObjectProperty .

gomodel:SYNGO_5171  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 1-3: immunogold EM imaging of the mouse hippocampal dentate molecular layer showed TRPV1 particles at dendrites and postsynaptic membranes of symmetric synapses, but not in presynaptic terminals. Importantly, TRPV1 immunolabeling is virtually abolished in TRPV1-KO mice. About 30% of the inhibitory synapses in the ML are TRPV1 immunopositive.\n\nBased on the known transmembrane topology of this protein, \"integral component of ... membrane\" term was selected.. Experimental description: M&M: \"6 TRPV1-WT and 3 TRPV1-KO adult (3 month old) mice of either sex were used in this study.\"\n\nantibody:\ngoat anti-TRPV1 antibody (1:100, VR1 (P-19), affinity purified goat polyclonal antibody raised against a peptide mapping near the amino terminus of VR1 of rat origin, sc-12498, Santa Cruz Biotechnology)" , "Automated change 2024-03-14: GO:0099055 replaced by GO:0045211" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-4973-5732" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_5171" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

