gomodel:ev_w_id_R-HSA-2671742_RO_0002234_R-HSA-2671749_R-HSA-2671742_Reactome_R-HSA-2671742
        a               owl:NamedIndividual , obo:ECO_0000313 ;
        dc:contributor  "GOC:reactome_curators" ;
