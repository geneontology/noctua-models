obo:GO_0003674  a  owl:Class .

gomodel:SYNGO_2847  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.4: \"Effects of G1 on hippocampal synaptic plasticity\"\n- \"Although DHPG-LTD in SC-CA1 synapses was not affected in G1-treated slices (Fig. 4C), it was altered in MF-CA3 synapses after G1 treatment (Fig. 4D). The maintainace of LTD was prolonged after G1 treatment. In addition, MF-CA3 and SC-CA1 synapse inputs-outputs were not altered after G1 treatment (Fig. 4E and F). These data suggest that G1 facilitated DHPG-LTD in the CA3, which likely explains the memory enhancement by G1.\". Experimental description: - \"Male and female C57BL/6 mice (12 months and 2 months) \"\n- \"Mouse GPR30 cDNA (full-length coding region) was generated by ...\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2018-05-29" ;
        dc:title          "SYNGO_BP_2847" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

