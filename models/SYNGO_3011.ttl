gomodel:SYNGO_3011  a     owl:Ontology ;
        rdfs:comment      "Rationale: Note: COMT metabolizes dopamine to an inactive compound (3-methoxytyramine).\n\nAbstract: \"Here, we employ two types of microdialysis to study these pathways using DAT, NET and MAO blockers in conscious mice, with or without Comt gene disruption. In quantitative no-net-flux microdialysis, DA levels were increased by 60% in the PFC of COMT-knockout (ko) mice, but not in the striatum and nucleus accumbens. In conventional microdialysis studies, we showed that selective NET and MAO inhibition increased DA levels in the PFC of wild-type mice by two- to fourfold, an effect that was still doubled in COMT-ko mice. Inhibition of DAT had no effect on DA levels in either genotype. Therefore, we conclude that in the mouse, PFC COMT contributes about one half of the total DA clearance.\". Experimental description: - \"Homozygous male and female COMT-ko mice ...\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0003-0593-3443" ;
        dc:date           "2018-03-27" ;
        dc:title          "SYNGO_BP_3011" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

pav:providedBy  a  owl:AnnotationProperty .

