gomodel:SYNGO_3949  a     owl:Ontology ;
        rdfs:comment      "Rationale: c-Jun N-terminal kinase (JNK)1-/--deficient mice lack mGluR-LTD in the hippocampal CA1 region. Also, LTD induced by PP-LFS (paired pulses separated by 50ms were delivered at low frequency 1Hz for 15min in the presence of the NMDAR antagonist D-AP-5) was strongly reduced.. Experimental description: M&M: JNK1-/- mice and control wild-type (WT) mice were of the C57B6/129 genetic background" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9900-4233" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2020-07-01" ;
        dc:title          "SYNGO_BP_3949" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

