:R-HSA-432030  a            owl:NamedIndividual , obo:GO_0015793 ;
        rdfs:comment        "Triglycerides stored in adipocytes are hydrolyzed to yield fatty acids and glycerol. The glycerol is passively transported out of the adipocyte and into the bloodstream by Aquaporin-7 (AQP7) located in the plasma membrane of adipocytes. Glycerol in the bloodstream is passively transported into liver cells by AQP9 located in the plasma membrane of hepatocytes. Once inside the liver cell the glycerol is a substrate for gluconeogenesis." ;
        rdfs:label          "Transport of glycerol from adipocytes to the liver by Aquaporins" ;
        dc:contributor      "Reviewed: Calamita, G, 2010-07-15" , "Edited: May, B, 2009-08-06" , "GOC:reactome_curators" , "Authored: May, B, 2009-08-06" , "Reviewed: Beitz, E, 2010-06-24" , "Reviewed: Mathai, JC, MacIver, B, 2010-07-31" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-432030" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-445717/R-HSA-445717> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

