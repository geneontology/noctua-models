obo:RO_0002333  a  owl:ObjectProperty .

gomodel:SYNGO_944  a      owl:Ontology ;
        rdfs:comment      "Rationale: Fig.3e,f shows that Teneurin-m loss results in postsynaptic spectrin disorganization at Drosophila neuromuscular junctions. In agreement with a postsynaptic role, Fig.1 shows that Teneurin-m is predominantly postsynaptically localized at Drosophila neuromuscular junctions. Loss of Teneurin-m in addition reduces the apposition of active zones and neurotransmitter clusters as show in Fig. 2.. Experimental description: \"Details of Drosophila stocks can be found in Methods.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0912-1514" , "https://orcid.org/0000-0002-3670-7863" ;
        dc:date           "2017-12-26" ;
        dc:title          "SYNGO_BP_944" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_7227" .

