<http://model.geneontology.org/R-HSA-6802968_R-HSA-6802973>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://identifiers.org/uniprot/P30307> ;
        <http://www.w3.org/2000/01/rdf-schema#comment>
                "Original Reactome ID: UniProt_P30307" , "located_in nucleoplasm" ;
