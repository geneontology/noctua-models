obo:GO_0003674  a  owl:Class .

gomodel:SYNGO_4078  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 6: Immunoelectron microscopy localises the SST immunoreaction product on dense-core vesicles (marked by small arrowhead). The synaptic membrane is marked by large arrows.\n\nThe paper mentions that the antibody against SST was from M. Sofroniew. Immunonuclear Corporation. It mentions that antibody specificity tests were described in PMID: 2413388, however, the paper fails to show any data on it. Given that the paper was published in 1986, it is difficult to find any additional information.. Experimental description: Adult male albino rats of the inbred Fischer or Sprague-Dawley strains were used. The paper fails to mention the above information, however, it links the methods used to a previously published paper (PMID: 2413388)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0003-2916-7616" ;
        dc:date           "2020-12-08" ;
        dc:title          "SYNGO_CC_4078" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

pav:providedBy  a  owl:AnnotationProperty .

