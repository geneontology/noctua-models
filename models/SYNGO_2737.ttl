obo:ECO_0007695  a  owl:Class .

lego:evidence  a  owl:AnnotationProperty .

gomodel:SYNGO_2737  a     owl:Ontology ;
        rdfs:comment      "Rationale: Using a constutitive Liprin a3 knockout (KO), Wong et.al. shows that Liprin a3 participates in synaptic vesicle exocytosis. In synaptophysin-pHluorin imaging experiments, KO neurons showed a reduction in the total amount of exocytosis. This was rescued by reintroduction of Liprin a3.\n\nThe KO is characterized in figure 2, showing absence of the protein in western blot using 3 different antibodies.. Experimental description: Primary mouse hippocampal cultures were generated from newborns as previously described (20), and all analyses were performed at DIV 14-17." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-7620-2704" , "https://orcid.org/0000-0002-1558-1958" ;
        dc:date           "2018-03-09" ;
        dc:title          "SYNGO_BP_2737" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

