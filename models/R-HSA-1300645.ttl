lego:evidence  a  owl:AnnotationProperty .

:R-HSA-1300645  a           owl:NamedIndividual , obo:GO_0007340 ;
        rdfs:comment        "The acrosome reaction is stimulated by zona pellucida binding and subsequent downstream events, including Ca2+ influx. Proacrosin cleavage is the hallmark event of the acrosome reaction. After the acrosome reactome the sperm has passed through the cumulus cells and the zona pellucida. The membrane of the sperm head and the membrane of the oocyte are drawn together through the interaction of the sperm-bound protein Izumo and the ooctye CD9 membrane protein." ;
        rdfs:label          "Acrosome Reaction and Sperm:Oocyte Membrane Binding" ;
        dc:contributor      "Authored: Gillespie, ME, 2013-02-12" , "Reviewed: Lishko, Polina V, 2013-05-21" , "GOC:reactome_curators" , "Edited: Gillespie, ME, 2013-05-23" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-1300645" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-1187000/R-HSA-1187000> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

