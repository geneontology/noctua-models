gomodel:SYNGO_2028  a     owl:Ontology ;
        rdfs:comment      "Rationale: \"Group II cells showed glycinergic sIPSCs and glycine induced currents in wild-type, Glra1spd-ot and Glra3-/- mice (τ~25 ms); however, glycinergic currents were absent in group II cells of Glra2-/- mice ... We propose that GlyRs of group II cells are dominated by the α2 subunit\".. Experimental description: \"Glycinergic input of widefield, displaced amacrine cells of the mouse retina\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2017-12-24" ;
