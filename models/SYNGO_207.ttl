gomodel:SYNGO_207  a      owl:Ontology ;
        rdfs:comment      "Rationale: Quantitative mass spectrometric analyses (iBAQ) of purified synaptosomes indicate the presence of RAB1B on synaptic terminals.\n\n28/8/2017 Pim\n- Data does not distinguish pre- from postsynaptic localization. 'synapse (GO:0045202)' term selected instead of 'presynapse'.. Experimental description: From main text \"To quantify the organization of synaptic vesicle recycling, we first purified synaptic boutons (synaptosomes) from the cellular layers of the cortex and cerebellum of adult rats, using a modified version of a classical brain fractionation protocol." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-5615-1014" ;
        dc:date           "2017-08-28" ;
        dc:title          "SYNGO_CC_207" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

