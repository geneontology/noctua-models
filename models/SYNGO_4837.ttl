gomodel:SYNGO_4837  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 1,3: Piccolo (PCLO) antibody immunoprecipitation from P4 rat brain yields Daam1.\n\nFigure 2: Daam1 is enriched in synaptosomal fractions and co-localizes with Piccolo in immmunostaining of cultured hippocampal neurons (16 DIV).. Experimental description: Figure 1: \"Piccolo antibody immunoprecipitation from P4 rat brain\"\n\nantibody:\nDaam1/Mouse monoclonal (Abcam)\n\nselected uniprot accession was the top-hit in BLAST from mouse swissprot record (there is none for rat Daam1)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-4973-5732" ;
        dc:date           "2022-09-04" ;
        dc:title          "SYNGO_CC_4837" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

