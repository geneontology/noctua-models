gomodel:SYNGO_203  a      owl:Ontology ;
        rdfs:comment      "Rationale: Quantitative immunogold reactivity against SNX1 in mouse hippocampal pyramidal neurons shows a predominant postsynaptic distribution. SNX1 is localized to endosome membranes, but the subclass of endosome (early/late/recycling) is not unambiguously determined. Experimental description: our wild-type eight-week-old male C57BL/6N mice were perfused transcardially with 4% paraformaldehyde/0.1 M sodium phosphate buffer (PB, pH 7.2) for light microscopic immuno- histochemistry or with 4% paraformaldehyde/0.1% glutaraldehyde/ 0.1 M PB for immunoelectron microscopy." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0001-5259-4945" ;
        dc:date           "2017-03-20" ;
        dc:title          "SYNGO_CC_203" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

