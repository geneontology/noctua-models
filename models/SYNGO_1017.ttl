obo:BFO_0000066  a  owl:ObjectProperty .

gomodel:SYNGO_1017  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.6 shows that the stimulation of hippocampal neurons with the soluble ectodomain of the postsynaptically anchored protein Lasso results in an increase in presynaptic Ca2+ concentration.\n\n1/11/2017 Pim\n- Although suggested by the authors the presynaptic effect of lasso exposure is not shown to be mediated by LPH1. I have refrained from suggesting the reciprocal annotation to this protein to the expert.. Experimental description: Fig.6 used human Lasso: \"Full-length Lasso cDNA (GenBank accession no. JF784339) was reconstructed\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0912-1514" , "https://orcid.org/0000-0002-3670-7863" ;
        dc:date           "2017-11-01" ;
        dc:title          "SYNGO_BP_1017" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_9606" .

