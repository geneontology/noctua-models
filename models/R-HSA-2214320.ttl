biolink:in_taxon  a  owl:AnnotationProperty .

:R-HSA-2214320  a           obo:GO_0030199 , owl:NamedIndividual ;
        rdfs:comment        "Collagen VII forms anchoring fibrils, composed of antiparallel dimers that connect the dermis to the epidermis (Bruckner-Tuderman 2009, Has & Kern 2010). During fibrillogenesis, the nascent type VII procollagen molecules dimerize in an antiparallel manner. The C-propeptide is then removed by Bone morphogenetic protein 1 (Rattenholl et al. 2002) and the processed antiparallel dimers laterally aggregate (Villone et al. 2008, Gordon & Hahn 2010)." ;
        rdfs:label          "Anchoring fibril formation" ;
        dc:contributor      "Reviewed: Ricard-Blum, Sylvie, 2012-11-19" , "Reviewed: Raleigh, Stuart, 2012-10-08" , "GOC:reactome_curators" , "Authored: Jupe, S, 2012-04-30" , "Edited: Jupe, S, 2012-11-12" , "Reviewed: Kalamajski, Sebastian, 2012-10-08" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-2214320" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-2022090/R-HSA-2022090> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

