gomodel:SYNGO_4936  a     owl:Ontology ;
        rdfs:comment      "Rationale: Theta burst-triggered LTP induces spine enlargement that is prohibited by inhibition of MMP9 (Fig. 1). Brief local puffing of MMP9 on naive spines induces potentiation and volume increase of spines. This is not the case when using inactive MMP9 (Fig. 2). MMP-9 drives integrin-dependent cofilin phosphorylation in dendritic spines (Fig. 4).. Experimental description: \"Animals. Acute hippocampal slices (350 um thick) were from 14- to 21-day-old Sprague-Dawley rats.\" (p. 19525)\n\n\"active- or inactive- (pro)-MMP-9 was delivered locally through the glass stimulating pipette by controlled pressure pulses\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-0269-0311" , "https://orcid.org/0000-0002-9880-1214" , "https://orcid.org/0000-0002-9681-3318" ;
        dc:date           "2023-10-24" ;
        dc:title          "SYNGO_BP_4936" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

