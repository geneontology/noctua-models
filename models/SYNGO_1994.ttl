gomodel:SYNGO_1994  a     owl:Ontology ;
        rdfs:comment      "Rationale: Spontaneous miniature fast postsynaptic currents (Fig.3, Table 1) and locally evoked EPSCs (Fig.5, Table 2) mediated by ACh (other transmitters and muscarinic ACh receptors were blocked) are mediated by alpha4beta2 and alpha7 nAChR subtypes. This is tested via sensivity for, respectively, DHβE and MLA.. Experimental description: Tissues are form rat species: \"After decapitation of young Wistar strain rats (10-20 days old),\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2017-12-24" ;
        dc:title          "SYNGO_MF_1994" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

