[ a                      owl:Axiom ;
  rdfs:comment           "Provides Input For Rule. The relation 'POLB incorporates a single nucleotide in place of excised AP residue in NEIL1,NEIL2-mediated AP site resolution' 'null' 'LIG3 ligates NEIL1,NEIL2-generated single strand break' was inferred because:\n reaction1 has an output that is an input of reaction 2. " , "Imported from Reactome: https://reactome.org/content/detail/R-HSA-5649702" ;
  lego:evidence          gomodel:ev_w_id_R-HSA-5649723_RO_0002413_R-HSA-5649734_Reactome_R-HSA-5649702 ;
  dc:contributor         "GOC:reactome_curators" ;
