gomodel:SYNGO_245  a      owl:Ontology ;
        rdfs:comment      "Rationale: Quantitative mass spectrometric analyses of highly purified synaptic vesicles indicates that Rab33B copurifies with these vesicles. This was corroborated using antibodies against Rab33B in immunoblots. Localisation studies using EGFP-Rab33b however does not support localisation to synaptic vesicles.. Experimental description: Legend to Table 1 \"Complete survey of the rat SV Rabome\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-5615-1014" ;
        dc:date           "2018-06-01" ;
        dc:title          "SYNGO_CC_245" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

