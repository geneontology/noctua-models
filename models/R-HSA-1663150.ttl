obo:GO_0004857  a  owl:Class .

dc:title  a     owl:AnnotationProperty .

:R-HSA-1663150  a           owl:NamedIndividual , obo:GO_0008150 ;
        rdfs:comment        "Sulfatase activity requires a unique posttranslational modification (PTM) of a catalytic cysteine residue into a formylglycine. This modification is impaired in patients with multiple sulfatase deficiency (MSD) due to defects in the SUMF1 (sulfatase-modifying factor 1) gene responsible for this PTM. SUMF2 can inhibit the activity of SUMF1 thereby providing a mechanism for the regulation of sulfatase activation (Ghosh 2007, Diez-Roux & Ballabio 2005)." ;
        rdfs:label          "The activation of arylsulfatases" ;
        dc:contributor      "GOC:reactome_curators" , "Reviewed: Matthews, Lisa, 2025-06-23" , "Edited: Jassal, B, 2011-10-14" , "Reviewed: D'Eustachio, P, 2012-05-14" , "Authored: Jassal, B, 2011-10-14" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-1663150" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-163841/R-HSA-163841> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

