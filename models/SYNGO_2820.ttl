obo:ECO_0006063  a  owl:Class .

gomodel:SYNGO_2820  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.4: \"Dendritic spine density is regulated by Preso overexpression and dominant-negative inhibition\"\n\nFig.5: \"Preso knockdown decreases the number of dendritic spines and excitatory synapses\"\n\nFig.6: \"Preso knockdown decreases excitatory synaptic transmission\"\n\nFig.7: \"Preso interacts with βPix and increases spine density in a manner requiring the PDZ and FERM domains\"\n- Note: betaPix is a known regulator of actin dynamics in the synapse\n\nFig.8: \"Knockdown or inhibition of Preso reduces F-actin levels in dendritic spines\". Experimental description: - \"Cultured hippocampal neurons were prepared from embryonic day 18 rat brain.\"\n- Overexpressed FRMPD4; preso is of human species: \"For Flag-tagged Preso expression constructs, the following regions of human Preso (KIAA0316) were subcloned into p3xFLAG-CMV7.1 (Sigma)\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2018-03-08" ;
        dc:title          "SYNGO_BP_2820" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

