<http://model.geneontology.org/R-HSA-8847867_R-HSA-8847883>
        a       <http://purl.obolibrary.org/obo/go/extensions/reacto.owl#REACTO_R-HSA-8847867> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
