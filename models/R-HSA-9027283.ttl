:R-HSA-9027283  a           obo:GO_1904894 , owl:NamedIndividual ;
        rdfs:comment        "STAT5 (STAT5A or STAT5B) directly binds the phosphorylated cytoplasmic domain of EPOR, where it is phosphorylated by JAK2 and LYN (Oda et al. 1998, inferred from mouse homologs, reviewed in Kuhrt and Wojchowski 2015). Phosphorylated STAT5 then dissociates from EPOR, dimerizes, and transits to the nucleus where it activates gene expression." ;
        rdfs:label          "Erythropoietin activates STAT5" ;
        dc:contributor      "Authored: May, Bruce, 2017-10-29" , "Reviewed: McGraw, Kathy L, 2018-08-14" , "Edited: May, Bruce, 2017-10-29" , "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-9027283" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-9006335/R-HSA-9006335> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

