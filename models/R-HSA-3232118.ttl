:R-HSA-3232118  a           obo:GO_0008150 , owl:NamedIndividual ;
        rdfs:comment        "Proteins classified as transcription factors constitute a disproportionate number of SUMOylation targets. In most cases SUMOylation inhibits transcriptional activation, however in some cases such as TP53 (p53) SUMOylation can enhance activation. Inhibition of transcription by SUMOylation may be due to interference with DNA binding, re-localization to inactive nuclear bodies, or recruitment of repressive cofactors such as histone deacetylases (reviewed in Girdwood et al. 2004, Gill 2005)." ;
        rdfs:label          "SUMOylation of transcription factors" ;
        dc:contributor      "Edited: May, B, 2013-03-23" , "Authored: May, B, 2013-03-23" , "Reviewed: May, Bruce, 2015-10-04" , "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-3232118" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-3108232/R-HSA-3108232> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

