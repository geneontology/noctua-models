obo:ECO_0007695  a  owl:Class .

gomodel:SYNGO_2905  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.4: \"Interaction of PIP5Kγ661 with AP-2 Is Essential for the NMDA-Induced AMPA Receptor Endocytosis\"\n\nFig.5: \"PIP5Kγ661 Activity Is Required for the NMDA-Induced AMPA Receptor Endocytosis\"\n\nFig.6: \"Suppression of NMDA-Induced AMPA Receptor Endocytosis by Knockdown of PIP5Kγ661\"\n\nFig.7: \"Suppression of Hippocampal CA1-LTD by Inhibiting the Interaction of PIP5Kγ661 with AP-2 and by Expression of Kinase-Dead PIP5Kγ661 Mutant\". Experimental description: - \"Culture of Hippocampal Neurons and Transfection: Hippocampi dissected from E16/17 ICR mice ...\"\n- \"Electrophysiology: Transverse hippocampal slices (300 μm thickness) were prepared from P14-21 ICR mice ...\"\n- Overexpressed PIP5Kγ; Pip5k1c was of mouse species. Traced back to PMID:17290217: \"To construct Flag- and Myc-tagged mammalian expression vectors for PIP5Kα, PIP5Kβ, PIP5Kγ635 and PIP5Kγ661, cDNAs were amplified from mouse brain total RNA using RT-PCR,..\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2018-03-15" ;
        dc:title          "SYNGO_BP_2905" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

