gomodel:SYNGO_519  a      owl:Ontology ;
        rdfs:comment      "Rationale: Fig. 3 EM microscopy shows SynGAP postsynaptic localization.\nLiteral\n\"The great majority (>90%) of synaptic profiles labeled for SynGAP in the PSD complex in dissociated hippocampal cultures under basal conditions.\". Experimental description: Experiment of neuronal colture staining are made in rat.\nLiteral from M&M\n\"Hippocampal cells from 21-day embryonic Sprague-Dawley rats were dissociated and grown on a glial cell layer as described previously by Lu et al. (1998) for 19-21 days.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-2949-9725" , "https://orcid.org/0000-0003-0662-9523" ;
        dc:date           "2017-05-26" ;
        dc:title          "SYNGO_CC_519" ;
        pav:providedBy    "https://syngo.vu.nl" ;
