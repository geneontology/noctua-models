pav:providedBy  a  owl:AnnotationProperty .

gomodel:SYNGO_1289  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig2A-C shows immunoEM localization of NFL (15nm gold, arrowheads) and NFH (10nm gold, arrows) in postsynaptic compartments with little staining in the presynaptic terminal. This is further confirmed by an alternative pre-embedding immuno-EM methods on mouse hippocampus in Supplementary figure 2, where panel F shows immunoreactivity for NFL and panel G for NFH. This reactivity is absent in the TKO lacking NFL, NFH and internexin (quantified in panel I), indicating that the antibody is specific. However, no quantification of pre- and post-synaptic immuno-gold localisation is provided. In the text (p987) the authors state \"Similar to NFM labeling, more labeling of NFL, NFH and α-internexin was seen in postsynaptic areas than in presynaptic areas.\". Experimental description: M&M: \"Adult male or female mice of the C57BL/6J-rich strain, aged 3 - 12 months were used in all experiments\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0001-5259-4945" ;
        dc:date           "2017-10-24" ;
        dc:title          "SYNGO_CC_1289" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

