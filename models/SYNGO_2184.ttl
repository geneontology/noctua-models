gomodel:SYNGO_2184  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.2: Authors show that furosemide can be used to distinguish alpha1 from alpha6 containing GABAArs.\n\nFig.3+4: Application of furosemide prevents or reverses synaptic strengthening induced by mROS.\n\nNote: \"Synaptic strengthening' is the effect of having more (alpha6-containing) GABAARs in the postsynaptic specialization that together generate more current and a resulting larger influence on the membrane potential. The application of the furosemide silences the newly aquired population of GABAARs at the synapse, masking the synaptic strengthening.. Experimental description: \"Mice were anesthetized with isoflurane and immediately decapitated\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2017-12-26" ;
        dc:title          "SYNGO_MF_2184" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

