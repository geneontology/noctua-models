gomodel:SYNGO_1912  a     owl:Ontology ;
        rdfs:comment      "Rationale: The paper describes cloning and functional expression of high-affinity GABA uptake system GAT-1.\n\nrule: NAS_MFCC-BP\nrationale:\nProtein has 'gamma-aminobutyric acid:sodium symporter activity (GO:0005332)' and is localized in the presynaptic membrane (show with high-resolution technique). The inference to term 'neurotransmitter reuptake (GO:0098810)' is trivial and non-controversial.\nPinf_CC:\n[P23978] SynGO ID 86 (PMID:25120439, EM). Experimental description: \"Rat brain GABA transporter protein, purified as described...\", p. 1303" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9880-1214" , "https://orcid.org/0000-0002-0269-0311" , "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-9681-3318" ;
        dc:date           "2018-07-02" ;
        dc:title          "SYNGO_BP_1912" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

