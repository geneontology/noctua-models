obo:BFO_0000066  a  owl:ObjectProperty .

gomodel:SYNGO_4702  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 3: \"Examples of localization of KIF1Bβ at postsynaptic sites (co-localization with polymerized F-actin, as revealed by phalloidin staining) are indicated with white arrows (blue and red color merges to purple), while examples of co-localization of KIF1B and synaptophysin (a presynaptic marker) are indicated with yellow arrows (green and red color merges to yellow)\". Experimental description: M&M: \"Spinal motor neurons and cortical neurons were obtained from E18-19 mice.\"\n\nantibody;\n\"A rabbit polyclonal antibody to synthetic peptide IRSKLSRRCPSQSKY [aa residues 1,756-1,770 in human KIF1Bβ (NM015074)] was custom-made and affinity-purified by Peptide Speciality Laboratories, Germany. It was used at a dilution of 1:500 for immunoblotting and 1:300 for immunofluorescence (IF).\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2022-07-29" ;
        dc:title          "SYNGO_CC_4702" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

