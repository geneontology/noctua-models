gomodel:ev_w_id_R-HSA-9931290_RO_0002333_UniProt_P23458_R-HSA-9931290_controller_Reactome_R-HSA-9931290
        a               owl:NamedIndividual , obo:ECO_0000313 ;
        dc:contributor  "GOC:reactome_curators" ;
        dc:date         "2026-06-29" ;
        dc:source       "Reactome:R-HSA-9931290" ;
        pav:providedBy  "https://reactome.org" .

:R-HSA-9931295  a           obo:GO_0008150 , owl:NamedIndividual ;
        rdfs:comment        "PD-L1 (CD274) glycosylation plays a critical role in determining the protein function and stability. PD-L1 is N-glycosylated at N192, N200 and N219 by the OST complex in the ER lumen. This process is important for PD-L1 stability and inhibits its targeting for proteasomal degradation by GSK3B (Li et al., 2016). Also, JAK1 activated by IL6 pathway positively regulates the glycosylation process by aiding in the process of recruiting endoplasmic reticulum-associated N-glycosyltransferase STT3A (part of the OST complex) to catalyse PD-L1 glycosylation (Chan et al., 2019). PD-L1 is phosphorylated by IL6-activated JAK1 at Tyr112 (Y112). This process aids in stabilizing the PD-L1 protein. PD-L1, once glycosylated in the ER lumen, get translocated to the Golgi complex for further glycosylation by B3GNT3 (Li et al., 2018) and K63-ubiquitination by MIB2 (Yu et al., 2023). Post Golgi, PD-L1 gets transported to the plasma membrane where it can bind with its receptor and induce immune tolerance." ;
        rdfs:label          "PD-L1(CD274) glycosylation and translocation to plasma membrane" ;
        dc:contributor      "Authored: Hung, Mien-Chie, Yamaguchi, Hirohito, 2025-08-26" , "Edited: Gillespie, Marc E, 2025-08-08" , "GOC:reactome_curators" , "Authored: Tiwari, Krishna, 2024-11-05" , "Reviewed: Hung, Mien-Chie, Yamaguchi, Hirohito, 2025-08-26" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-9931295" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-9909615/R-HSA-9909615> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

