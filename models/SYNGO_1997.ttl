gomodel:SYNGO_1997  a     owl:Ontology ;
        rdfs:comment      "Rationale: Authors show that synaptic currents that inhibit cochlear hair cells is blocked by alphaBtx and strychnine. alpha9 nACHR subunit is specifically expressed in cochlear hair cells and is specifically targeted by alphaBtx and strychnin in these cells (alpha7 and muscle-type nAChRs that are also sensitive to alphaBtx are not expressed).. Experimental description: Tissues are of rat species: \"We used whole-cell recording of IHCs in acutely excised apical turns of the rat organ of Corti (postnatal days 7 to 13)\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2017-12-24" ;
        dc:title          "SYNGO_MF_1997" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

