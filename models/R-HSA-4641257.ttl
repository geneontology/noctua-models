<http://model.geneontology.org/R-HSA-4641257/R-HSA-4641257>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/GO_0090263> ;
        <http://www.w3.org/2000/01/rdf-schema#comment>
                "AXIN is present in low concentrations in the cell and is considered to be the limiting component of the beta-catenin destruction complex in Xenopus; this may not be the case in mammalian cells, however (Lee et al, 2003; Tan et al, 2012). Cellular levels of AXIN are regulated in part through ubiquitin-mediated turnover. E3 ligases SMURF2 and RNF146 have both been shown to play a role in promoting the degradation of AXIN by the 26S proteasome (Kim and Jho, 2010; Callow et al, 2011; Zhang et al, 2011)." ;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Degradation of AXIN" ;
        <http://purl.org/dc/elements/1.1/contributor>
                "Reviewed: Rajakulendran, Nishani, 2014-01-22" , "Reviewed: van Amerongen, R, 2014-02-14" , "Authored: Rothfels, K, 2013-06-24" , "Edited: Gillespie, ME, 2013-10-02" , "GOC:reactome_curators" , "Edited: Matthews, L, 2007-09-04 11:49:29" , "Reviewed: Kikuchi, Akira, 2014-04-22" ;
        <http://purl.org/dc/elements/1.1/date>
                "2026-04-08" ;
        <http://purl.org/pav/providedBy>
                "https://reactome.org" ;
        <http://www.geneontology.org/formats/oboInOwl#hasDbXref>
                "R-HSA-4641257" ;
        <http://www.w3.org/2004/02/skos/core#narrower>
                <http://model.geneontology.org/R-HSA-201681/R-HSA-201681> ;
        <http://www.w3.org/2004/02/skos/core#note>
                "org.biopax.paxtools.model.level3.Pathway" .

<http://model.geneontology.org/R-HSA-3640845_R-HSA-3640861>
