:R-HSA-4641257  a           owl:NamedIndividual , obo:GO_0090263 ;
        rdfs:comment        "AXIN is present in low concentrations in the cell and is considered to be the limiting component of the beta-catenin destruction complex in Xenopus; this may not be the case in mammalian cells, however (Lee et al, 2003; Tan et al, 2012). Cellular levels of AXIN are regulated in part through ubiquitin-mediated turnover. E3 ligases SMURF2 and RNF146 have both been shown to play a role in promoting the degradation of AXIN by the 26S proteasome (Kim and Jho, 2010; Callow et al, 2011; Zhang et al, 2011)." ;
        rdfs:label          "Degradation of AXIN" ;
        dc:contributor      "Reviewed: Rajakulendran, Nishani, 2014-01-22" , "Reviewed: van Amerongen, R, 2014-02-14" , "Authored: Rothfels, K, 2013-06-24" , "Edited: Gillespie, ME, 2013-10-02" , "GOC:reactome_curators" , "Edited: Matthews, L, 2007-09-04 11:49:29" , "Reviewed: Kikuchi, Akira, 2014-04-22" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-4641257" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-201681/R-HSA-201681> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

