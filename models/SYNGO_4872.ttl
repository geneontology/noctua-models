obo:GO_0098793  a  owl:Class .

gomodel:SYNGO_4872  a    owl:Ontology ;
        rdfs:comment     "Rationale: Figure 7: immunogold EM imaging of RGS4 protein in macaque prefrontal cortex showed localization to the presynapse, albeit sparingly.\n\n\"Glut-like axons establishing axodendritic and axospinous synapses (arrowheads) displayed low expression of RGS4 and minimal axoplasmic labeling\".\n\nRegarding subcellular localization; \"presynaptic active zones were not labeled\".. Experimental description: M&M: \"The 3 adult rhesus macaques in this study were maintained and euthanized in accordance with the guidelines of Yale University Institutional Animal Care and Use Committee\".\nabstract: \"Here we present an ultrastructural reference map of RGS4 protein in macaque PFC based on immunogold electron microscopic analysis.\"\n\nantibody:\n\"The immunoaffinity purified RGS4 antibody (IgY) was raised in chicken against amino acids 127-205 of the RGS4 protein C-terminus (Abcam, Cambridge, MA), and recognizes human and rodent RGS4 based on sequence homology.\"" ;
        lego:modelstate  "production" ;
        dc:contributor   "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date          "2022-09-11" ;
        dc:title         "SYNGO_CC_4872" ;
        pav:providedBy   "https://syngo.vu.nl" .

