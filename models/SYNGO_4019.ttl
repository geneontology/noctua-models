gomodel:SYNGO_4019  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 3G: Immunoelectron TEM confirms the localisation of the ATP81A immunoreaction on the synaptic membrane (indicated by black arrows).\n\nThe paper fails to comment on the specificity of ATP81A antibody used.\n\nThe term synapse was used because the evidence isn't strong enough to annotate it to any other specific SynGO term.. Experimental description: Heterozygous mutant C57BL/6 Atp8a1 (+/-) mice purchased from Taconic Farm and Jackson Laboratories were used." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0003-2916-7616" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2021-01-20" ;
        dc:title          "SYNGO_CC_4019" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

