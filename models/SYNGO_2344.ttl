obo:GO_0003674  a  owl:Class .

gomodel:SYNGO_2344  a     owl:Ontology ;
        rdfs:comment      "Automated change 2024-03-14: GO:0099060 replaced by GO:0099634" , "Rationale: Figure 1\nc) immunofluorescence microscopy shows Shisa7 co-localization with Homer1 (marker protein of Glut postsynapses.)\nd) biochemical fractionation shows Shisa7 is enriched in PSD\ne) Precipitation of Flag-Shisa7 from HEK293 cells using a Flag antibody shows that upon co-expression it binds directly to homomeric GluA1, GluA2 and GluA3 receptors\n\n\"integral component\" based on the protein's transmembrane domain. Experimental description: \"Immunoprecipitations were performed on hippocampi of 8-14 week old male and female WT and Shisa7 KO mice\"\n\n24/01/2018 Pim\n- Overexpressed Shisa7 is of mouse species: \"The full-length coding DNA for exon4-containing mouse Shisa7 (reference NP_766325.3)\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-4973-5732" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_2344" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

