<http://model.geneontology.org/ev_w_id_R-HSA-9022314_RO_0002233_R-HSA-9005549_R-HSA-9022314_Reactome_R-HSA-9022692>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/ECO_0000313> ;
