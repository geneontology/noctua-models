gomodel:ev_w_id_REACTO_R-HSA-629658_R-HSA-112281_R-HSA-8986937_component_BFO_0000051_UniProtKB_P0DP23_R-HSA-629658_R-HSA-8986937_component_Reactome_R-HSA-629658
        a               owl:NamedIndividual , obo:ECO_0000313 ;
