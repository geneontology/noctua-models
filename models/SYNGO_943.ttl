gomodel:SYNGO_943  a      owl:Ontology ;
        rdfs:comment      "Rationale: Loss of Teneurin-a reduces the apposition of active zones and neurotransmitter clusters at Drosophila neuromuscular junctions as show in Fig. 2.\nFig.3a,c shows that Teneurin-a loss results in microtubule disorganization at the boutons of Drosophila neuromuscular junctions.\nIn agreement with a presynaptic effect, Fig.1 shows that Teneurin-a is presynaptically localized at Drosophila NMJs.\n\n6/11/2017 Pim\n- Teneurins are transsynaptic adhesion molecules that intracellularly couple to various components of the cytoskeleton.. Experimental description: \"Details of Drosophila stocks can be found in Methods.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0912-1514" , "https://orcid.org/0000-0002-3670-7863" ;
        dc:date           "2021-01-26" ;
        dc:title          "SYNGO_BP_943" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_7227" .

