<http://model.geneontology.org/ev_w_id_R-HSA-8875320_RO_0002233_R-HSA-8875330_R-HSA-8875320_Reactome_R-HSA-8876198_R-HSA-8875320_enabled_by_UniProt_Q6ZS11_R-HSA-8875320_controller>
        a       <http://purl.obolibrary.org/obo/ECO_0000313> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
