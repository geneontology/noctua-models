:R-HSA-9929491  a           owl:NamedIndividual , obo:GO_0008150 ;
        rdfs:comment        "SPOP:CUL3:RBX1 E3 ubiquitin ligase complex regulates the ubiquitination and degradation of PD-L1(CD274) protein. This is negatively regulated by Cyclin D:CDK4 complex which phosphorylates SPOP on Ser-6 (S6) and facilitates its sequestration by 14-3-3 protein gamma (Zhang et al., 2018), thus inhibiting SPOP-mediated recruitment in the E3 ubiquitin ligase complex." ;
        rdfs:label          "SPOP-mediated proteasomal degradation of PD-L1(CD274)" ;
        dc:contributor      "Reviewed: Hung, Mien-Chie, Yamaguchi, Hirohito, 2025-08-26" , "Edited: Gillespie, Marc E, 2025-08-08" , "GOC:reactome_curators" , "Authored: Tiwari, Krishna, 2024-11-05" , "Authored: Hung, Mien-Chie, Yamaguchi, Hirohito, 2025-08-26" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-9929491" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-9909615/R-HSA-9909615> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

