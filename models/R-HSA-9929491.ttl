        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/GO_0008150> ;
        <http://www.w3.org/2000/01/rdf-schema#comment>
                "SPOP:CUL3:RBX1 E3 ubiquitin ligase complex regulates the ubiquitination and degradation of PD-L1(CD274) protein. This is negatively regulated by Cyclin D:CDK4 complex which phosphorylates SPOP on Ser-6 (S6) and facilitates its sequestration by 14-3-3 protein gamma (Zhang et al., 2018), thus inhibiting SPOP-mediated recruitment in the E3 ubiquitin ligase complex." ;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "SPOP-mediated proteasomal degradation of PD-L1(CD274)" ;
        <http://purl.org/dc/elements/1.1/contributor>
                "Reviewed: Hung, Mien-Chie, Yamaguchi, Hirohito, 2025-08-26" , "Edited: Gillespie, Marc E, 2025-08-08" , "GOC:reactome_curators" , "Authored: Tiwari, Krishna, 2024-11-05" , "Authored: Hung, Mien-Chie, Yamaguchi, Hirohito, 2025-08-26" ;
        <http://purl.org/dc/elements/1.1/date>
                "2026-02-04" ;
        <http://purl.org/pav/providedBy>
                "https://reactome.org" ;
        <http://www.geneontology.org/formats/oboInOwl#hasDbXref>
                "R-HSA-9929491" ;
