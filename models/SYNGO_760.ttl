gomodel:SYNGO_760  a      owl:Ontology ;
        rdfs:comment      "Rationale: Fig. 2; LRRTM1 has a synaptogenic activity when transfected in COS cells cocultured with hippocampal neurons\nLiteral:\n\"we measured the amount of synapsin clustering associated with transfected COS cells and not associated with MAP2-positive dendrites to exclude interneuronal synapses. Robust synaptogenic activity was observed for LRRTM1-CFP\". Experimental description: Rat YFP-LRRTM1 overexpression in rat hippocampal neurons and COS cells was used\n\nLiteral\n\"Cloning full-length LRRTMs\nFull length cDNAs for LRRTMs were made using RT-PCR from p11 rat brain total RNA.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-2949-9725" , "https://orcid.org/0000-0003-0662-9523" ;
        dc:date           "2017-07-07" ;
        dc:title          "SYNGO_BP_760" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

