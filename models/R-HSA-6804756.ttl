gomodel:ev_w_id_R-HSA-6805103_RO_0002234_R-HSA-6805104_R-HSA-6805103_Reactome_R-HSA-6805103
        a               owl:NamedIndividual , obo:ECO_0000313 ;
        dc:contributor  "GOC:reactome_curators" ;
