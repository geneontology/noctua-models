gomodel:SYNGO_4897  a     owl:Ontology ;
        rdfs:comment      "Rationale: The study shows that in the absence of SARM1 disassembly of motorneuron presynapses and Wallerian degeneration after axotomy does not occur (or is significantly delayed). Similar observations were made for fly neuromucular junctions. Interestingly, SARM1 -/- axons are not protected from nerve growth factor (NGF) withdrawl-induced axonal degeneration (Fig. S5).. Experimental description: \"Sarm1 is required for Wallerian degeneration in mice in vivo.\" Legend to Fig. 4 (p. 484)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-0269-0311" , "https://orcid.org/0000-0002-9880-1214" , "https://orcid.org/0000-0002-9681-3318" ;
        dc:date           "2023-01-28" ;
        dc:title          "SYNGO_BP_4897" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

