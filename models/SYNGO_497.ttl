lego:evidence  a  owl:AnnotationProperty .

gomodel:SYNGO_497  a      owl:Ontology ;
        rdfs:comment      "Rationale: Neurons expressing the WT EGFP-PTEN show localization in dendritic spines.\n\n29/5/2017 Pim\n- Importantly, over-expressed EGFP-PTEN shows stimulus-dependent translocation into spines. This shows this is not an over-expression artifact.. Experimental description: Primary cultures of E18 rat embryo hippocampal neurons.\n\n28/8/2017 Pim\n- Species of EGFP-PTEN construct not mentioned in the paper. The corresponding author has been contacted (cvenero@psi.uned.es; jaesteban@cbm.csic.es; s.knafo@ikerbasque.org; d.d. 28/8/2017). Author stated:\n\nDear Pim,\nSure. We used the PTEN rat sequence for this construct.\nGood luck with your work.\nJose" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-1190-4481" , "https://orcid.org/0000-0002-9848-0262" , "https://orcid.org/0000-0002-2094-7491" , "https://orcid.org/0000-0002-4419-210X" ;
        dc:date           "2017-08-28" ;
        dc:title          "SYNGO_CC_497" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

