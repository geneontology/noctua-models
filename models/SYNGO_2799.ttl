        a       owl:Class .

gomodel:SYNGO_2799  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.8: \"Wnt5a acts through a non-canonical pathway and decreases the number of presynaptic input\"\n- \"We exposed cultures to recombinant Wnt5a at 8 DIV for 36 hours. We found that Wnt5a decreases 'active' β-catenin immunofluorescence intensity, indicating that Wnt5a does not activate the canonical pathway and may act as an antagonist to canonical signaling (Figure 8A-D).\"\n- \"To determine if Wnt5a affects hippocampal synapse formation, we exposed cultures to Wnt5a at 8 DIV for 36 hours and observed the effect on the number of VGLUT1 puncta. In contrast to canonical Wnts, exposure to Wnt5a led to a significant decrease in the number of presynaptic terminals (Figure 8E, F), implying that the activation of a noncanonical pathway negatively regulates synapse formation.\". Experimental description: - \"Hippocampi were dissected from P0 Long Evans rats, dissociated, and plated...\"\n- Species of Wnt5a is human and mouse (identical aa sequences; traced back via supplier R&D systems)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2018-03-07" ;
        dc:title          "SYNGO_BP_2799" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_9606" .

