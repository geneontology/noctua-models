gomodel:MGI_MGI_1195267
        a                     owl:Ontology ;
        rdfs:comment          "Michele Magrane (UniProt) challenged the annotation to the GO term \"protein serine/threonine kinase activity\" [GO:0004674] on 2024_07_24 with this comment: \"Recent evidence shows that ILK does not have protein kinase activity and is likely to act as a scaffold protein. See PMID:20005845 & PMID:21524996 which show lack of kinase activity as well as PMID:30367047 which describes a non-catalytic role for ILK and a recent review, PMID:35089438.\" \nFrom the review she listed, it seems that the actual function of ILK is still uncertain, so I deleted the kinase activity annotation without replacing it." ;
        lego:modelstate       "production" ;
        dc:contributor        "https://orcid.org/0000-0001-7476-6306" , "https://orcid.org/0000-0001-5501-853X" , "https://orcid.org/0000-0003-3394-9805" , "https://orcid.org/0000-0002-9796-7693" , "https://orcid.org/0000-0003-2689-5511" ;
        dc:date               "2024-07-25" ;
        dc:title              "Ilk (MGI:MGI:1195267)" ;
        dcterms:created       "2001-12-17" ;
        dcterms:dateAccepted  "2022-03-28" ;
        pav:providedBy        "http://informatics.jax.org" ;
        owl:versionIRI        gomodel:MGI_MGI_1195267 ;
        biolink:in_taxon      obo:NCBITaxon_10090 .

