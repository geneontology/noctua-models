:R-HSA-205025  a            obo:GO_2001233 , owl:NamedIndividual ;
        rdfs:comment        "NADE protein (p75NTR-associated cell death executor) may induce cell death upon NGF binding, but not BDNF, NT3, or NT4/5 binding, to p75NTR. The NADE-dependent apoptosis is modulated by the 14-3-3-epsilon protein (Kimura MT et al, 2001)." ;
        rdfs:label          "NADE modulates death signalling" ;
        dc:contributor      "Authored: Nasi, Sergio, Annibali, D, 2006-10-10" , "Reviewed: Friedman, WJ, 2008-05-20 12:23:46" , "Reviewed: Chao, MV, 2008-05-28 09:46:01" , "Edited: Jassal, B, 2008-05-20 12:26:36" , "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-205025" ;
