<http://model.geneontology.org/ev_w_id_R-HSA-5607732_RO_0002333_R-HSA-5607732_UniProt_O43318_Reactome_R-HSA-5607732>
        a       <http://purl.obolibrary.org/obo/ECO_0000313> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
