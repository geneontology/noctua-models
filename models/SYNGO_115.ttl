gomodel:SYNGO_115  a      owl:Ontology ;
        rdfs:comment      "Rationale: In cultured RIM1/RIM2 double knockout neurons, there is an about 40% reduction in the number of docked vesicles, as measured by electron microscopy in glutaradehyde fixed cultures. Due to their high homology, the synaptic functions of RIM1 and RIM2 are assumed to be redundant (Han 2015).. Experimental description: We cultured neurons from newborn conditional double KO mice and infected these neurons with lentiviruses expressing EGFP-tagged active or inactive cre-recombinases." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-7620-2704" , "https://orcid.org/0000-0002-1558-1958" ;
        dc:date           "2018-06-07" ;
        dc:title          "SYNGO_BP_115" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .
