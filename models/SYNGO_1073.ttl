gomodel:SYNGO_1073  a     owl:Ontology ;
        rdfs:comment      "Rationale: Immunohistochemical analysis of GlyT1 expression in neurons.\nFigure 6 A-F: Pre-embedding immunogold staining of GLYT1 in the hippocampus the neocortex, and the spinal cord.\nFigure 6 G-I, K: Post-embedding immunogold of GLYT1 in the dentate gyrus and the molecular layer of the cerebellum.\nThe profiles show localization in both the pre- and postsynaptic compartments, as well as in glial processes.\nFigure 6G shows post-embedding immunogold staining for GLYT1 at the post synaptic density.\nFigure 6J shows double post-embedding immunogold labeling for GLYT1 and NMDAR in the hippocampus, and demonstrates colocalization at the postsynaptic density.\n\n2/7/2017 Pim\n- Annotation was not made agains the membrane part of the PSD because staining does not suggest membrane localization.. Experimental description: \"Localization of the GLYT1 glycine transporter at glutamatergic synapses in the rat brain\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-7351-8706" , "https://orcid.org/0000-0002-0755-5899" , "https://orcid.org/0000-0003-0938-8534" , "https://orcid.org/0000-0003-3185-5709" ;
        dc:date           "2017-07-02" ;
        dc:title          "SYNGO_CC_1073" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

