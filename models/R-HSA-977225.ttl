<http://model.geneontology.org/ev_w_id_R-HSA-5693081_RO_0002333_UniProt_P09958_R-HSA-5693081_controller_Reactome_R-HSA-5693081>
        a       <http://purl.obolibrary.org/obo/ECO_0000313> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
