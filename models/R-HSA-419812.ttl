<http://model.geneontology.org/ev_w_id_R-HSA-420214_RO_0002233_R-HSA-420061_R-HSA-420214_Reactome_R-HSA-419812>
        a       <http://purl.obolibrary.org/obo/ECO_0000313> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
