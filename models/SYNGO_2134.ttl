obo:GO_0031594  a  owl:Class .

dc:source  a    owl:AnnotationProperty .

gomodel:SYNGO_2134  a     owl:Ontology ;
        rdfs:comment      "Rationale: Double labeling for 2 and 5 confirmed that these two chains are codistributed throughout synaptic BL (Fig. 3 l).\n\n\"We assessed the distribution of laminins in synaptic regions by using confocal microscopy to examine sections double labeled with chain-specific antibodies to laminins plus rhodamine-α-bungarotoxin, which binds to AChRs at the crests of junctional folds\"\n\n11/12/2017 Pim\n- The techniques used are insufficient to resolve the SC. However, laminins are well established components of the extracellular matrix. Colocalization with nAChRs in the NMJ can be safely inferred to represent SC localization. This is supported by author intent: \"Together, these observations reveal that each of the four BLs that abut synaptic sites bears a distinct complement of laminin chains: .... α2, α4, α5, β2, and γ1 in the primary cleft (laminins 4, 9, and 11);\". Experimental description: \"Mice deficient in laminin β2 and littermate controls were generated and genotyped as described by Noakes et al. (1995a).\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-4973-5732" ;
        dc:date           "2017-12-11" ;
        dc:title          "SYNGO_CC_2134" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

