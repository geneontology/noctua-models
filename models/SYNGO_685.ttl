obo:GO_0003674  a  owl:Class .

gomodel:SYNGO_685  a      owl:Ontology ;
        rdfs:comment      "Rationale: Authors show, using a specific antibody, that importin alpha 2 is present in rat forebrain synaptosomal and PSD fractions. In primary hippocampal cultures, immunoreactivity of importin alpha 2 colocalized with the postsynaptic density marker PSD-95. Altogether, this data supports the localization of importin alpha 1 in the postsynaptic region.. Experimental description: From M&M and results sections:\n -Rabbit polyclonal antibodies were generated against mouse importin 2 (mPendulin).\n-Primary cultured hippocampal neurons were prepared from P0-P1 Black 6 mouse or Sprague-Dawley rat pups.\n-Synaptosome and postsynaptic density (PSD) fractions were prepared from adult rat forebrain.\n\n13/6/2017 Pim\n- There are two species that are featured in this paper (rat and mouse). I allowed annotation to mouse based on the confocal data." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0575-6950" , "https://orcid.org/0000-0002-1585-539X" ;
        dc:date           "2018-06-01" ;
        dc:title          "SYNGO_CC_685" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

