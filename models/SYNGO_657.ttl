gomodel:SYNGO_657  a      owl:Ontology ;
        rdfs:comment      "Rationale: The authors use synaptopHlourin (synaptophysin tagged to a pH sensitive GFP) to measure the endocytosis of synaptic vesicles (SVs) into presynaptic nerve terminals in rat hippocampal cultures. Using siRNA to knockdown the annotated protein, clathrin heavy chain (CHC), the authors see reduced SV endocytosis in response to low frequency stimulation.. Experimental description: From materials and methods, \"Primary cultures of rat hippocampal neurons were prepared from E18 rats and cocultured with glia\"." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-7806-5662" ;
        dc:date           "2023-11-03" ;
        dc:title          "SYNGO_BP_657" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

