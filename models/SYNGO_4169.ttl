gomodel:SYNGO_4169  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig1 shows the localization of cytohesin-2 (ARNO) in mouse hippocampus CA1 region. Panel P shows immunogold localization to spines (PSD is visible, indicating glutamate synapse) by EM, and the immunogold reactivity for cytohesin-2 is quantified in panel Q, showing the highest density in spines.. Experimental description: Figure legend \"Cellular and subcellular localization of cytohesin-2 in the mousebrain. \"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0001-5259-4945" ;
