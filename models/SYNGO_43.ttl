gomodel:SYNGO_43  a       owl:Ontology ;
        rdfs:comment      "Rationale: Rab27b is present on a subset of synaptic vesicles where it is involved in the regulating of SV recycling.\n\nUniprot: has lipid anchor. Experimental description: Sequencing of cDNA encoded by plasmid. Not mentioned in the paper.\n\n19/01/2017 Pim\nNote: please note that the expert that created this annotation is part of the lab that created this publication. The species information is therefore derived from direct communication with the authors.\n\n3/2/2017 Pim:\nNote: the Rab27b protein is shown to be preset in rat preparations with antibodies (Fig.5). In Fig 7 Rab27b is shown to have functional consequens for SV release. For the CC anotation the rat data is sufficient; I corrected the species to Rat." , "Automated change 2024-03-14: GO:0098993 replaced by GO:0030672" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-5615-1014" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_43" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

