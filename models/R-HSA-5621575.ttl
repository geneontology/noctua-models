<http://model.geneontology.org/ev_w_id_R-HSA-5660660_RO_0002234_R-ALL-2485002_nucleoplasm_Reactome_R-HSA-5660660>
        a       <http://purl.obolibrary.org/obo/ECO_0000313> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
