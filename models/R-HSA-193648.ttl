:R-HSA-193648  a            obo:GO_0043065 , owl:NamedIndividual ;
        rdfs:comment        "Once bound by either NGF or proNGF, p75NTR interacts with NRAGE, thus leading to phosphorylation and activation of JUN Kinase (JNK). JNK controls apoptosis in two ways: it induces transcription of pro-apoptotic genes, and directly activates the cell death machinery. Only NGF-bound p75NTR is shown here." ;
        rdfs:label          "NRAGE signals death through JNK" ;
        dc:contributor      "Authored: Nasi, Sergio, Annibali, D, 2006-10-10" , "Reviewed: Chao, MV, 2008-05-28 09:46:01" , "GOC:reactome_curators" , "Edited: Jassal, B, 2008-05-20 12:26:36" , "Reviewed: Friedman, WJ, 2008-05-20 12:23:46" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-193648" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-204998/R-HSA-204998> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

