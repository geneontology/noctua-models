<http://model.geneontology.org/R-HSA-193648/R-HSA-193648>
        a       <http://purl.obolibrary.org/obo/GO_0043065> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
        <http://www.w3.org/2000/01/rdf-schema#comment>
                "Once bound by either NGF or proNGF, p75NTR interacts with NRAGE, thus leading to phosphorylation and activation of JUN Kinase (JNK). JNK controls apoptosis in two ways: it induces transcription of pro-apoptotic genes, and directly activates the cell death machinery. Only NGF-bound p75NTR is shown here." ;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "NRAGE signals death through JNK" ;
        <http://purl.org/dc/elements/1.1/contributor>
                "Authored: Nasi, Sergio, Annibali, D, 2006-10-10" , "Reviewed: Chao, MV, 2008-05-28 09:46:01" , "GOC:reactome_curators" , "Edited: Jassal, B, 2008-05-20 12:26:36" , "Reviewed: Friedman, WJ, 2008-05-20 12:23:46" ;
        <http://purl.org/dc/elements/1.1/date>
                "2026-04-09" ;
        <http://purl.org/pav/providedBy>
                "https://reactome.org" ;
        <http://www.geneontology.org/formats/oboInOwl#hasDbXref>
                "R-HSA-193648" ;
        <http://www.w3.org/2004/02/skos/core#narrower>
                <http://model.geneontology.org/R-HSA-204998/R-HSA-204998> ;
        <http://www.w3.org/2004/02/skos/core#note>
                "org.biopax.paxtools.model.level3.Pathway" .

