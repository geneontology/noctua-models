:R-HSA-211994  a            obo:GO_0016125 , owl:NamedIndividual ;
        rdfs:comment        "Cytochrome P450 8B1 (CYP8B1, sterol 12-alpha- hydroxylase) has a broad substrate specificity including a number of 7-alpha- hydroxylated C27 steroids. It is also involved in bile acid synthesis and is responsible for the balance between the formation of cholic acid and chenodeoxycholic acid (Gafvels et al. 1999)." ;
        rdfs:label          "Sterols are 12-hydroxylated by CYP8B1" ;
        dc:contributor      "Edited: Jassal, Bijay, 2008-05-19" , "GOC:reactome_curators" , "Authored: Jassal, Bijay, 2008-05-19" , "Reviewed: D'Eustachio, P, 2008-05-28 08:30:54" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-211994" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-211976/R-HSA-211976> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

