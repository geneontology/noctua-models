:YeastPathways_PYRUVDEHYD-PWY
        a                   owl:NamedIndividual , obo:GO_0006086 ;
        rdfs:comment        "The overall conversion of pyruvate to acetyl-CoA is catalyzed by the multienzyme pyruvate dehydrogenase complex. The pyruvate dehydrogenase complex is composed of: pyruvate dehydrogenase (E1&alpha; subunit (Pda1p) and E1&beta; subunit (Pdb1p)), dihydrolipoyllysine-residue acetyltransferase (E2 subunit (Lat1p)), and dihydrolipoyl dehydrogenase (E3 subunit (Lpd1p)). A fifth subunit (Protein X (Pdx1p)) of the pyruvate dehydrogenase complex links Lat1p to Lpd1p." ;
        rdfs:label          "pyruvate decarboxylation to acetyl CoA" ;
        layout:x            "287" ;
        layout:y            "38" ;
        dc:contributor      "GOC:sgd_curators" , "https://orcid.org/0000-0001-5472-917X" , "https://orcid.org/0000-0001-6787-2901" ;
        dc:date             "2024-07-16" ;
        pav:providedBy      "http://www.yeastgenome.org" ;
        oboInOwl:hasDbXref  "YeastPathways_PYRUVDEHYD-PWY" ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

