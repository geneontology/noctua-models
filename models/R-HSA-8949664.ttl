:R-HSA-8949664  a           obo:GO_0008150 , owl:NamedIndividual ;
        rdfs:comment        "Proteolytic processing of proSMDT1 (proEMRE) regulates assembly of properly regulated mitochondrial calcium uniporter (MCU) complex (Konig et al. 2016). C2orf47 (MAIP) in a complex with AFG3L2 (m-AAA protease) binds the transit peptide of proSMDT1, promotes cleavage of the transit peptide by mitochondrial processing endopeptidase, and prevents proteolytic destruction of proSMDT1. SMDT1 that is not then incorporated with the regulatory subunits MICU1 and MICU2 (or MICU1 and MICU3 in neurons) into the MCU complex is degraded by AFG3L2, preventing assembly of unregulated MCU. Unprocessed proSMDT1 is proteolyzed by YME1L1." ;
        rdfs:label          "Processing of SMDT1" ;
        dc:contributor      "GOC:reactome_curators" , "Authored: May, Bruce, 2016-11-28" , "Edited: May, Bruce, 2016-11-28" , "Reviewed: Drago, Ilaria, 2017-01-21" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-8949664" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-8949215/R-HSA-8949215> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

