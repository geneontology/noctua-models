obo:BFO_0000051  a  owl:ObjectProperty .

:R-HSA-9027276  a           owl:NamedIndividual , obo:GO_0051897 ;
        rdfs:comment        "PI3K can bind the activated EPO receptor (EPOR) by three different mechanisms: direct binding to phospho-Y479 of the EPOR, indirect binding via phosphorylated IRS2 bound to the EPOR, and indirect binding via phosphorylated GAB1 bound to the EPOR (Bouscary et al. 2003, Schmidt et al. 2004, reviewed in Kuhrt and Wojchowski 2015). PI3K phosphorylates phosphatidylinositol 4,5-bisphosphate to yield phosphatidylinositol 3,4,5-trisphosphate which recruits AKT1 to the membrane." ;
        rdfs:label          "Erythropoietin activates Phosphoinositide-3-kinase (PI3K)" ;
        dc:contributor      "GOC:reactome_curators" , "Authored: May, Bruce, 2017-10-29" , "Reviewed: McGraw, Kathy L, 2018-08-14" , "Edited: May, Bruce, 2017-10-29" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
