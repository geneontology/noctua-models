gomodel:SYNGO_4534  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig. 1 A shows by immunogold EM localization that the CYLD protein is localized in the postsynaptic density. Immunoreactivity increases after 2 min of NMDA treatment.. Experimental description: Hippocampal cells from 21-day embryonic Sprague-Dawley rats were dissociated and grown on a glial cell layer as ... for 3-4 weeks (p.2)\n\nAntibodies to CYLD: rabbit polyclonal (1:250 for Western blots, 1:100 for EM) is from Sigma (SAB4200060) and mouse monoclonal (E-4) used for immunoprecipitation is from Santa Cruz (sc-74434)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-0269-0311" , "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-9880-1214" , "https://orcid.org/0000-0002-9681-3318" ;
        dc:date           "2022-04-28" ;
        dc:title          "SYNGO_CC_4534" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

