gomodel:657ba49f00001182
        a                 owl:Ontology ;
        rdfs:comment      "Previous data already showed that PARs activate\nphospholipase C (PLC), which converts membrane bound\nphosphatidyl inositol (4,5)-bisphosphate into inositol\ntrisphosphate (InsP3) and diacylglycerol. InsP3 diffuses\ninto the cytoplasm and triggers release of Ca2 from the\nendoplasmic reticulum by binding to InsP3 receptors\n(Wang et al., 2002b)." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2979-8613" ;
        dc:date           "2025-04-14" ;
        dc:title          "astrocytic Best1-mediated glutamate on\npostsynaptic NMDARs upon PAR-1 activation (Human)" ;
        pav:providedBy    "https://www.uniprot.org" ;
        biolink:in_taxon  obo:NCBITaxon_9606 .

