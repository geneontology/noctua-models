<http://model.geneontology.org/657ba49f00001182> a owl:Ontology ;
    ns2:modelstate "production"^^xsd:string ;
    dc:contributor "https://orcid.org/0000-0002-2979-8613"^^xsd:string ;
    dc:date "2025-04-14"^^xsd:string ;
    dc:title """astrocytic Best1-mediated glutamate on
postsynaptic NMDARs upon PAR-1 activation (Human)"""^^xsd:string ;
    ns1:providedBy "https://www.uniprot.org"^^xsd:string ;
    rdfs:comment """Previous data already showed that PARs activate
phospholipase C (PLC), which converts membrane bound
phosphatidyl inositol (4,5)-bisphosphate into inositol
trisphosphate (InsP3) and diacylglycerol. InsP3 diffuses
into the cytoplasm and triggers release of Ca2 from the
endoplasmic reticulum by binding to InsP3 receptors
(Wang et al., 2002b)."""^^xsd:string ;
    ns4:in_taxon ns3:NCBITaxon_9606 .

