obo:BFO_0000066  a  owl:ObjectProperty .

gomodel:SYNGO_5434  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 6, S4: immunofluorescence imaging of overexpressed liprin-α2 (PPFIA2) in hippocampal neurons showed enrichment in dendritic spines and strong co-localization with PSD marker proteins PSD95 (DLG4) and Homer. For liprin-α, the N-terminal part (1-735) is required for the synaptic localization (Figure S4B). Further, liprin-α2 pulldowns suggested interaction with various PSD proteins (as well as presynaptic active zone constituents).. Experimental description: M&M: \"Female pregnant Wister rats were obtained from Janvier Laboratories. Hippocampal neurons were obtained from embryos of both genders at the embryonic day 18 (E18) stage of development.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2023-03-16" ;
        dc:title          "SYNGO_CC_5434" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

