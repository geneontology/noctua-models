gomodel:SYNGO_2987  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.1: \"Dact1 is present at forebrain synapses\"\n- \"This staining, which was absent from Dact1-/- HCNs (Fig 1B), colocalized with synaptic markers, including at punctate intensities of the excitatory postsynaptic marker protein PSD95 likely to correspond to postsynaptic sites (Fig 1C-H). Supporting a postsynaptic localization for Dact1, immunoblotting of subcellular fractions derived from forebrain cortical cultures revealed that recombinantly expressed FLAG-Dact1 co-partitioned with PSD95 in postsynaptic, as opposed to presynaptic, fractions (Fig 1I).\". Experimental description: - \"Dact1 is a postsynaptic protein required for dendrite, spine, and excitatory synapse development in the mouse forebrain\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2018-03-23" ;
        dc:title          "SYNGO_CC_2987" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

