<http://model.geneontology.org/R-HSA-9038123_R-HSA-9038161>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/go/extensions/reacto.owl#REACTO_R-HSA-9038123> ;
        <http://www.w3.org/2000/01/rdf-schema#comment>
                "Original Reactome ID: R-HSA-9038123" , "located_in nucleoplasm" ;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "HSP90:ATP:PTGES3:FKBP52:PGR:P4" ;
