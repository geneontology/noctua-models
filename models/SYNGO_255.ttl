gomodel:SYNGO_25523c32caa-5ace-412d-8581-84a95ef3241e
        a               owl:NamedIndividual , obo:UBERON_0002421 ;
        dc:contributor  "https://orcid.org/0000-0002-7620-2704" , "https://orcid.org/0000-0002-1558-1958" ;
