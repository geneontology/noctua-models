gomodel:SYNGO_1926  a     owl:Ontology ;
        rdfs:comment      "Rationale: Immuno-EM for drebrin A in neonatal tissue shows sub-membraneous labeling of drebrin A preferentially at developing, immature synaptic structures, more than at synaptic structures that have characteristics of more developed synapses. Based on these data it cannot be derived whether drebrin A is directly anchored in or to the membrane, more likely it is in close proximity, rather than directly attached.. Experimental description: from M&M: \"For the light and electron microscopic studies, Wistar rats were purchased from Charles River\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-6153-3586" , "https://orcid.org/0000-0002-2666-0758" ;
        dc:date           "2017-11-17" ;
        dc:title          "SYNGO_CC_1926" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

