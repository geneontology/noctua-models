:R-HSA-2428928  a           owl:NamedIndividual , obo:GO_0008150 ;
        rdfs:comment        "The phosphorylated type 1 insulin-like growth factor receptor phosphorylates IRS1, IRS2, IRS4 and possibly other IRS/DOK family members (reviewed in Pavelic et al. 2007, Chitnis et al. 2008, Maki et al. 2010, Parrella et al. 2010, Siddle et al. 2012). The phosphorylated IRS proteins serve as scaffolds that bind the effector molecules PI3K and GRB2:SOS. PI3K then activates PKB (AKT) signaling while GRB2:SOS activates RAS-RAF-MAPK signaling." ;
        rdfs:label          "IRS-related events triggered by IGF1R" ;
        dc:contributor      "GOC:reactome_curators" , "Authored: May, B, 2012-08-06" , "Reviewed: Holzenberger, Martin, 2012-11-09" , "Edited: May, B, 2012-08-06" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-2428928" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-2428924/R-HSA-2428924> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

