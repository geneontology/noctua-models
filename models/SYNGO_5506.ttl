obo:ECO_0001232  a  owl:Class .

gomodel:SYNGO_5506  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 1D: Quantitative analysis of synaptotagmin 1 immunogold labeling over presynaptic terminal cytoplasm at synapses in the hippocampus of synaptotagmin 1 KO and WT mice.\n\nFigure 2A: Ultrastructural examination by immunogold EM show SYT1 localization to the presynaptic cytosol, presynaptic active zone, PSD, postsynaptic cytosol and the postsynaptic membrane (quantified in figure 3)\n\nFigure 2B: Ultrastructural examination by immunogold EM shows association of SYT1 to postsynaptic vesicles.\n\nFigure 2D-I: confirmation of postsynaptic localization of SYT1 with IF on dissociated hippocampal culture, co-staining with PSD95.. Experimental description: From M&M: \"Anti-synaptotagmin 1 was raised in rabbit and used at for electron microscopy, light microscopy and immunofluorescence. Anti-synaptotagmin 1 (Millipore, MA, Cat#AB5600) was used for EM.\"\nAntibody specificity control shown in Figure 1." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2023-10-29" ;
        dc:title          "SYNGO_CC_5506" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

