obo:GO_0050804  a  owl:Class .

gomodel:SYNGO_2405  a     owl:Ontology ;
        rdfs:comment      "Rationale: Basal synaptic transmission was significantly reduced at MPP-DG synapses of netrin-G2-KO mice.\nMPP-DG synapses of netrin-G2-KO mice showed significantly increased PPR at all interstimulus intervals.\nPTP at the SC-CA1 synapses was facilitated in netrin-G2-KO.\nLTP induced by TBuS (an LTP-stimulation protocol) at SC-CA1 synapses was increased in netrin-G2-KO mice.. Experimental description: Materials and Methods\nElectrophysiology.\nMice were deeply anesthetized with halothane (Takeda) and killed by decapitation." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-6194-9648" , "https://orcid.org/0000-0001-5518-6584" ;
        dc:date           "2018-02-07" ;
        dc:title          "SYNGO_BP_2405" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

