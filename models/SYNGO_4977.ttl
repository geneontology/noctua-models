obo:RO_0002333  a  owl:ObjectProperty .

gomodel:SYNGO_4977  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 3: Cathepsin D (CTSD / CatD) is localized to GABAergic presynaptic endosomes\n\nFigure 4, 5: cultured hippocampal neurons from Cathepsin D knockouts showed a reduction of HRP-labeled endocytic vesicles of small-to-medium size in GABAergic synapses and an increase in endosome-like vesicles. In contrast, glutamatergic SV remain grossly unaffected.\n\nAuthors concluded; \"Together, these data demonstrate that GABAergic presynaptic endosomal CatD is essential for processing and production of SV from ELV, thus contributing to SV recycling and biogenesis.\". Experimental description: Sprague Dawley rats were used for the immunogold EM and immunocytochemistry experiments. Human and mice brain slices were used for the immunohistochemistry experiments." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2023-02-05" ;
        dc:title          "SYNGO_BP_4977" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

