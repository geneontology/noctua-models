obo:ECO_0005589  a  owl:Class .

obo:ECO_0006003  a  owl:Class .

gomodel:SYNGO_2456  a     owl:Ontology ;
        rdfs:comment      "Rationale: LRRC4 interacts with netrin-G CAMs through its ectodomain in an isoform-specific manner.\nLRRC4 localizes to the postsynaptic side of excitatory synapses.\nLRRC4 expression in heterologous cells induces functional presynaptic differentiation in contacting neurites.\nDirect aggregation of LRRC4 on the dendritic surface induces clustering of excitatory postsynaptic proteins.. Experimental description: Methods\nImmunoelectron microscopy.\nFor quantitative electron microscopy, we used two immunoreacted sections from each of two rats labeled with secondary antibody to rabbit Fab fragments coupled to 10 nm gold particles (British BioCell).\n\nCoculture assay.\nCoculture assays were performed essentially as described (17,18).\n(ref. 17) Cell Culture.\nHippocampal neuron cultures were prepared from E18 rat embryos.\n\nDNA constructs.\nFull-length mouse NGL-2 (DQ177325, aa 1-652; from a brain cDNA library; Clontech) and NGL-2 ΔC (1-649) were subcloned into pEGFP-N1." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-6194-9648" , "https://orcid.org/0000-0001-5518-6584" ;
        dc:date           "2018-02-21" ;
        dc:title          "SYNGO_BP_2456" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

