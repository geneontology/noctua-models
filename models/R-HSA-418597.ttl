<http://model.geneontology.org/ev_w_id_R-HSA-392129_BFO_0000066_reaction_R-HSA-392129_location_lociGO_0005886_Reactome_R-HSA-418597>
        a       <http://purl.obolibrary.org/obo/ECO_0000313> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
