gomodel:ev_w_id_R-HSA-201476_RO_0002411_R-HSA-201425_Reactome_R-HSA-201451_R-HSA-201425_enabled_by_UniProt_P51668_R-HSA-201425_controller
        a               owl:NamedIndividual , obo:ECO_0000313 ;
        dc:contributor  "GOC:reactome_curators" ;
