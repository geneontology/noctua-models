<http://model.geneontology.org/ev_w_id_R-HSA-201476_RO_0002411_R-HSA-201425_Reactome_R-HSA-201451_R-HSA-201425_enabled_by_UniProt_P51668_R-HSA-201425_controller>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/ECO_0000313> ;
        <http://purl.org/dc/elements/1.1/contributor>
                "GOC:reactome_curators" ;
