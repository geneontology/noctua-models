obo:RO_0002333  a  owl:ObjectProperty .

gomodel:SYNGO_5252  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 4: NEDD8-conjugating enzyme Ubc12 (UBE2M) is present in pre- and post-synaptic biochemical fractions from mouse hippocampi. Blotting all neddylated proteins showed many Ubc12 targets in pre- and post-synapse.\n\nFurthermore, authors show that neddylation (which directly involves Ubc12) takes place at the synapse.. Experimental description: Results, Figure 4 legend: \"This panel shows an immunoblot of synaptosomal fractions from mouse hippocampi.\"\n\nantibody:\nAnti-Ubc12, rabbit, Lifespan BioSciences, #LS-B432" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2023-03-09" ;
        dc:title          "SYNGO_CC_5252" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

