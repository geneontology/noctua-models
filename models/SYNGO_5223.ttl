obo:BFO_0000066  a  owl:ObjectProperty .

gomodel:SYNGO_5223  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure S2a: confocal imaging of immunofluorescence labeling for overexpressed human-PPT1, Synaptophysin (SYP) and MAP2 in mouse primary neuronal culture showed partial co-localization of PPT1 and Synaptophysin.\n\nFigure S2b: biochemical fractions prepared from whole brains of wildtype mice (with PPT1-knockouts as control) showed PPT1 was enriched in P2 as compared to whole lysate and present in various synaptic subfractions (e.g. plasma membrane and synaptic vesicle) with strongest enrichment in synaptic cytosol (LS2).\n\nFigure 2: mass-spectrometry of synaptosomes prepared from wildtype and PPT1-knockout knockout mice showed a large number of synaptic substrates for PPT1.\n\n\"We detected PPT1 in all synaptic subcompartments and found high levels of PPT1 enzyme activity in the synaptic cytosol.\". Experimental description: Figure S2 legend: \"Endogenous PPT1 is present in all synaptic fractions of a subcellular fractionation of whole brains (8 WT and 8 PPT1 KO mice; age = 2 months; run in biological triplicate)\"\n\nantibody:\nRabbit polyclonal anti-PPT1 (used at 1:200 for ICC), GeneTex, Cat #: GTX110677; RRID: AB_1951370\nRabbit polyclonal anti-PPT1 (used at 1:50 for WB), This paper; Thermo Fisher Scientific Life Sciences Solutions, Custom Antibody; Project VH2380" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2023-03-04" ;
        dc:title          "SYNGO_CC_5223" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

dc:date  a      owl:AnnotationProperty .

