gomodel:SYNGO_334  a      owl:Ontology ;
        rdfs:comment      "Rationale: Using electron microscopy and an antibody specific for GLYT2, GLYT2 is found in presynaptic terminals of the ventral horn of the spinal cord (Fig 5B) and terminals of golgi cells in the cerebellum (Fig 7C).\n\n16/5/2017 Pim\n- Expert observes the immuno-EM staining in the presynaptic plasma membrane. Moreover, the function of the protein is pumping glycine across the plasma membrane. This also justifies the addition of \"glycinergic\" in the synapse type information.. Experimental description: \"Three rats (Wistar strain, Mellegaard Hansen,\nDenmark) were deeply anesthetized with pentobarbital (100 mglkg)...\"" , "Automated change 2024-03-14: GO:0099056 replaced by GO:0042734" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-7480-0826" , "https://orcid.org/0000-0003-4022-8707" , "https://orcid.org/0000-0003-2533-9548" , "https://orcid.org/0000-0002-1212-5623" , "https://orcid.org/0000-0002-5648-066X" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_334" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

