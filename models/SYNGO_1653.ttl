gomodel:SYNGO_1653  a     owl:Ontology ;
        rdfs:comment      "Rationale: Table S1 contains 452 proteins identified in PSD (detergent-resistant synaptic junctional proteins) preparations of rat and mouse brains.\nFor proteins coming from datasets derived from PSD (detergent-resistant synaptic junctions) preparations without defined selection / enrichment of the pre- or postsynaptic compartment we cannot assign these proteins to excitatory and/or inhibitory nor to the presynapse or / and postsynapse without further information.\n\n17/11/2017 Pim\n- Listed as \"apolipoprotein A-IV [Mus musculus]\" in Table S1. Experimental description: Rodents: \"Rats or mice were euthanized by CO2 in compliance with New York University Medical Center's Institutional Animal Care and Use Committee,...\", p. 858" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-0269-0311" , "https://orcid.org/0000-0002-9681-3318" , "https://orcid.org/0000-0002-9880-1214" ;
        dc:date           "2017-11-17" ;
        dc:title          "SYNGO_CC_1653" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

