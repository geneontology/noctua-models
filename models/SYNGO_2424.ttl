gomodel:SYNGO_2424  a     owl:Ontology ;
        rdfs:comment      "Rationale: pharmacological inhibition of mGlur4 reduces evoked synaptic responses and changes both short and longer (post-tetanic potentiation) forms of plasticity strongly implying a presynaptic regulation. KO of this proteins largely mimics the pharmacological intervention and removes any further action of antagonists.. Experimental description: MATERIALS AND METHODS\nProduction of mGluR4 KO mice" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-5648-066X" , "https://orcid.org/0000-0001-7480-0826" , "https://orcid.org/0000-0003-4022-8707" , "https://orcid.org/0000-0002-1212-5623" , "https://orcid.org/0000-0003-2533-9548" ;
        dc:date           "2018-03-19" ;
        dc:title          "SYNGO_BP_2424" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

