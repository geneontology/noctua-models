<http://model.geneontology.org/R-HSA-9954910_R-HSA-9955731>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/go/extensions/reacto.owl#REACTO_R-HSA-9954910> ;
        <http://www.w3.org/2000/01/rdf-schema#comment>
                "Original Reactome ID: R-HSA-9954910" , "located_in cytosol" ;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "ABCE1:ATP:PELO:80S Ribosome:non-stop mRNA:peptidyl-tRNA with elongating peptide" ;
        <http://purl.org/dc/elements/1.1/contributor>
                "GOC:reactome_curators" ;
        <http://purl.org/dc/elements/1.1/date>
                "2026-02-25" ;
        <http://purl.org/pav/providedBy>
                "https://reactome.org" ;
        <http://www.geneontology.org/formats/oboInOwl#hasDbXref>
                "Reactome:R-HSA-9954910" ;
        <http://www.w3.org/2004/02/skos/core#exactMatch>
                <http://www.reactome.org/biopax/95/48887#Complex2804> ;
        <http://www.w3.org/2004/02/skos/core#note>
