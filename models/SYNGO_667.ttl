obo:BFO_0000050  a  owl:ObjectProperty .

gomodel:SYNGO_667  a      owl:Ontology ;
        rdfs:comment      "Rationale: Fbxl20/SCRAPPER is enriched in synaptic membrane fractions from mouse brain (Figure 1D). Immunofluorescence analysis revealed a punctate distribution of SCRAPPER (Figure 1F) that predominantly colocalized with synaptophysin, a known synaptic vesicle protein and presynapse marker.. Experimental description: M&M:\n\"Subcellularly, SCRAPPER was enriched in synaptic membrane fractions from the **mouse** brain (Figure 1D).\"\n\"Primary cultured neurons from SCR-KO **mice** were prepared with P1- P3 mice\"." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9900-4233" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2017-05-22" ;
        dc:title          "SYNGO_CC_667" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

