:R-HSA-211163  a            owl:NamedIndividual , obo:GO_2000074 ;
        rdfs:comment        "The unphosphorylated form of FOXO1A shuttles between the nucleus and cytoplasm, maintaining a substantial concentration of this protein in the nucleoplasm, where it functions as a transcription factor. Phosphorylation of the protein, catalyzed by activated AKT, causes its exclusion from the nucleus (Zhang et al. 2002)." ;
        rdfs:label          "AKT-mediated inactivation of FOXO1A" ;
        dc:contributor      "Edited: D'Eustachio, P, 2008-05-12 21:43:33" , "GOC:reactome_curators" , "Reviewed: Jensen, J, 2008-05-12 21:46:53" , "Authored: Ferrer, J, Tello-Ruiz, MK, 2008-05-23" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-211163" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-210745/R-HSA-210745> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

