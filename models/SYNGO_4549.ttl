gomodel:SYNGO_4549  a     owl:Ontology ;
        rdfs:comment      "Automated change 2024-03-14: GO:0099056 replaced by GO:0042734" , "Rationale: Fig. 7 shows the localization of Syndecan-2 at the synaptic membranes both at the pre- and postsynaptic side. Fig. 8 shows an almost symmetric distribution of immunogold particles. Although peaking at the synaptic membrane, syndecan-2 labeling extends deeper into the presynaptic than the postsynaptic side.\n\n\"integral component ..\" was inferred from transmembrane topology of Syndecan-2. Experimental description: \"For electron microscopy, pentobarbital-anesthetized (60 mg/kg) male Sprague-Dawley rats (250-350 g) were perfused intraaortically with mixed aldehyde fixatives...\" (p.140)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-9880-1214" , "https://orcid.org/0000-0002-9681-3318" , "https://orcid.org/0000-0002-0269-0311" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_4549" ;
        pav:providedBy    "https://syngo.vu.nl" ;
