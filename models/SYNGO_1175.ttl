gomodel:SYNGO_1175  a     owl:Ontology ;
        rdfs:comment      "Automated change 2024-03-14: GO:0030285 replaced by GO:0030672" , "Rationale: Knause et al. raised an antibody against synaptoporin. They isolate different fractions of the brain by subcellular fractionation and observed that synaptoporin is enriched in the purified synaptic vesicle fraction. Also, they performed immunoblot analysis of synaptic vesicles purified by both gradient centrifugation and size-exclusion chromatography and observed that synaptophysin and synaptoporin cofractionate through all steps (Fig. 6).. Experimental description: Synaptic vesicles and different subcellular fractions isolated from rat brain were analyzed by Western blotting using synaptoporin-specific antibodies." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-0808-7003" , "https://orcid.org/0000-0002-3898-5197" , "https://orcid.org/0000-0003-1542-3498" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_1175" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

