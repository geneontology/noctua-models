obo:BFO_0000066  a  owl:ObjectProperty .

gomodel:SYNGO_494  a      owl:Ontology ;
        rdfs:comment      "Rationale: CAPS-1 is essential for synaptic vesicle priming. Isolated, autaptic hippocampal neurons deficient for CAPS-1 as well as CAPS-1 and -2 exhibit reduced evoked neurotransmitter release, spontaneous release and readily-releasable pool size in response to hypertonic sucrose application, without a change in the vesicular release probability.\n\n12/5/2017 Pim\n- The \"regulation of...\" box not checked because CAPS1 is shown to be \"Essential Synaptic Vesicle Priming Proteins\" (see title of referenced paper).. Experimental description: M&M: Mutant Mouse Strains. CAPS-1 KO mice were published previously (Speidel et al., 2005). CAPS-2 KO mice were generated by homologous recombination in embryonic stem cells (Figure S1)." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-0755-5899" , "https://orcid.org/0000-0003-0938-8534" , "https://orcid.org/0000-0001-7351-8706" , "https://orcid.org/0000-0003-3185-5709" ;
        dc:date           "2017-06-30" ;
        dc:title          "SYNGO_BP_494" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

