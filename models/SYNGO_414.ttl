gomodel:SYNGO_414  a      owl:Ontology ;
        rdfs:comment      "Rationale: Average enrichment of 40S ribosomal protein S27 in docked synaptic vesicles vs. free vesicles is 4.1 fold (Table S1) and about 1.4 fold in VGLUT1 vs. VGAT positive terminals.\n\n8/8/2017 Pim\n- Protein is considererd as a marker protein of ribosomes.. Experimental description: To isolate docking complexes from rat brain, we first prepared synaptosomes and subjected them to limited proteolysis to dissociate pre- and postsynaptic membranes (Figure 1A). p. 286" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9681-3318" , "https://orcid.org/0000-0002-9880-1214" , "https://orcid.org/0000-0002-0269-0311" , "https://orcid.org/0000-0001-9377-7414" ;
        dc:date           "2018-05-28" ;
        dc:title          "SYNGO_CC_414" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

