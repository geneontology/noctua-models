:R-HSA-426048  a            obo:GO_0019369 , owl:NamedIndividual ;
        rdfs:comment        "Diacylglycerol (DAG) is an important source of arachidonic acid, a signalling molecule and the precursor of the prostaglandins. In human platelet almost all the DAG produced from phosphatidylinositol degradation contains arachidonate (Takamura et al. 1987). DAG is hydrolysed by DAG lipase to 2-arachidonylglycerol (2-AG) which is further hydrolysed by monoacylglycerol lipase. 2-AG is an agonist of cannabinoid receptor 1." ;
        rdfs:label          "Arachidonate production from DAG" ;
        dc:contributor      "Authored: Jupe, S, 2009-06-11" , "GOC:reactome_curators" , "Edited: Jupe, S, 2009-09-09" , "Reviewed: Akkerman, JW, 2009-09-04" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-426048" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-114508/R-HSA-114508> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

