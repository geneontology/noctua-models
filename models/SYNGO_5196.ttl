gomodel:SYNGO_5196  a     owl:Ontology ;
        rdfs:comment      "Automated change 2024-03-14: GO:0099061 replaced by GO:0098839" , "Rationale: Figure 4, S5: STED super-resolution microscopy of hippocampal neurons stained for SynDIG4 (PRRT1), TARP-γ8 (CACNG8) and Homer (HOMER1) showed localization of SynDIG4 to postsynaptic densities.\n\nBased on the known transmembrane topology of this protein, \"integral component of ... membrane\" term was selected.. Experimental description: M&M: \"Primary neuronal culture - Hippocampi were dissected from E18 wildtype mice ...\"\n\nantibody:\n\"Anti-SynDIG4 (L102_45, mouse, Neuromab) was used for immunoblot analysis at 1:1000 and immunocytochemistry at 1:100.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2024-03-14" ;
