gomodel:SYNGO_1355  a     owl:Ontology ;
        rdfs:comment      "Rationale: Localization of eIF4E in the synaptic region (lipid draft and PSD fraction) of the rat cerebral cortex at the electron microscopic level.\n\n25/9/2017 Pim\n- The authors describe localization of patches of high labeling at many sites in the spine sometimes associated witht the PSD. Because of this 'traveling' appearance I decided not to propose annotation to the more specific term 'postsynaptic density'.. Experimental description: Wistar rats (males, 6 weeks old)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2094-7491" , "https://orcid.org/0000-0002-9848-0262" , "https://orcid.org/0000-0002-1190-4481" , "https://orcid.org/0000-0002-4419-210X" ;
        dc:date           "2017-09-25" ;
        dc:title          "SYNGO_CC_1355" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

