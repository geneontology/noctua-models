gomodel:SYNGO_1688  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 5E-G show that the NFL neuromuscular junction (NMJ) synapse are more polyinnervated at P11 compared to littermate controls, indicative of a delay in synapse elimination, which is part of normal NMJ maturation (see Fig2 for a time series of wt mice). The authors state that the NFL -/- mouse NMJ is 79% delayed in synapse elimination (p12913), although no time series is shown for this.. Experimental description: Figure legend:\"E: Significant delay in synapse elimination in NF-L -/- mice compared with littermate controls \"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0001-5259-4945" ;
        dc:date           "2018-05-30" ;
        dc:title          "SYNGO_BP_1688" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

