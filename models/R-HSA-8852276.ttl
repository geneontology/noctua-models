<http://model.geneontology.org/ev_w_id_REACTO_R-HSA-9908177_R-HSA-68819_R-HSA-8852354_component_BFO_0000051_REACTO_R-HSA-9908021_R-HSA-9908177_R-HSA-8852354_component_Reactome_R-HSA-9908177>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/ECO_0000313> ;
        <http://purl.org/dc/elements/1.1/contributor>
