gomodel:SYNGO_2145  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.2: \"Distribution and subcellular fractionation of GRIP1 and GRIP2 protein in brain\"\n- Literal: \"Treatment of synaptic plasma membrane fractions with various detergents to generate PSD fractions demonstrated that GRIP1 and GRIP2 were enriched in the PSD (Fig.2 e)\"\n\nNote: the localization of GRIP2 is not as well described as of GRIP1 in this paper.. Experimental description: \"To specifically examine the tissue distribution of GRIP1 and GRIP2, various rat tissues were analyzed by Western blot techniques using the GRIP1- and GRIP2-specific antibodies.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-6153-3586" , "https://orcid.org/0000-0002-2666-0758" ;
        dc:date           "2018-03-20" ;
        dc:title          "SYNGO_CC_2145" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

