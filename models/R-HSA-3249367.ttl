gomodel:ev_w_id_R-HSA-3249371_RO_0002234_R-HSA-3249369_R-HSA-3249371_Reactome_R-HSA-3249367
        a               owl:NamedIndividual , obo:ECO_0000313 ;
        dc:contributor  "GOC:reactome_curators" ;
