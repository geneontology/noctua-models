<http://model.geneontology.org/ev_w_id_R-HSA-9749583_RO_0002333_UniProt_Q9Y694-2_R-HSA-9749583_controller_Reactome_R-HSA-9749583>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/ECO_0000313> ;
