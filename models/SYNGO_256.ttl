gomodel:SYNGO_256  a      owl:Ontology ;
        rdfs:comment      "Automated change 2024-03-14: GO:0099055 replaced by GO:0045211" , "Rationale: EphB2 shows weak interaction with PSD fraction (Fig.2). EphB2 is predominantly present in the plasma membrane of dendritic spine shafts in hippocampus (Fig.4/5/6) and thalamus (Fig.7/8). The data point justifies term \"integral component of postsynaptic membrane (GO:0099055). Experimental description: The electron microscopic analysis was carried out on brain tissue from one EphA4 KO (EphA4-/-), one wild-type littermate (EphA4+/+) (Dottori et al. 1998) and 4 C57BL/6 adult male mice." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0912-1514" , "https://orcid.org/0000-0002-3670-7863" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_256" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

