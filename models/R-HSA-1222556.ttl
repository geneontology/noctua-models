gomodel:ev_w_id_REACTO_R-HSA-1222484_R-HSA-1222405_R-HSA-1222516_component_BFO_0000051_UniProtKB_P27449_R-HSA-1222484_R-HSA-1222516_component_Reactome_R-HSA-1222484
        a               owl:NamedIndividual , obo:ECO_0000313 ;
        dc:contributor  "GOC:reactome_curators" ;
