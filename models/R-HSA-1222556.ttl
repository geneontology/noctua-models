          <http://model.geneontology.org/ev_w_id_R-HSA-1222342_RO_0002233_R-ALL-1470070_phagocytic_vesicle_lumen_Reactome_R-HSA-1222556> , <http://model.geneontology.org/ev_w_id_R-HSA-1222342_RO_0002233_R-ALL-1470070_phagocytic_vesicle_lumen_Reactome_R-HSA-1222342> ;
