<http://model.geneontology.org/ev_w_id_R-HSA-9836435_RO_0002333_R-HSA-9836435_UniProt_P19525_Reactome_R-HSA-9833482>
        a       <http://purl.obolibrary.org/obo/ECO_0000313> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
