:R-HSA-9818027  a           owl:NamedIndividual , obo:GO_0008150 ;
        rdfs:comment        "Subpathway representing cytoprotective genes regulated by NFE2L2 (NRF2). NFE2L2 is well-studied for its role in oxidative stress where it gets activated by ROS and then induces a plethora of gene expression regulation the oxidative damage. It induces genes/enzymes that regulate the phase 2 detoxification system (eg. GSTs and Glutathione system), ROS scavenging (SODs,PRDX1 ) and cytoprotection (HO1) by regulating inflammation and tissue damage (Tonelli et al, 2018; Shaw et al, 2020)" ;
        rdfs:label          "NFE2L2 regulating anti-oxidant/detoxification enzymes" ;
        dc:contributor      "GOC:reactome_curators" , "Edited: Tiwari, Krishna, 2022-10-10" , "Authored: Tiwari, Krishna, 2022-10-10" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-9818027" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-9759194/R-HSA-9759194> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

