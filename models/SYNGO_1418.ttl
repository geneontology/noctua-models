gomodel:SYNGO_1418  a     owl:Ontology ;
        rdfs:comment      "Automated change 2024-03-14: GO:0099065 replaced by GO:0098897" , "Rationale: postsynaptic immuno gold labeling of nAChR alpha 7 in HC. Experimental description: Postembedding immunogold labeling for electron microscopy. Freeze- substituted tissue was used to preserve greater immunoreactivity of the tissue and achieve maximum staining intensity. Three adult (all 22 months old) CFHB male rats were anesthetized with Sagatal and per- fused through the heart with 50 ml of 0.9% saline followed by 250 ml 0.1 M phosphate buffer, pH 7.4, containing 4% paraformaldehyde, 0.05% glutaraldehyde, and 0.2% picric acid (Somogyi and Takagi, 1982). Hip- pocampus was dissected immediately, and" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0001-9425-2935" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_1418" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

