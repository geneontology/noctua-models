gomodel:SYNGO_1584  a     owl:Ontology ;
        rdfs:comment      "Rationale: Knockout mice for the alpha1D gene were created. The loss of this calcium channel gene resulted in deafness in the mice. Recordings of Ca currents from inner hair cells shows they have lost almost all voltage-dependent Ca currents. Measurements of auditory brain stem responses show profound deficits in auditory-evoked responses in the knockout mice. Experimental description: Experimental Procedures" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-2533-9548" , "https://orcid.org/0000-0003-4022-8707" , "https://orcid.org/0000-0001-7480-0826" , "https://orcid.org/0000-0002-5648-066X" , "https://orcid.org/0000-0002-1212-5623" ;
        dc:date           "2018-08-17" ;
        dc:title          "SYNGO_MF_1584" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

