        <http://purl.obolibrary.org/obo/BFO_0000066>
                <http://model.geneontology.org/reaction_R-HSA-9839751_location_lociGO_0005743> ;
        <http://purl.obolibrary.org/obo/RO_0002233>
                <http://model.geneontology.org/R-ALL-5696069_mitochondrial_intermembrane_space> , <http://model.geneontology.org/R-HSA-9839792_R-HSA-9839751> , <http://model.geneontology.org/R-ALL-189422_R-HSA-9839751> ;
        <http://purl.obolibrary.org/obo/RO_0002234>
                <http://model.geneontology.org/R-ALL-9839058_mitochondrial_intermembrane_space> , <http://model.geneontology.org/R-ALL-5696026_mitochondrial_intermembrane_space> , <http://model.geneontology.org/R-HSA-9839129_R-HSA-9839751> ;
        <http://purl.obolibrary.org/obo/RO_0002333>
