<http://identifiers.org/uniprot/Q15738>
        a       owl:Class .

:R-HSA-6807062  a           owl:NamedIndividual , obo:GO_0006695 ;
        rdfs:comment        "The transformation of zymosterol into cholesterol can follow either of routes, one in which reduction of the double bond in the isooctyl side chain is the final step (cholesterol synthesis via desmosterol, also known as the Bloch pathway) and one in which this reduction is the first step (cholesterol biosynthesis via lathosterol, also known as the Kandutsch-Russell pathway). The former pathway is prominent in the liver and many other tissues while the latter is prominent in skin, where it may serve as the source of the 7-dehydrocholesterol that is the starting point for the synthesis of D vitamins (Kandutsch & Russell 1960; Mitsche et al. 2015)." ;
        rdfs:label          "Zymostenol biosynthesis via lathosterol (Kandutsch-Russell pathway)" ;
        dc:contributor      "Authored: D'Eustachio, Peter, 2015-11-02" , "Reviewed: Hill, David P, 2025-10-24" , "Edited: D'Eustachio, Peter, 2015-11-02" , "Reviewed: Hill, David P, 2025-05-30" , "GOC:reactome_curators" , "Reviewed: Jassal, Bijay, 2015-11-02" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-6807062" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-191273/R-HSA-191273> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

