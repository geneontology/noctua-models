obo:GO_0003674  a  owl:Class .

gomodel:SYNGO_5163  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 6, 7, 8: immunogold-EM of the hippocampus showed MGL (monoacylglycerol lipase, gene MGLL) was exclusively localized to symmetric and asymmetric presynaptic terminals (i.e. not postsynaptic).\n\nFigure 10: in the amygdala, MGL immunostaining was present presynaptically in subsets of axon terminals.\n\nThe ultrastructural distribution of MGL and FAAH in the amygdala, similar to the hippocampus, is complementary: i.e. FAAH is located postsynaptically, MGL presynaptically.. Experimental description: Both mice and rats were used. Assume rat was used in the EM localizations, as the title of the paper states: \"Segregation of two endocannabinoid-hydrolyzing enzymes into pre- and postsynaptic compartments in the rat hippocampus, cerebellum and amygdala\"\n\nantibody:\nrabbit anti-MGL serum (Dinh et al., 2002) PMID:12136125\n\ncontrols:\n\"In case of MGL the antibody was preabsorbed with the immunizing peptide (SSPRRTPQNVPYQDL).\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2023-02-25" ;
        dc:title          "SYNGO_CC_5163" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

