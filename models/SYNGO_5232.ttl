gomodel:SYNGO_5232  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 2, 7: A large portion of Tmub1/HOPS colocalizes with GluR2 at recycling endosomes.\n\nFigure 5: Recycling of internalized GluR2 to cell surface is delayed in Tmub1/HOPS-RNAi neurons.\n\nFigure 6: Recycling of internalized GluR2 to cell surface is enhanced in neurons overexpressing Tmub1/HOPS.. Experimental description: Results, Figure 2 legend: \"(A) Double immunostaining of Tmub1/HOPS along with the dendritic marker MAP2 using cultured rat hippocampal neurons.\"\n\nantibody:\n\"For the production of the rabbit polyclonal antibody for Tmub1/HOPS, a fusion protein containing 29-191 aa of Tmub1/HOPS attached to a GST tag at the N terminus was purified on a GST column and used as an antigen. The antibody was purified by affinity chromatography using a HiTrap NHS-activated column (GE Healthcare, Uppsala, Sweden) coupled with maltose-binding protein-Tmub1/HOPS fusion proteins. \"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-4973-5732" ;
        dc:date           "2023-03-04" ;
        dc:title          "SYNGO_BP_5232" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

obo:BFO_0000050  a  owl:ObjectProperty .
