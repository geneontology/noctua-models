gomodel:SYNGO_2361  a     owl:Ontology ;
        rdfs:comment      "Rationale: The taurine transporter transports taurine into neurons.\n\nTaurine transporter (TAUT) KO mice exhibit a strong reduction in the taurine concentration in different brain regions (Table 2). Taurine levels were determined from microdissected, homogenized tissue samples using an amino acid analyser.\n\n25/01/2018 Pim\n- Taurine is a modulator of LTP (Fig.1+2). KO of the taurine transporter strengthens this effect.. Experimental description: Genotyped 6- to 11-week-old TAUT KO (n= 11) and wild-type (WT, n= 10) mice..." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-0755-5899" , "https://orcid.org/0000-0001-7351-8706" , "https://orcid.org/0000-0003-0938-8534" , "https://orcid.org/0000-0003-3185-5709" ;
        dc:date           "2018-01-25" ;
        dc:title          "SYNGO_BP_2361" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

