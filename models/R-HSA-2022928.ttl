gomodel:ev_w_id_R-HSA-2076611_RO_0002233_R-ALL-741440_Golgi_lumen_Reactome_R-HSA-2022928_R-HSA-2076611_enabled_by_UniProt_Q96QI5_R-HSA-2076611_controller
