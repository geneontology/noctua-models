        pav:providedBy  "https://reactome.org" .

:R-HSA-2022928  a           obo:GO_0015012 , owl:NamedIndividual ;
        rdfs:comment        "Heparan sulfate (HS) and heparin (sometimes collectively called HS-GAG) chains consist of the variably sulfated repeating disaccharide units heparan (Ido-GlcNAc) or heparosan (GlcA-GlcNAc). Heparin is exclusively made in mast cells whereas HS is made by virtually every type of cell in the body. As the chain length increases, the polysaccharides can undergo modifications such as epimerisation of glucuronic acid to iduronic acid and deacetylation and sulfation of GlcNAc to form sulfated glucosamine (Stringer & Gallagher 1997, Sasisekharan & Venkataraman 2000)." ;
        rdfs:label          "HS-GAG biosynthesis" ;
        dc:contributor      "Reviewed: Hill, David P, 2025-06-02" , "Reviewed: D'Eustachio, P, 2012-03-28" , "Authored: Jassal, B, 2011-12-01" , "Edited: Jassal, B, 2011-12-01" , "Reviewed: Matthews, Lisa, 2025-05-30" , "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-2022928" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-1638091/R-HSA-1638091> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

