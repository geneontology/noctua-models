gomodel:SYNGO_5468  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 1c: NESH (ABI3) was detected in synaptosomal fractions prepared from rat hippocampal lysate.\n\nFigure 1d: \"Cellular localization of NESH was examined in primary cultured hippocampal neuron at 19 DIV. Mature hippocampal neurons were double-stained with antibodies against NESH, SPIN90 or PSD95 and with Alexa Fluor 594-conjugated phalloidin.\". Experimental description: M&M: \"For primary neuronal cultures, hippocampal neurons were dissected from E18-E19 Sprague-Dawley rat embryos,\"\n\nantibody: \"To generate anti-NESH antibody, a cDNA corresponding to the C-terminal region of NESH (amino acids 204-367) was amplified by PCR and subcloned into pGEX4T-1 vector for GST fusion protein expression.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2023-03-19" ;
        dc:title          "SYNGO_CC_5468" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

