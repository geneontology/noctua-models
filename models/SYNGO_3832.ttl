gomodel:SYNGO_3832  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.3: \"Parkin immunoreactivity in neurons\"\n- \"Parkin immunoreactivity was also detected in dendrites (arrows in B) and nerve terminals (arrowhead in B) at the level a symmetric synapse on the upper part of the nerve terminal. Within these cellular compartments, Parkin immunoreactivity was also associated with synaptic vesicles (arrow in B), where the staining appeared weaker, however. Furthermore, not all nerve terminals were Parkin immunopositive.\"\n- \"In Parkin-immunostained terminals, labeling was present in the pre- and post-synaptic elements of the synapse (Fig. 3B). Yet, staining intensity was lower in pre-synaptic elements than in post-synaptic elements.\". Experimental description: - \"Parkin in the rat brain\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2018-06-29" ;
        dc:title          "SYNGO_CC_3832" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

