obo:GO_0098978  a  owl:Class .

gomodel:SYNGO_532  a      owl:Ontology ;
        rdfs:comment      "Rationale: Fig. 2b Shank1 is present in PSD fractions\nLiteral\n\"By immunoblotting, the Shank1-specific 1356 antibody confirmed the absence of Shank1 protein in the PSD fraction of Shank1 knock-out brains.\"\nFig-3b Shank1 colocalized with PSD-95. Experimental description: Experiment of biochemistry are made in mouse\nLiteral from M&M\n\"The Triton-extracted PSD fraction (PSDI) was purified from the forebrains of individual 2- to 3-month-old mice, as described previously .\"\nExperiment of immunohistochemistry are made in mouse.\nLiteral from M&M\n\"Primary hippocampal cultures were prepared from the brains of individual mouse embryos at embryonic day 18 (E18) to E19 as described previously.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-2949-9725" , "https://orcid.org/0000-0003-0662-9523" ;
        dc:date           "2017-11-08" ;
        dc:title          "SYNGO_CC_532" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

