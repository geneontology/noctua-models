obo:ECO_0005589  a  owl:Class .

gomodel:SYNGO_5554  a     owl:Ontology ;
        rdfs:comment      "Rationale: Cultured hippocampal neurons were immunostained for endogenous synaptophysin (SYP), PSD95 (DLG4) and Lingo1. The latter partially co-localized with both pre- and post-synaptic marker proteins SYP and DLG4 in confocal microscopy. STED super-resolution microscopy showed Lingo1 localization at the presynapse.\n\n---\n\nThe experimental data annotated here will be included in an upcoming manuscript (by the SynGO consortium) that describes the SynGO 1.2 update, when a PMID is available this annotation will be updated with the respective reference.. Experimental description: Microscopy experiments were performed in cultured hippocampal mouse neurons.\n\nantibody: Alomone, APR-081, Rabbit, poly" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2023-11-28" ;
        dc:title          "SYNGO_CC_5554" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

