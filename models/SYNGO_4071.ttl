gomodel:SYNGO_4071  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 4: Immunohistochemistry shows that CRLR colocalises with presynaptic markers VGlut1 and synaptophysin indicating that it is located in the presynapse.\n\nFigure 6: Immunoelectron microscopy localises CRLR to dense-core vesicles in the presynapse.\n\nThe authors comment that the CRLR antibody was raised against the C-terminal 18 residues of rat CRLR and was derived from Cottrell et al. (2005).. Experimental description: Adult male Sprague-Dawley rats were used for the immunohistochemical and immunoelectron experiments." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-2916-7616" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2023-01-28" ;
        dc:title          "SYNGO_CC_4071" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

