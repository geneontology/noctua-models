gomodel:SYNGO_3709  a     owl:Ontology ;
        rdfs:comment      "Rationale: This paper describes that \"exogenous FILIP localised to dendritic spines and dendrites of primary cultured hippocampal neurons.\". Experimental description: Localization is based on overexpression of Flag-tagged FILIP. In the M&M the following is described: \"The full-length rat l-FILIP cDNA was amplified using PCR and inserted into the pCAGGS vector\". But note that the construct is expressed mouse hippocampal neurons." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-6153-3586" , "https://orcid.org/0000-0002-2666-0758" ;
        dc:date           "2018-05-31" ;
        dc:title          "SYNGO_CC_3709" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

