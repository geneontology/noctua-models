obo:ECO_0007719  a  owl:Class .

gomodel:SYNGO_1315  a     owl:Ontology ;
        rdfs:comment      "Rationale: Authors perform immunocytochemistry in primary hippocampal cultures and observed JAK immunoreactivity using confocal microscopy. This was found forming clusters decorating dendrites and in colocalization with dendritic spine protrusions labeled with an anti-MAP2 antibody and a subpopulation of clusters labeled with PSD-95.\nBiochemical subcellular fractionation revealed enrichment of JAK2 in the synaptosomal fraction.. Experimental description: Experiments have been done using rats: rat embryos were used for primary hippocampal cultures (Sprague-Dawley) and juvenile Wistar rats for preparation of\nhippocampal slices." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0575-6950" , "https://orcid.org/0000-0002-1585-539X" ;
        dc:date           "2017-11-15" ;
        dc:title          "SYNGO_CC_1315" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

