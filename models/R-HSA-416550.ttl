:R-HSA-416550  a            obo:GO_0008150 , owl:NamedIndividual ;
        rdfs:comment        "Repulsive Sema4D-Plexin-B1 signaling involves four GTPases, Rnd1, R-Ras, Rho and Rac1. Sema4D-Plexin-B1 binding promotes Rnd1-dependent activation of the plexin-B1 GAP domain and transient suppression of R-Ras activity. R-Ras inactivation promotes PI3K and Akt inactivation followed by GSK-3beta activation and CRMP2 inactivation. Plexin-B1 also transiently associates with and activates p190Rho-GAP, triggering a transient decrease in activated Rho." ;
        rdfs:label          "Sema4D mediated inhibition of cell attachment and migration" ;
        dc:contributor      "GOC:reactome_curators" , "Reviewed: Kumanogoh, A, Kikutani, H, 2009-09-01" , "Authored: Garapati, P V, 2009-03-23 09:59:28" , "Edited: Garapati, P V, 2009-03-23 10:00:38" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-416550" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-400685/R-HSA-400685> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

