:R-HSA-8874081  a           owl:NamedIndividual , obo:GO_0008150 ;
        rdfs:comment        "MET receptor activates the focal adhesion kinase PTK2 (FAK1) in a process that depends on the simultaneous interaction of PTK2 with integrins and with MET. SRC is needed for PTK2 to become fully active. Activation of PTK2 is needed for HGF-induced cell motility (Beviglia et al. 1999, Parr et al. 2001, Chen and Chen 2006, Lietha et al. 2007, Chen et al. 2011, Brami-Cherrier et al. 2014)." ;
        rdfs:label          "MET activates PTK2 signaling" ;
        dc:contributor      "Authored: Orlic-Milacic, Marija, 2016-06-14" , "Edited: Orlic-Milacic, Marija, 2016-06-14" , "Reviewed: Heynen, Guustaaf, 2016-07-11" , "Reviewed: Birchmeier, Walter, 2016-07-11" , "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-8874081" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-8875878/R-HSA-8875878> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

