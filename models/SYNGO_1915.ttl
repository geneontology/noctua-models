obo:BFO_0000066  a  owl:ObjectProperty .

gomodel:SYNGO_1915  a     owl:Ontology ;
        rdfs:comment      "Rationale: BCAN controls AMPARs and Kv channels. Using immunoprecipitation assays and high-resolution microscopy on primary culture parvalbumin (PV)-positive neurons, it is shown that the synaptic localization of GluA1-containing AMPA receptors as well as of Kv1.3 and Kv1.1 potassium channels is downregulated in the absence of Brevican.\nFig. 3 and Fig. S3 imply that BCAN is necessary for the maturation.. Experimental description: \"Hippocampi from E18 mouse embryos (both sexes) were dissected...\", Supplemental e5" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-0269-0311" , "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-9681-3318" , "https://orcid.org/0000-0002-9880-1214" ;
        dc:date           "2017-11-24" ;
        dc:title          "SYNGO_BP_1915" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

