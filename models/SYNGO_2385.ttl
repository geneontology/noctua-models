gomodel:SYNGO_2385  a     owl:Ontology ;
        rdfs:comment      "Rationale: GRIN2D is a well known component of NMDARs. Via PPDA sensitivity NR2D-containing NMDARs are shown to act as extrasynaptic spillover receptors, that move into the PSD upon induction of LTP.\n\n- PPDA is proposed as a specific inhibitor of NR2D-containing NMDARs. Experimental description: \"Transverse hippocampal slices (350 μm) were prepared from the brains of male Wistar rats ...\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0003-0593-3443" ;
        dc:date           "2018-01-30" ;
        dc:title          "SYNGO_MF_2385" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

