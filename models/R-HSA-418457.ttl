<http://model.geneontology.org/reaction_R-HSA-418456_enabled_by_UniProt_Q01064_R-HSA-418456_controller_location_lociGO_0005829>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/GO_0005829> ;
