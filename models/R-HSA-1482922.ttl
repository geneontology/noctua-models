:R-HSA-1482922  a           owl:NamedIndividual , obo:GO_0036149 ;
        rdfs:comment        "In the acyl chain remodelling pathway (Lands cycle), phosphatidylinositol (PI) is hydrolyzed by phospholipases and subsequently reacylated by acyltransferases. These cycles modify the fatty acid composition of glycerophospholipids to generate diverse molecules asymmetrically distributed in the cell membrane (Ghomashchi et al. 2010, Singer et al. 2002, Gijon et al. 2008, Lee et al. 2008)." ;
        rdfs:label          "Acyl chain remodelling of PI" ;
        dc:contributor      "Edited: Williams, MG, 2011-08-12" , "GOC:reactome_curators" , "Authored: Williams, MG, 2011-09-14" , "Reviewed: Wakelam, Michael, 2012-05-14" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-1482922" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-1483206/R-HSA-1483206> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

