obo:BFO_0000066  a  owl:ObjectProperty .

gomodel:SYNGO_3996  a     owl:Ontology ;
        rdfs:comment      "Rationale: Hippocampal neurons of ROCK1 heterozygous mice showed reduced spine density (also reduced excitatory synapses) without significant changes in spine or PSD morphology. The mutant neurons also show reduction in mEPSC frequencies and depressed input/output curves. Impairments in spatial learning and memory and in fear conditioning paradigms were also observed.. Experimental description: Materials and Methods \"The Rock1?/- and Rock2?/- mice were gifted from Dr. Robert W. Caldwell of Augusta University\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-5615-1014" ;
        dc:date           "2020-07-24" ;
        dc:title          "SYNGO_BP_3996" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

