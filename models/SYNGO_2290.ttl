gomodel:SYNGO_2290  a     owl:Ontology ;
        rdfs:comment      "Rationale: This paper uses measurements of synaptic Ca2+ (Figure 3F) and release probability (4C) in wild-type and calretinin knock out mice. This shows elevated synaptic Ca2+ and increased transmitter release consistent with its role as an endogenous fixed buffer.\n\n24/01/2018 Pim\n- A kinetic model is fitted that postulates Calretinin as a fast calcium buffer. The model is validated in Calretinin KO mice. Calretinin has 6 Ca2+-binding domains (EF hands).. Experimental description: Materials and Methods: Patch-clamp recordings were performed at 20°C-22°C on acute slices prepared from 21- to 27-day-old C57BL/6 or CR-/- mice..........................." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0938-8534" , "https://orcid.org/0000-0001-7351-8706" , "https://orcid.org/0000-0002-0755-5899" , "https://orcid.org/0000-0003-3185-5709" ;
        dc:date           "2018-01-24" ;
        dc:title          "SYNGO_MF_2290" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

