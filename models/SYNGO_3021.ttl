gomodel:SYNGO_3021  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.2: \"Postembedding immunogold labeling for the proteins studied here\"\n- \"Gold particles coding for seven different proteins contributing to the biochemically defined NMDA receptor complex accumulated mainly over the PSD (Fig. 2).\"\n\nFig.3: \"Graph shows \"lateral\" position of gold particles\"\n- \"Results of this procedure are given in Table3. These data reveal a laminar organization of proteins within the PSD; some (PSD-95 and NR2) lay close to the plasma membrane, others (CRIPT, GKAP, Shank, and DLC) lay markedly farther away\". Experimental description: - \"Material from seven male Sprague Dawley rats (Charles River, Wilmington, MA; 220-400 gm)...\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2018-03-27" ;
        dc:title          "SYNGO_CC_3021" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

