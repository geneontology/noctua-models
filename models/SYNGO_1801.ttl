gomodel:SYNGO_1801  a     owl:Ontology ;
        rdfs:comment      "Rationale: This paper describes experiments on GRIP1/2 double-knockout neurons demonstrating that GRIP1 is required for activity-induced recycling of AMPARs (but not endocytosis or steady-state AMAPR surface levels), and that GRIP1 is associated with endosomes, as well as proteins of the exocyst complex targeting AMPAR-containing endosomes to the membrane. Together, these studies indicate that GRIP1 and 2 are required for AMPAR transport from endosomes to the postsynaptic membrane. Experimental description: from the main text: \"neuronal cultures were prepared from GRIP1 conditional (flox/flox) and GRIP2 conventional (-/-) KO mice.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-6153-3586" , "https://orcid.org/0000-0002-2666-0758" ;
        dc:date           "2018-06-07" ;
        dc:title          "SYNGO_BP_1801" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

