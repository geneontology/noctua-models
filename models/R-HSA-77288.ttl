obo:CHEBI_57945  a  owl:Class .

:R-HSA-77288  a             obo:GO_0006635 , owl:NamedIndividual ;
        rdfs:comment        "The complete beta-oxidation spiral produces and consumes intermediates with a trans configuration. Mitochondrial beta-oxidation of unsaturated fatty acids leads to intermediates not compatible with the four enzymatic steps responsible for the beta-oxidation of saturated fatty acids. Unsaturated fatty acids that have bonds in the cis configuration require three separate enzymatic steps to prepare these molecules for the beta-oxidation pathway. The further processing of these intermediates requires additional enzymes, depending on the position of the double bonds in the original fatty acids. Described here is the beta-oxidation of linoleoyl-CoA." ;
        rdfs:label          "mitochondrial fatty acid beta-oxidation of unsaturated fatty acids" ;
        dc:contributor      "Edited: Gillespie, ME, 0000-00-00 00:00:00" , "GOC:reactome_curators" , "Authored: Gillespie, ME, 2003-10-25 00:00:00" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-77288" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-77289/R-HSA-77289> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

