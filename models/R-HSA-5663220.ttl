[ a       <http://www.w3.org/2002/07/owl#Axiom> ;
  <http://www.w3.org/2000/01/rdf-schema#comment>
          "Imported from Reactome: https://reactome.org/content/detail/R-HSA-5663220" ;
  <http://geneontology.org/lego/evidence>
          <http://model.geneontology.org/ev_w_id_R-HSA-5665809_RO_0002234_R-HSA-5665949_R-HSA-5665809_Reactome_R-HSA-5665809> , <http://model.geneontology.org/ev_w_id_R-HSA-5665809_RO_0002234_R-HSA-5665949_R-HSA-5665809_Reactome_R-HSA-5663220> ;
