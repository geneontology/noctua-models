gomodel:SYNGO_1325  a     owl:Ontology ;
        rdfs:comment      "Rationale: Functional characterisation in HEK cells of overexpressed GABAAR alpha 1 and 3 subunints.\n\nrule: NAS_MFCC-BP\nrationale:\nProtein has ligand-gated ion channel receptor activity and is localized in the presynaptic membrane (shown with high-resolution technique). The inference to term ligand-gated ion channel activity involved in regulation of presynaptic membrane potential (GO:0099507) is trivial and non-controversial.\nPinf_CC:\n[P20236] SyNGO ID 1252 (PMID:12732237, EM). Experimental description: Heterologous expression of recombinant GABAA receptors. Rat" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0001-9425-2935" ;
        dc:date           "2018-06-29" ;
        dc:title          "SYNGO_MF_1325" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

