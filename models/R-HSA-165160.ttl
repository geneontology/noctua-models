obo:GO_0005829  a  owl:Class .

:R-HSA-165160  a            obo:GO_0008150 , owl:NamedIndividual ;
        rdfs:comment        "AKT (PKB) is recruited to the plasma membrane by binding phosphatidylinositol (3,4,5)-trisphosphate (PIP3). AKT is then activated by phosphorylation. Activated AKT in turn phosphorylates Phosphodiesterase 3B (PDE3B) which hydrolyzes 3',5'-cyclic AMP (cAMP) (reviewed in Manning and Toker 2017)." ;
        rdfs:label          "PDE3B signalling" ;
        dc:contributor      "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-165160" ;
