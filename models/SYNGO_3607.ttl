obo:ECO_0000303  a  owl:Class .

gomodel:SYNGO_3607  a     owl:Ontology ;
        rdfs:comment      "Rationale: 14/5/2018 Pim\nrule: NAS_CPLX_2\nrationale: Polyribosomes are present in dendritic spines (PMID:12165474, electron microscopy). The ribosome is the central holoenzyme in the process of \"translation (GO:0006412)\". RL23A is a generally accepted constituent of the ribosome that together with other ribosomal subunits contributes to the intrinsic activity of the ribosomal complex.. No functions of RL23A are known independent from the ribosomal complex. Inference to term \"translation (GO:0006412)\" occurs_in \"postsynapse (GO:0098794:)\" is trivial.\nC_ref CC: PMID:12165474 (dendritic spine head)\nP_inf CC: SynGO ID #3157\nP_inf CC additional:\n- Bayes et al.(2012), PMID:23071613, TableS1, prep:psd\n- Distler et al.(2014), PMID:25211037, Table S1, prep:synapse\nComplex membership: RL23A protein is a fixed member of the 60S ribosomal subunit complex.\n- Shown in crystal structure (PMID:28138070, see Fig.1, name: ul23)\n- GO annotations to \"structural constituent of ribosome (GO:0003735)\" (ISO and IEA). Experimental description: \"In-depth protein profiling of the postsynaptic density from mouse hippocampus using data-independent acquisition proteomics.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9880-1214" , "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-9681-3318" , "https://orcid.org/0000-0002-0269-0311" ;
        dc:date           "2018-05-23" ;
        dc:title          "SYNGO_BP_3607" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

