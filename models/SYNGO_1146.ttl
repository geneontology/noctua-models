gomodel:SYNGO_1146  a     owl:Ontology ;
        rdfs:comment      "Rationale: Immunolabelling of Adenosine A2B Receptors (A2BR) in purified synaptosomes shows co-localization of A2BR with the glutamatergic synaptic vesicle marker vGlut1.\n\nIn the study a commercial antibody was used (no KO control).. Experimental description: Male C57/BL6 mice (10-12 weeks old) were obtained from Charles River (Barcelona, Spain) and A2BR-KO mice (Belikoff et al., 2011) were kindly donated" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-3185-5709" , "https://orcid.org/0000-0001-7351-8706" , "https://orcid.org/0000-0003-0938-8534" , "https://orcid.org/0000-0002-0755-5899" ;
        dc:date           "2017-08-17" ;
        dc:title          "SYNGO_CC_1146" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

