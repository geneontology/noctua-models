<http://model.geneontology.org/ev_w_id_R-HSA-198599_RO_0002234_R-ALL-29370_cytosol_Reactome_R-HSA-198599>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/ECO_0000313> ;
        <http://purl.org/dc/elements/1.1/contributor>
                "GOC:reactome_curators" ;
        <http://purl.org/dc/elements/1.1/date>
                "2026-02-02" ;
        <http://purl.org/dc/elements/1.1/source>
                "Reactome:R-HSA-198599" ;
        <http://purl.org/pav/providedBy>
