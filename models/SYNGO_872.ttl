dc:date  a      owl:AnnotationProperty .

gomodel:SYNGO_872  a      owl:Ontology ;
        rdfs:comment      "Rationale: Mint1 regulates inhibitory transmission and Fig. 7 shows that Mint1 KO mice exhibit paired-pulse depression of IPSCs. This supports an impairment in the regulation of GABA release and release probability.\n\nSingle KO of Mint1 does not impair excitatory transmission as shown in Fig. 5 but the additionally referenced annotation demonstrates that Mint1 acts redundantly with Mint2 to control presynaptic release at excitatory synapses.. Experimental description: Mint1 KO mice were studied." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0912-1514" , "https://orcid.org/0000-0002-3670-7863" ;
        dc:date           "2018-03-19" ;
        dc:title          "SYNGO_BP_872" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

