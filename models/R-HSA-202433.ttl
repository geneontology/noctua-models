<http://model.geneontology.org/ev_w_id_R-HSA-202216_RO_0002234_R-HSA-202162_R-HSA-202216_Reactome_R-HSA-202433>
        a       <http://purl.obolibrary.org/obo/ECO_0000313> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
