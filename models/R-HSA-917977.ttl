:R-HSA-917977  a            obo:GO_0033572 , owl:NamedIndividual ;
        rdfs:comment        "Endocytosis of iron loaded transferrin/receptor complex leads, after acidification of the endosome, to the separation of iron and its diffusion out of the vesicle. The endosome is not fused with a lysosome but recycles its content back to the cell surface where soon transferrin dissociates from its receptor (Dautry-Varsat, 1986)." ;
        rdfs:label          "Transferrin endocytosis and recycling" ;
        dc:contributor      "Authored: Stephan, R, 2010-07-11" , "GOC:reactome_curators" , "Edited: Jassal, Bijay, 2010-07-30" , "Reviewed: D'Eustachio, P, 2010-11-05" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-917977" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-917937/R-HSA-917937> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

