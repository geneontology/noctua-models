gomodel:SYNGO_5384  a     owl:Ontology ;
        rdfs:comment      "Automated change 2024-03-14: GO:0030285 replaced by GO:0030672" , "Rationale: Figure 2k: immunogold EM of mouse DRG neurons showed VGLUT3 localized at the membranes of synaptic vesicles.\n\nBased on the known transmembrane topology of this protein, \"integral component of ... membrane\" term was selected.. Experimental description: mice were used for all experiments. \"Sixteen TAFA4Venus heterozygous (±) knock in mice\", \"Twelve 3-week-old GINIP mice\", Six CD1 mice (n = 3 for LM; n = 3 for EM), as control animals to verify peptidergic and non-peptidergic marker expression in genetically unmodified animals." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-4973-5732" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_5384" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .
