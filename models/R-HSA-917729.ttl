[ a       <http://www.w3.org/2002/07/owl#Axiom> ;
  <http://www.w3.org/2000/01/rdf-schema#comment>
          "Imported from Reactome: https://reactome.org/content/detail/R-HSA-917729" ;
  <http://geneontology.org/lego/evidence>
