dc:source  a    owl:AnnotationProperty .

gomodel:SYNGO_84  a       owl:Ontology ;
        rdfs:comment      "Rationale: Using GFP knock-in mice, the authors show that munc18-1 accumulates in boutons/nerve terminals and collocalizes with the vesicle cluster. In FRAP experiments, a significant fraction of the protein was found to be in the immobile fraction (40%), probably via binding to syntaxin (half of the immobile fraction). Experimental description: Cells: \"Generation of Munc18-1-Venus knockin mice\"\nKnockin: \" a genomic sequence 5' of, and including, exon 20 of the munc18-1 gene from 129/Sv embryonic stem (ES) cell DNA, was subcloned using PCR into pGEM-T Easy (Promega),\"\n\nAnnotation against mouse is correct!" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2020-06-10" ;
        dc:title          "SYNGO_CC_84" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

