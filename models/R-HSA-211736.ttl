obo:BFO_0000066  a  owl:ObjectProperty .

skos:exactMatch  a  owl:AnnotationProperty .

:R-HSA-211736  a            owl:NamedIndividual , obo:GO_0008150 ;
        rdfs:comment        "In response to stress signals, the p21-activated protein kinase PAK-2 stimulates a cell death response characterized by increased cell rounding and apoptotic chromatin condensation (see Jakobi et al., 2003). PAK-2 is proteolytically cleaved by caspase-3 producing a constitutively active fragment, PAK-2p34. Following cleavage, PAK-2p34 is autophosphorylated at Thr 402 and transported to the nucleus where it accumulates due to the loss of its nuclear export signal motif (Jakobi et al., 2003). The activity of PAK-2p34 appears to be regulated both by proteosomal degradation (Jakobi et al., 2003) and by association with the GTPase-activating protein PS-GAP/ RHG-10. This interaction inhibits the kinase activity of PAK-2p34 and changes the localization of PAK-2p34 from the nucleus to the perinuclear region (Koeppel et al., 2004). PAK-2p34 may function in the down-regulation of translation initiation in apoptosis through phosphorylation of Mnk1 (Orton et al.,2004)." ;
        rdfs:label          "Stimulation of the cell death response by PAK-2p34" ;
        dc:contributor      "GOC:reactome_curators" , "Reviewed: Chang, E, 2008-05-21 00:05:41" , "Edited: Matthews, L, 2008-06-12 00:23:53" , "Authored: Jakobi, R, 2008-02-05 11:04:14" , "Edited: Matthews, L, 2008-02-03 20:50:13" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-211736" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-75153/R-HSA-75153> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

