	<http://purl.org/pav/providedBy> "https://reactome.org" ;
	<http://purl.obolibrary.org/obo/RO_0002233> <http://model.geneontology.org/CHEBI_37565_R-HSA-8941613> , <http://model.geneontology.org/R-HSA-109796_R-HSA-8941613> ;
	<http://purl.obolibrary.org/obo/RO_0002234> <http://model.geneontology.org/CHEBI_58189_R-HSA-8941613> , <http://model.geneontology.org/R-HSA-109783_R-HSA-8941613> ;
