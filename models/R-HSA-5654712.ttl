<http://model.geneontology.org/R-HSA-5654712> <http://geneontology.org/lego/modelstate> "development" ;
	<http://purl.org/pav/providedBy> "https://reactome.org" ;
	<https://w3id.org/biolink/vocab/in_taxon> <http://purl.obolibrary.org/obo/NCBITaxon_9606> ;
	a <http://www.w3.org/2002/07/owl#Ontology> ;
	<http://www.w3.org/2000/01/rdf-schema#comment> "For logical inference, import the integrated tbox ontology http://purl.obolibrary.org/obo/go/extensions/go-lego-reacto.owl" , "http://www.reactome.org" , "Imported from Reactome: https://reactome.org/content/detail/R-HSA-5654712" ;
	<http://purl.org/dc/elements/1.1/title> "FRS-mediated FGFR4 signaling - imported from: Reactome" ;
	<http://purl.org/dc/elements/1.1/contributor> "GOC:reactome_curators" ;
	<http://purl.org/dc/elements/1.1/date> "2023-06-21" .

<http://model.geneontology.org/R-HSA-5654712/R-HSA-5654712> <http://purl.org/pav/providedBy> "https://reactome.org" ;
	<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "R-HSA-5654712" ;
	<http://www.w3.org/2004/02/skos/core#narrower> <http://model.geneontology.org/R-HSA-5654716/R-HSA-5654716> ;
	a <http://purl.obolibrary.org/obo/GO_0008150> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
	<http://www.w3.org/2000/01/rdf-schema#comment> "The FRS family of scaffolding adaptor proteins has two members, FRS2 (also known as FRS2 alpha) and FRS3 (also known as FRS2beta or SNT-2). Activation of FGFR tyrosine kinase allows FRS proteins to become phosphorylated on tyrosine residues and then bind to the adaptor GRB2 and the tyrosine phosphatase PPTN11/SHP2. Subsequently, PPTN11 activates the RAS-MAP kinase pathway and GRB2 activates the RAS-MAP kinase , PI-3-kinase and ubiquitinations/degradation pathways by binding to SOS, GAB1 and CBL, respectively, via the SH3 domains of GRB2. FRS2 acts as a central mediator in FGF signaling mainly because it induces sustained levels of activation of ERK with ubiquitous expression.<br><br><br>" ;
	<http://www.w3.org/2000/01/rdf-schema#label> "FRS-mediated FGFR4 signaling" ;
	<http://www.w3.org/2004/02/skos/core#note> "org.biopax.paxtools.model.level3.Pathway" ;
	<http://purl.org/dc/elements/1.1/contributor> "GOC:reactome_curators" , "Authored: de Bono, B, 2007-01-10 10:27:18" , "Reviewed: Gotoh, N, 2011-08-26" , "Reviewed: Mohammadi, M, 2007-02-06 21:44:35" , "Edited: Jupe, S, 2010-02-03" ;
	<http://purl.org/dc/elements/1.1/date> "2023-06-21" .

