obo:GO_0099577  a  owl:Class .

gomodel:SYNGO_199  a      owl:Ontology ;
        rdfs:comment      "Rationale: FMRP knockdown enhances synaptic vesicle exocytosis in presynaptic terminals of DRG neurons via regulating the translation and the surface expression of CaV2.2 channels.\n\n20/2/2017 Pim:\n-Fig.4: FRMP promotes proteasomal degradation of CaV2.2 channels\n-Fig.8: FMRP knockdown enhances synaptic vesicle exocytosis in presynaptic terminals of DRG neurons via CaV2.2 channels.. Experimental description: P10 DRG neurons were prepared from male Sprague Dawley rats.\n\n20/2/2017 Pim:\nFig.4 uses human cell line (tsa201) that overexpress **rabbit** Cav2.2 (M&M: \"The following cDNAs were used: CaV2.2 (D14157)\"). The effect of FMRP KD on synaptic transmission is shown in Fig.8 using **rat** DRG neurons. Annotation is against the rat species." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9880-1214" , "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-0269-0311" , "https://orcid.org/0000-0002-9681-3318" ;
        dc:date           "2018-06-01" ;
        dc:title          "SYNGO_BP_199" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

