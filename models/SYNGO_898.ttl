gomodel:SYNGO_898  a      owl:Ontology ;
        rdfs:comment      "Rationale: Deletion of Neurexin-1alpha reduces spontaneous excitatory synaptic transmission (Fig.1), and Neurexin-1alpha KO mice have decreased evoked excitatory synaptic strength (Fig. 2). The data are consistent with a presynaptic loss of synaptic strength in absence of this Neurexin isoform.. Experimental description: Conditional KO mice were studied." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0912-1514" , "https://orcid.org/0000-0002-3670-7863" ;
