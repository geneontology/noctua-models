gomodel:SYNGO_2349  a     owl:Ontology ;
        rdfs:comment      "Rationale: From Results section:\n\n2nd section, 5th paragraph: \"both 14-3-3h and rEag1 proteins were present in the SPM fraction, implying a co-localization of the two proteins in the synapse\" ... \"we found that rEag1 as well as 14-3-3h were detected in both the PSD I and the PSD II fractions.\". Experimental description: fig 6. (from results section) \"Via sucrose gradient centrifugation, the P2 fraction of rat forebrain homogenates was separated into multiple fractions, from which we collected the synaptosomal (SPM) fraction.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-6893-6177" , "https://orcid.org/0000-0002-5265-6306" ;
        dc:date           "2018-01-26" ;
