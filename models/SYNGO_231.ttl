dc:contributor  a  owl:AnnotationProperty .

gomodel:SYNGO_231  a      owl:Ontology ;
        rdfs:comment      "Automated change 2024-03-14: GO:0099055 replaced by GO:0045211" , "Rationale: SynCAM 1 marks the edge of the synaptic cleft and approximately 70% of the SynCAM 1 protein that is in synaptic membranes is present in the postsynaptic membrane. A smaller fraction of the protein is presynaptically localized.\n\n6/3/2017 Pim\n- localization of SynCAM1 in the postsynaptic membrane can be inferred from its TM domain.. Experimental description: This study used tissue sections from mouse hippocampus and neurons cultured from rat hippocampus\n\n6/3/2017 Pim:\nFig.2A/B/D --> mouse\nFig.2E-H/Fig.3 --> rat\n\nSince the data in Fig.2A-D is sufficient to claim that SynCAM1 is localized to the postsynaptic membrane (see Fig.2B) I we can use **mouse** as the species." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-3670-7863" , "https://orcid.org/0000-0003-0912-1514" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_231" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

