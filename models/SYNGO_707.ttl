dc:date  a      owl:AnnotationProperty .

gomodel:SYNGO_707  a      owl:Ontology ;
        rdfs:comment      "Rationale: NCS-1 immunoreactivity at the Calyx of Held synapse.\n\nFigure 3a shows a prominent immunofluorescence signal for NCS-1 at the presynaptic compartment for calyx of Held synapses, that partially colocalizes with staining against the presynaptic marker Syntaxin (it is not mentioned which isoform).\nFigure 3b evaluates the antibody specificity (since a KO control is missing): Pretreatment of the NCS-1 antibody with recombinant NCS-1 leads to no NCS-1 immunofluorescence, but has no effect on the syntaxin signal.\n\n30/5/2017 Pim:\n- Literal: \" NCS-1 immunofluorescence signal (green, left) and syntaxin immunofluorescence signal (red, center) partially overlapped (yellow, right), indicating that NCS-1 is expressed in both the presynaptic and postsynaptic compartments.\". Experimental description: Brainstem slices were prepared from Wister rats (14 - 18 days old) as described (1, 2)." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-7351-8706" , "https://orcid.org/0000-0002-0755-5899" , "https://orcid.org/0000-0003-0938-8534" , "https://orcid.org/0000-0003-3185-5709" ;
        dc:date           "2017-05-30" ;
        dc:title          "SYNGO_CC_707" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

