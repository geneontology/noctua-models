obo:ECO_0007695  a  owl:Class .

lego:evidence  a  owl:AnnotationProperty .

gomodel:SYNGO_559  a      owl:Ontology ;
        rdfs:comment      "Rationale: First description of the Munc13-1 knock out mouse using electrophysiology in autistic mouse hippocampal and stratal neurons.\n\nFigure 1 shows a 90% reduction in glutamatergic synaptic transmission. GABAergic transmission id not impaired.\n\nFigure 2 shows that the impaired glutamatergic neurotransmission results from a decrease in the size of the readily releasable vesicle pool, assessed by sucrose application.. Experimental description: Mouse knock-out model; Deletion mutations in the mouse gene for Munc13-1 were\ngenerated by homologous recombination in embryonic stem cells." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-7351-8706" , "https://orcid.org/0000-0003-3185-5709" , "https://orcid.org/0000-0002-0755-5899" , "https://orcid.org/0000-0003-0938-8534" ;
        dc:date           "2017-08-16" ;
        dc:title          "SYNGO_BP_559" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

