lego:evidence  a  owl:AnnotationProperty .

gomodel:SYNGO_5477  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 2: ASIC2a associates with PSD-95 through its PDZ-binding domain.\n\nFigure 3: PSD-95 increases ASIC2a in spines.\n\nFigure 5: Endogenous ASIC2 enriches in synaptosomes and coimmunoprecipitates with ASIC1.\n\nFigure 8: Eliminating ASIC2 decreases the density of dendritic spines. \"We found that disrupting the ASIC2 gene reduced the density of synapses (Fig. 8A,B). The reduction was primarily due to a decrease in spine synapses, with no effect on the density of shaft synapses.\". Experimental description: \"Representative Western blots of total lysate (L) and synaptosomal fraction (S) of whole brain from wild-type and Myc-ASIC2a transgenic mice.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2023-03-19" ;
        dc:title          "SYNGO_BP_5477" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

