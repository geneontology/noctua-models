gomodel:SYNGO_92  a       owl:Ontology ;
        rdfs:comment      "Rationale: EM localization after peroxidase reaction at the active zone of A) mossy fibre terminals in the CA3, B) active zone of the shaft synapse in CA3, C) immunoreactivity in shaft synapse of the molecular layer of CA3, D,E) ultrastructural localization of Bassoon in isolated nerve terminals by immunogold EM.. Experimental description: Electron micrographs of ultrathin sections of rat brain (A-C) and agarose-embedded synaptosomal preparations (D-F) are shown. p. 506" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9880-1214" , "https://orcid.org/0000-0002-9681-3318" , "https://orcid.org/0000-0002-0269-0311" , "https://orcid.org/0000-0001-9377-7414" ;
