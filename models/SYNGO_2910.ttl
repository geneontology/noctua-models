gomodel:SYNGO_2910  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.1: \"Increased AMPA mEPSC amplitudes in hippocampal neuron from SJ1-KO mice\"\n\nFig.3: \"Both SJ1-145 and SJ1-170 revert the increase in mEPSC amplitude observed in SJ1-KO neurons\"\n\nFig.4: \"The phosphatase activity of SJ1 is necessary to restore normal mEPSC amplitude in SJ1-KO mice\"\n\nFig.5: \"Internalization of AMPA receptors following the application of NMDA is impaired in SJ1-KO neurons\". Experimental description: - \"Primary hippocampal neuronal cultures were prepared as described (51) from newborn littermates derived from the mating of mice heterozygous for the SJ1 null mutation (14).\"\n- Species of over-expressed Synaptojanin 1 is not stated in the publication." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2018-03-15" ;
        dc:title          "SYNGO_BP_2910" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

