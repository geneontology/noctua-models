<http://model.geneontology.org/reaction_R-HSA-9754130_location_lociGO_0005654>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/GO_0005654> ;
        <http://purl.org/dc/elements/1.1/contributor>
                "GOC:reactome_curators" ;
