gomodel:R-HSA-9617324
        a                 owl:Ontology ;
        rdfs:comment      "For logical inference, import the integrated tbox ontology http://purl.obolibrary.org/obo/go/extensions/go-lego-reacto.owl" , "Imported from Reactome: https://reactome.org/content/detail/R-HSA-9617324" , "http://www.reactome.org" ;
        lego:modelstate   "development" ;
        dc:contributor    "GOC:reactome_curators" ;
        dc:date           "2026-06-29" ;
        dc:title          "Negative regulation of NMDA receptor-mediated neuronal transmission - imported from: Reactome" ;
        pav:providedBy    "https://reactome.org" ;
        biolink:in_taxon  obo:NCBITaxon_9606 .

:R-HSA-9617324  a           owl:NamedIndividual , obo:GO_0008150 ;
        rdfs:comment        "The duration of NMDA receptor-mediated neuronal transmission can be limited by binding of the activated calmodulin to the activated NMDA receptor. In addition to shortening the NMDA channel pore open state, calmodulin interferes with ACTN2-mediated anchoring of NMDA receptors to the postsynaptic density (Ehlers et al. 1996, Wyszynski et al. 1997). Protein phosphatases PPM1E and PPM1F dephosphorylate activated calcium/calmodulin-dependent kinases (CaMKs), thus halting CaMK-mediated signaling (Ishida, Okuno et al. 1998, Ishida et al. 1998, Kitani et al. 2003)." ;
        rdfs:label          "Negative regulation of NMDA receptor-mediated neuronal transmission" ;
        dc:contributor      "GOC:reactome_curators" , "Reviewed: Hansen, Kasper B, 2018-11-02" , "Authored: Orlic-Milacic, Marija, 2018-10-10" , "Edited: Orlic-Milacic, Marija, 2018-11-07" , "Reviewed: Yi, Feng, 2018-11-02" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-9617324" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-442755/R-HSA-442755> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

