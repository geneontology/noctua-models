gomodel:SYNGO_5185  a     owl:Ontology ;
        rdfs:comment      "Rationale: immunogold labeling for DCX and GABA or VGLUT1 in rat dentate gyrus showed DCX at presynaptic terminals (Fig. 2d, 3a/d/f, 4c/e/f, 5a/b/c) and at postsynaptic sites (Fig. 3a/b/e, 5c).. Experimental description: M&M: \"21-day-old (Wistar, n=4; GAERS, n=3), 100-150 g and 3-month-old (Wistar, n=5; GAERS, n=5), 250-300 g male Wistar rats and GAERS were used in the study.\"\n\nantibody:\nanti-DCX antibody (Abcam, Cat #: ab18723, 1:200 in TBST pH 7.6)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2023-02-27" ;
        dc:title          "SYNGO_CC_5185" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

