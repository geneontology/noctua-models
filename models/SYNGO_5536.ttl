gomodel:SYNGO_5536  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 1: Overexpression of the phospho-blocking T1067A CYFIP2 mutant affects stubby spine density and neurite outgrowth in cultured hippocampal neurons.. Experimental description: biological system used for experiment; \"Cultured hippocampal neurons were prepared from rat brains of 18-day-old embryos\"\n\nhuman protein was used for overexpression;\n\"The full-length human CYFIP2 cDNA (pOTB7 CYFIP2) was purchased from Open Biosystems and subcloned into the pEGFP-N1 plasmid (Clontech, Mountain View, California, USA). Mutagenesis reactions were performed using the QuikChange II XL Site-Directed Mutagenesis Kit (Agilent Technologies, Santa Clara, California, USA) according to the manufacturer's instructions to generate pEGFP-N1 full-length S582A, S582D, T1067A, T1067E, and S968F CYFIP2 construct\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" ;
        dc:date           "2023-11-07" ;
        dc:title          "SYNGO_BP_5536" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_9606" .

