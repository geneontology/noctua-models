gomodel:SYNGO_2023  a     owl:Ontology ;
        rdfs:comment      "Rationale: \"Striatal synaptosomes from wild-type and α5 null mutant mice (n=3 each genotype) were assayed for α-CtxMII-resistant (α4β2*-nAChR) DA release by 5 s exposures to ACh (0.1-3,000 μM). The results of the biphasic curve fit indicate that α5 deletion results in a significant decrease in HS maximal release (P<0.05).\". Experimental description: \"Striatal synaptosomes from wild-type and α5 null mutant mice ...\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2018-03-19" ;
