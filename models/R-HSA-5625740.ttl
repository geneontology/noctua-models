<http://model.geneontology.org/R-HSA-377179_R-HSA-5623667>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/go/extensions/reacto.owl#REACTO_R-HSA-377179> ;
        <http://www.w3.org/2000/01/rdf-schema#comment>
                "located_in plasma membrane" , "Original Reactome ID: R-HSA-377179" ;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "PDK1:PIP3" ;
        <http://purl.org/dc/elements/1.1/contributor>
