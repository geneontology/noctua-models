obo:BFO_0000066  a  owl:ObjectProperty .

gomodel:SYNGO_2309  a     owl:Ontology ;
        rdfs:comment      "Rationale: The work established two agonists as selective for mAchR-1 activation by showing the agonist induced G-protein activation in hippocampal membranes from wild-type mice is lost in mAchR-1 knockout animals. These agonists selectively increased synaptic transmission in the CA1 and this agonist induced increase in synaptic transmission was lost in the mAChR-1 knockout mice.. Experimental description: Materials and Methods: Transverse hippocampal slices prepared from adult (6-9 weeks old) male C57/BL6J, wild-type (WT) or M1R KO mice............................" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-0755-5899" , "https://orcid.org/0000-0003-3185-5709" , "https://orcid.org/0000-0003-0938-8534" , "https://orcid.org/0000-0001-7351-8706" ;
        dc:date           "2018-05-29" ;
        dc:title          "SYNGO_BP_2309" ;
        pav:providedBy    "https://syngo.vu.nl" ;
