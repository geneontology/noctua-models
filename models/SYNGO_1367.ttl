gomodel:SYNGO_1367  a     owl:Ontology ;
        rdfs:comment      "Rationale: eIF4B is found dendritically (near but doesn't co-localize completely with synaptophysin) in hippocampal primary neurons by immunofluorescence.\n\n24/9/2017 Pim\n- Authors refer to the localization as 'synapto-dendritic\".\n- A role for eIF4B phosphorylation in LTP induction is concluded, but to my opinion this is purely correlational and therefore would refrain from annotating this.. Experimental description: Sprague Dawley rats (Hilltop Lab Animals)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-1190-4481" , "https://orcid.org/0000-0002-2094-7491" , "https://orcid.org/0000-0002-9848-0262" , "https://orcid.org/0000-0002-4419-210X" ;
        dc:date           "2017-09-25" ;
        dc:title          "SYNGO_CC_1367" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

