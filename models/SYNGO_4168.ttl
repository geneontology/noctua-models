obo:GO_0098944  a  owl:Class .

gomodel:SYNGO_4168  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig1B shows immunohistochemical stain of the mouse brain using the RAB11FIP3 antibody, which is largely blocked by pre-incubation with the antigen (Fig1B'), indicating the specificity of the antibody.\n\nFig2 shows the localization of RAB11FIP3 in mouse hippocampus. Panel G shows immunogold localisation to the spine head by electron microscopy (PSDs are also visible here) and panel H shows the localisation to tubular endosomes. Together with its interaction with RAB11 (see additional reference) these can be classified as recycling endosomes at the postsynaptic side.. Experimental description: Figure legend \"Immunohistochemical localization of FIP3 in mouse hippocampus.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0001-5259-4945" ;
        dc:date           "2021-01-02" ;
        dc:title          "SYNGO_CC_4168" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

