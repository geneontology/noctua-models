obo:BFO_0000050  a  owl:ObjectProperty .

:R-HSA-111995  a            owl:NamedIndividual , obo:GO_0008150 ;
        rdfs:comment        "Phospholipase A2 (PLA2) enzymes hydrolyze arachidonic acid (AA) from the sn-2 position of phospholipids. AA is a precursor of eicosanoids, lipid mediators involved in inflammtory responses. PLA2 enzymes function as regulators of phospholipid acyl turnover, either as housekeepers for membrane repair or for the production of imflammatory lipid mediators. There are diverse forms of PLA2 enyzmes including secretory (sPLA2), calcium-independent and cytosolic (cPLA2). The cPLA2 form which mediates arachidonic acid release is annotated here." ;
        rdfs:label          "phospho-PLA2 pathway" ;
        dc:contributor      "GOC:reactome_curators" , "Authored: Le Novere, N, Jassal, B, 2004-03-31 12:22:05" , "Edited: Jassal, Bijay, 2008-11-06" , "Reviewed: Castagnoli, L, 2008-11-06 12:55:54" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-111995" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-111996/R-HSA-111996> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

