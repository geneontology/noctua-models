gomodel:SYNGO_1939  a     owl:Ontology ;
        rdfs:comment      "Rationale: tPA is involved via activation of plasmin (Fig. 4B) to convert proBDNF into the mature mBDNF. tPA-/- mice are deficient for L-LTP, which can be rescued by either application of tPA itself (Fig. 4A) or mBDNF (Fig. 1E). proBDNF is not able to rescue this phenotype (Fig. 2B) but needs the protease plasmin (Fig. 4B).. Experimental description: Literal: \"Plasminogen-/- mice also exhibited severe impairment in L-LTP (Fig. 1F)\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9880-1214" , "https://orcid.org/0000-0002-0269-0311" , "https://orcid.org/0000-0002-9681-3318" , "https://orcid.org/0000-0001-9377-7414" ;
        dc:date           "2018-01-25" ;
        dc:title          "SYNGO_BP_1939" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

