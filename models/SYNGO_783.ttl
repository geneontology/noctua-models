gomodel:SYNGO_783  a      owl:Ontology ;
        rdfs:comment      "Rationale: The human proline transporter (PROT) transports proline in a sodium and chloride dependent manner.\n\nTransfected HeLa cells expressing PROT take up radiolabeled L-proline (Fig.2a). The transport is sodium and chloride-dependent (Fig.2a and b). Application of structural analogs inhibit transport of radiolabeled cells (Fig.4).. Experimental description: The rPROT cDNA was used as a template in a PCR containing 0.25 mCi of [32P]dCTP to generate a 690-bp radiolabeled probe that was used to screen at high stringency a human hippocampal cDNA library..." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0938-8534" , "https://orcid.org/0000-0002-0755-5899" , "https://orcid.org/0000-0001-7351-8706" , "https://orcid.org/0000-0003-3185-5709" ;
        dc:date           "2017-08-25" ;
        dc:title          "SYNGO_BP_783" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_9606" .

