obo:ECO_0007695  a  owl:Class .

gomodel:SYNGO_113  a      owl:Ontology ;
        rdfs:comment      "Rationale: RIM2 knockout cultures have a reduction in the size of the sucrose pool at inhibitory synapses, demonstrating a role for RIM2 in vesicle priming. Due to the strong homology between RIM1 and RIM2, both proteins are assumed to be redundant in this process. Action potential mediated pool measurements have confirmed a role in priming for RIM1 and RIM2 at the Calyx of Held (Han et.al. 2011).. Experimental description: Primary hippocampal neuronal cultures were prepared from newborn pups of RIM1αβf/f, RIM2αβγf/f, or RIM1αβf/f/RIM2αβγf/f mice according to standard protocols (4, 21)." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-7620-2704" , "https://orcid.org/0000-0002-1558-1958" ;
        dc:date           "2018-06-07" ;
        dc:title          "SYNGO_BP_113" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

