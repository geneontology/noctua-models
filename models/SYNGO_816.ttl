gomodel:SYNGO_816  a      owl:Ontology ;
        rdfs:comment      "Rationale: Electron microscopy of post-embedding immunogold-labelled Rat cerebellar tissue sections (from P5, P12 and adult) stained with an antibody specific for γ-actin. γ-actin was localized to both the presynapse and postsynapse, but was especially present in the dendritic spines.\n\n9/6/2017 Pim\nTicket made under IC flag since inferred form known function of actin and the actin cytoskeleton.. Experimental description: Sprague-Dawley Rats" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-1212-5623" , "https://orcid.org/0000-0003-2533-9548" , "https://orcid.org/0000-0001-7480-0826" , "https://orcid.org/0000-0003-4022-8707" , "https://orcid.org/0000-0002-5648-066X" ;
