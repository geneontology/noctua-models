obo:RO_0002333  a  owl:ObjectProperty .

gomodel:SYNGO_418  a      owl:Ontology ;
        rdfs:comment      "Rationale: Function: Intra-axonal synthesis of p35 regulates vesicle recycling in developing neurons.\n\nData show that presynaptic repression of cap-dependent mRNA translation enlarges synaptic vesicle recycling pool size without changing the total pool (Experiment: neuronal stimulation, FM-dye uptake and immunolabeling in neurons expressing rem4A or not, Fig 2). This effect is due in part to decreased levels of p35 (Experiment: Western blots of whole cell lysates show that rem4A expression decreased p35 levels (Fig 3A). FM-dye uptake data shows an increase in dye intensity and area in p35 knockdown axons (Fig 3 G-J)).\n\nLocation: Immunolabeling for endogenous p35 shows that p35 is localized to vesicle release sites. p35 colocalized with vGlut labeled clusters along dendrites (Fig 3E), but also with vGlut clusters at nonsynaptic hot spots in axons having no nearby dendrites (Fig. 3F).. Experimental description: Hippocampi were isolated from embryonic day 18 (E18) rats." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-1212-5623" , "https://orcid.org/0000-0003-4022-8707" , "https://orcid.org/0000-0003-2533-9548" , "https://orcid.org/0000-0001-7480-0826" , "https://orcid.org/0000-0002-5648-066X" ;
        dc:date           "2017-06-20" ;
        dc:title          "SYNGO_BP_418" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

