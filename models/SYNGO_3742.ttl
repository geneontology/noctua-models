obo:ECO_0001225  a  owl:Class .

gomodel:SYNGO_3742  a     owl:Ontology ;
        rdfs:comment      "Rationale: The authors generate an amphiphysin I KO mouse. In fig3 they demonstrate that uptake of the endocytic tracer FM2-10 is reduced in synaptosomes prepared from KO mice when compared to wild-type mice.\n\nIn fig 5 the authors use EM to demonstrate that loading of synaptic vesicles with a fluid phase tracer, HRP is decreased in cortical neurons prepared from amphiphysin KO mice.. Experimental description: From the abstract, \"We have now generated amphiphysin 1 knockout mice\"." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-7806-5662" ;
        dc:date           "2018-06-07" ;
        dc:title          "SYNGO_BP_3742" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

