<http://model.geneontology.org/ev_w_id_R-HSA-3928607_RO_0002233_R-HSA-2424458_R-HSA-3928607_Reactome_R-HSA-3928607>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/ECO_0000313> ;
