gomodel:SYNGO_5410  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 3-5: Gαz (GNAZ) and Src were detected in co-immunoprecipitations from synaptosomal membranes prepared, with relative abundances dependant on morphine icv-injection. Pulldown of Gαz identified phosphorylated Src at increased amount after Gαi2 (GNAI2) knockdown.\n\n\"Notwithstanding, the ex vivo study was also conducted in synaptosomal membranes derived from the cerebral cortex and striatum. Since the results were always comparable, only those results corresponding to PAG membranes are shown in the figures.\". Experimental description: M&M: \"Male albino CD-1 mice weighing 22-25 g were housed and used ...\"\n\nGαz (mouse) shRNA for knockdown; PMID:15617734\nGαz antibody; PMID: 15827571" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2023-03-15" ;
        dc:title          "SYNGO_CC_5410" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

