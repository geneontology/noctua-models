obo:BFO_0000066  a  owl:ObjectProperty .

gomodel:SYNGO_5101  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 3: TRIM47 and PSD95 (DLG4) were detected in synaptoneurosomes prepared from rat hippocampus (P14 and P60) by ficoll density gradient centrifugation and enriched as compared to crude fractions. Confocal imaging of immunofluorescence labeling for TRIM47 and PSD95 (DLG4) in cultured hippocampal neurons at DIV7 showed co-localization and this was further increased at DIV21.. Experimental description: Results, Figure 3 legend: \"Synaptoneurosome is prepared from rat hippocampus ... Rat brain sections at P14 and P60 are immunostained for TRIM47 ...\"\n\nantibody:\nTRIM47 (1:500; Bethyl Laboratories, #A301-194A)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-4973-5732" ;
        dc:date           "2023-02-24" ;
        dc:title          "SYNGO_CC_5101" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

