:R-HSA-163615  a            obo:GO_0034199 , owl:NamedIndividual ;
        rdfs:comment        "A number of inactive tetrameric PKA holoenzymes are produced by the combination of homo- or heterodimers of the different regulatory subunits associated with two catalytic subunits. When cAMP binds to two specific binding sites on the regulatory subunits, these undergo a conformational change that causes the dissociation of a dimer of regulatory subunits bound to four cAMP from two monomeric, catalytically active PKA subunits." ;
        rdfs:label          "PKA activation" ;
        dc:contributor      "Reviewed: D'Eustachio, Peter, 2024-01-29" , "Edited: Jassal, Bijay, 2008-11-06" , "Authored: Le Novere, N, Jassal, B, 2004-03-31 12:22:05" , "GOC:reactome_curators" , "Reviewed: D'Eustachio, Peter, 2024-03-04" , "Reviewed: Castagnoli, L, 2008-11-06 12:55:54" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-163615" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-111931/R-HSA-111931> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

