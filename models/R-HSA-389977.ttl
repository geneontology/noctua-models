<http://model.geneontology.org/R-HSA-389977> <http://geneontology.org/lego/modelstate> "development" ;
	<http://purl.org/pav/providedBy> "https://reactome.org" ;
	<https://w3id.org/biolink/vocab/in_taxon> <http://purl.obolibrary.org/obo/NCBITaxon_9606> ;
	a <http://www.w3.org/2002/07/owl#Ontology> ;
	<http://www.w3.org/2000/01/rdf-schema#comment> "For logical inference, import the integrated tbox ontology http://purl.obolibrary.org/obo/go/extensions/go-lego-reacto.owl" , "http://www.reactome.org" , "Imported from Reactome: https://reactome.org/content/detail/R-HSA-389977" ;
	<http://purl.org/dc/elements/1.1/title> "Post-chaperonin tubulin folding pathway - imported from: Reactome" ;
	<http://purl.org/dc/elements/1.1/contributor> "GOC:reactome_curators" ;
