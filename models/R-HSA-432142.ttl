dc:source  a    owl:AnnotationProperty .

:R-HSA-432142  a            owl:NamedIndividual , obo:GO_0008150 ;
        rdfs:comment        "Physiological concentrations (1g/L) of Low density lipoprotein (LDL) enhance platelet aggregation responses initiated by thrombin, collagen, and ADP. This enhancement involves the rapid phosphorylation of p38 mitogen-activated protein kinase (p38MAPK) at Thr180 and Tyr182. The receptor for LDL is ApoER2, a splice variant of the classical ApoE receptor. ApoER2 stimulation leads to association of the Src family kinase Fgr which is probably responsible for subsequent phosphorylation of p38MAPK. This stimulation is transient because LDL also increases the activity of PECAM-1, which stimulates phosphatases that dephosphorylate p38MAPK." ;
        rdfs:label          "Platelet sensitization by LDL" ;
        dc:contributor      "Edited: Jupe, S, 2010-06-07" , "GOC:reactome_curators" , "Reviewed: Kunapuli, SP, 2010-06-07" , "Authored: Akkerman, JW, 2009-09-04" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-432142" ;
