obo:ECO_0006003  a  owl:Class .

gomodel:SYNGO_2540  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 4 Legend:\n\n-Literal: \"Within puncta of the neuropil, RC3-1 and RC3-5 antisera revealed immunolabeling mainly in dendritic spines (S) forming asymmetrical synaptic junctions with axonal terminals (AT) (C and D).\"\n\nResults section: \"Ultrastructure of RC3 Neurons.\"\n\n-Literal: \"In puncta, RC3 [neurogranin, nrgn] immunolabeling was observed principally in dendritic shafts and dendritic spines. Dendritic shafts and spine necks contained slight traces of RC3. In contrast, RC3-containing spine heads were the most frequent immunolabeled profiles and had the heaviest deposits of label in all cases (Fig. 4 C and D).. Experimental description: Methods section:\n\n-Literal: \"Morphological analyses identified RC3 [neurogranin, nrgn] in fixed tissue sections\n(14). Ten adult rats were anesthetized with sodium pentobarbital...\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-6893-6177" , "https://orcid.org/0000-0002-5265-6306" ;
        dc:date           "2018-02-22" ;
        dc:title          "SYNGO_CC_2540" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

