gomodel:SYNGO_2738  a     owl:Ontology ;
        rdfs:comment      "Rationale: Using a constutitive Liprin a3 knockout (KO), Wong et.al. shows that Liprin a3 mediates synaptic vesicle docking. In transmission electron microscopy of individual sections, KO showed an ~25% reduction in the number of docked vesicles. Tethered vesicles (<100 nm from the active zone) were similarly affected. Similar observations were observed with two different fixation methods (glutaraldehyde and cryo-fixation).\n\nThe KO is characterized in figure 2, showing absence of the protein in western blot using 3 different antibodies.. Experimental description: Primary mouse hippocampal cultures were generated from newborns as previously described (20), and all analyses were performed at DIV 14-17." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-7620-2704" , "https://orcid.org/0000-0002-1558-1958" ;
        dc:date           "2018-03-09" ;
        dc:title          "SYNGO_BP_2738" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

pav:providedBy  a  owl:AnnotationProperty .

