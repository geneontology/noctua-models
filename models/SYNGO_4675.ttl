gomodel:SYNGO_4675  a     owl:Ontology ;
        rdfs:comment      "Rationale: SEC8 binds to SAP102 via its C-term PDZ-binding domain. Overexpression of deletion mutant of SEC8 lacking its 4 amino acid C-term PDZ-binding domain was used as dominant negative approach.\nFig. 7 shows that hippocampal neurons transfected with Sec8delta4 have lower intensity of NR2B fluorescence and concomitant lower mEPSC amplitude (mIPSC amplitudes unaffected). Experimental description: No info on species used to culture hippocampal neurons. All other assays (fractionation, biochemistry) in the paper use Sprague Dawley rat brains." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9900-4233" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2022-07-29" ;
        dc:title          "SYNGO_BP_4675" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

