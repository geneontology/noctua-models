gomodel:SYNGO_958  a      owl:Ontology ;
        rdfs:comment      "Automated change 2024-03-14: GO:0099026 replaced by GO:0042734" , "Rationale: Fig 3: Contactin-5 / NB-2 in cultured hippocampal neurons co-localized with presynaptic synapsin.\nFig 4: Synaptosomal fractions of P15 mouse cereral cortices analyzed by western blotting showed strong expression of contactin-5 / NB-2 in a fraction containing both presynaptic Kv1.2 and postsynaptic PSD95, and in a fraction containing only presynaptic Kv1.2\n\n12/10/2017 Pim\n- Based on the known lipid anchor of the protein, the \"anchored component of ... membrane\" term was chosen.. Experimental description: \"C57BL/6J mice were housed in a specific pathogen-free facility kept under optimal hygiene conditions at Nagaoka University of Technology.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-3670-7863" , "https://orcid.org/0000-0003-0912-1514" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_958" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

