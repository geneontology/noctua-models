gomodel:SYNGO_2387  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.3: \"Recovery of SC/CA1 LTP inGFPGluR-A-expressing GluR-A-/- mice\"\n\nMice defective in the AMPAR subunit GRIA1; GluR1 do not show the phenomenon of hippocampal LTP which is known to be caused by AMPARs moving into the PSD. Reexpression of GFP-Glur1 can rescue this defect.. Experimental description: \"We analyzed whether in adult GluR-A-deficient mice, synaptic plasticity can be restored by controlled expression of GluR-A.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2018-01-30" ;
        dc:title          "SYNGO_MF_2387" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

