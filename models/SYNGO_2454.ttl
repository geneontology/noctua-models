obo:ECO_0006063  a  owl:Class .

gomodel:SYNGO_2454  a     owl:Ontology ;
        rdfs:comment      "Rationale: LRFN4 expressed in nonneural cells induce presynaptic differentiation in contacting axons.\nLRFN4 induce excitatory and inhibitory presynaptic protein clustering.\nLRFN4 induce the uptake of synaptotagmin lumenal domain antibodies in contacting axons of cocultured neurons.\nOverexpression of LRFN4 in cultured neurons increases the amount of presynaptic contacts.\nOverexpression of LRFN4 in cultured neurons increases the amount of excitatory and inhibitory presynaptic contacts.. Experimental description: Materials and Methods\nNeuron culture, transfection, and immunocytochemistry.\nPrimary hippocampal cultures were prepared from embryonic day 18 rat hippocampi.\n\ncDNA constructs.\n\nFull-length human SALM1 (aa 1-788), rat SALM2 (aa 1-766), mouse SALM3 (aa 1-636), mouse SALM4 (aa 1-626), and mouse SALM5 (aa 1-719) were subcloned into pEGFP-N1 vector (Clontech)." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-6194-9648" , "https://orcid.org/0000-0001-5518-6584" ;
        dc:date           "2018-02-21" ;
        dc:title          "SYNGO_BP_2454" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

