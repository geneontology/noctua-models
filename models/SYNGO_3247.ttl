gomodel:SYNGO_3247  a     owl:Ontology ;
        rdfs:comment      "Rationale: At the fly NMJ, EJC amplitude is elevated by 79% in alk temp sensitive (ts) mutants, and increased by >2-fold in alkts/alk1transheterozygotes, compared to wild-type controls. No data on spontaneous EJC/P amplitude. No effect on NMJ morphology. Experimental description: M&M Drosophila Stocks:The jebko5644 and alk1null mutations have been fully described by us and others (Loren et al., 2001; Weiss et al.,2001), and were analyzed in our recent study (Rohrboughand Broadie, 2011)." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9900-4233" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2018-06-19" ;
        dc:title          "SYNGO_BP_3247" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_7227" .

