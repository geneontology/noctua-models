:R-HSA-5689877  a           obo:GO_0008150 , owl:NamedIndividual ;
        rdfs:comment        "The Josephin domain is present in four human DUBs: Ataxin-3 (ATXN3), ATXN3L, Josephin-1 (JOSD1) and JOSD2. All have been shown to possess DUB activity (Tzveltkov & Breuer 2007, Weeks et al. 2011). Josephin domain DUBs may specialize in distinguishing between polyubiquitin chains of different lengths (Eletr & Wilkinson 2014)." ;
        rdfs:label          "Josephin domain DUBs" ;
        dc:contributor      "Edited: Jupe, Steve, 2016-05-05" , "GOC:reactome_curators" , "Reviewed: Meldal, Birgit, 2016-05-16" , "Authored: Jupe, Steve, 2015-04-16" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-5689877" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-5688426/R-HSA-5688426> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

