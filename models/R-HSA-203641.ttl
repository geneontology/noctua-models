        pav:providedBy  "https://reactome.org" .

:R-HSA-203641  a            obo:GO_0046209 , owl:NamedIndividual ;
        rdfs:comment        "eNOS traffic inducer (NOSTRIN) is a novel 506-amino acid eNOS-interacting protein. Along with a decrease in eNOS activity, NOSTRIN causes translocation of eNOS from the plasma membrane to intracellular vesicular structures. NOSTRIN functions as an adaptor protein through homotrimerization and recruitment of eNOS, dynamin-2, and N-WASP to its SH3 domain. Studies indicated that NOSTRIN may facilitate vesicle fission and endocytosis of eNOS by coordinating the function of dynamin and N-WASP, which in turn, recruits the Arp2/3 complex, initiating actin filament polymerization. Overall, this process is thought to occur via caveolar endocytosis. <br><br><br><br>" ;
        rdfs:label          "NOSTRIN mediated eNOS trafficking" ;
        dc:contributor      "GOC:reactome_curators" , "Reviewed: Enikolopov, G, 2008-02-28 17:52:44" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-203641" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-202131/R-HSA-202131> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

