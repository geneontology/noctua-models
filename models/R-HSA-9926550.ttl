<http://model.geneontology.org/R-HSA-9926486_binding_9926440_R-HSA-9825710>
        a       <http://purl.obolibrary.org/obo/GO_0005488> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
        <http://purl.obolibrary.org/obo/BFO_0000050>
                <http://model.geneontology.org/R-HSA-9926550/R-HSA-9926550> ;
