gomodel:SYNGO_1771  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.1E shows Farp1 enrichment in synaptic plasma membrane preparations and Fig.1F shows biochemical enrichment of Farp1 in detergent-resistant fractions of synaptosomes, consistent with a localization of Farp1 to postsynaptic scaffolds. GFP-tagged Farp1 is enriched in spines as shown in Figs.1G and 2A.\n\nFig.2G/H shows that Farp1 is recruited to membrane via interaction with the TM protein SynCAM 1 in HEK cells and they co-localize in spines.. Experimental description: The full-length coding sequence of Farp1 was amplified from a rat brain P11 cDNA library." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0912-1514" , "https://orcid.org/0000-0002-3670-7863" ;
        dc:date           "2022-05-06" ;
        dc:title          "SYNGO_CC_1771" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

