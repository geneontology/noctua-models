<http://model.geneontology.org/68d5ebd600002481> a owl:Ontology ;
    ns4:modelstate "development"^^xsd:string ;
    dc:contributor "https://orcid.org/0009-0002-7487-1936"^^xsd:string ;
    dc:date "2026-05-22"^^xsd:string ;
    dc:title "Cholesterol and TG counter transport between HDL and VLDL enabled by CETP Hsap"^^xsd:string ;
    ns1:providedBy "https://holthuis-lab-uos.de"^^xsd:string ;
    rdfs:comment "Automated change 2026-03-12: GO:0005615 replaced by GO:0005576"^^xsd:string,
        """Cannot add lipoprotein particles as CC: high-density lipoprotein particle - GO:0034364; GO:0034362 - low-density lipoprotein particle

Allows the net movement of cholesteryl ester from high density lipoproteins/HDL to triglyceride-rich very low density lipoproteins/VLDL, and the equimolar transport of triglyceride from VLDL to HDL (PubMed:24293641, PubMed:3281933, PubMed:3600759)."""^^xsd:string ;
    ns3:in_taxon ns2:NCBITaxon_9606 .

