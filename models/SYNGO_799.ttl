gomodel:SYNGO_799  a      owl:Ontology ;
        rdfs:comment      "Automated change 2024-03-14: GO:0099056 replaced by GO:0042734" , "Rationale: Figure 1 shows enriched binding of P2X ligands to nerve terminals (synaptosomes). This is extended by subjecting the synaptosomes to differential detergent extraction at distinct pH (Figure 3 A).This highlights extraction of synaptosomes (syn) to generate biochemical fractions enriched for general presynaptic (pre), postsynaptic (post) of neuronal active zone (NAZ) components. P2X-3 is selectively extracted into the presynaptic membrane and further enriched in the NAZ. The figure (3B bottom of three panels) has selective staining with the same P2X-3 selective antibody on glass immobilized synaptosomes. (Antibodies quality controlled by Alamone).\n\n30/10/2017 Pim\n- Based on the known transmembrane topology of the protein, the \"integral component of ... membrane\" term was chosen.. Experimental description: Material and methods: Male Wistar rats (8weeks)...." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-3185-5709" , "https://orcid.org/0000-0002-0755-5899" , "https://orcid.org/0000-0003-0938-8534" , "https://orcid.org/0000-0001-7351-8706" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_799" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

