obo:GO_0003674  a  owl:Class .

gomodel:SYNGO_1654  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig. 5 F shows clearly the labeling of Cerebellin-1 at the parallel fibre-interneuron synapses.\nFig. 6 quantifies the immunogold-localization.\n\n17/11/2017 Pim\n- CBLN1_MOUSE, Precerebellin, Cerebellin-1 is a known secreted protein that has no TM domains or other known lipid-interacting domains. The localization at the synaptic junction is therefore reasonably assumed to be in the postsynaptic cleft.. Experimental description: \"Cbln1 accumulates and colocalizes with Cbln3 and GluRδ2 at parallel fiber-Purkinje cell synapses in the mouse cerebellum\", Title of paper" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9681-3318" , "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-0269-0311" , "https://orcid.org/0000-0002-9880-1214" ;
        dc:date           "2017-11-17" ;
        dc:title          "SYNGO_CC_1654" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

