gomodel:SYNGO_4683  a     owl:Ontology ;
        rdfs:comment      "Rationale: Authors use hippocampal slices to measure electrophysiological properties of Notch1 CA1 cKO neurons. Using field recordings, authors find that LTP and LTD, measured at CA3->CA1 connections, were reduced in slices where Notch1 is selectively removed in CA1 neurons.\n\nOn the other hand, in these conditions there is no presynaptic defect, as authors find that basal transmission was the same for mutants and controls (Figure 4G), and paired-pulse facilitation (Figure 4H).. Experimental description: from M&M: \"All mice were maintained in accordance with the Institutional\" ..." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-1212-5623" , "https://orcid.org/0000-0002-2345-393X" , "https://orcid.org/0000-0002-9888-0928" ;
        dc:date           "2022-07-29" ;
        dc:title          "SYNGO_BP_4683" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

