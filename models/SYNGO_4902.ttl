gomodel:SYNGO_4902  a     owl:Ontology ;
        rdfs:comment      "Rationale: Autophagy-dependent PKA signaling regulates synaptic GLUR1 localization and AMPAR function (Fig. 7). Conditional KO of ATG5 leads to increased GluR1 levels (panel C,D,E). ATG5 cKO causes increased Ca2+ signals (K) that are blocked by CNQX (L).\nAmplitude (S) and frequency (T) of AMPAR sEPSC is increased in pyramidal KO neurons to the WT.. Experimental description: \"Conditional tamoxifen-inducible ATG5 and ATG16L1 KO mice...\" (p.19 of 32; e110963)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9880-1214" , "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-9681-3318" , "https://orcid.org/0000-0002-0269-0311" ;
        dc:date           "2023-01-29" ;
        dc:title          "SYNGO_BP_4902" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

