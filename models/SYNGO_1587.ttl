obo:RO_0002333  a  owl:ObjectProperty .

gomodel:SYNGO_1587  a     owl:Ontology ;
        rdfs:comment      "Rationale: GABAB1-deficient (GABAB1-/-) mice were generated. Using classical electrophysiological techniques together with application of baclofen, a GABA B agonist, authors showed lost of Pre- and Postsynaptic GABAB Responses in GABA B1 -/- mice. This demonstrates that GABAB1 is an essential component of pre- and postsynaptic GABAB receptors.. Experimental description: Horizontal slices containing the hippocampus (300 um thick) were prepared from P12 to P21 mice using standard procedures." , "Automated change 2026-01-08: GO:0099579 replaced by GO:0099528" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-2533-9548" , "https://orcid.org/0000-0001-7480-0826" , "https://orcid.org/0000-0002-5648-066X" , "https://orcid.org/0000-0002-1212-5623" , "https://orcid.org/0000-0003-4022-8707" ;
