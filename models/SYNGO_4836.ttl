gomodel:SYNGO_4836  a     owl:Ontology ;
        rdfs:comment      "Rationale: Septin-3 is present at the presynapse (Figure S3), binds to autophagy proteins LC3B and GABARAPL2 (Figure 2,3), localizes to LC3B positive autophagic vesicles (Figure 7) and accumulates in primary neurons upon autophagy enhancement or blockade, similar to autophagy proteins (Figure 5,6).. Experimental description: supplemental figures; \"Fig. S3 Electron micrographs of mouse brain slice\"\n\nantibody:\nmouse anti-SEPT3, 1:50 (sc-74431, Santa Cruz)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-4973-5732" ;
        dc:date           "2022-09-04" ;
        dc:title          "SYNGO_BP_4836" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

