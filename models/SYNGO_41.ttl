obo:ECO_0006013  a  owl:Class .

gomodel:SYNGO_41  a       owl:Ontology ;
        rdfs:comment      "Rationale: Snapin facilitates the synchronization of synaptic vesicle fusion. Snapin null mutant mice show reduced frequency of miniature excitatory postsynaptic currents (mini-EPSCs) and smaller release-ready vesicle pool (RRP) size (Fig.1), snapin deficiency results in EPSCs with multiple peaks and increased rise and decay times, reflecting \"desynchronized\" SV fusion (Fig.3).. Experimental description: M&M : \"Snapin (+/-) breeders were backcrossed with C57/BL6 wild-type **mice** every 3-4 months to maintain well-defined genetic background while minimizing genetic drifts.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9900-4233" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2018-03-19" ;
        dc:title          "SYNGO_BP_41" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

