:R-HSA-2161541  a           obo:GO_0006805 , owl:NamedIndividual ;
        rdfs:comment        "Abacavir activation proceeds steps of phosphorylation, deamination to yield carbovir monophosphate, and phosphorylation of the latter compound to yield the triphosphate. In addition, abacavir can be conjugated with glucuronide or oxidized to its 5'-carboxylate derivative, the two major forms in which it is excreted from the body (Yuen et al. 2008)." ;
        rdfs:label          "Abacavir metabolism" ;
        dc:contributor      "Edited: D'Eustachio, P, 2012-03-16" , "Authored: D'Eustachio, P, 2012-03-14" , "Reviewed: Jassal, B, 2012-03-16" , "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-2161541" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-2161522/R-HSA-2161522> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

