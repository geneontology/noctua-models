gomodel:SYNGO_1630  a     owl:Ontology ;
        rdfs:comment      "Rationale: Quantitative mass spectrometric analyses (iBAQ) of purified synaptosomes indicate the presence of GDI2 in synaptic terminals.\n\n10/10/2017 Pim\n- Listed as GDI beta in Table S2. Experimental description: From main text \"To quantify the organization of synaptic vesicle recycling, we first purified synaptic boutons (synaptosomes) from the cellular layers of the cortex and cerebellum of adult rats, using a modified version of a classical brain fractionation protocol." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-5615-1014" ;
        dc:date           "2017-10-10" ;
        dc:title          "SYNGO_CC_1630" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .
