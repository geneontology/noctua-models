obo:RO_0002333  a  owl:ObjectProperty .

gomodel:SYNGO_1765  a     owl:Ontology ;
        rdfs:comment      "Rationale: Loss of ErbB4 in cortical PV+ interneurons impairs their ability to form inhibitory terminals (Fig. 3c-e, g, h), suggesting that ErbB4 acts presynaptically to establish GABAergic synapses onto pyramidal neurons in the cortex. In addition, loss of ErbB4 in PV+ interneurons reduced the number of excitatory synapses they receive, indicating postsynaptic roles of ErbB4 in the control of excitatory synaptic inputs to PV+ cells.. Experimental description: The generation of mice used in this study has been previously described.\n\nNote: no information on species origin of constructs" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0912-1514" , "https://orcid.org/0000-0002-3670-7863" ;
        dc:date           "2018-06-01" ;
        dc:title          "SYNGO_BP_1765" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

