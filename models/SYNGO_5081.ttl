obo:BFO_0000066  a  owl:ObjectProperty .

gomodel:SYNGO_5081  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 3: synaptic localization of FABP5 was investigated in the dorsal raphe nucleus (DRn) of wildtype and FABP5 knockout mice using postembedding immunogold electron microscopy. Gold particles were observed in knockouts, so authors relied on statistical testing to conclude subcellular localization of FABP5. Cytoplasmic FABP5 was observed in postsynapse and postsynaptic density, but not at the presynapse (when compared to knockouts).. Experimental description: M&M: \"Immunofluorescence and Electron Microscopy. DRn sections (30-50 μm) from wild-type and FABP5 KO mice were processed with rabbit anti-FABP5 at 1:500 dilution for immunofluorescence and electron microscopy analysis.\"\n\nantibody:\n\"FABP5 antibody (Biovendor RD184060100, RRID: AB-344491)\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2023-02-23" ;
        dc:title          "SYNGO_CC_5081" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

