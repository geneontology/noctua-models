<http://model.geneontology.org/ev_w_id_R-HSA-9604387_RO_0002234_R-HSA-9604390_R-HSA-9604387_Reactome_R-HSA-9604387>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/ECO_0000313> ;
