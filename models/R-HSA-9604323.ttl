<http://model.geneontology.org/ev_w_id_REACTO_R-HSA-9918358_R-HSA-9918350_R-HSA-9604642_component_BFO_0000051_REACTO_R-HSA-9918356_R-HSA-9918358_R-HSA-9604642_component_Reactome_R-HSA-9604323>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/ECO_0000313> ;
