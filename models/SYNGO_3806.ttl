obo:GO_0048787  a  owl:Class .

lego:evidence  a  owl:AnnotationProperty .

gomodel:SYNGO_3806  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.1: \"Localisation of integrin-α3 at the AZs of NMJs\"\n- \"To determine the localisation of integrin-α3 at the mouse NMJ, we stained longitudinal sections of sternomastoid muscle from embryonic day (E)18.5 mice with antibodies to integrin-α3 and with fluorescently conjugated α-bungarotoxin to mark postsynaptic AChR clusters (Fig. 1). We found a clear localisation of integrin-α3 apposed to the AChR plaque (Fig. 1A). Imaging at high magnification revealed that integrin-α3 was specifically concentrated at AZs, colocalizing with bassoon-positive puncta (Fig. 1B); this was verified using line scans across the synapse to measure fluorescence intensities and spatial distribution of integrin-α3, bassoon and AChRs (Fig. 1E).\"\n\n- Based on the known transmembrane topology of the protein, the \"integral component of ... membrane\" term was chosen.. Experimental description: - \"4% PFA in PBS was used to fix dissected muscles from E18.5 embryos for 2h, or for cardiac perfusion of 2-month-old mice. \"" , "Automated change 2024-03-14: GO:0099059 replaced by GO:0048787" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0003-0593-3443" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_3806" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

