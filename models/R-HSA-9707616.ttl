                "Hemes bind LY96" ;
        <http://purl.obolibrary.org/obo/BFO_0000050>
                <http://model.geneontology.org/R-HSA-9707616/R-HSA-9707616> ;
        <http://purl.obolibrary.org/obo/BFO_0000066>
                <http://model.geneontology.org/reaction_R-HSA-9707594_location_lociGO_0005576> ;
        <http://purl.obolibrary.org/obo/RO_0002233>
                <http://model.geneontology.org/R-HSA-9707658_R-HSA-9707594> , <http://model.geneontology.org/R-ALL-9707310_extracellular_region> ;
