<http://model.geneontology.org/reaction_R-HSA-917870_location_lociGO_0005886>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/GO_0005886> ;
        <http://purl.org/dc/elements/1.1/contributor>
