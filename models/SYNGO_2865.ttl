gomodel:SYNGO_2865  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.1: \"RGS14 is enriched in hippocampal CA2 neurons\"\n- \"At the electron microscopic (EM) level, RGS14 labeling in CA2 hippocampal neurons is predominantly found in dendritic shafts (Fig. 1G), as well as necks or heads of dendritic spines (Fig. 1 H and I), including an apparent enrichment at some postsynaptic densities (PSD) (Fig. 1I).\"\n\nSee also: pmd:29518331. Experimental description: - \"Electron Microscopy (EM)\": Mice were transcardially perfused ...\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2018-03-16" ;
        dc:title          "SYNGO_CC_2865" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

