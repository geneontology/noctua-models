gomodel:SYNGO_876  a      owl:Ontology ;
        rdfs:comment      "Automated change 2024-03-14: GO:0099061 replaced by GO:0098839" , "Rationale: The paper characterizes the subcellular localization of both mu-type and delta-type opioid receptors using immuogold-silver and peroxidase labelling.\nFigure 1 is a quantification of the labelled profiles, showing a substantial labeling rate of delta-type opioid receptors at spines.\nFigure 2 presents a quantification, showing that in labelled spines, a small proportion of delta-tpye immunolabeling is at the postsynaptic membrane.\nFigure 6 is a scheme illustrating the main subcellular localization of the receptors.. Experimental description: 'Seven adult male Sprague Dawley rats (250-350 gm; Taconic, Germantown, NY) were anesthetized with sodium pentobarbital (100 mg/kg, i.p.).'" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-3185-5709" , "https://orcid.org/0000-0001-7351-8706" , "https://orcid.org/0000-0003-0938-8534" , "https://orcid.org/0000-0002-0755-5899" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_876" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

