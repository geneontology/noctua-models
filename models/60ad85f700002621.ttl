gomodel:60ad85f700002621
        a                 owl:Ontology ;
        rdfs:comment      "These four genes (BLM, FES, MAN2A2, HDDC3) are next to each other on chr15q26.1 and all 4 are driven by one enhancer bound by GR within a BLM intron. This model is an attempt to capture this 'one enhancer for four target gene promoters' system. Furthermore, they reside in the same Topologically Associated Domain (TAD).\n\nThis model evolved to having one NR3C1 glucocorticoid receptor activity unit because in this case it binds to ONE enhancer that activates the proomoters of its four target genes." , "Automated change 2023-03-16: RO:0002213 replaced by RO:0002407" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-6913-5104" , "https://orcid.org/0000-0002-1706-4196" , "https://orcid.org/0000-0002-8534-6582" ;
        dc:date           "2026-06-05" ;
        dc:title          "Transcription Factor - Target Gene NR3C1 BLM FES HDDC3 MAN2A2" ;
        pav:providedBy    "http://greekc.org" , "http://www.wormbase.org" ;
        biolink:in_taxon  obo:NCBITaxon_9606 .

