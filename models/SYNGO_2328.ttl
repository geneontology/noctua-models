obo:GO_0099151  a  owl:Class .

gomodel:SYNGO_2328  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.4: \"Direct aggregation of NGL-3 on the surface of dendrites induces coclustering of excitatory postsynaptic proteins\"\nFig.5: \"Knockdown of NGL-3 leads to decreases in the number and function of excitatory synapses\"\nFig.8: \"LAR expressed in non-neural cells induces excitatory postsynaptic differentiation in contacting dendrites\". Experimental description: Dissociated culture is of rat species: \" Briefly, primary hippocampal neuron cultures at 10 d in vitro (10 DIV) prepared from embryonic day 18-19 (E18-19) rats were cocultured with HEK293T cells expressing NGLs, LAR or EGFP, followed by immunostaining at 13 DIV. \"\n\n15/01/2018 Pim\n- Overexpressed LRRC4b is of rat species: \"Full-length human NGL-1 (NM_020929, amino acids 1-641) and rat NGL-3 (XM_218615, amino acids 1-709) were subcloned into pEGFP-N1 (Clontech).\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-6194-9648" , "https://orcid.org/0000-0001-5518-6584" ;
        dc:date           "2018-01-25" ;
        dc:title          "SYNGO_BP_2328" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .
