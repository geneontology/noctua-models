obo:ECO_0006013  a  owl:Class .

gomodel:SYNGO_2144  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.3: \"NMDA-mediated synaptic activity and plasticity in Tg+/kif17-/- mice\"\nKIF17 mutants show defects in LTP induction. These results suggest that mutation of the KIF17 CTD leads to defective NMDA receptor-dependent synaptic activity and plasticity.\n\nFig.4 OE of KIF17 mutants in KIF17 null background showed that GluN2B clusters were much less mobile, traveling anterogradely at a much slower velocity. Fig.6/7 KIF17 mutants show reduced amounts of functional NMDARs on the neuronal surface.. Experimental description: \"Transgenic founder mice were produced by microinjection....\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-6153-3586" , "https://orcid.org/0000-0002-2666-0758" ;
        dc:date           "2023-03-04" ;
        dc:title          "SYNGO_BP_2144" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

