dc:source  a    owl:AnnotationProperty .

gomodel:SYNGO_5079  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 2: eEF1A constructs were generated by PCR amplification of the desired cDNA sequences of rat eEF1A1 and eEF1A2. Overexpressing a control construct, eEF1A1 and eEF1A2 in DIV2 hippocampal neurons enabled observation of the effects of both eEF1A isoform on postsynaptic gephyrin (GPHN) clusters. The effect of both isoforms was very similar, resulting in increased number, size and density of postsynaptic gephyrin clusters.. Experimental description: plasmids:\n\"eEF1A constructs were generated by PCR amplification of the desired cDNA sequences of rat eEF1A1 and eEF1A2. PCR products were cloned into pcDNA3.1 mCherry (Jeromin, Seattle) using BamHI sites inserted at the 5'- and the 3'-end of the PCR products, resulting in C-terminal fusion constructs with mCherry. At the N-terminus, all fusion proteins were tagged with a hexahistidyl peptide sequences. Expression constructs have been sequenced, and expression was confirmed by Western blot analysis and immunofluorescence of transfected hippocampal neurons.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-4973-5732" ;
        dc:date           "2023-02-23" ;
        dc:title          "SYNGO_BP_5079" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

