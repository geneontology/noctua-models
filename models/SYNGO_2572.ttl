obo:ECO_0006054  a  owl:Class .

gomodel:SYNGO_2572  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.1: \"Ghrelin was applied for 60 min (Fig. 1A3 and C). In control slices, the average spine density was 0.302/unit area ± 0.039 SEM (n = 30 images taken from 10 slices) (Fig. 1A2). Ghrelin (200 nM) increased the average spine density to 0.499/unit area ± 0.058 SEM (n = 30 images taken from 10 slices, p < 0.001) (Fig. 1A3). The effect of ghrelin was blocked by the ghrelin receptor antagonist, D-Lys3-GHSR-6 (100 uM) (0.333/unit area ± 0.041 SEM, n = 30 images taken from 10 slices), suggesting the involvement of the ghrelin receptor activation and possible downstream signaling cascades in the induction of ghrelin-mediated changes in dendritic spines.\". Experimental description: \"The hippocampal slice culture was prepared from P6 postnatal male pups of Sprague-Dawley rats ...\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2018-02-16" ;
        dc:title          "SYNGO_BP_2572" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

