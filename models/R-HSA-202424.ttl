	<http://www.w3.org/2000/01/rdf-schema#comment> "For logical inference, import the integrated tbox ontology http://purl.obolibrary.org/obo/go/extensions/go-lego-reacto.owl" , "http://www.reactome.org" , "Imported from Reactome: https://reactome.org/content/detail/R-HSA-202424" ;
	<http://purl.org/dc/elements/1.1/title> "Downstream TCR signaling - imported from: Reactome" ;
	<http://purl.org/dc/elements/1.1/contributor> "GOC:reactome_curators" ;
