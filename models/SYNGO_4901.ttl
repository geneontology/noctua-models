gomodel:SYNGO_4901  a     owl:Ontology ;
        rdfs:comment      "Rationale: The paper demonstrates that autophagy is required for LTD at Schaffer collateral synapses. Fig. 7 shows that both conditional knockout and shRNA knockdown of ATG5 disrupts the maintenance of LTD induced by either low-frequency stimulation, or the application of NMDA, or of the group 1 mGluR agonist DHPG. ATG5-cKO also leads to altered cognitive flexibility (Fig. 8).. Experimental description: \"The mice were maintained in a pathogen-free environment and housed in groups of five animals per cage with constant temperature and humidity and a 12 h/12 h light/dark cycle.\" (p.17)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9880-1214" , "https://orcid.org/0000-0002-0269-0311" , "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-9681-3318" ;
        dc:date           "2023-01-29" ;
        dc:title          "SYNGO_BP_4901" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

