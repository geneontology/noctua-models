obo:ECO_0007695  a  owl:Class .

pav:providedBy  a  owl:AnnotationProperty .

gomodel:SYNGO_1800  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.5: Myo6 exists in a complex with the AMPAR, AP-2, and SAP97 in rat brain\nFig.6: Sv/sv hippocampal neurons display dysfunctional AMPA-induced AMPAR internalization\nFig.7: Sv/sv hippocampal neurons display dysfunctional insulin-induced AMPAR internalization identical to the disruption of clathrin-mediated endocytosis. Experimental description: M&M:\nSv/wt (Myo6sv/J) mice were purchased from The Jackson Laboratory\n\nFor immunohistochemistry 1-yr-old C57/B6J mice (The Jackson Laboratory) were used.\n\nC57/B6J mouse brains or Lewis rat brain regions were homogenised and used for PSD fractionations\n\nIPs were done by extracts made from adult rat brain." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-6153-3586" , "https://orcid.org/0000-0002-2666-0758" ;
        dc:date           "2018-05-30" ;
        dc:title          "SYNGO_BP_1800" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

