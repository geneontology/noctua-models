gomodel:SYNGO_348  a      owl:Ontology ;
        rdfs:comment      "Rationale: Syntaxin 2 is detected by immunoblotting in all fractions derived from rat brain subcellular fractionation (Fig. S3). Note that the protein was not particularly enriched in the SV fraction relative to other fractions. This is might be an indirect evidence that it localizes to synaptic plasma membranes (similar to syntaxin 1), however it can not be excluded that it's present on SV membranes as well. Further investigation is required.. Experimental description: Purification of SVs from Rat Brain:\nSVs were purified from rat brain, as described in detail in previous pub-\nlications (Nagy et al., 1976; Huttner et al., 1983)." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-1542-3498" , "https://orcid.org/0000-0002-0808-7003" , "https://orcid.org/0000-0002-3898-5197" ;
        dc:date           "2017-10-09" ;
        dc:title          "SYNGO_CC_348" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

