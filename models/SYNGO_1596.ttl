gomodel:SYNGO_1596  a     owl:Ontology ;
        rdfs:comment      "Rationale: hnRNP K localised is enriched in dendritic spines of primary rat hippocampal neurons (div 18). Since the overlap with PSD-95 staining is better than with VGLUT staining, the signal is assumed to be post-synaptic.\n\n25/9/2017 Pim\n- Literal: \"In hippocampal neurons, hnRNP K was detected in the dendritic spines and colocalized with the presynaptic protein VGLUT1 and the postsynaptic scaffolding protein PSD-95\". Experimental description: \"All experiments were performed on dissociated hippocampal neurons prepared from rat embryos of either sex at a gestational age of 18 d and transfected at 12 d in ...\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9848-0262" , "https://orcid.org/0000-0002-4419-210X" , "https://orcid.org/0000-0002-2094-7491" , "https://orcid.org/0000-0002-1190-4481" ;
        dc:date           "2017-09-25" ;
        dc:title          "SYNGO_CC_1596" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

