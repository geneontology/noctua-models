gomodel:SYNGO_3804  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.1: \"OPHN1 Is Important for Efficient SV Endocytosis\"\nFig.2: \"Presynaptic OPHN1 Knockdown Augments Short-Term Synaptic Depression\"\nFig.3: \"Interaction of OPHN1 with Endophilin A1 (Endo A1)\"\nFig.4: \"OPHN1/Endophilin A1 Interaction and OPHN1 Rho-GAP Activity Are Important for Efficient SV Endocytosis\"\n\nNote:\nEndophilin is also known to be involved in 'regulation of synaptic vesicle endocytosis (GO:1900242)'.. Experimental description: - \"Primary hippocampal neuron cultures were prepared from embryonic day 18 old rats as previously described [12].\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0003-0593-3443" ;
