obo:GO_0003674  a  owl:Class .

gomodel:SYNGO_3801  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.2: \"HCN1 Deletion Increases Magnitude and Prolongs Duration of Distal Ca2+ Events\"\nFig.3: \"Pharmacological Blockade of Ih with ZD7288 Increases Amplitude and Duration of Distal Ca2+ Events\"\nFig.5: \"Acute Blockade of Ih Prolongs Duration of the Long-Lasting Dendritic Depolarization in Response to PP but Not SC Stimulation\"\nFig.6: \"Ca2+ Signals in Distal Dendrites Are Initiated by Activation of NMDA and AMPA Receptors, and Mediated by Ni2+-Insensitive T-Type and N-Type Voltage-Gated Ca2+ Channels\"\nFig.8: \"Coapplication of ZD7288 with Elevated KCl Prevents the Hyperpolarization Induced by Ih Blockade and Inhibits Ca2+ Spike Enhancement\"\n\nNote: the involvement of HCN1 in regulation of NMDA and AMPAR currents places the function of HCN1 in the synaptic scope.. Experimental description: - \"Horizontal brain slices were prepared from P30-P50 HCN1 KO mice (-/-) or wild-type (+/+) littermates\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2021-01-02" ;
        dc:title          "SYNGO_BP_3801" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

