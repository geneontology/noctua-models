obo:ECO_0001225  a  owl:Class .

gomodel:SYNGO_1656  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig2 shows that in the developing calyx synapse of Septin 5 null mice there are more vesicles associated with the active zone (Fig2 E, G, H & I) at the age of P8-9. This difference is gone in mature calyx synapses at P16-18 (Fig2 F-I). This phenotype is mirrored by an enhanced evoked response, larger RRP and less synaptic decay in immature calyx synapses of Septin 5 null animals (Fig3). The lack of phenotype in neurosecretion in adult animals is also reported in hippocampus (see additional ref 11739749).. Experimental description: M&M\" \"Brainstem slices were prepared from P8-P19 mice of wild-type and Sept5 knockout genotype (CD1 strain).\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0001-5259-4945" ;
        dc:date           "2017-10-26" ;
        dc:title          "SYNGO_BP_1656" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

