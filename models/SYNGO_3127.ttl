gomodel:SYNGO_3127  a     owl:Ontology ;
        rdfs:comment      "Rationale: [Fig.1: \"Effects of Sema3A or Sema7A knockdown in Purkinje cells on climbing fiber synapse elimination in olivo-cerebellar cocultures.\"]\n\n[Fig.2: \"Postsynaptic Sema3A and Sema7A have opposite effects on climbing fiber synapse elimination in vivo.\"]\n\n[Fig.3: \"Sema7A mediates synapse elimination downstream of mGluR1\"]\n\nFig.4: \"Sema3A and Sema7A regulate synapse elimination through their receptors on climbing fibers.\". Experimental description: - \"Retrograde semaphorin signaling regulates synapse elimination in the developing mouse brain\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0003-0593-3443" ;
