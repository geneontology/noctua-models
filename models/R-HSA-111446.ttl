oboInOwl:hasDbXref  a  owl:AnnotationProperty .

:R-HSA-111446  a            owl:NamedIndividual , obo:GO_1903749 ;
        rdfs:comment        "BIM acts as a sentinel to check the integrity of the cytoskeleton. It exists as two variant proteins: BIM-EL and BIM-L. In healthy cells, these two isoforms are sequestered to the dynein motor complex on microtubules via the dynein light chain DLC1. JNK or MAPK8 releases BIM in response to UV irradiation by phosphorylation." ;
        rdfs:label          "Activation of BIM and translocation to mitochondria" ;
        dc:contributor      "Reviewed: Vaux, D, 0000-00-00 00:00:00" , "Authored: Gopinathrao, G, 2004-08-19 20:25:42" , "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-111446" ;
