gomodel:SYNGO_74  a       owl:Ontology ;
        rdfs:comment      "Rationale: Using immuno electron microscopy, it is demonstrated that RIBEYE is specifically located in the ribbon of the ribbon synapse.. Experimental description: Immunogold electron microscopy was performed largely as previously described (Schmitz and Drenckhahn 1993). Bovine retina fixed with 2% freshly depolymerized paraformaldehyde, 0.1% glutaraldehyde in PBS for 3 hr at 4°C were washed with PBS (six times, each for 10 min) and infiltrated with 0.5% tannic acid (Mallinckrodt) in PBS (1 hr at 4°C)." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-7620-2704" , "https://orcid.org/0000-0002-1558-1958" ;
        dc:date           "2017-03-28" ;
        dc:title          "SYNGO_CC_74" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_9913" .

