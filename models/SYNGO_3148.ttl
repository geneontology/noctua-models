obo:ECO_0000303  a  owl:Class .

<http://identifiers.org/rgd/621182>
        a       owl:Class .

gomodel:SYNGO_3148  a     owl:Ontology ;
        rdfs:comment      "Rationale: 14/5/2018 Pim\nrule: NAS_CPLX_1\nrationale: Polyribosomes are present in dendritic spines (PMID:12165474, electron microscopy). RL18 is a generally accepted constituent of the ribosome. No functions of RL18 are known independent from the ribosomal complex. Inference to term 'ribosome (GO:0005840)' part_of 'postsynapse (GO:0098794)' is trivial.\nC_ref CC: PMID:12165474 (dendritic spine head)\nP_inf CC: SynGO ID #618\nP_inf CC additional:\n- Collins et al.(2006), PMID:16635246, consensus, prep:psd\n- Distler et al.(2014), PMID:25211037, Table S1, prep:synapse\nComplex membership: RL18 protein is a fixed member of the 60S ribosomal subunit complex.\n- Shown in crystal structure (PMID:28138070, see Fig.1, name: eL18)\n- GO annotations to 'structural constituent of ribosome' (ISO and IEA). Experimental description: \"PSD fractions were prepared from rat forebrains largely as previously described (4, 9).\" p. 21004" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9880-1214" , "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-9681-3318" , "https://orcid.org/0000-0002-0269-0311" ;
        dc:date           "2018-05-23" ;
        dc:title          "SYNGO_CC_3148" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

