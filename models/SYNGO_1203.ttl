gomodel:SYNGO_1203  a     owl:Ontology ;
        rdfs:comment      "Rationale: GluR1 detection with immuno EM in presynaptic glutamatergic terminals in neostriatum\n\n8/9/2017 Pim\n- Only plasma membrane annotation made since relating to known function of the protein.\n- Based on the known transmembrane topology of the protein, the \"integral component of ... membrane\" term was chosen. Experimental description: Nine rats were deeply anaesthetized (700 mg chloral hydrate / kg) and perfused transcardially with 200 mL of PBS, followed by 300 mL of 4% paraformaldehyde and 0.1% glutaraldehyde in 0.1 m phosphate- NaOH buffer, pH 7.4 (PB)." , "Automated change 2024-03-14: GO:0099059 replaced by GO:0048787" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0001-9425-2935" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_1203" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

