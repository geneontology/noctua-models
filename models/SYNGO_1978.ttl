gomodel:SYNGO_1978  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.1: congenital myasthenic syndrome patient shows abnormal channel kinetics of motor endplate synapses.\n(The abnormal kinetic are traced back to a eT264P mutation in the epsylon subunit of the muscle type nAChR (Fig.3))\nFig.4: this effect on ch channel kinetics was confirmed recordings on heterologous expression of WT and eT264P mutant receptors in HEK cells.. Experimental description: Data is on human motor end plates (EP) of congenital myasthenic syndrome patient." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2017-12-24" ;
        dc:title          "SYNGO_MF_1978" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_9606" .

