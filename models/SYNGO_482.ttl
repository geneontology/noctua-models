lego:evidence  a  owl:AnnotationProperty .

gomodel:SYNGO_482  a      owl:Ontology ;
        rdfs:comment      "Rationale: Dlg immunofluorescence on larval neuromuscular junction shows abnormality in synaptic boutons upon Kette mutations.\n\nKette is 60% homologous to human NCKAP1 and 48% homologous to NCKAP1L, as assessed by BLAST. Thus it is the likely ortholog of the NCKAP1 proteins.. Experimental description: The wild-type strain was Sevenless" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-1190-4481" , "https://orcid.org/0000-0002-2094-7491" , "https://orcid.org/0000-0002-4419-210X" , "https://orcid.org/0000-0002-9848-0262" ;
