gomodel:ev_w_id_R-HSA-3772436_RO_0002333_R-HSA-3772436_R-HSA-3772407_Reactome_R-HSA-201688
        a               owl:NamedIndividual , obo:ECO_0000313 ;
        dc:contributor  "GOC:reactome_curators" ;
