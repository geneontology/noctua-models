:R-HSA-72731  a             owl:NamedIndividual , obo:GO_0008150 ;
        rdfs:comment        "The active eIF2:GTP complex may be formed by direct binding of GTP to free eIF2 or by GDP-GTP exchange on the eIF2:GDP:eIF2B complex. The eIF2:GDP complex binds eIF2B forming an eIF2:GDP:eIF2B intermediate complex. eIF2B is a guanine nucleotide releasing factor required to cause GDP release so that a new GTP molecule can bind and activate eIF2. Phosphorylated eIF2:GDP sequesters all eIF2B as an inactive complex, and thus, reuse of eIF2 is inhibited as a consequence of the tight bond it forms with eIF2B, which prevents nucleotide exchange. Therefore, in the absence of free eIF2B, excess eIF2 remains in its inactive GDP-bound form and protein synthesis slows dramatically." ;
        rdfs:label          "Recycling of eIF2:GDP" ;
        dc:contributor      "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-72731" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-72737/R-HSA-72737> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

<http://identifiers.org/uniprot/Q14232>
