<http://model.geneontology.org/R-HSA-2311324_R-HSA-2172183_controller>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/go/extensions/reacto.owl#REACTO_R-HSA-2311324> ;
        <http://www.w3.org/2000/01/rdf-schema#comment>
                "located_in cytosol" , "Original Reactome ID: R-HSA-2311324" ;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "CCNB1,CCNB2:p-T161-CDK1" ;
        <http://purl.org/dc/elements/1.1/contributor>
