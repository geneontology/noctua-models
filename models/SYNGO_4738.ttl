gomodel:SYNGO_4738  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 2: Synaptic NMDAR-dependent calpain activation degrades PHLPP1 and activates Akt and ERK1/2 pathway. (rat brain P2 fraction, purified μ-calpain = CAPN1, calpain 1)\n\nFigure 6: A μ-calpain-specific inhibitor blocks synaptic NMDAR-induced PHLPP1 degradation but not extrasynaptic NMDAR induced neurotoxicity.\n\nFigure 8: μ-calpain but not m-calpain (CAPN2, calpain 2) is recruited to synaptic NMDAR complex following synaptic NMDAR activation.. Experimental description: M&M: \"Primary neuronal cultures. Cortical tissues were dissected from embryonic day 18 rats and digested with papain (2 mg/ml, Sigma) for 30 min at 37°C.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2022-08-02" ;
        dc:title          "SYNGO_BP_4738" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

