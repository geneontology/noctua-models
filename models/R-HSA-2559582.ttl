<http://model.geneontology.org/ev_w_id_R-HSA-3788745_BFO_0000066_reaction_R-HSA-3788745_location_lociGO_0005654_Reactome_R-HSA-2559582>
        a       <http://purl.obolibrary.org/obo/ECO_0000313> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
        <http://purl.org/dc/elements/1.1/contributor>
