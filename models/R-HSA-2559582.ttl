<http://model.geneontology.org/R-HSA-68524_R-HSA-3788724>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/go/extensions/reacto.owl#REACTO_R-HSA-68524> ;
        <http://www.w3.org/2000/01/rdf-schema#comment>
                "located_in nucleoplasm" , "Original Reactome ID: R-HSA-68524" ;
