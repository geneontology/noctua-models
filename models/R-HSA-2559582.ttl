gomodel:ev_w_id_R-HSA-3788745_BFO_0000066_reaction_R-HSA-3788745_location_lociGO_0005654_Reactome_R-HSA-2559582
        a               owl:NamedIndividual , obo:ECO_0000313 ;
        dc:contributor  "GOC:reactome_curators" ;
