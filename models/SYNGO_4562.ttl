obo:GO_0098842  a  owl:Class .

gomodel:SYNGO_4562  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig. 4A shows colocalization of SNX27 with early endosomes marked by Rab5 in postsynaptic puncta of hippocampal neurons (16 DIV).. Experimental description: \"Hippocampal neuronal cultures were prepared from P0 mouse pups\", p. 11\n\nGFP-SNX27 and mCherry SNX27 were generated by subcloning human SNX27 (Origene) into pEGFP-N1 or pmCherry-N1 (Clontech) using Bgl11 and BamH1.\n\nThe source or generation of the antibody for targeting endogenous SNX27 and Rab5 is not described." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-9880-1214" , "https://orcid.org/0000-0002-0269-0311" , "https://orcid.org/0000-0002-9681-3318" ;
        dc:date           "2023-03-01" ;
        dc:title          "SYNGO_CC_4562" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

