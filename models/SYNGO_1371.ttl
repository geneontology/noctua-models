obo:ECO_0007719  a  owl:Class .

gomodel:SYNGO_1371  a     owl:Ontology ;
        rdfs:comment      "Rationale: 28/8/2017 Pim\n- CYFIP1 Is Part of Two Complexes, the WRC actin-regulatory complex and the FMRP-eIF4E translational complex (Fig.1)\n- BDNF-induced Rac1 activation inhibits CYFIP interaction with the FMRP-eIF4E translational complex (Fig.2)\n- Rac1 activation promotes CYFIP1 and FMRP-Dependent mRNA Translation of the synaptic target protein Arc (Fig.3).. Experimental description: 3- to 4-week-old males C57BL/6J\n\nCyfi-EGFP construct is human: \" Human CYFIP1 coding region (Q7L576) was cloned into the pEYFP-C1 plasmid (Clontech)\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2094-7491" , "https://orcid.org/0000-0002-4419-210X" , "https://orcid.org/0000-0002-1190-4481" , "https://orcid.org/0000-0002-9848-0262" ;
        dc:date           "2017-12-18" ;
        dc:title          "SYNGO_BP_1371" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

