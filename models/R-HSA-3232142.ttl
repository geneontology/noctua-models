oboInOwl:hasDbXref  a  owl:AnnotationProperty .

:R-HSA-3232142  a           obo:GO_0008150 , owl:NamedIndividual ;
        rdfs:comment        "Several ubiquitin E3 ligases are regulated by SUMOylation (reviewed in Wilson and Heaton 2008). SUMOylation appears to be necessary for nuclear import of MDM2, the E3 ligase that ubiquitinylates TP53 (p53). SUMOylation of VHL abolishes its ubiquitin ligase activity. HERC2, RNF168, and BRCA1 are ubiquitin ligases that are SUMOylated during DNA damage response and repair." ;
        rdfs:label          "SUMOylation of ubiquitinylation proteins" ;
        dc:contributor      "GOC:reactome_curators" , "Reviewed: Niskanen, Einari, 2018-05-09" , "Authored: May, B, 2013-03-23" , "Reviewed: Niskanen, Einari, 2018-08-08" , "Edited: May, B, 2013-03-23" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-3232142" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-3108232/R-HSA-3108232> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

