[ a                      owl:Axiom ;
  rdfs:comment           "ES: We investigated LET-23 expression using a LET-23–GFP fusion protein 36 and LET-23 antibodies.  Both methods revealed LET-23 expression in the ALA neuron, identified by the position of its cell body in the dorsal ganglion and its two lateral axonal projections, in two ventral head neurons that send projections into the nerve ring, and in a single tail neuron (Fig. 3a)." ;
  lego:evidence          :57c82fad00000294 ;
  dc:contributor         "https://orcid.org/0000-0002-1706-4196" ;
  dc:date                "2016-09-07" ;
  owl:annotatedProperty  obo:BFO_0000050 ;
  owl:annotatedSource    :57c82fad00000292 ;
  owl:annotatedTarget    :57c82fad00000291
] .

