:R-HSA-212718  a            owl:NamedIndividual , obo:GO_0007165 ;
        rdfs:comment        "Activated epidermal growth factor receptors (EGFR) can stimulate phosphatidylinositol (PI) turnover. Activated EGFR can activate phospholipase C-gamma1 (PLC-gamma1, i.e. PLCG1) which hydrolyses phosphatidylinositol 4,5-bisphosphate (PIP2) to inositol 1,4,5-triphosphate (IP3) and diacylglycerol (DAG). IP3 is instrumental in the release of calcium from intracellular stores and DAG is involved in protein kinase C activation." ;
        rdfs:label          "EGFR interacts with phospholipase C-gamma" ;
        dc:contributor      "Authored: Jassal, Bijay, 2008-02-13" , "Reviewed: Heldin, CH, 2008-02-12 09:44:02" , "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-212718" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-177929/R-HSA-177929> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

