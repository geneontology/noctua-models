obo:ECO_0006048  a  owl:Class .

gomodel:SYNGO_2400  a     owl:Ontology ;
        rdfs:comment      "Rationale: LTP induced by theta-burst stimulation was reduced at BCR-/- SC-CA1 synapses compared with that at WT synapses.. Experimental description: Materials and Methods\nAnimals.\nBCR-/- and ABR-/- mice in genetic backgrounds of 50% 129Sv plus 50% C57BL/6 and 50% 129Sv plus 50% Black Swiss, respectively, were backcrossed with C57BL/6 females. Littermates were used as controls for spine analysis, LTP/long-term depression (LTD) analysis, and all behavioral assays." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-6194-9648" , "https://orcid.org/0000-0001-5518-6584" ;
        dc:date           "2018-02-07" ;
        dc:title          "SYNGO_BP_2400" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

