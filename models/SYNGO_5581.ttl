gomodel:SYNGO_5581  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 7: Norbin specifically regulates the mGluR-mediated AMPAR endocytosis.\n\nFigure 9: PKA binding to AMPARs through Norbin is critical for the mGluR-mediated AMPAR endocytosis.\n\nauthors conclude:\n\"Together, these results suggest that activation of Group I mGluRs led to enhanced interaction of PKA with the AMPARs, which is essential for the mGluR-mediated AMPAR endocytosis; and Norbin acts as a scaffolding protein which recruits PKA to the AMPARs subsequent to the activation of Group I mGluRs.\". Experimental description: M&M: \"Primary neuron cultures were prepared from P0 C57BL/6 mice of both sexes as described previously with minor change\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2023-11-28" ;
        dc:title          "SYNGO_BP_5581" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

