lego:evidence  a  owl:AnnotationProperty .

gomodel:SYNGO_1829  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.6 The ECD of IL-1RAcP and IL-1RAcPb bind the PTPδ ECD\nFig.9 PTPδ induces postsynaptic differentiation through IL-1RAcPb (shown with PTPδA3-ECD-Fc beads on neurons of wild-type (Il1rap+/+) and IL-1RAcP knock-out (Il1rap-/-) mice). Experimental description: - Overexpressed PTPδ is of mouse species; \"The entire coding sequences of mouse IL1RAPL1, IL-1R type 1 (IL-1R1), N-cadherin, neuroligin (NLGN) 1, PTPδ, PTPδA6...\" (traced back to PMID:21940441)\n- Cells are of mouse species: \"Cell cultures, transfection, and coculture assay. Primary cortical cultures were prepared from mice at postnatal day 0 (P0) essentially as described previously\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-2949-9725" , "https://orcid.org/0000-0003-0662-9523" ;
        dc:date           "2017-11-06" ;
        dc:title          "SYNGO_BP_1829" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

