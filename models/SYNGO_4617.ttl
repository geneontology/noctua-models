obo:GO_0098793  a  owl:Class .

gomodel:SYNGO_4617  a     owl:Ontology ;
        rdfs:comment      "Rationale: \"Fig. 5 Ultrastructural location of Mint2 in motor neuron. Preembedding immunogold-silver labeling shows that Mint2 distributed outside nucleus (a), located in vesicle (b), expressed in axons in myelin and presynapse (c, d)\". Experimental description: \"Male Sprague Dawley rats (200-250 g) were obtained from Second Military Medical University. Rats were kept under standard housing condition with 12 h light/dark cycle and free to food and water\"\n\n\"The sections were incubated with mouse anti-Mint1 or mouse anti-Mint2 monoclonal antibody respectively (BD Bioscience, California, USA)\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" ;
