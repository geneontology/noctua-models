        a       owl:Class .

obo:GO_0032455  a  owl:Class .

:R-HSA-167060  a            owl:NamedIndividual , obo:GO_0032455 ;
        rdfs:comment        "All neurotrophins (NTs) are generated as pre-pro-neurotrophin precursors. The signal peptide is cleaved off as NT is associated with the endoplasmic reticulum (ER). The resulting pro-NT can form a homodimer spontaneously which then transits to the Golgi apparatus and then onto the trans-Golgi network (TGN). Resident protein convertases (PCs) can cleave off the pro-sequence and mature NT is is targeted to constitutively released vesicles. The pro-NT form can also be released to the extracellular region." ;
        rdfs:label          "NGF processing" ;
        dc:contributor      "GOC:reactome_curators" , "Reviewed: Greene, LA, 2007-11-08 15:39:37" , "Authored: Nasi, Sergio, Annibali, D, 2006-10-10" , "Edited: Jassal, Bijay, 2006-10-10" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-167060" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-9036866/R-HSA-9036866> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

