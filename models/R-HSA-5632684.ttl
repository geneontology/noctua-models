<http://model.geneontology.org/ev_w_id_R-HSA-5635102_RO_0002233_R-HSA-5610373_R-HSA-5635102_Reactome_R-HSA-5632684>
        a       <http://purl.obolibrary.org/obo/ECO_0000313> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
