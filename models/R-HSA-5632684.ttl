<http://model.geneontology.org/ev_w_id_REACTO_R-HSA-9918351_R-HSA-9918352_R-HSA-5635854_component_BFO_0000051_UniProtKB_P25786_R-HSA-9918351_R-HSA-5635854_component_Reactome_R-HSA-5632684>
        a       <http://purl.obolibrary.org/obo/ECO_0000313> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
        <http://purl.org/dc/elements/1.1/contributor>
