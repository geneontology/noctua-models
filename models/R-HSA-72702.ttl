obo:RO_0002234  a  owl:ObjectProperty .

:R-HSA-72702  a             obo:GO_0008150 , owl:NamedIndividual ;
        rdfs:comment        "The 80S ribosome bound to the mRNA moves along the mRNA molecule from its initial site to the initiation codon and forms a 48S complex, in which the initiation codon is base paired to the anticodon of the Met-tRNAi. Proper recognition of the AUG initiation codon depends on base pairing with the anticodon of the Met-tRNAi and requires eIF1, eIF1A, eIF2 and eIF5." ;
        rdfs:label          "Ribosomal scanning and start codon recognition" ;
        dc:contributor      "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-72702" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-72737/R-HSA-72737> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

