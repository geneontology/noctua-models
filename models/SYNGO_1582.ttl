obo:BFO_0000050  a  owl:ObjectProperty .

gomodel:SYNGO_1582  a     owl:Ontology ;
        rdfs:comment      "Automated change 2024-03-14: GO:0099059 replaced by GO:0048787" , "Rationale: A previously described antibody against mGluR8 (K88) was used to localize mGluR8 in the rat hippocampus. Slices of rat brain were processed for immunogold EM and mGluR8 was found to localize to the presynape of perforant path CA3 and DG neurons. Both symmetric and asymmetric synapses were observed.\n\n20/11/2017 Pim\n- Based on the known transmembrane topology of the protein, the \"integral component of ... membrane\" term was chosen.. Experimental description: Wistar, Materials & Methods" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-1212-5623" , "https://orcid.org/0000-0003-2533-9548" , "https://orcid.org/0000-0003-4022-8707" , "https://orcid.org/0000-0002-5648-066X" , "https://orcid.org/0000-0001-7480-0826" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_1582" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

