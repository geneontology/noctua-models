gomodel:ev_w_id_R-HSA-6793591_RO_0002234_R-ALL-379705_mitochondrial_matrix_Reactome_R-HSA-6793591
        a               owl:NamedIndividual , obo:ECO_0000313 ;
        dc:contributor  "GOC:reactome_curators" ;
