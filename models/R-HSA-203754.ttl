        dc:title          "NOSIP mediated eNOS trafficking - imported from: Reactome" ;
        pav:providedBy    "https://reactome.org" ;
        biolink:in_taxon  obo:NCBITaxon_9606 .

:R-HSA-203754  a            obo:GO_0046209 , owl:NamedIndividual ;
        rdfs:comment        "eNOS-interacting protein (NOSIP) is a 34-kDa nucleocytoplasmic shuttling protein that binds to the COOH-terminal region (amino acids 366-486) of the eNOS oxygenase domain. This protein association promotes translocation of eNOS from the plasma membrane caveolae to the cytoskeleton and inhibits eNOS activity. Studies have found that NOSIP accumulates in the cytoplasm specifically during the G2 phase of the cell cycle." ;
        rdfs:label          "NOSIP mediated eNOS trafficking" ;
        dc:contributor      "Reviewed: Enikolopov, G, 2008-02-28 17:52:44" , "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-203754" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-202131/R-HSA-202131> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

