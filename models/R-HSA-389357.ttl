gomodel:ev_w_id_R-HSA-9755778_R-HSA-198270_controller_BFO_0000051_R-HSA-198270_UniProt_P0DTC5_Reactome_R-HSA-389357
        a               owl:NamedIndividual , obo:ECO_0000313 ;
        dc:contributor  "GOC:reactome_curators" ;
