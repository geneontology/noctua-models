gomodel:SYNGO_595  a      owl:Ontology ;
        rdfs:comment      "Rationale: IF5A1_RAT was found in table 1.\nFor proteins coming from datasets derived from PSD (detergent-resistant synaptic junctions) preparations without defined selection / enrichment of the pre- or postsynaptic compartment we cannot assign these proteins to excitatory and/or inhibitory nor to the presynapse or / and postsynapse without further information.\n\n12/6/2017 Pim\n- The NCBInr protein sequence with id 20864488 was traced back to current rat Uniprot protein sequence wiith accession 'Q3T1J1'. This best match had score:\nE-value: 4.9e-86\nScore: 663\nIdent.: 100.0%\nPositives : 100.0%\nQuery Length: 127\nMatch Length: 154. Experimental description: \"In brief, in the original method, forebrains of 30 days old untreated rats were homogenized in homogenization buffer ...\". P. 988" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9880-1214" , "https://orcid.org/0000-0002-0269-0311" , "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-9681-3318" ;
        dc:date           "2017-06-12" ;
        dc:title          "SYNGO_CC_595" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

