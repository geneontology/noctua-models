obo:BFO_0000050  a  owl:ObjectProperty .

gomodel:SYNGO_733  a      owl:Ontology ;
        rdfs:comment      "Rationale: In fig 4b the authors use cortical cultures from control and knockout mice. Using transfected syaptopHlourin they demonstrated that endocytosis, as determined by quenching of pHlourin fluorescence is decreased in KO mice compared to control following a 10 Hz for 30 sec stimulus. In fig 4d they use the same experimental set up to demonstrate that endocytosis is decreased in the KO mice during stimulation.\n\nIn fig 3C,D the authors demonstrate that synapses in the KO mice depress faster in response to a 20 Hz train of 1000 action potentials. fig 3E reveals that the readily-releasable pool of synaptic vesicles is smaller in the KO mice.\n\nIn fig 5C, the increase in CCVs observed following stimulation of cortical neurons with KCl (driving synaptic vesicle release) is less in KO neurons than in control neurons.. Experimental description: From introduction, \"Exons 2-6 of the PIPK1γ gene (Pip5k1c; hereafter referred to as PIPK1γ), which encode most of the catalytic region, were deleted by homologous recombination in mouse...\"." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-7806-5662" ;
        dc:date           "2018-03-15" ;
        dc:title          "SYNGO_BP_733" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

dc:source  a    owl:AnnotationProperty .

