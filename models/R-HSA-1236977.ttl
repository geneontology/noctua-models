<http://model.geneontology.org/ev_w_id_R-HSA-1236948_RO_0002333_UniProt_P25774_R-HSA-1236948_controller_Reactome_R-HSA-1236977_R-HSA-1236948_enabled_by_UniProt_P25774_R-HSA-1236948_controller>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/ECO_0000313> ;
