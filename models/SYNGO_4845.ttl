obo:ECO_0007695  a  owl:Class .

gomodel:SYNGO_4845  a     owl:Ontology ;
        rdfs:comment      "Automated change 2024-03-14: GO:0099063 replaced by GO:0098944" , "Rationale: Figure 1: Recycling endosomes localize to postsynaptic spines (immunoEM, Fig. 1d). Immunofluorescence imaging shows TfR (Transferrin receptor protein 1), a marker for recycling endosomes, at postsynapses (Fig. 1b,c). This is confirmed by immunogold EM of adult rat CA1 hipocampus (Fig. 1f).\n\nBased on the known transmembrane topology of this protein, \"integral component of ... membrane\" term was selected.. Experimental description: Supplemental M&M: \"Hippocampal neuron cultures were prepared from E18 rat embryos\"\n\nTfR-GFP was kindly provided by Gary Banker (Oregon Health Sciences University).\nTfR-pHluorin was generated by replacing GFP in TfR-GFP with superecliptic pHluorin amplified by polymerase chain reaction (PCR)\nantibody: mouse anti-TfR antibody (Zymed Laboratories Inc.)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_4845" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

