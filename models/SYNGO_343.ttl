obo:RO_0002333  a  owl:ObjectProperty .

gomodel:SYNGO_343  a      owl:Ontology ;
        rdfs:comment      "Rationale: EphrinB2 is required in presynaptic neurons to mediate the formation of presynaptic specializations in response to postsynaptic EphB2 receptors (Fig. 1A,B). Knock-down of ephrinB2 reduces the overall density of presynaptic sites (Fig. 4A,D,E).. Experimental description: \"Primary dissociated cortical neurons were prepared from embryonic day 17 (E17) to E18 rats.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0912-1514" , "https://orcid.org/0000-0002-3670-7863" ;
        dc:date           "2023-11-08" ;
        dc:title          "SYNGO_BP_343" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

