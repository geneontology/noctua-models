:R-HSA-205043  a            obo:GO_0043065 , owl:NamedIndividual ;
        rdfs:comment        "NRIF (nuclear receptor-interacting factor) is a DNA binding protein that is essential for p75-mediated apoptosis in retina and sympathetic neurons. Neurotrophin or proneurotrophin binding to p75TR induces nuclear translocation of NRIF, which involves gamma-secretase cleavage of p75NTR ICD (Intra Cellular Domain). Once in the nucleus, NRIF mediates apoptosis, probably by acting as transcription factor." ;
        rdfs:label          "NRIF signals cell death from the nucleus" ;
        dc:contributor      "Authored: Nasi, Sergio, Annibali, D, 2006-10-10" , "Reviewed: Friedman, WJ, 2008-05-20 12:23:46" , "GOC:reactome_curators" , "Reviewed: Chao, MV, 2008-05-28 09:46:01" , "Edited: Jassal, B, 2008-05-20 12:26:36" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-205043" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-204998/R-HSA-204998> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

