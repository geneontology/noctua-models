gomodel:SYNGO_5145  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 6: confocal imaging of α-actinin-2 (ACTN2) knockdown constructs in 6DIV hippocampal neurons showed formation of dendritic spines was strongly impaired.\n\nauthors conclude:\n\"We found that spines in neurons lacking α-actinin-2 are largely devoid of detectable actin filament bundles, suggesting that α-actinin-2 helps to form a template for the hierarchical addition of PSD molecules within the spine.\". Experimental description: M&M: \"Low-density hippocampal cultures were prepared from E19 rat embryos as described previously\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2023-02-25" ;
        dc:title          "SYNGO_MF_5145" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

