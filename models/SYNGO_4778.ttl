obo:GO_0003674  a  owl:Class .

gomodel:SYNGO_4778  a     owl:Ontology ;
        rdfs:comment      "Automated change 2024-03-14: GO:0099029 replaced by GO:0048787" , "Rationale: Figure 6: \"live-cell labeling of MSNs cotransfected with HA-tagged CACNA2D subunits and soluble\neGFP revealed that all CACNA2D isoforms are expressed on the surface of presynaptic axonal varicosities and thus can in theory contribute to synaptic functions in GABAergic neurons\"\n\nFigure 8: presynaptic overexpression of CACNA2D1 (α2δ-1 Calcium Channel) was enriched at synaptic puncta\n\nDavies A, et al. 2010 (PMID:20080692, Fig. 4G) showed CACNA2D subunits are most likely linked to the plasma membrane via GPI anchor, hence we selected \"anchored component of ... membrane\". Experimental description: M&M:\n\"Animal procedures for WT BALB/c and 2 mutant mice were performed\"\n\n\"Genotyping for the Cacna2d1 gene was done as published previously (Fuller-Bicer et al., 2009) with some modifications by use of standard PCR conditions (annealing at 52°C for 30 s). Primers were as follows: WT-F1: 5'-GAGCTTTCTTTCTTCTGATTCCAC-3', mutant-F2: 5'-CTGCACGAGACTAGTGAGACG-3', R: 5'-ACATTCTCAAGACTGTAGGCAGAG-3'. Expected band sizes were 346 bp for WT (α2δ-1+/+) and 635 bp for knock-out (α2δ-1-/-) animals, respectively, and heterozygous mice showed both bands.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_4778" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

