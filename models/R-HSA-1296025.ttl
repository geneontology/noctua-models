:R-HSA-1296025  a           owl:NamedIndividual , obo:GO_0071805 ;
        rdfs:comment        "ATP sensitive K+ channels couple intracellular metabolism with membrane excitability. These channels are inhibited by ATP so are open in low metabolic states and close in high metabolic states, resulting in membrane depolarization triggering responses such as insulin secretion, modulation of vascular smooth muscle and cardioprotection. The channel comprises four Kir6.x subunits and four regulatory sulphonylurea receptors (SUR) (Akrouh et al, 2009)." ;
        rdfs:label          "ATP sensitive Potassium channels" ;
        dc:contributor      "Edited: Mahajan, SS, 2011-05-23" , "GOC:reactome_curators" , "Authored: Mahajan, SS, 2011-05-18" , "Reviewed: Jassal, Bijay, 2010-09-23" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-1296025" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-1296065/R-HSA-1296065> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

