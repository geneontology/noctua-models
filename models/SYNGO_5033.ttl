gomodel:SYNGO_5033  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 4a: Both CIN85 (SH3KBP1) and dendrin (DDN) were detected in various synaptic biochemical fractions of rat brain, including the postsynaptic density fraction.\n\nFigure 4b: CIN85 (SH3KBP1) synaptic localization was shown using immunofluorescence labeling with confocal imaging of CIN85 and synaptophysin (SYP) in rat hippocampal neurons. The imaging resolution is too low to narrow down localization to pre- and/or post-synapse.. Experimental description: Figure 4 legend: \"Immunofluorescence of endogenous CIN85 and synaptophysin in rat hippocampal neurons\"\nM&M: \"Rabbit anti-dendrin and anti-CIN85 antibodies were raised against the products of pGex4T-1 dendrin-C and pET32a-CIN85.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" ;
        dc:date           "2023-02-18" ;
        dc:title          "SYNGO_CC_5033" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

