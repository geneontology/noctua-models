obo:ECO_0000279  a  owl:Class .

gomodel:SYNGO_5295  a     owl:Ontology ;
        rdfs:comment      "Rationale: protein tyrosine phosphatase-interacting protein 51 (PTPIP51, gene RMDN3) is a known mitochondrial membrane protein (PMID:26899735).\n\nFigure 1: SIM super-resolution microscopy of cultured rat hippocampal neurons showed PTPIP51 localized to the postsynaptic compartment (identified by immunostaining for dendrites with MAP2 and PSD95/DLG4).\n\nFigure 1e: VAPB and PTPIP51 are present in synaptoneurosome biochemical fractions prepared from rat brain.. Experimental description: M&M: \"Hippocampal neurons were obtained from embryonic day 18 rat embryos and cultured in Neurobasal medium ...\"\n\nantibody:\n\"Rabbit and rat antibodies to VAPB and PTPIP51 were as described [9]. PMID:22131369\nRabbit anti-PTPIP51 and chicken anti-MAP 2 were from Gentex.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2023-03-10" ;
        dc:title          "SYNGO_CC_5295" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

