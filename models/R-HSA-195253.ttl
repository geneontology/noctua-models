:R-HSA-195253  a            obo:GO_0008150 , owl:NamedIndividual ;
        rdfs:comment        "The beta-catenin destruction complex plays a key role in the canonical Wnt signaling pathway. In the absence of Wnt signaling, this complex controls the levels of cytoplamic beta-catenin. Beta-catenin associates with and is phosphorylated by the destruction complex. Phosphorylated beta-catenin is recognized and ubiquitinated by the SCF-beta TrCP ubiquitin ligase complex and is subsequently degraded by the proteasome (reviewed in Kimelman and Xu, 2006)." ;
        rdfs:label          "Degradation of beta-catenin by the destruction complex" ;
        dc:contributor      "Edited: Matthews, L, 2007-04-03 12:38:03" , "GOC:reactome_curators" , "Authored: Kimelman, D, 2007-04-03 12:34:14" , "Reviewed: Pagano, M, 2007-04-27 13:02:18" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-195253" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-195721/R-HSA-195721> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

