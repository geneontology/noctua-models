gomodel:SYNGO_1665  a     owl:Ontology ;
        rdfs:comment      "Rationale: This protein shows biochemical enrichment in the PSD fraction of mouse hippocampus, cortex and cerebellum (sTable 1) and co-localizes with HOMER1 in 3D-SIM microscopy of mouse primary hippocampal neurons.\n\n16/10/2017 Pim\n- Homer1 is used as a marker of the postsynapse.\n\nAntibodies used:\nanti-HOMER1 (1 in 1000, cat. no. 160 004, Synaptic systems)\nanti-PLEKHA5 (1 in 250, cat. no. sc-390311, Santa cruz). Experimental description: Materials and Methods, Preparation of cellular sub-fractions:\n\"Subcellular fractions were prepared from 3-month-old C57BL6 mice as described in 41\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2017-10-16" ;
        dc:title          "SYNGO_CC_1665" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

