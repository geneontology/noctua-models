gomodel:ev_w_id_R-HSA-400071_RO_0002411_R-HSA-400092_Reactome_R-HSA-400042_R-HSA-400071_enabled_by_UniProt_P18825_R-HSA-400071_controller
        a               owl:NamedIndividual , obo:ECO_0000313 ;
        dc:contributor  "GOC:reactome_curators" ;
