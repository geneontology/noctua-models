obo:ECO_0006003  a  owl:Class .

gomodel:SYNGO_551  a      owl:Ontology ;
        rdfs:comment      "Rationale: Immuo-EM shows NUFIP1 association both with ribosomes located at the endoplasmic reticulum membrane and polyribosomes near synapses.\n\nFurthermore NUFIP1 is present in active synaptoneurosomes: brain nuclear and synaptoneurosomal extracts were analyzed for the presence of CREB, NUFIP1 and αCaMKII. NUFIP1 was detected in both the nuclear and synaptoneurosomal fractions, whereas the nuclear protein CREB is only present in the nuclear extracts.\n\n29/8/2017 Pim\n- I cannot discern pre- and post-synaptic sites in the EM images in Fig.9 and therefore agree to the non-discriminating term 'synapse (GO:0045202)'.. Experimental description: EM was performed on mouse hippocampal slices\nSynaptosome preparation was performed on rat pups (P12-14)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-1190-4481" , "https://orcid.org/0000-0002-9848-0262" , "https://orcid.org/0000-0002-2094-7491" , "https://orcid.org/0000-0002-4419-210X" ;
        dc:date           "2017-08-29" ;
        dc:title          "SYNGO_CC_551" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

