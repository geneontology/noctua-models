obo:BFO_0000066  a  owl:ObjectProperty .

:R-HSA-428890  a            owl:NamedIndividual , obo:GO_0008150 ;
        rdfs:comment        "ABL (ABL1 or ABL2) plays a dual role in the ROBO pathway. As a key enzymatic component in the signaling pathway, ABL supports repellent signaling (by recruiting the necessary actin binding proteins) and also feeds back on the receptor (by down regulating through phosphorylation) to adjust the sensitivity of the pathway.<br>ABL cooperates with multiple effectors, including the actin binding protein Capulet (Capt) and Orbit/MAST/CLASP, suggesting that ABL simultaneously coordinates the dynamics of two major cytoskeletal systems to achieve growth cone repellent guidance." ;
        rdfs:label          "Role of ABL in ROBO-SLIT signaling" ;
        dc:contributor      "Reviewed: Jaworski, Alexander, 2017-07-31" , "Edited: Garapati, P V, 2008-09-05 06:02:05" , "GOC:reactome_curators" , "Authored: Garapati, P V, 2008-09-05 06:02:05" , "Edited: Orlic-Milacic, Marija, 2017-06-26" , "Reviewed: Kidd, T, 2009-08-18" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-428890" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-376176/R-HSA-376176> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

