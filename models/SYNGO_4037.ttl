gomodel:SYNGO_4037  a     owl:Ontology ;
        rdfs:comment      "Rationale: Oprd1 was detected in Liquid chromatography-mass spectrometry results of LDCVs.\nFigure 1: Subcellular fractionation shows immunoblotting of Oprd1 in LDCVs fraction.\nFigure 2A: Double immunofluorescence staining shows the distribution of Oprd1(green) with Substance P positive LDCV (red).\nFigure 2B: Post-embedding immunogold (inset) staining against Oprd1 displays localisation on the surface of LDCV.\nFigure S2A: Supplementary figure compares Oprd1 staining in oprd -/- and oprd +/+ mice. The lack of staining in oprd -/- displays the specificity of Oprd1 antibody.\nFigure S2C: Cross-reactivity for the secondary antibody was checked in the absence of primary antibody.. Experimental description: Mice were used for EM and immunostaining experiments, while rats were used for subcellular fractionation and MS." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0003-2916-7616" ;
        dc:date           "2020-12-08" ;
        dc:title          "SYNGO_CC_4037" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

