gomodel:SYNGO_5473  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 1, 2: Alsin (ALS2) interacts with GRIP1 and both proteins co-localize at the postsynapse.\n\nFigure 4: Increased ratio of synaptic GluR2-lacking AMPARs versus GluR2-containing AMPARs in ALS2 -/- cortical neurons.\n\nFigure 5: Decreased presentation of GluR2 at the plasma membrane of ALS2 -/- cortical neurons after AMPA treatment.. Experimental description: \"The generation of ALS2 knock-out mice was performed as described previously (Cai et al., 2005)\"\n\nconstruct;\n\"The full-length mouse ALS2 cDNA clone was obtained by a combination of 5' rapid amplification of cDNA ends PCR and screening of a mouse brain cDNA library (Origene, Rockville, MD).\"\n\nantibody:\n\"The alsin polyclonal antibody (1:1000), ALS2-1081, was made by immunizing rabbit with a polypeptide corresponding to alsin residues 1081-1110 (Yamanaka et al., 2003).\" PMID:14668431" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2023-03-19" ;
        dc:title          "SYNGO_BP_5473" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

