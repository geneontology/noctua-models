obo:BFO_0000051  a  owl:ObjectProperty .

:R-HSA-1296072  a           owl:NamedIndividual , obo:GO_0071805 ;
        rdfs:comment        "Voltage-gated K+ channels (Kv) determine the excitability of heart, brain and skeletal muscle cells. Kv form octameric channel with alpha subunits that forms the pore of the channel and associated beta subunits. The alpha subunits associate with beta subunits with a stoichiometry of alpha4beta4.The alpha subunits have been classified into 12 families, 1-12 with several representatives from each family. Members of Kv 1-4 form both homotetramers and heterotetramers, however, members of Kv 5-12 form functional heterotetramers. Kv's are expressed in the axon, at axon nodes, somatodendritic sites and axon termini." ;
        rdfs:label          "Voltage gated Potassium channels" ;
        dc:contributor      "Reviewed: Jassal, Bijay, 2010-09-23" , "Authored: Mahajan, SS, 2011-05-18" , "GOC:reactome_curators" , "Edited: Mahajan, SS, 2011-05-23" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-1296072" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-1296071/R-HSA-1296071> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

