<http://model.geneontology.org/ev_w_id_R-HSA-3318486_RO_0002233_R-ALL-113560_nucleoplasm_Reactome_R-HSA-3214847>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/ECO_0000313> ;
