gomodel:5df932e000002968
        a                owl:Ontology ;
        rdfs:comment     "Shows two possible patterns for activation of GPCR depending on the type of ligand, one by a gene product (receptor ligand activity), and one for a small molecule ligand. Note that this model has two G protein activities, one for the G-alpha subunit (upstream), and another for the Rho GTPase (downstream)." , "Automated change 2026-03-12: GO:0005615 replaced by GO:0005576" , "Automated change 2023-03-16: RO:0002213 replaced by RO:0002629" ;
        lego:modelstate  "development" ;
        dc:contributor   "https://orcid.org/0000-0002-9074-3507" ;
        dc:date          "2026-03-12" ;
        dc:title         "GPCR signaling through G-alpha-12/13 (Rho-activating)" ;
        pav:providedBy   "http://geneontology.org" .

