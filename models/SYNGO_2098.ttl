obo:ECO_0005589  a  owl:Class .

gomodel:SYNGO_2098  a     owl:Ontology ;
        rdfs:comment      "Rationale: Over-expresison of dominant negative Rab8 decreases AMPAR currents (Fig 1) and surface levels of GluR2 (Figure 4) by regulating both basal as well as activity dependent synaptic insertion of AMPARs (Figs 5 and 7).\n\n---------------\nNote: The cellular location of rab8 in synapses in unknown and might include the TGN or recycling endosomes (see model in Fig.8). Neither of these routes is detailed in the experiments. As a result, the selected term does not mention a source cellular compartment involved in the NTR trafficking event.. Experimental description: - Over-expressed protein was from rat species: \"Rab8a, Rab4a, and Rab11a coding sequences were cloned by PCR from a commercial rat brain cDNA preparation (catalog no. 7150; Clontech).\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-5615-1014" ;
        dc:date           "2018-01-24" ;
        dc:title          "SYNGO_BP_2098" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

