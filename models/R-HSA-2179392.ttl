:R-HSA-2179392  a           owl:NamedIndividual , obo:GO_0008150 ;
        rdfs:comment        "Gastrin, through the action of diacylglycerol produced from downstream G alpha (q) events, transactivates EGFR via a PKC-mediated pathway by activation of MMP3 (Matrix Metalloproteinase 3) which allows formation of mature HBEGF (heparin-binding epidermal growth factor) by cleaving pro-HBEGF. Mature HBEGF is then free to bind the EGFR, resulting in EGFR activation (Dufresne et al. 2006, Liebmann 2011)." ;
        rdfs:label          "EGFR Transactivation by Gastrin" ;
        dc:contributor      "Authored: Jassal, Bijay, Tripathi, S, 2012-04-04" , "Reviewed: D'Eustachio, P, 2012-04-23" , "Edited: Jassal, Bijay, Tripathi, S, 2012-04-04" , "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-2179392" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-881907/R-HSA-881907> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

