obo:GO_0003674  a  owl:Class .

gomodel:SYNGO_1808  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.6:\n- MyoVb is Required for LTP-Induced Spine Exocytosis. Tested with optical physiology using a TfR-superecliptic pHluorin.\n- Disrupting MyoVb Prevents Both AMPA Receptor Delivery and Spine Growth Following LTP Stimuli. Tested with optical physiology using a GluR1-superecliptic pHluorin.\n\n3/11/2017 Pim\n- I have decided against functionally linking role in RE-localization to the the observed phenomena of AMPAR insertion and spine morphology since not directly shown in paper.. Experimental description: M&M:\nHippocampal neuron cultures were prepared from E18 rat embryos\nco-IPs of endogenous proteins were done from whole rat brains\nElectrophysiology was done in brain slices from MyoVb Y119G transgenic mice or wild type FVB mice (Charles River)\n\n3/11/2017 Pim\n-Experiments in Fig.6 are with rat neurons" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-6153-3586" , "https://orcid.org/0000-0002-2666-0758" ;
        dc:date           "2017-11-03" ;
        dc:title          "SYNGO_BP_1808" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

