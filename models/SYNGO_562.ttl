gomodel:SYNGO_562  a      owl:Ontology ;
        rdfs:comment      "Rationale: Purified synaptic vesicles from a crude hippocampal LS1 fraction were analyzed\nusing western blotting to identify the expression of VGLUT1.\nIn Figure 4b the LS1 fraction was analyzed using western blotting. A clear signal for VGLUT1 was observed in the total crude vesicular fraction (lane T), indicating that a subset of SVs in the fraction is expressing VGLUT1. As an indirect control for antibody specificity, a subset of the SVs that were immunoisolated for VGLUT2 do not show a VGLUT1 WB signal.. Experimental description: Wistar rats, kept at the animal facilities at the Institute of Basic Medical Sciences,\nUniversity of Oslo (Norway) or at VU University Medical Center (Amsterdam, The\nNetherlands), were handled according to the European regulations and under\nveterinary agreement and supervision." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-7351-8706" , "https://orcid.org/0000-0002-0755-5899" , "https://orcid.org/0000-0003-0938-8534" , "https://orcid.org/0000-0003-3185-5709" ;
        dc:date           "2017-08-16" ;
        dc:title          "SYNGO_CC_562" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

