obo:UBERON_0002421  a  owl:Class .

gomodel:SYNGO_5433  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 6, S4: immunofluorescence imaging of overexpressed TANC2 in hippocampal neurons showed enrichment in dendritic spines and strong co-localization with PSD marker proteins PSD95 (DLG4) and Homer. Analysis of the truncated isoforms revealed that the C-terminal part of TANC2 (1501-1900), which includes the PDZ binding domain, is responsible for the synaptic localization (Figure S4A). Further, TANC2 pulldowns suggested interaction with various PSD proteins.. Experimental description: M&M: \"Female pregnant Wister rats were obtained from Janvier Laboratories. Hippocampal neurons were obtained from embryos of both genders at the embryonic day 18 (E18) stage of development.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-4973-5732" ;
        dc:date           "2023-03-16" ;
        dc:title          "SYNGO_CC_5433" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

