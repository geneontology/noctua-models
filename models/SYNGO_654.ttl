gomodel:SYNGO_654  a      owl:Ontology ;
        rdfs:comment      "Rationale: CPEB, and specifically synaptic CPEB, is needed for long-term facilitation (LTF) in Aplysia, as evidenced by inhibition of CPEB expression using an antisense oligo.\n\nNote that Aplysia has probably only one CPEB family member, i.e., it is not self-evident that the functional orthologue of ApCPEB (in this instance) is CPEB3 rather than CPEB1 or CPEB4.. Experimental description: Aplysia californica" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4419-210X" , "https://orcid.org/0000-0002-2094-7491" , "https://orcid.org/0000-0002-9848-0262" , "https://orcid.org/0000-0002-1190-4481" ;
        dc:date           "2018-05-31" ;
        dc:title          "SYNGO_BP_654" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_6500" .

