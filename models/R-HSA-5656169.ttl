<http://identifiers.org/uniprot/Q70EL4>
        a       owl:Class .

:R-HSA-5656169  a           owl:NamedIndividual , obo:GO_0008150 ;
        rdfs:comment        "The initiation and extent of translesion DNA synthesis (TLS) has to be tightly controlled in order to limit TLS-induced mutagenesis, caused by the low fidelity of TLS-participating DNA polymerases. Since monoubiquitination of PCNA at lysine residue K164 is a prerequisite for the assembly of TLS complexes on damaged DNA templates, PCNA deubiquitination is a key step in TLS termination that allows DNA polymerase switching from Y family DNA polymerases involved in TLS to replicative DNA polymerases delta and epsilon (Povlsen et al. 2012, Park et al. 2014)." ;
        rdfs:label          "Termination of translesion DNA synthesis" ;
        dc:contributor      "Edited: Orlic-Milacic, Marija, 2014-12-11" , "GOC:reactome_curators" , "Authored: Orlic-Milacic, Marija, 2014-12-11" , "Reviewed: Borowiec, James, 2015-01-07" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-5656169" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-110313/R-HSA-110313> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

