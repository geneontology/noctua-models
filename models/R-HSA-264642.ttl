biolink:in_taxon  a  owl:AnnotationProperty .

:R-HSA-264642  a            obo:GO_0006836 , owl:NamedIndividual ;
        rdfs:comment        "Acetylcholine neurotransmitter release cycle involves synthesis of acetylecholine, loading of synaptic vesicles, docking and priming of the acetyl choline loaded synaptic vesicles and then release of acetylcholine. This cycle occurs in neurons of central nervous system (CNS), peripheral, autonomic and somatic nervous system. In the CNS, the acetylcholine is released by the presynaptic neurons into the synaptic cleft where the released acetylcholine is accessible to acetylcholine receptors located on the postsynaptic neurons." ;
        rdfs:label          "Acetylcholine Neurotransmitter Release Cycle" ;
        dc:contributor      "Reviewed: Wen, Hua, 2020-01-24" , "Authored: Mahajan, SS, 2008-01-14 16:01:52" , "Edited: Mahajan, SS, 2008-11-18 00:03:09" , "Reviewed: Kavalali, E, 2008-04-24 16:31:34" , "GOC:reactome_curators" ;
