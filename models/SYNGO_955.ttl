obo:ECO_0000279  a  owl:Class .

gomodel:SYNGO_955  a      owl:Ontology ;
        rdfs:comment      "Rationale: Function: Intra-axonal synthesis of p35 regulates vesicle recycling in developing neurons.\n\nLocation: Immunolabeling for endogenous p35 shows that p35 is localized to vesicle release sites. p35 colocalized with vGlut labeled clusters along dendrites (Fig 3E), but also with vGlut clusters at nonsynaptic hot spots in axons having no nearby dendrites (Fig. 3F). p35 levels at SV recycling sites is under control of rem4A (Fig.3G). Experimental description: Hippocampi were isolated from embryonic day 18 (E18) rats." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-4022-8707" , "https://orcid.org/0000-0001-7480-0826" , "https://orcid.org/0000-0002-5648-066X" , "https://orcid.org/0000-0003-2533-9548" , "https://orcid.org/0000-0002-1212-5623" ;
        dc:date           "2017-06-20" ;
        dc:title          "SYNGO_CC_955" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

