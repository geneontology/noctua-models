gomodel:SYNGO_4600  a     owl:Ontology ;
        rdfs:comment      "Rationale: Super-resolution STED imaging performed in rat hippocampal neurons revealed localization of MAP1BLC3 at the presynaptic boutons labeled by Synaptophysin.. Experimental description: This antibody was purified from hybridoma (clone 4E12) supernatant using protein A agarose. This hybridoma was established by fusion of mouse myeloma cell P3U1 with C3H mouse lymphocyte immunized with the recombinant human LC3 [MAP1LC3B (1-120 aa)].\nThis antibody reacts with LC3 (MAP1LC3A, B) on Immunocytochemistry, Western blotting and Immunoprecipitation." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0575-6950" , "https://orcid.org/0000-0002-1585-539X" ;
        dc:date           "2022-09-04" ;
        dc:title          "SYNGO_CC_4600" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

