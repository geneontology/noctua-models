gomodel:SYNGO_498  a      owl:Ontology ;
        rdfs:comment      "Rationale: In a co-immunoprecipitation experiment, confirmed interaction between PAK7 and DISC1 in synaptoneurosomal preparations from total mouse brain.\nImmunostaining for PAK7 (green) and DISC1 (red) in brain sections containing hippocampus and cortex of P7 mice.\n\n29/5/2017 Pim\n- There is a confusing nomenclature of PAK/PAK57 in uniprot. The names appear to be synonyms. This is also mentioned by the authors (\"gene p21 Protein-Activated Kinase 7 (PAK7, also called PAK5)\").. Experimental description: Mouse brain at P7-10." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9848-0262" , "https://orcid.org/0000-0002-4419-210X" , "https://orcid.org/0000-0002-2094-7491" , "https://orcid.org/0000-0002-1190-4481" ;
        dc:date           "2017-05-29" ;
        dc:title          "SYNGO_CC_498" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

