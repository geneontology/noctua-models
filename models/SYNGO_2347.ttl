obo:GO_0099092  a  owl:Class .

gomodel:SYNGO_2347  a     owl:Ontology ;
        rdfs:comment      "Rationale: Results section: \"Immunostaining of G3PD in Brain Slice\"\n\n- Literal:\"As many as 66% of all morphologically identifiable synapses with well-defined PSDs exhibited immunoreactivity, including symmetric and asymmetric synapses and those with perforated PSDs.\"\n\nFigure 1 Legend:\n\n- Literal: \"The G3PD antibody was diluted 1:2,000. T marks unlabeled terminals whereas arrowheads mark immunoreactive PSD at a dendritic spine.\"\n\nDiscussion, 3rd paragrah :\n\n-Literal: \"Our finding of G3PD*, PGK, LDH, aldolase, and possibly other glycolytic enzymes in the PSD suggests there exists at the PSD level a rather complete glycolytic complex for the generation of ATP\".\n\n*G3PD = GAPDH. Experimental description: Figure 1 Legend: \"Electron micrographic localization of rat visual cortex G3PD\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-6893-6177" , "https://orcid.org/0000-0002-5265-6306" ;
        dc:date           "2018-02-01" ;
        dc:title          "SYNGO_CC_2347" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

