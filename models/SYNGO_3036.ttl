gomodel:SYNGO_3036  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.1: \"IP3K-A accumulates in dendritic spines upon LTP induction\"\n\nFig.6: \"IP3K-A recruits activated Rac1 onto F-actin fibers\"\n- \"Furthermore, p-PAK-IRs were dramatically merged with overexpressed GFP-IP3K-A signals, which are localized on the F-actin in the head of dendritic protrusions (Figure 3A and Figure 6C), suggesting that IP3K-A-dependent targeting of activated Rac onto F-actin cytoskeleton also occurs in neurons.\". Experimental description: - \"Cell culture: The rat hippocampus (embryonic, 18.5 days) was dissected...\"\n- \"To construct pEGFP-tagged wild-type and deletion and point mutants of IP3K-A (Genbank access #NM-031045)\" --> rat\n- Fig.7: \"IP3K-A knockout mice\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0003-0593-3443" ;
        dc:date           "2018-03-28" ;
        dc:title          "SYNGO_CC_3036" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

