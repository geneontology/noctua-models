gomodel:SYNGO_814  a      owl:Ontology ;
        rdfs:comment      "Rationale: The authors use a fluorescently labeled overexpression of human b-actin to study the dynamics (G-actin/F-actin transitions) of the actin cytoskeleton in dendritic spines. As inferred by the curator and based on the author's intent it is derived that the b-actin gene provides the structural basis of the F-actin skeleton at the postsynapse.. Experimental description: The annotation of ACTB is made against the human protein since a human OE protein was used; the neurons used were of rat origin." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-5648-066X" , "https://orcid.org/0000-0002-1212-5623" , "https://orcid.org/0000-0003-2533-9548" , "https://orcid.org/0000-0001-7480-0826" , "https://orcid.org/0000-0003-4022-8707" ;
        dc:date           "2017-06-09" ;
        dc:title          "SYNGO_CC_814" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_9606" .

pav:providedBy  a  owl:AnnotationProperty .

