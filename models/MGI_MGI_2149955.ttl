:9f471a1a-3fd8-4803-8160-13aea8b33553
        a                   owl:NamedIndividual , obo:ECO_0000315 ;
        rdfs:comment        "In Olig3 mutant mice  the development of class A neurons is impaired; dI1 neurons are generated in reduced numbers  whereas dI2 and dI3 neurons are misspecified and assume the identity of class B neurons." ;
        lego:evidence-with  "MGI:MGI:3573868" ;
        dc:contributor      "https://orcid.org/0000-0003-3394-9805" ;
        dc:date             "2013-06-06" ;
        dc:source           "PMID:15769945" ;
        dcterms:created     "2013-06-06" ;
        pav:providedBy      "http://informatics.jax.org" .

:53515eea-358e-4953-89f3-92af7132045c
        a                   owl:NamedIndividual , obo:ECO_0000315 ;
        rdfs:comment        "differences in the migration of class A neurons were apparent at E11 and more pronounced by E12.5  as observed by ectopically located neurons in the lateral positions of the dorsal spinal cord and at sites typically occupied by class B neurons" ;
        lego:evidence-with  "MGI:MGI:3573868" ;
        dc:contributor      "https://orcid.org/0000-0003-3394-9805" ;
        dc:date             "2013-06-06" ;
        dc:source           "PMID:15769945" ;
        dcterms:created     "2013-06-06" ;
        pav:providedBy      "http://informatics.jax.org" .

