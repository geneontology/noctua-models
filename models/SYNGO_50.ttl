gomodel:SYNGO_50  a       owl:Ontology ;
        rdfs:comment      "Rationale: Increased average peak quantal release per synapse in rab3a KO neurons treated with either MK-801 or AP5 and enhanced paired-pulse facilitation in these neurons indicate a higher quantal release per synapse (i.e. more synaptic vesicles fuse per synapse) during stimulation.\n\n19/01/2017 Pim\nThis annotation build s on well established information that rab3a is a protein attached to the SV membrane.. Experimental description: \"Low-density microisland cultures of hippocampal pyramidal neurons were prepared from E15-E17 wild-type, rab3A-mutant and synaptotagmin I mutant mouse embryos as described.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-5615-1014" ;
        dc:date           "2017-04-25" ;
        dc:title          "SYNGO_BP_50" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

