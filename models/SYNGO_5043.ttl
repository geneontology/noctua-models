lego:evidence  a  owl:AnnotationProperty .

gomodel:SYNGO_5043  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 4: biochemical fractions of striata from wildtype and INPP4A-knockout mice showed INPP4A localized to the PSD and that its knockout increased NR1 and (phosphorylated) NR2B expression levels. Experimental description: Results, Figure 4a legend: \"Increased NR1 and NR2B at the PSD in the absence of INPP4A. PSD and non-PSD (Sup) fractions were prepared from striata of wild-type and Inpp4a-/- (KO) mice.\"\n\nantibody:\nAnti-INPP4A pAb from Santa Cruz" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" ;
        dc:date           "2023-02-20" ;
        dc:title          "SYNGO_CC_5043" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

