obo:GO_0099170  a  owl:Class .

gomodel:SYNGO_941  a      owl:Ontology ;
        rdfs:comment      "Rationale: The authors investigate the role of PLCs in long-term depression (LTD) in the visual cortex. They find that knockout of PLC-b1 abolishes LTD in this preparation (Figure 6A). This appears to be a postsynaptic effect, because postsynaptic superfusion with the PLC antagonist U73112 (U...2) also blocks LTD (Figure 6B).\n\n24/11/2017 Pim\n- Since the authors investigate the site of action, I allow annotation to the postsynaptic process.. Experimental description: To directly test the involvement of PLC in LTD,we used slices prepared from mice lacking the b1 isoform of PLC (PLC b1)." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-7620-2704" , "https://orcid.org/0000-0002-1558-1958" ;
        dc:date           "2017-11-24" ;
        dc:title          "SYNGO_BP_941" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

