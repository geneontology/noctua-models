lego:evidence  a  owl:AnnotationProperty .

gomodel:SYNGO_488  a      owl:Ontology ;
        rdfs:comment      "Rationale: The paper shows that knockdown of Transmembrane-agrin in mature hippocampal neurons reduces synapse density. Depletion of TM-agrin in dendrites or axons alone reduces synapse numbers. Depletion in dendrites is more efficient than depletion in axons.. Experimental description: \"Rat hippocampal neuron cultures and transfection\" p. 169" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-0269-0311" , "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-9880-1214" , "https://orcid.org/0000-0002-9681-3318" ;
        dc:date           "2017-09-06" ;
        dc:title          "SYNGO_BP_488" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

