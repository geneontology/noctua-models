dc:source  a    owl:AnnotationProperty .

:R-HSA-9648002  a           owl:NamedIndividual , obo:GO_0008150 ;
        rdfs:comment        "RAS proteins undergo several processing steps during maturation including farnesylation, carboxy-terminal cleavage and carboxymethylation, among others. These steps are required for their membrane localization and function and ultimately for their ability to activate RAF (reviewed in Gysin et al, 2011; Ahearn et al, 2018)." ;
        rdfs:label          "RAS processing" ;
        dc:contributor      "Reviewed: Gavathiotis, Evripidis, 2020-05-04" , "GOC:reactome_curators" , "Edited: Rothfels, Karen, 2020-05-26" , "Authored: Rothfels, Karen, 2019-10-25" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-9648002" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-5673001/R-HSA-5673001> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

