gomodel:SYNGO_4700  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 1c: Pum2 localizes within the dendritic compartment of mature hippocampal neuronal cultures.\n\nFigure 3b: \"Pum2 is found in the dendritic shaft within close proximity of the base of dendritic spines. Immunostaining for Pum2 (red) and the postsynaptic marker PSD95 (green) demonstrates close apposition of PSD95 puncta and Pum2 particles\"\n\nFigure 4b: \"Dendritic Pum2 puncta contain mRNA. Immunostaining for Pum2 (green) was combined with FISH using an oligo-dT probe to detect mRNA. Pum2-containing puncta showed strong colocalization with mRNA(red). Some Pum2 puncta did not contain mRNA(arrows),whereas all mRNA contained Pum2(arrowheads).\". Experimental description: M&M: \"Rat hippocampal neurons were cultured and transiently transfected as described by Goetze et al. (2004)\"\n\nantibody:\nrabbit polyclonal anti-Pum2 antibodies (dilution, 1:2000; Acris, Hiddenhausen, Germany)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" ;
        dc:date           "2022-07-29" ;
        dc:title          "SYNGO_CC_4700" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

pav:providedBy  a  owl:AnnotationProperty .

