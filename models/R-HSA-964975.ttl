        pav:providedBy  "https://reactome.org" .

:R-HSA-964975  a            obo:GO_0042816 , owl:NamedIndividual ;
        rdfs:comment        "Animals cannot synthesize pyridoxal 5'-phosphate (PLP) which is a ligand in aminotransferases and other enzymes. PLP's accessible derivatives pyridoxine, pyridoxal, and pyridoxamine are traditionally called vitamins B6. They are taken up nutritionally from bacteria and plants, but also created from PLP in the body. The pathways used to recycle PLP from these three compounds can therefore be called vitamin B6 activation as well as PLP salvage. Because of the close similarity of the molecules, only two enzymes are needed for the task (McCormick & Chen, 1999)." ;
        rdfs:label          "Vitamin B6 activation to pyridoxal phosphate" ;
        dc:contributor      "GOC:reactome_curators" , "Edited: Jassal, B, 2010-09-20" , "Authored: Stephan, R, 2010-09-16" , "Reviewed: D'Eustachio, P, 2010-11-08" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-964975" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-196849/R-HSA-196849> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

