<http://model.geneontology.org/ev_w_id_R-HSA-6810894_RO_0002411_R-HSA-6814387_Reactome_R-HSA-6809371>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/ECO_0000313> ;
