obo:RO_0002333  a  owl:ObjectProperty .

gomodel:SYNGO_4908  a     owl:Ontology ;
        rdfs:comment      "Rationale: ATG16L1 and ATG5 are well known to be involved in LC3 lipid conjugation which is essential for autophagosome formation. Here authors show that ATG16L1 (and also ATG5) are involved in the regulation of axonal microtubuli and transport of axonal cargo. In accordance with this, ATG16L1 KO cells and ATG5 KO cells show axonal dwellings in cortical axons that are mostly located at presynaptic sites (Fig. 2, 3) and a reduction of microtubuli dynamics (Fig. 4).. Experimental description: Experiments were performed in tissue or neurons from Atg16L1flox/flox mice that were crossed with a CamKIIa-Cre line or with CAG-cre/Esr1 line for tamoxifen-inducible KOs." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0575-6950" , "https://orcid.org/0000-0002-1585-539X" ;
        dc:date           "2023-01-28" ;
        dc:title          "SYNGO_BP_4908" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

