        rdfs:comment      "Imported from Reactome: https://reactome.org/content/detail/R-HSA-9026286" , "For logical inference, import the integrated tbox ontology http://purl.obolibrary.org/obo/go/extensions/go-lego-reacto.owl" , "http://www.reactome.org" ;
        lego:modelstate   "development" ;
