gomodel:SYNGO_2867  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.5: \"The regulation of spine length by FILIP in primary neurons requires Hsc70\"\n- \"We did not observe an effect of VER-155008 on control neurons that did not express FILIP. However, VER-155008 treatment of FILIP-expressing hippocampal neurons led to significantly shorter spines than vehicle treatment of FILIP-expressing hippocampal neurons.\"\n\nNote: VER-155008 is a Hsc70-inhibitor.. Experimental description: - \"The piriform cortices and the hippocampal formation were dissected from mouse brains at E17.5.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2018-03-15" ;
        dc:title          "SYNGO_BP_2867" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

