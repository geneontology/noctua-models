obo:GO_0003674  a  owl:Class .

gomodel:SYNGO_4890  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 4B: Cleaved caspase-3 is shown to be present in hippocampal synaptosome preparations, but not in total hippocampal homogenates, shown by an immunoblot.\nFigure 4C: Immuno-EM shows caspase-3-immunopositive postsynaptic compartments in CA1 dendritic spines. The immunoprecipitates were specifically concentrated in the PSD. No immunoreactivity was found in cell soma, nuclei, presynaptic terminals or surrounding glial projections.. Experimental description: \"Heterozygous male Tg2576 mice and wild-type littermates were used for all experiments.\"\n\"The brain was rapidly dissected and the hippocampus was homogenized in homogenization buffer\"\n\"free-floating sections were incubated with an antibody to cleaved caspase-3 (1:100, Cell Signaling)\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2023-01-31" ;
        dc:title          "SYNGO_CC_4890" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

