gomodel:SYNGO_236  a      owl:Ontology ;
        rdfs:comment      "Rationale: The immunoglobulin adhesion protein SynCAM3/Necl-1/Cadm3 localizes at the contact sites of neurons and glia cells and the presynaptic SynCAM3/Necl-1/Cadm3 likely forms trans-homo dimers.\n\n21/6/2017 Pim\n- AZ membrane appears to be devoid of gold particles.. Experimental description: Neurons were cultured from mice for Fig. 4 and tissue was obtained from mice for Fig. 3." , "Automated change 2024-03-14: GO:0099056 replaced by GO:0042734" ;
        lego:modelstate   "production" ;
