dc:title  a     owl:AnnotationProperty .

:R-HSA-5576894  a           obo:GO_0061337 , owl:NamedIndividual ;
        rdfs:comment        "Phase 1 of the cardiac action potential is the inactivation of the fast Na+ channels. The transient net outward current causing the small downward deflection (the \"notch\" of the action potetial) is due to the movement of K+ and Cl- ions. In pacemaker cells, this phase is due to rapid K+ efflux and closure of L-type Ca2+ channels (Park & Fishman 2011, Grant 2009)." ;
        rdfs:label          "Phase 1 - inactivation of fast Na+ channels" ;
        dc:contributor      "GOC:reactome_curators" , "Authored: Jassal, Bijay, 2014-05-27" , "Edited: Jassal, Bijay, 2014-05-27" , "Reviewed: Colotti, Gianni, 2015-11-09" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-5576894" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-5576891/R-HSA-5576891> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

