obo:ECO_0006003  a  owl:Class .

gomodel:SYNGO_4613  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig. 4. Electron micrographs from adult rat cerebral cortex (Cx, A,B) and hippocampal CA3 region (Hc, C,D) stained for Kilon. (A, B) Dendritic spines exhibited strong Kilon immunoreactivity at postsynaptic sites in the cortical neurons. (C, D) The immunoreactivity was also seen at postsynaptic sites of dendritic and somatic synapses in hippocampal pyramidal neurons.. Experimental description: \"Male Wistar rats were used for these experiments. Rats were housed under standard conditions, in a 12-h light:dark cycle with free access to food and water.\"\n\nmonoclonal antibody against Kilon (clone 8-9B3, dilution 1:500)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2022-05-01" ;
        dc:title          "SYNGO_CC_4613" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

