lego:evidence  a  owl:AnnotationProperty .

gomodel:SYNGO_4996  a     owl:Ontology ;
        rdfs:comment      "Rationale: Nrxn1/3 - Cbln1/2 trans-synaptic signaling complexes differentially control NMDA- and AMPA-receptors in different synapses in diverse neural circuits without regulating synapse or spine formation. The Neurexin alternative splicing site 4 (SS4) is critical to these signaling pathways.\n\nWhile no EM/STED imaging is shown for synaptic cleft localization of Cbln2, it can be inferred from presented electrophysiological assays (that included extensive genetic controls) and authors depict this in Figure 9. Note that high-resolution evidence for synaptic cleft localization of Cbln1 and Cbln3 has been shown by immunogold EM (PMID:19250438 Fig. 5, PMID:17331201 Fig. 6).. Experimental description: M&M: \"The Cbln1 conditional KO and Cbln2 conditional/constitutive KO mouse lines were described in Seigneur and Südhof, 2017. SS4 +conditional knockin (cKI) mice of Nrxn1 and Nrxn3 were described previously (Aoto et al., 2013; Dai et al., 2019; Dai et al., 2021). All mice above were maintained on a mixed C57BL/6/SV129/CD1 (wild type) background.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2023-02-09" ;
        dc:title          "SYNGO_CC_4996" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

dc:date  a      owl:AnnotationProperty .

