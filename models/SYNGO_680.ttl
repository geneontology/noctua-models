obo:GO_0098700  a  owl:Class .

gomodel:SYNGO_680  a      owl:Ontology ;
        rdfs:comment      "Rationale: The paper characterizes for the first time the vesicular GABA transporter.\n\nIn figure 5a light vesicles purified by differential centrifugation from PC12 cell clones stably expressing VGAT are tested for 3H-GABA uptake and show a more uptake than membranes prepared from untransfected PC12 cells.\nFigure 5c demonstrates specificity of the transporter to GABA by testing the block of 3H-GABA uptake using a series of compounds at increasing concentrations.. Experimental description: To determine biochemically whether the rat unc-47 homologue\nencodes the vesicular GABA transporter, we expressed the cDNA in\nrat pheochromocytoma PC12 cells." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-3185-5709" , "https://orcid.org/0000-0002-0755-5899" , "https://orcid.org/0000-0003-0938-8534" , "https://orcid.org/0000-0001-7351-8706" ;
        dc:date           "2017-11-23" ;
        dc:title          "SYNGO_BP_680" ;
        pav:providedBy    "https://syngo.vu.nl" ;
