<http://model.geneontology.org/UniProtKB_P51665_R-HSA-9907994_R-HSA-5362448_component>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://identifiers.org/uniprot/P51665> ;
        <http://www.w3.org/2000/01/rdf-schema#comment>
                "Original Reactome ID: UniProt_P51665" , "located_in cytosol" ;
