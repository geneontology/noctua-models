obo:RO_0002333  a  owl:ObjectProperty .

gomodel:SYNGO_2745  a     owl:Ontology ;
        rdfs:comment      "Rationale: Postsynaptic NLGN2; neuroligin 2 is a regulator of presynaptic assembly via presynaptic beta-neurexin.\n\nFig.2: \"Neuroligin Expression in HEK293 Cells Causes Accumulation of Synapsin in Axons\"\n- \"...when HEK293 cells were transfected with a construct encoding epitope-tagged neuroligin-1 ab or neuroligin-2, dramatic accumulations of synapsin were observed (Figure 2 2D-2I).\"\n\nFig.5: \"Overexpression of Adhesion Molecules Is Not Sufficient to Induce Synaptic Vesicle Clustering in Pontine Axons\"\n- \". Experimental description: - Over-expressed NLGN2; neuroligin 2 is of rat species: \"Murine neuroligin-1 and -2, and neurexin-1β cDNAs were cloned from purified cerebellar granule cells by RT-PCR. Primers were designed based upon the published rat sequences.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0003-0593-3443" ;
        dc:date           "2018-03-02" ;
        dc:title          "SYNGO_BP_2745" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

