gomodel:SYNGO_742  a      owl:Ontology ;
        rdfs:comment      "Rationale: Description of the GlyT1 knockout.\nFigure 2 illustrates [3H]Glycine Uptake in P2 membranes from brainstem/spinal cord mixed tissue and forebrain tissue from newborn mice. The figure shows a 70-80% reduction in [3H]Glycine Uptake in the knockout animals compared with the WT animals in both samples.. Experimental description: Generation of GlyT1-/- Mice" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-7351-8706" , "https://orcid.org/0000-0002-0755-5899" , "https://orcid.org/0000-0003-0938-8534" , "https://orcid.org/0000-0003-3185-5709" ;
        dc:date           "2018-05-28" ;
