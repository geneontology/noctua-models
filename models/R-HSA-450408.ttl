[ a       <http://www.w3.org/2002/07/owl#Axiom> ;
  <http://www.w3.org/2000/01/rdf-schema#comment>
          "Imported from Reactome: https://reactome.org/content/detail/R-HSA-450408" ;
  <http://geneontology.org/lego/evidence>
          <http://model.geneontology.org/ev_w_id_REACTO_R-HSA-9908170_R-HSA-9908177_R-HSA-450466_component_BFO_0000051_UniProtKB_Q99460_R-HSA-9908170_R-HSA-450466_component_Reactome_R-HSA-450408> , <http://model.geneontology.org/ev_w_id_REACTO_R-HSA-9908170_R-HSA-9908177_R-HSA-450466_component_BFO_0000051_UniProtKB_Q99460_R-HSA-9908170_R-HSA-450466_component_Reactome_R-HSA-9908170> ;
