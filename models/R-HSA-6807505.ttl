[ a       <http://www.w3.org/2002/07/owl#Axiom> ;
  <http://www.w3.org/2000/01/rdf-schema#comment>
          "Imported from Reactome: https://reactome.org/content/detail/R-HSA-6807505" ;
  <http://geneontology.org/lego/evidence>
          <http://model.geneontology.org/ev_w_id_R-HSA-6810238_RO_0002233_R-HSA-6810225_R-HSA-6810238_Reactome_R-HSA-6810238> , <http://model.geneontology.org/ev_w_id_R-HSA-6810238_RO_0002233_R-HSA-6810225_R-HSA-6810238_Reactome_R-HSA-6807505> ;
  <http://purl.org/dc/elements/1.1/contributor>
          "GOC:reactome_curators" ;
  <http://purl.org/dc/elements/1.1/date>
          "2026-02-02" ;
  <http://purl.org/pav/providedBy>
          "https://reactome.org" ;
  <http://www.w3.org/2002/07/owl#annotatedProperty>
          <http://purl.obolibrary.org/obo/RO_0002233> ;
  <http://www.w3.org/2002/07/owl#annotatedSource>
          <http://model.geneontology.org/R-HSA-6810238> ;
