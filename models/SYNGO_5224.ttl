obo:RO_0002333  a  owl:ObjectProperty .

gomodel:SYNGO_5224  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 1g: confocal imaging of immunofluorescence labeling for KIF17 and PSD-95 (DLG4) in cultured neurons from mice showed extensive co-localization (but not with presynaptic marker VGLUT1).. Experimental description: M&M: \"Primary Neuron Culture\nThe day before the experiment, the coverslips were coated with a poly-L-lysine solution, washed with sterilized deionized water, and dried before use. The brains of C57BL/6 mice (P0-P1) were dissected, and the tissue was mechanically minced and treated with 0.25% trypsin (37°C, 5% CO2) for 10 min.\"\n\nantibody for confocal:\nanti-KIF17 (Proteintech, Wuhan, China; Cat No. 14615-1-AP)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2023-03-04" ;
        dc:title          "SYNGO_CC_5224" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

