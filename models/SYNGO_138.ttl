gomodel:SYNGO_138  a      owl:Ontology ;
        rdfs:comment      "Rationale: RAB11B was detected on highly purified synaptic vesicles using mass spectrometric and immunoblot analyses. GFP-RAB11B colocalises well with synaptophysin puncta in transiently transfected cultured hippocampal neurons.. Experimental description: Legend to Figure 2 \"Enrichment profiles of Rab GTPases on purified SVs isolated from rat brain homogenates, determined by quantitative immunoblotting\"\n\nSpecies of OE Rab11B in Fig 3 is human. Other figures show localization of rat protein. Annotation accepted against rat species." , "Automated change 2024-03-14: GO:0098993 replaced by GO:0030672" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-5615-1014" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_138" ;
        pav:providedBy    "https://syngo.vu.nl" ;
