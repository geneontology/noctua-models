gomodel:SYNGO_2210  a     owl:Ontology ;
        rdfs:comment      "Automated change 2024-03-14: GO:0099699 replaced by GO:0097060" , "Rationale: ITGB3 was localized in synapses of hippocampal neurons.\nITGB3 was enriched in synaptic membrane fractions.\n\n16/01/2018 Pim\n- Based on the known transmembrane topology of the protein, the \"integral component of ... membrane\" term was chosen.. Experimental description: Materials and Methods\nHippocampal neuron culture, transfection\nCultures of hippocampal neurons were prepared from embryonic day 15 (E15) to E16 mouse embryos.\nBiochemical assays\nSubcellular fractionation of adult mouse hippocampi was performed as previously described with modification." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-6194-9648" , "https://orcid.org/0000-0001-5518-6584" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_2210" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

