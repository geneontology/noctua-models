obo:GO_0008150  a  owl:Class .

:R-HSA-975574  a            obo:GO_0008150 , owl:NamedIndividual ;
        rdfs:comment        "The transfer of a bisecting GlcNAc by MGAT3 commits the pathway toward the synthesis of hybrid glycans, because MAN2 is not able to operate on bisected oligosaccharides (Schachter et al 2000, Priatel JJ et al, 1997). The expression of MGAT3 over MGAT2 in a tissue can regulate the synthesis of hybrid toward complex N-glycans. The addition of a GlcNAc between the two arms also prevents the action of MGAT4, MGAT5 and FUT8." ;
        rdfs:label          "Reactions specific to the hybrid N-glycan synthesis pathway" ;
        dc:contributor      "Edited: Jassal, B, 2010-09-30" , "Authored: Dall'Olio, GM, 2009-11-10" , "Reviewed: Gagneux, P, 2010-11-18" , "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-975574" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-975576/R-HSA-975576> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

