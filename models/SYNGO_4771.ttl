obo:ECO_0007719  a  owl:Class .

gomodel:SYNGO_4771  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 3: immunofluorescence staining and confocal microscopy showed early endosome marker protein EEA1 was localized to dendrites but, to a lesser extend, also at and near dendritic spines in cultured hippocampal neurons. EEA1 localization to spines, as well as co-localization of GluA1 and EEA1 (anywhere in dendrites/spines), was increased upon stimulus.. Experimental description: M&M: \"Primary cultures of embryonic hippocampal cells were prepared from CD1 mice on embryonic day E17.5-E18.5.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2022-08-05" ;
        dc:title          "SYNGO_CC_4771" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

