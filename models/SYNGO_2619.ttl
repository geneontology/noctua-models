gomodel:SYNGO_2619  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.2: \"Overexpression of Slitrk1 and Slitrk2 in cultured neurons increases the amount of presynaptic excitatory and inhibitory contacts\"\nFig.3: \"Knockdown of Slitrk1 by shRNA in cultured neurons reduces synapse density\". Experimental description: - \"E18-19 rat embryos were obtained from Sprague Dawley females (Charles River). Cultures of hippocampal neurons were prepared from the embryos according to previously described protocols\"\n- \"Full-length human Slitrk1 (aa 1-696) and human Slitrk2 (aa 1-845) ....\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0003-0593-3443" ;
        dc:date           "2018-02-19" ;
        dc:title          "SYNGO_BP_2619" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

