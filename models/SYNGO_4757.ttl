obo:ECO_0001230  a  owl:Class .

gomodel:SYNGO_4757  a     owl:Ontology ;
        rdfs:comment      "Rationale: AP3S2 (AP3-σ3B) was detected in SV biochemical fractions, but not enriched as compared to the P2 fraction.\n\nThis protein was also detected in SV biochemical fractions in Takamori et al. 2006 (PMID: 17110340).\n\nAP3S1 (AP3-σ3A) and AP3S2 (AP3-σ3A) were also detected in SV biochemical fractions prepared from rat brain that were subjected to sucrose gradients and a series of western blots (PMID:9590176, Fig.4).\n\nThis protein is part of the ubiquitous AP3 complex (PMID:9118953, PMID:9151686).. Experimental description: M&M: \"Brain Synaptosomes and SV Purifications. Synaptosomes (P2') and SVs were purified from whole brain of 4- to 6-wk-old Sprague-Dawley rats following the same protocols used in ref. 2 and previously described in ref. 34 for SV, and in ref. 4 for P2'.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2023-03-15" ;
        dc:title          "SYNGO_CC_4757" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

