:R-HSA-901042  a            obo:GO_0008150 , owl:NamedIndividual ;
        rdfs:comment        "The unfolded protein is recognized by a chaperon protein (calnexin or calreticulin) and the folding process starts. The binding of these protein requires a mono-glucosylated glycan (Caramelo JJ and Parodi AJ, 2008) and lectin-based interaction with client proteins is the predominant contributor to chaperone activity of calreticulin (inferred from the mouse homolog in Lum et al. 2016)." ;
        rdfs:label          "Calnexin/calreticulin cycle" ;
        dc:contributor      "Authored: Dall'Olio, GM, 2009-11-10" , "Reviewed: Gagneux, P, 2010-08-17" , "Edited: Jassal, B, 2010-07-02" , "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-901042" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-532668/R-HSA-532668> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

