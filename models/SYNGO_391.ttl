gomodel:SYNGO_391  a      owl:Ontology ;
        rdfs:comment      "Rationale: Fig. 1 CA1-region synapses immunolabeled with ephrinB2 antibody and analyzed by electron microscopy indicate ephrinB2 expression at postsynaptic sites.\n\n23/6/2017 Pim\n- CA1 neurons express the ephrinB2 protein consistent with postsynaptic localization.\n- 30% of gold particles are on the presynaptic compartment\n- Based on the known transmembrane topology of the protein, the \"integral component of ... membrane\" term was chosen.. Experimental description: The generation and genotypic analysis of ephrinB2 knock-in mutant and wild-type control mice has been described previously." , "Automated change 2024-03-14: GO:0099061 replaced by GO:0098839" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0912-1514" , "https://orcid.org/0000-0002-3670-7863" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_391" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

