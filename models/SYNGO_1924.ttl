gomodel:SYNGO_1924  a     owl:Ontology ;
        rdfs:comment      "Rationale: this paper shows that downregulation of Drebrin A using antisense oligonucleotides reduces clustering of F-actin in dendritic spines and reduces the density of spines in hippocampal neurons, which could be restored by re-expression of Drebrin A. This suggests that Drebrin controls the organization of the actin cytoskeleton and thereby regulates spine morphogenesis. Experimental description: rat hippocampal cultures were used: \"[...] hippocampi were dissected from embryonic 18-d-old Wistar rats [...]\".\n\n23/11/2017 Pim\n- Overexpressed drebrin A is of rat species: \"The cDNA of rat drebrin A tagged with enhanced green fluorescent protein (GFP) \"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-6153-3586" , "https://orcid.org/0000-0002-2666-0758" ;
        dc:date           "2017-11-23" ;
        dc:title          "SYNGO_BP_1924" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

