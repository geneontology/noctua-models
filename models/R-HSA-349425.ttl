:R-HSA-349425  a            owl:NamedIndividual , obo:GO_0008150 ;
        rdfs:comment        "COP1 is one of several E3 ubiquitin ligases responsible for the tight regulation of p53 abundance. Following DNA damage, COP1 dissociates from p53 and is inactivated by autodegradation via a pathway involving ATM phosphorylation of COP1 on Ser(387), autoubiquitination and proteasome mediated degradation. Destruction of COP1 results in abrogation of the ubiquitination and degradation of p53 (Dornan et al., 2006)." ;
        rdfs:label          "Autodegradation of the E3 ubiquitin ligase COP1" ;
        dc:contributor      "GOC:reactome_curators" , "Reviewed: Dixit, VM, 2009-11-17" , "Edited: Matthews, L, 2009-11-09" , "Authored: Matthews, L, 2008-06-12 21:09:06" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-349425" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-69541/R-HSA-69541> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

