gomodel:SYNGO_3971  a     owl:Ontology ;
        rdfs:comment      "Rationale: Subcellular fractionation experiments indicate that RAP2A is present in the crude synaptic membrane fraction and the crude synaptic vesicle fraction, but not the synaptic soluble cytoplasm fraction.. Experimental description: Subcellular fractionation of rat brains was performed based on published protocols (Huttner et al., 1983; Mizoguchi et al., 1989). Briefly, 10 male Sprague- Dawley rats (200-250 g) were anaesthetized, decapitated, and cortices were isolated in 0.32 M sucrose." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-3185-5709" , "https://orcid.org/0000-0002-0755-5899" , "https://orcid.org/0000-0001-7351-8706" , "https://orcid.org/0000-0003-0938-8534" ;
        dc:date           "2020-07-06" ;
        dc:title          "SYNGO_CC_3971" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

