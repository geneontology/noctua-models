obo:UBERON_0002421  a  owl:Class .

gomodel:SYNGO_2115  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.2: \"... the uncoating efficiency (the decrease in clathrin fluorescence associated with permeabilized cells as a function of time) of brain cytosol from newborn mice was dramatically impaired by the lack of auxilin (compare wild-type and knockout at P0.5 in Fig. 2B)\"\n\nfig3; increase in clathrin coats seen in mouse hippocampus immuno-EM in auxilin knockouts compared to wildtype (recorded experimental evidence refers to this figure)\n\nfig4: Accumulation of CCVs and clathrin cages at auxilin knockout synapses seen in mouse cerebellum EM,\n\nFig.5: reduced endocytosis rate in mouse hippocampus observed by fluorescence tracing of synaptopHluorin protein fused to VAMP2. Experimental description: \"Auxilin heterozygote mice were backcrossed with C57BL/6 mice for more than eight generations before phenotypic analysis\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-4973-5732" ;
        dc:date           "2017-12-11" ;
        dc:title          "SYNGO_BP_2115" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

