[ a                      owl:Axiom ;
  rdfs:comment           "We then compared the transport characteristics of motors and vesicles in WT and syd-2 mutant backgrounds by UNC-104::GFP particle analysis in living worms in sub-lateral neurons (Fig. 2C-F) and in isolated neurons\n(Fig. 3) by using spinning-disc confocal time-lapse fluorescence\nmicroscopy. Two examples of moving particles in a time series is shown in Fig. 2A (Movie S1) with corresponding positions indicated in the kymograph (Fig. 2B;1-5,6-9;x, static particle) and active anterograde and retrograde traffic events are shown in Fig. S3B.  PMID:19880746" ;
  lego:evidence          :56cbaef000000088 , :56cbaef000000082 ;
  dc:contributor         "https://orcid.org/0000-0002-1706-4196" ;
  dc:date                "2016-02-24" ;
  owl:annotatedProperty  obo:RO_0002333 ;
  owl:annotatedSource    :56cbaef000000080 ;
  owl:annotatedTarget    :56cbaef000000081
] .

