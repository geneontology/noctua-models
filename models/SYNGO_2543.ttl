gomodel:SYNGO_2543  a     owl:Ontology ;
        rdfs:comment      "Rationale: \"To isolate axon-terminal D2 autoreceptor effects on DA release and uptake, we have used electrochemical recordings of evoked DA overflow in striatal slice preparations. Comparison of WT with D2-/- mice (Jung et al., 1999) revealed that the absence of D2 autoreceptor activity alters the kinetics of DA signaling via effects on both release and uptake.\". Experimental description: \"We used mice lacking the D2 receptor (D2-/-) and their WT littermates \"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2018-03-09" ;
        dc:title          "SYNGO_BP_2543" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

pav:providedBy  a  owl:AnnotationProperty .

