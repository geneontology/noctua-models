gomodel:SYNGO_543  a     owl:Ontology ;
        rdfs:comment     "Rationale: Fig. 5 Presynaptic localization of MAGI1 in retinal cells\nFig. 7 Depletion of MAGI-1 alters synaptic localization of Sidekick-2 in photoreceptors.\nLiteral\n\"knockdown of MAGI-1 prevents synaptic localization of Sidekick to the presynaptic membrane of photoreceptors in vivo.\"\n\n15/5/2017 Pim\n- KD of magi-1 happens in the presynaptic cells and therefore support presynaptic localization of MAGI-1. Experimental description: Literal from M&M\n\"Retinal cells were dissociated from embryonic chicks at E16.\"" ;
        lego:modelstate  "production" ;
        dc:contributor   "https://orcid.org/0000-0003-2949-9725" , "https://orcid.org/0000-0003-0662-9523" ;
        dc:date          "2023-03-17" ;
        dc:title         "SYNGO_CC_543" ;
        pav:providedBy   "https://syngo.vu.nl" .

