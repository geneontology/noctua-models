gomodel:SYNGO_2317  a     owl:Ontology ;
        rdfs:comment      "Automated change 2024-03-14: GO:0099060 replaced by GO:0099634" , "Rationale: Results: \"Cadherin-10 is localized to excitatory and inhibitory pre- and post-synaptic sites\"\n- Literal \"To assess pre- vs. post-synaptic location of cadherin-10, we performed immunogold-EM, which showed cadherin-10 labeling was both at the presynaptic active zone and the PSD of excitatory synapses (Fig. 2A). Double labeling for the inhibitory neurotransmitter GABA revealed that cadherin-10 gold particles were also present pre- and postsynaptically at inhibitory synapses\"\n\n30/12/2017 Pim\n- Based on the known transmembrane topology of the protein, the \"integral component of ... membrane\" term was chosen.. Experimental description: Materials and Methods: \"Cortical slice preparation and imaging: Male Sprague-Dawley rats were deeply anesthetized....\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-6893-6177" , "https://orcid.org/0000-0002-5265-6306" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_2317" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

