obo:GO_0098978  a  owl:Class .

gomodel:SYNGO_1018  a     owl:Ontology ;
        rdfs:comment      "Rationale: The experiments in Figs. 5 and 6 use a co-culture approach to demonstrate that the surface contact with the immunoglobulin adhesion protein SynCAM 1 is sufficient to induce neurons to assemble specializations that are positive for presynaptic markers and that contain recycling synaptic vesicles. Further, SynCAM 1-induced neuronal specializations release glutamate.\nThese results support that SynCAM 1 is sufficient to induce neurons to form functional presynaptic terminals.. Experimental description: \"A full-length eukaryotic expression vector encoding SynCAM (pCMV-SynCAM) was constructed by cloning the insert of a mouse EST clone (obtained from American Type Culture Collection, clone # 3333644)\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0912-1514" , "https://orcid.org/0000-0002-3670-7863" ;
        dc:date           "2017-10-12" ;
        dc:title          "SYNGO_BP_1018" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

