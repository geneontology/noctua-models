dc:contributor  a  owl:AnnotationProperty .

:R-HSA-77108  a             obo:GO_0046952 , owl:NamedIndividual ;
        rdfs:comment        "The levels of acetone in ketone bodies are much lower than those of acetoacetic acid and beta-hydroxybutyric acid. Acetone cannot be converted back to acetyl-CoA, and is excreted in urine, or breathed out through the lungs. Extrahepatic tissues utilize ketone bodies by converting the beta-hydroxybutyrate successively to acetoacetate, acetoacetatyl-CoA, finally to acetyl-CoA (Sass 2011)." ;
        rdfs:label          "Ketone body catabolism" ;
        dc:contributor      "Authored: Joshi-Tope, G, 2003-10-19 14:58:00" , "Edited: Jassal, Bijay, 2016-06-30" , "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-77108" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-74182/R-HSA-74182> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

