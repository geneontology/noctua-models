gomodel:SYNGO_2848  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.8: \"Within dendritic spines, gold particles [for PACSIN1] were found at synaptic and perisynaptic sites, along the extrasynaptic plasma membrane, and associated with intracellular vesicles in lateral domains of the PSD (Fig. 8a). Double-labeling showed NR3A and PACSIN1 immunoparticles colocalizing at the same synaptic specialization (Fig. 8a).\"\n\nNote: with perisynaptic the authors mean attached to the lateral side of the PSD.. Experimental description: \"Rats were perfused with 4% paraformaldehyde and 0.05-0.6%...\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2018-03-09" ;
        dc:title          "SYNGO_CC_2848" ;
        pav:providedBy    "https://syngo.vu.nl" ;
