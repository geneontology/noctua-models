obo:GO_0003674  a  owl:Class .

gomodel:SYNGO_123  a      owl:Ontology ;
        rdfs:comment      "Rationale: Subcellular fractions were prepared from whole rat brain and immunoblot detection of CSP was performed. Authors compared the fraction distribution of CSP protein to SV2 (a marker for synaptic vesicles) and found similar distribution between them. Both proteins were enriched in the purified SV fraction.\n\n23/5/2017 Pim\nUniprot states that CSpa is palmitoylated. This and the experimental evidence support the \"anchored component... \" term. Experimental description: Subcellular fractions were prepared from whole rat brain and immunoblot detection of csp was performed." , "Automated change 2024-03-14: GO:0098993 replaced by GO:0030672" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-3898-5197" , "https://orcid.org/0000-0002-0808-7003" , "https://orcid.org/0000-0003-1542-3498" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_123" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

