lego:evidence  a  owl:AnnotationProperty .

:R-HSA-9020933  a           obo:GO_0038155 , owl:NamedIndividual ;
        rdfs:comment        "Interleukin-23 (IL23) is a heterodimer of Interleukin-12 subunit beta (IL12B, IL-12p40), which is shared with IL12, and Interleukin-23 subunit alpha IL23A (IL-23p19) subunit. The functional receptor for IL23 consists of Interleukin-12 receptor subunit beta-1 (IL12RB1), which is shared with the IL12 receptor, and Interleukin-23 receptor (IL23R). IL23R is mainly expresed on activated memory T cells, Natural Killer cells, monocytes/macrophage and at low levels on dendritic cells (DCs). IL23 is mainly secreted by activated macrophages and DCs in peripheral tissues such as skin, intestinal mucosa and lung. IL23 is proinlflammatory and implicated in several autoimmune inflammatory disorders such as colitis, gastritis, psoriasis and arthritis. It is similar to IL-12 both in structure and its ability to memory T cells to increase interferon-γ (IFN-γ) production and proliferation, the ability of IL-23 to induce IL-17. IL23 activates the Janus kinases JAK2 and TYK2, resulting in phosphorylation of the receptor complex, which forms the docking sites for Signal transducer and activator of transcription 3 (STAT3) and STAT4 to bind and become phosphorylated." ;
        rdfs:label          "Interleukin-23 signaling" ;
        dc:contributor      "Reviewed: Meldal, Birgit, 2016-01-28" , "Reviewed: van de Vosse, Esther, 2017-05-12" , "GOC:reactome_curators" , "Authored: Duenas, Corina, 2016-12-02" , "Edited: Jupe, Steve, 2017-11-10" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-9020933" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-447115/R-HSA-447115> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

