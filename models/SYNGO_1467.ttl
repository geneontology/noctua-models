gomodel:SYNGO_1467  a     owl:Ontology ;
        rdfs:comment      "Rationale: Synapsin-II and Syn-I/II double knockouts, but not synapsin-I knockouts, exhibit decreased post-tetanic potentiation and severe synaptic depression upon repetitive stimulation. The phenotype of the synapsin knockouts could be explained either by deficient recruitment of synaptic vesicles to the active zone, or by impaired maturation of vesicles at the active zone.. Experimental description: Methods: generation of synapsin II KO mice. ES cells from SV129 mice." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9900-4233" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2017-10-26" ;
        dc:title          "SYNGO_BP_1467" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

