:R-HSA-193993  a            obo:GO_0006705 , owl:NamedIndividual ;
        rdfs:comment        "Aldosterone, the major human mineralocorticoid, is synthesized in the zona glomerulosa of the adrenal cortex from pregnenolone. Pregnenolone is converted to progesterone in two reactions, both catalyzed by 3-beta-hydroxysteroid dehydrogenase/isomerase. Progesterone is hydroxylated by CYP21A2 to form deoxycorticosterone, which in turn is converted to aldosterone in a three-reaction sequence catalyzed by CYP11B2 (Payne and Hales 2004)." ;
        rdfs:label          "Mineralocorticoid biosynthesis" ;
        dc:contributor      "Authored: Jassal, Bijay, 2008-10-01" , "Edited: Jassal, B, 2007-04-20 21:09:56" , "GOC:reactome_curators" , "Reviewed: D'Eustachio, P, 2007-04-20 21:11:21" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-193993" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-196071/R-HSA-196071> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

