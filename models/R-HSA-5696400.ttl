:R-HSA-5696400  a           obo:GO_0006289 , owl:NamedIndividual ;
        rdfs:comment        "Double incision at the damaged DNA strand excises the oligonucleotide that contains the lesion from the open bubble. The excised oligonucleotide is ~27-30 bases long. Incision 5' to the damage site, by ERCC1:ERCC4 endonuclease, precedes the incision 3' to the damage site by ERCC5 endonuclease (Staresincic et al. 2009)." ;
        rdfs:label          "Dual Incision in GG-NER" ;
        dc:contributor      "Authored: Hoeijmakers, JH, 2004-01-29 18:08:33" , "GOC:reactome_curators" , "Authored: Orlic-Milacic, Marija, 2015-06-16" , "Reviewed: Fousteri, Maria, 2015-08-03" , "Edited: Orlic-Milacic, Marija, 2015-06-16" , "Authored: Joshi-Tope, G, 2003-07-14 15:01:00" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-5696400" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-5696399/R-HSA-5696399> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

