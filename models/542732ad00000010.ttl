[ a                      owl:Axiom ;
  rdfs:comment           "We found that C. elegans expressed immunopurified\nNLS-EGL-4 phosphorylated recombinant HPL-2 and\nthat the level of 32P incorporation diminished when the predicted\nPKG phosphorylation sites within HPL-2 were mutated (Figures\n4D and S3G)." ;
  lego:evidence          :55d513a800000015 ;
  dc:contributor         "https://orcid.org/0000-0002-7073-9172" , "https://orcid.org/0000-0002-1706-4196" ;
  dc:date                "2015-08-21" ;
