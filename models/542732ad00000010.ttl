[ a                      owl:Axiom ;
  rdfs:comment           "In   the   naıve   animal,   GFP::EGL-4   is   evenly   distributed\nthroughout  the  cytosol  of  the  AWC  and  after  prolonged  odor\nexposure  it  redistributes  to  the  nucleus  (Figure  1C  and  1D  and\n[26])." ;
  lego:evidence          :55d513a800000013 ;
  dc:contributor         "https://orcid.org/0000-0002-1706-4196" ;
