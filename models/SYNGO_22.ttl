gomodel:SYNGO_22  a       owl:Ontology ;
        rdfs:comment      "Rationale: DVAP-33A, is localized to neuromuscular junctions where it localises to both the pre- and postsynaptic compartments of the NMJ. Immunogold Labeling Reveals Membrane and Microtubular Association of DVAP-33A. DVAP-33A Associates with Microtubules In Vitro. Loss of DVAP-33A Causes Fewer but Larger Boutons at NMJs. Mutations in DVAP-33A Affect the Synaptic Microtubule Cytoskeleton.. Experimental description: All experiments conducted in Drosphila." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9900-4233" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2017-03-21" ;
        dc:title          "SYNGO_CC_22" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_7227" .

