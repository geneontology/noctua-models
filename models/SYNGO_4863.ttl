obo:GO_0098978  a  owl:Class .

gomodel:SYNGO_4863  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 1: immunofluorescence and EM imaging show VAMP4 is a marker of recycling endosomes in soma and dendrites of hippocampal neurons.\n\nFigure 2: shRNA knockdown of VAMP4, but not VAMP2, impairs recycling endosome exocytosis and recycling to the plasma membrane.\n\nFigure 5: VAMP4 regulates the recycling of AMPA receptors and its availability for chemical-LTP\n\nAuthors conclude: \"These results show that AMPAR exocytosis depends on VAMP2, and that VAMP4 is necessary for the trafficking of AMPARs to a compartment that undergoes exocytosis after cLTP.\". Experimental description: M&M: \"Dissociated hippocampal neurons from E18 Sprague-Dawley rat embryos of either sex were prepared as described (Kaech and Banker, 2006).\"\n\nPlasmids generated in this study have been deposited to Addgene (VAMP4-SEP #174406, VAMP4 KD1 mScarlet shRNA #174407, VAMP4 KD2 mScarlet shRNA #174408)." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-4973-5732" ;
        dc:date           "2022-09-08" ;
        dc:title          "SYNGO_BP_4863" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

