obo:GO_0003674  a  owl:Class .

gomodel:SYNGO_1723  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig1b and Supplementary 1 CAMKv is localized at synapses\nCaMKv was present in the synaptic plasma membrane and postsynaptic density (PSD) of the adult rat brain (Supplementary Fig. 1b). Immunofluorescence staining further demonstrated the co-localization of CaMKv puncta with the postsynaptic scaffold protein PSD-95 (Fig. 1b).. Experimental description: Experiments were done in cortical neurons\nLiteral \"Sprague-Dawley rat embryos were killed at embryonic day 18.The cortical neurons were seeded on a culture plate or culture dishes\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-2949-9725" , "https://orcid.org/0000-0003-0662-9523" ;
        dc:date           "2017-11-09" ;
        dc:title          "SYNGO_CC_1723" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

