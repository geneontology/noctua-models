gomodel:R-HSA-5173214
        a                 owl:Ontology ;
        rdfs:comment      "http://www.reactome.org" , "Imported from Reactome: https://reactome.org/content/detail/R-HSA-5173214" , "For logical inference, import the integrated tbox ontology http://purl.obolibrary.org/obo/go/extensions/go-lego-reacto.owl" ;
        lego:modelstate   "development" ;
        dc:contributor    "GOC:reactome_curators" ;
        dc:date           "2026-06-29" ;
        dc:title          "O-glycosylation of TSR domain-containing proteins - imported from: Reactome" ;
        pav:providedBy    "https://reactome.org" ;
        biolink:in_taxon  obo:NCBITaxon_9606 .

:R-HSA-5173214  a           owl:NamedIndividual , obo:GO_0036066 ;
        rdfs:comment        "The O-fucosylation of proteins containing thrombospondin type 1 repeat (TSR) domains is an important PTM, regulating many biological processes such as Notch signalling, inflammation, wound healing, angiogenesis amd neoplasia (Adams & Tucker 2000, Moremen et al. 2012). Fucose addition is carried out by two protein fucosyltransferases, POFUT1 and 2. Only POFUT2 recognises the consensus sequence CSXS/TCG found in TSR1 domains and the fucosyl residue is attached to the hydroxyl group of conserved serine (S) or threonine (T) residues within the consensus sequence. The modification was first demonstrated on thrombospondin 1, found in platelets and the ECM (Hofsteenge et al. 2001, Luo et al. 2006). The resulting O-fucosyl-protein is subsequently a substrate for beta-1,3-glucosyltransferase-like protein (B3GALTL), which adds a glucosyl moiety to form the rare disaccharide modification Glc-beta-1,3-Fuc. More than 60 human proteins contain TSR1 domains, The disaccharide modification has been demonstrated on a small number of these TSR1 domain-containing proteins such as thrombospondin 1 (Hofsteenge et al. 2001, Luo et al. 2006), properdin (Gonzalez de Peredo et al. 2002) and F-spondin (Gonzalez de Peredo et al. 2002). The ADAMTS (a disintegrin-like and metalloprotease domain with thrombospondin type-1 repeats) superfamily consists of 19 secreted metalloproteases (ADAMTS proteases) and at lease five ADAMTS-like proteins in humans. Five members of the ADAMTS superfamily have also had experimental confirmation of the disaccharide modification. Examples are ADAMTS13 (Ricketts et al. 2007) and ADAMTSL1 (Wang et al. 2007). In the two reactions described here, the TSR1 domain-containing proteins with similarity to the experimentally confirmed ones are included as putative substrates." ;
        rdfs:label          "O-glycosylation of TSR domain-containing proteins" ;
        dc:contributor      "Reviewed: D'Eustachio, Peter, 2014-02-07" , "Authored: Jassal, B, 2013-11-25" , "GOC:reactome_curators" , "Edited: Jassal, B, 2013-11-25" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-5173214" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-5173105/R-HSA-5173105> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

[ a                      owl:Axiom ;
  rdfs:comment           "Imported from Reactome: https://reactome.org/content/detail/R-HSA-5173214" , "Provides Input For Rule. The relation 'POFUT2 transfers fucose to TSR domain-containing proteins' 'null' 'B3GALTL transfers glucose to O-fucosyl-proteins' was inferred because:\n reaction1 has an output that is an input of reaction 2. " ;
  lego:evidence          gomodel:ev_w_id_R-HSA-5173192_RO_0002413_R-HSA-5173005_Reactome_R-HSA-5173214 ;
  dc:contributor         "GOC:reactome_curators" ;
  dc:date                "2026-06-29" ;
  pav:providedBy         "https://reactome.org" ;
  owl:annotatedProperty  obo:RO_0002413 ;
