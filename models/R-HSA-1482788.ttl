:R-HSA-1482788  a           obo:GO_0036151 , owl:NamedIndividual ;
        rdfs:comment        "In the acyl chain remodelling pathway (Lands cycle), phosphatidylcholine (PC) is hydrolysed by phopholipases and subsequently reacylated by acyltransferases. These cycles modify the fatty acid composition of glycerophospholipids to generate diverse molecules asymmetrically distributed in the cell membrane (Ghomashchi et al. 2010, Singer et al. 2002, Cao et al. 2008, Zhao et al. 2008)." ;
        rdfs:label          "Acyl chain remodelling of PC" ;
        dc:contributor      "Edited: Williams, MG, 2011-08-12" , "Reviewed: Wakelam, Michael, 2012-05-14" , "GOC:reactome_curators" , "Authored: Williams, MG, 2011-09-14" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-1482788" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-1483206/R-HSA-1483206> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

