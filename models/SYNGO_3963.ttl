gomodel:SYNGO_3963  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig2 shows cells expressing syntaxin13 (STX13) lacking its transmembrane domain AMPA receptors are no longer inserted upon stimulation. Fig 3 shows that LTP is blocked by the acute infusion of STX13-dTM peptide, and not by another syntaxin molecule (STX7), suggesting the effect is specific to STX13. Given that STX13 is localised at recycling endosomes (see CC ticket), it is unlikely that STX13 is directly involved in the delivery of AMPA receptors to the plasma membrane, rather is regulates this process.. Experimental description: Hippocampal neuron cultures were prepared from E18 rat embryos." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0001-5259-4945" ;
        dc:date           "2020-06-15" ;
        dc:title          "SYNGO_BP_3963" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

