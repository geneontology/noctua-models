obo:BFO_0000050  a  owl:ObjectProperty .

:R-HSA-8866423  a           obo:GO_0034379 , owl:NamedIndividual ;
        rdfs:comment        "Very low-density lipoprotein (VLDL) is synthesised in the liver in two steps. First, apolipoprotein B-100 (APOB-100) is co- and post-translationally lipidated in the rough ER lumen. After transfer to the smooth ER lumen, lipidated APOB-100 acquires lipids to become bona fide VLDL. Lipid composition of VLDL - triglycerides (50-60%), cholesterol (10-12%), cholesterol esters (4-6%), phospholipids (18-20%), and apolipoprotein B (8-12%). When VLDL assembly is complete, it travels along the Golgi apparatus to be eventually secreted from the liver into general circulation. In circulation, VLDL can acquire more lipoproteins. At least two other apolipoproteins are constituents; apolipoprotein C-I (APOC1, around 20%) and apolipoprotein C4 (APOC4, minor amount) (Gibbons et al. 2004; Olofsson et al. 2000)." ;
        rdfs:label          "VLDL assembly" ;
        dc:contributor      "Reviewed: D'Eustachio, Peter, 2016-04-05" , "Edited: Jassal, Bijay, 2016-04-01" , "GOC:reactome_curators" , "Authored: Jassal, Bijay, 2016-04-01" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-8866423" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-8963898/R-HSA-8963898> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

