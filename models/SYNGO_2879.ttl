gomodel:SYNGO_2879  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.6: \"Selective dynamin 1 inhibition through siRNA impairs both synaptic plasticity and associative memory\"\n- \"Next, we infused Penetratin1-conjugated dynamin 1-siRNA (80 nM in a final volume of 1.5 μl over 1 minute, bilateral intrahippocampal infusions twice a day for 3 days prior to electrophysiology or behavior). We found a reduction in both contextual fear memory and LTP (Fig. 6B-D).\". Experimental description: - \"Specific Pathogen Free, male mice, aged 4-5 months, were obtained from Jackson Laboratories. \"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2018-03-13" ;
        dc:title          "SYNGO_BP_2879" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

