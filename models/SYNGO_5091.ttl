obo:ECO_0001225  a  owl:Class .

gomodel:SYNGO_5091  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 4: reverse-IPs and mutated-domain-controls showed l-afadin can interact with alphaE-catenin and alphaN-catenin.\n\nFigure 2, 3, 5: dendritic puncta for N-cadherin and alphaN-catenin in cultured hippocampal neurons were reduced in afadin (AFDN) deficient mice and could be rescued by overexpressing l-afadin (long isoform) but not s-afadin (short isoform). Overexpressing a mutated construct of l-afadin showed its FAB domain was required (Fig. 3). Disrupting the αN-catenin to l-afadin binding incurs the same phenotype (Fig. 5).. Experimental description: Results, Figure 3 legend: \"The neurons were obtained from the afadin-deficient mice and were transfected with the indicated constructs\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-4973-5732" ;
        dc:date           "2023-02-24" ;
        dc:title          "SYNGO_BP_5091" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

