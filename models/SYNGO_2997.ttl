gomodel:SYNGO_2997  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig. 5 implies that RIBEYE is essential for the formation of synaptic ribbons at photoreceptor synapes and bipolar synapses. RIBEYE KO causes a loss of synaptic vesicles in the vicinity of the active zone (Fig. 5) and severly impairs neurotransmitter release at bipolar cell to amacrine cell synapses (Fig.6).. Experimental description: \"Generation of RIBEYE KI GCamP3 (RBEKI+neo allele)-mutated mice\nwas performed using standard procedures.\" p. 1110" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9880-1214" , "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-0269-0311" , "https://orcid.org/0000-0002-9681-3318" ;
        dc:date           "2018-05-22" ;
        dc:title          "SYNGO_MF_2997" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

