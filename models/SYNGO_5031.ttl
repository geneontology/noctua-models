lego:evidence  a  owl:AnnotationProperty .

gomodel:SYNGO_5031  a     owl:Ontology ;
        rdfs:comment      "Rationale: \"Transmission electron microscopy confirmed dendrin immunoreactivity in the dorsal horn neurons of the SC from M-SH-C rats, by using immunogold staining. As expected, gold particles were found in the postsynaptic area as well as in the neuronal soma and nucleus. It seems that the immunoreaction was distributed randomly throughout the neuronal soma and nucleus. Although less numerous, the gold particles were found in the presynaptic area and axon terminals confirming the immunoreactivity for dendrin in these areas as well. The immunoreaction in these areas usually was distributed near the presynaptic membrane close to synaptic vesicles and mitochondria (Fig. 7)\". Experimental description: Result section: \"Transmission electron microscopy confirmed dendrin immunoreactivity in the dorsal horn neurons of the SC from M-SH-C rats, by using immunogold staining.\"\n\nantibody;\nanti-dendrin antibody (1:500, AB15299-I, EMD Millipore, Temecula, USA)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" ;
        dc:date           "2023-02-18" ;
        dc:title          "SYNGO_CC_5031" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

