<http://model.geneontology.org/ev_w_id_R-HSA-159431_RO_0002333_UniProt_Q14032_R-HSA-159431_controller_Reactome_R-HSA-159418>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/ECO_0000313> ;
