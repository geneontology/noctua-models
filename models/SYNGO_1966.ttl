gomodel:SYNGO_1966  a     owl:Ontology ;
        rdfs:comment      "Rationale: The synaptogenic activity of Hevin/SPARCL1 is antagonized by SPARC (Fig. 4C). Hevin is locally required for synapse formation (SynGO ID 1004) (Sing et al (2016), PMID: 26771491), at retinocollicular synapses.\n\n20/11/2017 Pim\n- Note this protein is secreted from glial cells and is a regulator of synapse formation.. Experimental description: \"RGCs were purified by sequential immunopanning to greater than 99.5% purity from P5 to P7 Sprague-Dawley rats (Charles River)...\", p E448" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-0269-0311" , "https://orcid.org/0000-0002-9880-1214" , "https://orcid.org/0000-0002-9681-3318" ;
        dc:date           "2017-11-26" ;
        dc:title          "SYNGO_BP_1966" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

