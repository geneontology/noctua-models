obo:RO_0002333  a  owl:ObjectProperty .

:R-HSA-3065676  a           obo:GO_0008150 , owl:NamedIndividual ;
        rdfs:comment        "The UBA2:SAE1 complex catalyzes the formation of a thioester linkage between the C-terminal glycine of the mature SUMO and a cysteine residue (cysteine-173) in UBA2 (SAE2) (reviewed in Wang and Dasso 2009, Wilkinson and Henley 2010, Hannoun et al. 2010, Gareau and Lima 2010). During the process the C-terminal glycine residue of SUMO is reacted with ATP to yield pyrophosphate and a transient intermediate, SUMO adenylate. The SUMO adenylate then reacts with the thiol group of the cysteine residue of UBA2 (Olsen et al. 2010)." ;
        rdfs:label          "SUMO is conjugated to E1 (UBA2:SAE1)" ;
        dc:contributor      "GOC:reactome_curators" , "Authored: May, B, 2013-02-06" , "Edited: May, B, 2013-02-06" , "Reviewed: Garg, Amit K, 2013-05-16" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-3065676" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-3215018/R-HSA-3215018> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

