gomodel:SYNGO_60  a       owl:Ontology ;
        rdfs:comment      "Rationale: This publication demonstrates with immuno-EM and immunofluorescence that RIM1 is specifically localized at the active zone in spinal cord and ribbon synapses. It makes use of two separate antibodies, plus additional controls (including secondary only). No knockout control is provided.. Experimental description: Double and single immunofluorescence labelling of cryostat sections from rat spinal cord and bovine retinae was performed27 with two independent polyclonal Rim antibodies and multiple monoclonal antibodies to synaptic vesicle proteins." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-7620-2704" , "https://orcid.org/0000-0002-1558-1958" ;
        dc:date           "2017-03-21" ;
        dc:title          "SYNGO_CC_60" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

