:R-HSA-211733  a            owl:NamedIndividual , obo:GO_0043066 ;
        rdfs:comment        "Stimulation of cell death by PAK-2 requires the generation and stabilization of the caspase-activated form, PAK-2p34 (Walter et al., 1998;Jakobi et al., 2003). Levels of proteolytically activated PAK-2p34 protein are controlled by ubiquitin-mediated proteolysis. PAK-2p34 but not full-length PAK-2 is degraded by the 26 S proteasome (Jakobi et al., 2003). It is not known whether ubiquitination and degradation of PAK-2p34 occurs in the cytoplasm or in the nucleus." ;
        rdfs:label          "Regulation of activated PAK-2p34 by proteasome mediated degradation" ;
        dc:contributor      "Reviewed: Chang, E, 2008-05-21 00:05:41" , "Edited: Matthews, L, 2008-02-03 20:50:13" , "Authored: Jakobi, R, 2008-02-05 11:04:14" , "GOC:reactome_curators" , "Edited: Matthews, L, 2008-06-12 00:23:53" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-211733" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-169911/R-HSA-169911> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

