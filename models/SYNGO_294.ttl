gomodel:SYNGO_294  a      owl:Ontology ;
        rdfs:comment      "Rationale: Average enrichment of Calnexin in docked synaptic vesicles is 4.5 fold (Boyken et al. 2013).\nNote:\nTo date Calnexin is considered mainly as a single-pass type 1 membrane protein of the ER membrane (Wiest et al. 1995).\nHowever, Calnexin has also been detected in postsynatic membranes (SynGO ID 295). Accordingly it may also appear in the presynaptic membrane. Alternatively the preparation may contain ER components.. Experimental description: To isolate docking complexes from rat brain, we first prepared synaptosomes and subjected them to limited proteolysis to dissociate pre- and postsynaptic membranes (Figure 1A). p. 286" , "Automated change 2024-03-14: GO:0099059 replaced by GO:0048787" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-0269-0311" , "https://orcid.org/0000-0002-9681-3318" , "https://orcid.org/0000-0002-9880-1214" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_294" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

