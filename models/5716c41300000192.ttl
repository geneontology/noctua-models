[ a                      owl:Axiom ;
  rdfs:comment           "ES:  Neurons receive information from the environment or other\nneurons through dendritic structures termed neuronal receptive\nendings (NREs).  AFD NREs consist of microvilli and a single simple cilium\n(Figure 1A) (Doroquez et al., 2014; Perkins et al., 1986).  A null lesion in the gene, kcc-3 (ok228), results in temperature- and age-dependent loss of AFD NREs." ;
  lego:evidence          :5716c41300000320 ;
  dc:contributor         "https://orcid.org/0000-0002-1706-4196" ;
