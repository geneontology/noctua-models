:R-HSA-389542  a            owl:NamedIndividual , obo:GO_0006740 ;
        rdfs:comment        "The conversion of isocitrate to 2-oxoglutarate (alpha-ketoglutarate) with the concomitant synthesis of NADPH from NADP+ is thought to play a significant role in supplying NADPH for other reactions in both the cytosol and the peroxisome (Geisbrecht and Gould 1999). The activity of H6PD (Hexose-6-phosphate dehydrogenase) is thought to play a role in maintaining NADP+ : NADPH balance within the endoplasmic reticulum (Zielinska et al. 2011)." ;
        rdfs:label          "NADPH regeneration" ;
        dc:contributor      "Reviewed: Jassal, Bijay, 2009-02-27" , "GOC:reactome_curators" , "Reviewed: D'Eustachio, Peter, 2024-02-08" , "Edited: D'Eustachio, P, 2009-01-07 23:39:54" , "Authored: D'Eustachio, P, 2009-01-07 23:39:54" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-389542" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-8978934/R-HSA-8978934> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

