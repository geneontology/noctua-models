gomodel:SYNGO_436  a      owl:Ontology ;
        rdfs:comment      "Rationale: Confocal microscopy experiments described in this article provide evidence that PKA RIIB is present at the postsynapse. Images suggest that RIIB is localized to dendritic spines, but the resolution is not sufficient to make that claim. A knockout control for the antibody is not provided.\n\n23/5/2017:\n- Fig.4 literal: \"Arrows indicate the localization of PKARIIβ at the base of dendritic spines.\". I agree on the selected 'postsynapse' term.. Experimental description: Co-staining of endogenous LRRK2 (green) and PKARIIβ (red) in cultured mouse hippocampal neurons at 15 DIV. The middle two panels show the boxed areas in the top panel. The bottom panel shows LRRK2 (green) and PKARIIβ (red) staining in 15 DIV Lrrk2-/- hippocampal neurons (arrowheads point to dendritic spines). Scale bars represent 20 μm (top) and 5 μm (bottom)." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-7620-2704" , "https://orcid.org/0000-0002-1558-1958" ;
        dc:date           "2017-05-23" ;
        dc:title          "SYNGO_CC_436" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

pav:providedBy  a  owl:AnnotationProperty .

