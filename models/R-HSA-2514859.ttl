:R-HSA-2514859  a           obo:GO_0022400 , owl:NamedIndividual ;
        rdfs:comment        "To terminate the single photon response and restore the system to its basal state, the three activated intermediates in phototransduction, rhodopsin (MII), transducin alpha subunit with GTP bound (GNAT1-GTP) and phosphodiesterase 6 (PDE6) all need to be efficiently deactivated. In addition, the cGMP concentrations must be restored to support reopening of the CNG channels. This section describes the inactivation and recovery events of the activated intermediates involved in phototransduction (Burns & Pugh 2010, Korenbrot 2012)." ;
        rdfs:label          "Inactivation, recovery and regulation of the phototransduction cascade" ;
        dc:contributor      "Reviewed: Makino, C, 2013-04-11" , "Edited: Jassal, B, 2012-10-11" , "Authored: Jassal, B, 2012-10-11" , "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-2514859" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-2514856/R-HSA-2514856> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

