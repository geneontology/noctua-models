:R-HSA-2395516  a           obo:GO_0006124 , owl:NamedIndividual ;
        rdfs:comment        "NADPH, ferredoxin reductase (FDXR, Adrenodoxin reductase), and ferredoxins (FDX1, FDX1L) comprise a short electron transport chain that provides electrons for biosynthesis of iron-sulfur clusters and steroid hormones (Sheftel et al. 2010, Shi et al. 2012, reviewed in Grinberg et al. 2000, Lambeth et al. 1982)." ;
        rdfs:label          "Electron transport from NADPH to Ferredoxin" ;
        dc:contributor      "GOC:reactome_curators" , "Edited: May, B, 2012-06-29" , "Authored: May, B, 2011-06-04" , "Reviewed: Rouault, Tracey A, 2012-10-11" , "Reviewed: Tong, Wing-Hang, 2012-10-11" , "Authored: Lill, R, 2012-09-24" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
