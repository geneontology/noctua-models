        a       owl:Class .

:R-HSA-1237112  a           obo:GO_0071267 , owl:NamedIndividual ;
        rdfs:comment        "Methionine salvage is a sequential pathway of six reactions that create methionine from 5'-methylthioadenosine (MTA) which is a byproduct of polyamine biosynthesis in nearly all organisms. The process happens completely in the cytosol. It is important in humans for recycling of sulphur that has to be assimilated using energy. (Pirkov et al, 2008; Albers, 2009)" ;
        rdfs:label          "Methionine salvage pathway" ;
        dc:contributor      "Authored: Stephan, R, 2010-10-24" , "Edited: Jassal, B, 2011-03-30" , "GOC:reactome_curators" , "Reviewed: D'Eustachio, P, 2011-05-23" ;
