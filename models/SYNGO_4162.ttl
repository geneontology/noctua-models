gomodel:SYNGO_4162  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig4: Vti1a colocalizes with synaptobrevin in mossy fibre nerve terminals.\nFig 5: Vti1a is enriched in synaptic vesicle (CPG3) fraction, similar to synaptobrevin.\nFig6: To confirm that Vti1a is localized to synaptic vesicles, the CPG3 fraction was analyzed by immunogold electron microscopy. Vti1a antiserum specifically stained synaptic vesicles similar to the staining by synaptic vesicle marker synaptophysin.\nFigure 1: Antibody specificity was tested by Western blot from brain lysates which recognised the calculated MW (~27 kDa) of the Vti1a protein.. Experimental description: Adult female Sprague Dawley rats were used for the immunoprecipitation and immunofluorescence experiments." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-2916-7616" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2021-01-18" ;
        dc:title          "SYNGO_CC_4162" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

