:R-HSA-8964038  a           obo:GO_0034383 , owl:NamedIndividual ;
        rdfs:comment        "LDL (low-density lipoproteins) are complexes of a single molecule of apoprotein B-100 (apoB-100) non-covalently associated with triacylglycerol, free cholesterol, cholesterol esters, and phospholipids.Clearance of LDL from the blood involves binding to LDL receptors associated with coated pits at the cell surface, forming complexes that are internalized and passed via clathrin-coated vesicles to endosomes, where they dissociate. The LDL particles move into lysosomes and are degraded while the LDL receptors are returned to the cell surface. This process occurs in most cell types but is especially prominent in hepatocytes. It plays a major role in returning cholesterol from peripheral tissues to the liver (Hobbs et al. 1990)." ;
        rdfs:label          "LDL clearance" ;
        dc:contributor      "Reviewed: Jassal, Bijay, 2016-08-04" , "Authored: D'Eustachio, P, 2007-04-30 14:17:00" , "Edited: D'Eustachio, P, 2007-04-30 14:17:00" , "Authored: Jassal, Bijay, 2016-02-10" , "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-8964038" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-8964043/R-HSA-8964043> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

