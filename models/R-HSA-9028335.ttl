:R-HSA-9028335  a           obo:GO_0051897 , owl:NamedIndividual ;
        rdfs:comment        "Neurotrophin receptor NTRK2 (TRKB), activated by BDNF or NTF4, activates PI3K, resulting in formation of the PIP3 secondary messenger. PIP3 activates AKT signaling, and AKT signaling activates mTOR signaling (Yuen and Mobley 1999, Cao et al. 2013)." ;
        rdfs:label          "Activated NTRK2 signals through PI3K" ;
        dc:contributor      "GOC:reactome_curators" , "Reviewed: Antila, Hanna, 2018-02-13" , "Authored: Orlic-Milacic, Marija, 2018-01-05" , "Edited: Orlic-Milacic, Marija, 2018-02-20" , "Reviewed: Castrén, Eero, 2018-02-13" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-9028335" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-9006115/R-HSA-9006115> ;
