gomodel:SYNGO_4722  a     owl:Ontology ;
        rdfs:comment      "Rationale: Confocal, STED (Figure 1) and STORM (Figure 3) microscopy showed GFP-CLCa (clathrin light-chain-A, CLTA) and Homer1 are adjacently localized at dendritic spines. Taken together, results showed CLCa is localized at the postsynaptic endocytic zone (Figure 7).. Experimental description: M&M: \"Hippocampal cultures were prepared from brain of embryonic day 18 (E18) Wistar rats (both genders) as described before (Scheefhals et al., 2019)\"\n\n\"GFP-CLCa knock-in construct (Willems et al., 2020).\" PMID:32275651" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2022-07-31" ;
        dc:title          "SYNGO_CC_4722" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

