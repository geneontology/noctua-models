obo:GO_0003674  a  owl:Class .

gomodel:SYNGO_2677  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.2: \"c-Abl modulates the synaptic contact number and PSD-95 clustering\"\n- \"These results suggest that c-Abl activity specifically modulates PSD-95 clustering and not the general structure of the postsynaptic compartment.\"\n\nFig.3: \"c-Abl kinase activity modulates synaptic clustering of PSD-95\"\n- \"Altogether, these results demonstrate that c-Abl activity is required for PSD-95 clustering.\"\n\nFig.4: \"c-Abl interacts with PSD-95, and STI571 modulates PSD-95 tyrosine phosphorylation in hippocampal culture\"\n\nFig.5: \"PSD-95 tyrosine phosphorylation is regulated by c-Abl activity\"\n- \"these results indicate that GST-PSD-95 can be tyrosine phosphorylated by c-Abl.\"\n\nFig.6: \"Tyrosine 533 residue of PSD-95 is phosphorylated by c-Abl and is relevant for PSD-95 clustering\"\n- \"These results indicate that the regulation of PSD-95 clustering by c-Abl is mediated by Y533 phosphorylation.\". Experimental description: - \"Rat hippocampal cultures were prepared as described...\"\n- Species of overexpressed c-Abl; ABL1 is not stated in the paper." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2023-03-17" ;
        dc:title          "SYNGO_BP_2677" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

