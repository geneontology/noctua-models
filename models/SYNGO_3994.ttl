obo:GO_0045202  a  owl:Class .

gomodel:SYNGO_3994  a     owl:Ontology ;
        rdfs:comment      "Rationale: Immunoblotting of rat brain subcellular fractions indicates the presence of RhoB in synaptosomes.\n11/01/2021 Dnyanada: The paper detects RhoB in the crude synaptic vesicle fraction (Sy) and the membrane-bound compartment fraction (Sy Mb) of the rat brain using a polyclonal antibody against RhoB. The quality of the images used in the additional literature field (PMID: 20203211) isn't optimal; and the juxtaposition with synaptophysin & colocalisation with PSD95 isn't robust to qualify the annotation to the SynGO term 'postsynapse'.\nBased on this, the generic term \"synapse\" was chosen.. Experimental description: Materials and Methods \"Isolation and Fractionation of Synaptic Vesicles from Rat Brain - Synaptic vesicles were prepared from rat brains according to Huttner et\nal.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-5615-1014" ;
        dc:date           "2021-01-18" ;
        dc:title          "SYNGO_CC_3994" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

