obo:GO_0004674  a  owl:Class .

:R-HSA-380972  a            owl:NamedIndividual , obo:GO_0051726 ;
        rdfs:comment        "Upon formation of a trimeric LKB1:STRAD:MO25 complex, LKB1 phosphorylates and activates AMPK. This phosphorylation is immediately removed in basal conditions by PP2C, but if the cellular AMP:ATP ratio rises, this activation is maintained, as AMP binding by AMPK inhibits the dephosphorylation. AMPK then activates the TSC complex by phosphorylating TSC2. Active TSC activates the intrinsic GTPase activity of Rheb, resulting in GDP-loaded Rheb and inhibition of mTOR pathway." ;
        rdfs:label          "Energy dependent regulation of mTOR by LKB1-AMPK" ;
        dc:contributor      "Reviewed: Zwartkruis, Fried J T, 2015-05-14" , "GOC:reactome_curators" , "Authored: Katajisto, P, Makela, T, Wu, J, 2008-11-19" , "Edited: Jassal, B, 2008-11-19 15:14:38" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-380972" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-165159/R-HSA-165159> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

