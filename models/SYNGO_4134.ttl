obo:UBERON_0002421  a  owl:Class .

gomodel:SYNGO_4134  a     owl:Ontology ;
        rdfs:comment      "Rationale: Punctate staining and partial colocalisation of ARL6IP5 with synaptophysin and lack of colocalisation with PSD95 suggests that a small fraction of ARL6IP5 is present at the presynapse.\n\n28/01/2021 Dnyanada: Western Blot from mouse brain lysates shows a ~23kD band representative of addicsin's predicted molecular weight. This band disappears when pre-absorbed with antigenic peptide. However, information on this \"antigenic peptide\" is missing.. Experimental description: In the adult mouse brain, coronal microtome sections 25 um thick were stained by using a VECTASTAINTM Elite ABC kit (Vector, Burlingame, CA), as described previously." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-5615-1014" ;
        dc:date           "2021-01-28" ;
        dc:title          "SYNGO_CC_4134" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

