gomodel:ev_w_id_R-HSA-202214_RO_0002233_R-ALL-29356_R-HSA-202214_Reactome_R-HSA-202427_R-HSA-202214_enabled_by_UniProt_P08575_R-HSA-202214_controller
        a               owl:NamedIndividual , obo:ECO_0000313 ;
