obo:GO_0003674  a  owl:Class .

gomodel:SYNGO_2410  a     owl:Ontology ;
        rdfs:comment      "Rationale: TANC overexpression in cultured neurons increases the density of dendritic spines and excitatory synapses.\nSelective decrease in spine density in the CA3 region of the TANC1-/- hippocampus.. Experimental description: Primary neuron culture, transfection, and immunohistochemistry.\nCultured hippocampal neurons were prepared from embryonic (embryonic day 18) rat brain as described previously (Goslin and Banker, 1991).\n\ncDNA constructs.\n\nHuman TANC1 [amino acids 217-1861; ΔC (a mutant that lacks the last three residues), amino acids 217-1858) and human TANC2 (amino acids 129-1990; ΔC, amino acids 129-1897) were subcloned from the KIAA1728 and KIAA1636 into p3XFLAG-CMV (Sigma)." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-6194-9648" , "https://orcid.org/0000-0001-5518-6584" ;
        dc:date           "2018-02-07" ;
        dc:title          "SYNGO_BP_2410" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

