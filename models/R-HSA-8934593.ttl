<http://model.geneontology.org/ev_w_id_R-HSA-8937728_BFO_0000066_reaction_R-HSA-8937728_location_lociGO_0005654_Reactome_R-HSA-8934593>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/ECO_0000313> ;
        <http://purl.org/dc/elements/1.1/contributor>
