obo:RO_0002333  a  owl:ObjectProperty .

gomodel:SYNGO_3587  a     owl:Ontology ;
        rdfs:comment      "Rationale: 18/5/2018 Pim\nrule: NAS_CPLX_1\nrationale: Ribosomes are present in the axonal compartment (Fig.1, RL22 used as marker protein using the RiboTag mouse line; electron and fluorescence microscopy) and protein translation is shown to occur in this compartment (PMID:27321671). RS16 is a generally accepted constituent of the ribosome. No functions of RS16 are known independent from the ribosomal complex. Inference to term \"ribosome (GO:0005840)\" part_of \"presynapse (GO:0098793)\" is trivial.\nC_ref CC: SynGO ID #1681 (\"presynaptic ribosome\")\nP_inf CC: SynGO ID #3209\nP_inf CC additional:\n- Collins et al.(2006), PMID:16635246, consensus, prep:psd\n- Distler et al.(2014), PMID:25211037, Table S1, prep:synapse\nComplex membership: RS16 protein is a fixed member of the 40S ribosomal subunit complex.\n- Shown in crystal structure (PMID:28138070, see Fig.1, name: us9)\n- GO annotations to \"structural constituent of ribosome (GO:0003735)\" (ISO and IEA). Experimental description: \"In-depth protein profiling of the postsynaptic density from mouse hippocampus using data-independent acquisition proteomics.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9880-1214" , "https://orcid.org/0000-0002-9681-3318" , "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-0269-0311" ;
        dc:date           "2018-05-28" ;
        dc:title          "SYNGO_CC_3587" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

