obo:BFO_0000066  a  owl:ObjectProperty .

gomodel:SYNGO_2951  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.2: \"Localization of Axin in neurons. (ai)Immunofluorescence of endogenous Axinand synaps in in rat hippocampal neurons\"\n- \"A total of 38.4 ± 2.5% of Axin clusters wereoverlapped with S-SCAM clusters and 45 ± 3.3% ofS-SCAM clusters were overlapped with Axin clusters(Fig. 2aii). In the subcellular fractionation of rat brain, Axinwas detected in various fractions including synaptic plasmamembrane and post-synaptic density fractions (Fig. 2b).b-Catenin and GSK3b were also detected in the post-synapticdensity fractions, although both proteins were partially solublein 0.5% (w/v) Triton X-100\". Experimental description: - \"Localization of Axin in neurons. (ai)Immunofluorescence of endogenous Axinand synaps in in rat hippocampal neurons\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0003-0593-3443" ;
        dc:date           "2018-03-23" ;
        dc:title          "SYNGO_CC_2951" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

