:R-HSA-2022870  a           obo:GO_0050650 , owl:NamedIndividual ;
        rdfs:comment        "Chondroitin sulfate (CS) glycosaminoglycan chains consist of N-acetylgalactosamine (GalNAc) residues alternating in glycosidic linkages with glucuronic acid (GlcA). They are bound to the tetrasaccharide linker moiety of core proteins like aggrecan, versican, or decorin. GalNAc residues are sulfated to varying degrees on 4- and/or 6- positions. The steps below describe the biosynthesis of a simple CS chain on a set of possible core proteins (reviewed in Pavao et al. 2006; Silbert & Sugumaran 2002; Mikami & Kitagawa, 2013; Nowicka & Gręda, 2019)." ;
        rdfs:label          "CS-GAG biosynthesis" ;
        dc:contributor      "Reviewed: D'Eustachio, Peter, 2025-03-12" , "Reviewed: D'Eustachio, P, 2012-03-28" , "Edited: Jassal, B, 2011-12-01" , "Authored: Jassal, B, 2011-12-01" , "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-2022870" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-1793185/R-HSA-1793185> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

