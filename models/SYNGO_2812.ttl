gomodel:SYNGO_2812  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.1: \"Wnt7a specifically stimulates the formation and function of excitatory synapses\"\nFig.2: \"Wnt7a acts through Dvl1 to regulate spine morphogenesis\"\nFig.3: \"Wnt mutant mice exhibit defects in dendritic spine morphogenesis and excitatory synaptic function in the hippocampus\"\n[Fig.6: \"Wnt7a induces CaMKII phosphorylation and promotes CaMKII activity at spines.\"]. Experimental description: - \"Hippocampal slices were prepared as described (1) from postnatal day (P)8 wild-type or Wnt7a; Dvl1 mutant mice\"\n- \"Primary hippocampal cultures were prepared from embryonic day 18 Sprague-Dawley rat e...\"\n- \"Medium-density cultures (100 cells per mm2) were treated with purified recombinant Wnt7a (50-100 ng/mL was used) (R&D Systems).\" --> This is a human protein." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2018-03-08" ;
        dc:title          "SYNGO_BP_2812" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

