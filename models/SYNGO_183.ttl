gomodel:SYNGO_183  a      owl:Ontology ;
        rdfs:comment      "Rationale: Immunostaining in Calyx in wistar Rats. Although less clear, positive signals were also discerned for Kv1.1, Kv1.2, and Kv1.3.. Experimental description: MM: Immunocytochemistry. Wistar rats (13-15 d old) were anesthetized with Nembutal and transcardially perfused with a fixative (4% parafor- maldehyde and 0.1% picric acid in 0.1 M sodium phosphate, pH 7.4). After fixation, rats were decapitated, and tissue blocks of the brainstem including the MNTB region were removed for postfixation for 1 d at 4°C" , "Automated change 2024-03-14: GO:0099055 replaced by GO:0045211" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-9425-2935" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_183" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

