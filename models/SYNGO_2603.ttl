gomodel:SYNGO_2603  a     owl:Ontology ;
        rdfs:comment      "Rationale: ITGB3 Suppresses GluR2 Endocytosis.\nPostsynaptic ITGB3 Affects AMPAR Subunit Composition.\n\n21/2/2018 Pim\nFig.1: \"RGD Peptides Reduce mEPSC Amplitude\"\nFig.3: \"Integrins Regulate GluR2 Endocytosis\"\nFig.5: \"Postsynaptic Expression of β3 Integrins Alters mEPSC Amplitude\"\nFig.6: \"Postsynaptic β3 Integrins Affect AMPAR Subunit Composition\". Experimental description: Experimental procedures\nNeuronal Cultures and Transfection\nDissociated rat hippocampal cultures were transfected at 8-12 DIV using a Ca2+ phosphate protocol.\n\nDNA Constructs\nWTβ3 (human integrin β3A subunit, kindly provided by Dr Mark Ginsberg)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-6194-9648" , "https://orcid.org/0000-0001-5518-6584" ;
        dc:date           "2018-02-21" ;
        dc:title          "SYNGO_BP_2603" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_9606" .

