obo:GO_0098978  a  owl:Class .

gomodel:SYNGO_1366  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig 5 shows that eIF4AIII Knockdown Increases Excitatory Synaptic Transmission and GLUR1 Levels at Synapses in cultured cortical neurons (DIV7).\n\nFurthermore in fig. 2 and 3 show that eIF4AIII binds mRNAs that are typically dendritic, such as Arc\n\n13/11/2017 Pim\n- The eIF4AIII protein is shown 1) to be localized to dendrites and 2) to regulate the expression of the postsynaptic Arc and Glur1 proteins. This allows for the straight forward inference to 'postsynapse'.. Experimental description: p3-5 Long-Evans rats" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9848-0262" , "https://orcid.org/0000-0002-4419-210X" , "https://orcid.org/0000-0002-2094-7491" , "https://orcid.org/0000-0002-1190-4481" ;
        dc:date           "2017-11-13" ;
        dc:title          "SYNGO_BP_1366" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

