obo:GO_0098850  a  owl:Class .

gomodel:SYNGO_4183  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig. 1E shows the association of Mover with synaptic vesicles by pre-embedding immunogold labeling. The supporting paper (PMID 23723986) shows immunogold localization of mover to the cytoplasmic surface of synaptic vesicles in a biochemical synaptic vesicle preparation.\n\n18/01/2021 Dnyanada: The specificity of the anti-mover antibody was verified in S2, where western blot analyses showed an almost complete loss of Mover protein upon KD-shRNA expression while expression of the mismatched control shRNA had no effect as compared to wild-type controls.. Experimental description: Sprague Dawly rats were injected with AAV particles into the VCN at P2 as described earlier (p. 530; Exp. Procedues). P12/P13 rats previously injected with AAV particles ... (p. 530)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9880-1214" , "https://orcid.org/0000-0002-0269-0311" , "https://orcid.org/0000-0002-9681-3318" , "https://orcid.org/0000-0001-9377-7414" ;
        dc:date           "2021-01-18" ;
        dc:title          "SYNGO_CC_4183" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .
