gomodel:SYNGO_1207  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig. 3, 6 and 7: Genetic Deletion of SV2C Results in 32% Reduced Striatal Dopamine Release. Measured with fast-scan cyclic voltametry in the dorsal striatum both at baseline and in presence of nicotine.. Experimental description: SV2C-KO mice. We obtained three lines of C57BL/6 ES cells from the European Conditional Mouse Mutagenesis Program containing the SV2C \"knockout- first construct\" (63). ES cells containing the construct were injected into blastocysts. Chimeric mice were bred with C57BL/6J mice." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9900-4233" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2018-06-19" ;
        dc:title          "SYNGO_BP_1207" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

