gomodel:SYNGO_2946  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.2: \"eEF2 phosphorylation by eEF2K plays a key role in remodeling spine morphology\"\n\nFig.3: \"eEF2 phosphorylation by eEF2K regulates synapse morphology\"\n\nFig.4: \"Activity regulates eEF2K-dependent spine morphogenesis\"\n\nFig.5: \"eEF2 phosphorylation by eEF2K regulates local protein synthesis\"\n\nFig.6: \"Neuronal activity modulates BDNF protein and transcripts in a biphasic manner, through the eEF2-eEF2K pathway\"\n\nFig.7: \"Activity modulates BDNF synthesis in dendrites\"\n\nFig.8: \"BDFN overexpression rescues spine phenotype due to eEF2K knock-down\". Experimental description: - \"Hippocampal neuron cultures were prepared from 18- to 19-d-old rat embryos from Charles River.\"\n- \"rat eEF2K mRNA (GenBank accession number NM_007908)\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2018-04-30" ;
