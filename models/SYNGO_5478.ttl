obo:BFO_0000050  a  owl:ObjectProperty .

gomodel:SYNGO_5478  a     owl:Ontology ;
        rdfs:comment      "Rationale: \"ASIC1a Increased the Density of Dendritic Spines.\nWhile examining ASIC1a localization, we were surprised to find that transfecting hippocampal slice neurons with ASIC1a increased spine density >20% (Fig. 2). As an additional test, we studied hippocampal slices from ASIC1a transgenic mice and observed a similar increased spine density (Fig. 2). In contrast to the effects of ASIC1a, expressing ASIC2a, which is highly homologous to ASIC1a but much less pH-sensitive, failed to alter spine density (Fig. 2B).\"\n\nFigure 3: Reducing ASIC1a decreased spine density.\n\nFigure 7: The CaMKII inhibitory peptide AIP inhibited the ASIC1a-induced increase in spine density.. Experimental description: Results: \"As an additional test, we studied hippocampal slices from ASIC1a transgenic mice and observed a similar increased spine density (Fig. 2).\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2023-03-19" ;
        dc:title          "SYNGO_BP_5478" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

