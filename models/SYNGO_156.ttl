lego:evidence  a  owl:AnnotationProperty .

gomodel:SYNGO_156  a      owl:Ontology ;
        rdfs:comment      "Rationale: This paper describes the targeted disruption of the mouse Collybistin (CB) gene. CB-deficient mice display a region-specific loss of postsynaptic gephyrin and GABA A receptor clusters in the hippocampus and the basolateral amygdala. Significant impairment of inhibitory synapse function is shown by electrophysiology.. Experimental description: Impaired GABAergic transmission and altered hippocampal synaptic plasticity in collybistin-deficient mice." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-0269-0311" , "https://orcid.org/0000-0002-9880-1214" , "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-9681-3318" ;
        dc:date           "2017-07-07" ;
        dc:title          "SYNGO_BP_156" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

