gomodel:SYNGO_930  a      owl:Ontology ;
        rdfs:comment      "Rationale: In synaptosomal fractions from hippocampal CA1 tissues GluN2B protein levels were significantly increased in Eps8-/- mice.\n\n22/6/2017 Pim\nFig.3 \" Conditional deletion of Eps8 elevates synaptic GluN2B-containing NMDAR activity\"\nFig.4 \"Conditional deletion of Eps8 increases synaptic GluN2B subunit expression\"\nThese two lines of evidence show that the number of receptor molecules in the synaptic density are increased.\n- ifenprodil used as Glun2B-selective antagonist. Experimental description: \"synaptosomal fraction from hippocampal CA1 tissues to examine the expression patterns of NMDAR subunits in WT and Eps8-/- mice'\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0912-1514" , "https://orcid.org/0000-0002-3670-7863" ;
        dc:date           "2017-10-12" ;
        dc:title          "SYNGO_BP_930" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

