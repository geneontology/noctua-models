gomodel:SYNGO_4158  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig3: HA-tagged Nrg3 localises with pre (VGlut) and postsynaptic markers (PSD95) in pyramidal cells.\n\n20/01/2021 Dnyanada: The immunofluorescence images do not provide sufficient resolution to distinguish between pre and postsynaptic localisation and hence the ontology term \"synapse\" was chosen. The paper does not comment on antibody specificity.. Experimental description: the DNA sequences of the predominant isoforms for Nrg1 (GenBank: NM_178591, Ensembl Transcript ID: ENSMUST00000073884.5) and Nrg3 (GenBank: NM_008734, Ensembl Transcript ID:ENSMUST00000166968.8)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9888-0928" , "https://orcid.org/0000-0002-1212-5623" , "https://orcid.org/0000-0002-2345-393X" ;
        dc:date           "2021-01-20" ;
        dc:title          "SYNGO_CC_4158" ;
        pav:providedBy    "https://syngo.vu.nl" ;
