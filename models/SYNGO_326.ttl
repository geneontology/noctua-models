obo:RO_0002333  a  owl:ObjectProperty .

gomodel:SYNGO_326  a      owl:Ontology ;
        rdfs:comment      "Rationale: This study uses two methods to describe the subcellular localization of RIM4gamma.\n\n-Using subcellular fractionation based on synaptosomes, RIM4gamma was detected in a triton-insoluble fraction. This fraction is enriched in pre-and postsynaptic densities. (Figure 2A).\n-In confocal microscopy, RIM4gamma was present in dendrites, with some overlap with the synaptic markers synapsin and PSD95 (figure 2C-E).\n\nNeither experiment has sufficient resolution to discriminate between pre- and postsynaptic localization.\n\nThe antibody used was verified using RNA knockdown and western blot analysis (Figure 3A).. Experimental description: The studies were performed on brains of Wistar rats of either sex (Charles River)." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-7620-2704" , "https://orcid.org/0000-0002-1558-1958" ;
        dc:date           "2018-06-01" ;
        dc:title          "SYNGO_CC_326" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

