<http://model.geneontology.org/R-HSA-74977_R-HSA-74987>
        a       <http://purl.obolibrary.org/obo/go/extensions/reacto.owl#REACTO_R-HSA-74977> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
