gomodel:SYNGO_2038  a     owl:Ontology ;
        rdfs:comment      "Rationale: \"mAb-GlyRβ revealed immunoreactive puncta along the dendrites and on the somata of SCNs. B-D: Double-labeling with mAb-GlyRβ and a VIAAT antibody revealed significant apposition of GlyRβ puncta to inhibitory nerve terminals. E-G: Additionally, GlyRβ staining colocalized with gephyrin clusters detected by a polyclonal antibody.\"\n\n18/02/2021 Dnyanada: The high degree of colocalisation of GlyRβ puncta with gephyrin make it suitable for a specific ontology term \"postsynaptic specialization\" (previously annotated to the term \"synapse\").. Experimental description: \"Synaptic localization of mAb-GlyRβ immunoreactivity in cultured rat spinal neurons\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2021-02-18" ;
        dc:title          "SYNGO_CC_2038" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

