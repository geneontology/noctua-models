gomodel:SYNGO_1671  a     owl:Ontology ;
        rdfs:comment      "Rationale: SPARC antagonizes Hevin/SPARCL1 (Fig. 4C), a protein, which is locally required synapse formation (SynGO ID 1004) (Sing et al (2016), PMID: 26771491), at retinocollicular synapses.\n\n20/11/2017 Pim\n- Note this protein is secreted from glial cells and is a regulator of synapse formation.. Experimental description: \"RGCs were purified by sequential immunopanning to greater than 99.5% purity from P5 to P7 Sprague-Dawley rats (Charles River)...\", p E448" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9681-3318" , "https://orcid.org/0000-0002-0269-0311" , "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-9880-1214" ;
        dc:date           "2017-12-05" ;
        dc:title          "SYNGO_BP_1671" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

