<http://model.geneontology.org/ev_w_id_R-HSA-9011300_RO_0002333_R-HSA-9011300_R-HSA-9011265_Reactome_R-HSA-9011300>
        a       <http://purl.obolibrary.org/obo/ECO_0000313> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
