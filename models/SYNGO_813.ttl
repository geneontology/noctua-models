obo:GO_0098982  a  owl:Class .

gomodel:SYNGO_813  a      owl:Ontology ;
        rdfs:comment      "Rationale: The taurine transporter transports taurine into neurons.\n\nTaurine transporter (TAUT) KO mice exhibit a strong reduction in the taurine concentration in different brain regions (Table 2). Taurine levels were determined from microdissected, homogenized tissue samples using an amino acid analyser.. Experimental description: Genotyped 6- to 11-week-old TAUT KO (n= 11) and wild-type (WT, n= 10) mice..." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-0755-5899" , "https://orcid.org/0000-0003-0938-8534" , "https://orcid.org/0000-0001-7351-8706" , "https://orcid.org/0000-0003-3185-5709" ;
