:R-HSA-5689603  a           owl:NamedIndividual , obo:GO_0008150 ;
        rdfs:comment        "DUBs of the Ub C-terminal Hydrolase (UCH) family are thiol proteases that have an N-terminal catalytic domain sometimes followed by C-terminal extensions that mediate protein-protein interactions. Humans have four UCH DUBs (UCH-L1, UCH-L3, UCH37/UCH-L5, and BAP1) that can be divided into the smaller UCH DUBs (UCH-L1 and UCH-L3), which cleave small leaving groups from the C-terminus of ubiquitin (Larsen et al. 1998), and the larger UCH DUBs (UCH37 and BAP1), which can disassemble poly-Ub chains (Misaghi et al. 2009, Lam et al. 1997)." ;
        rdfs:label          "UCH proteinases" ;
        dc:contributor      "Edited: Jupe, Steve, 2016-05-05" , "Reviewed: Meldal, Birgit, 2016-05-16" , "GOC:reactome_curators" , "Authored: Jupe, Steve, 2015-04-16" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-5689603" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-5688426/R-HSA-5688426> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

