gomodel:63d320cd00000877
        a                 owl:Ontology ;
        rdfs:comment      "UniProt PPI\n\n\"When\ntaken together, we conclude that FAM83B binds to EGFR, thereby\nincreasing EGFR autophosphorylation and elevating PLD activity,\nwhich is required for FAM83B-mediated transformation, growth\nfactor independence and decreased EGFR-TKI sensitivity.\"\nIn addition they have exp showing activation of egfr by egf" ;
        lego:modelstate   "development" ;
        dc:contributor    "https://orcid.org/0000-0002-8075-8625" ;
        dc:date           "2025-06-20" ;
        dc:title          "FAM83B directly activates the EGFR (Human)" ;
        pav:providedBy    "https://www.uniprot.org" ;
        biolink:in_taxon  obo:NCBITaxon_9606 .

