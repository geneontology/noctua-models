gomodel:SYNGO_1932  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.4: \"Cbln1 directly promotes the clustering of GluD2 and other postsynaptic molecules\"\nCbln1 interacts with the postsynaptic protein GluD2. GluD2 clustered in Purkinje cells around beads coated with HA-Cbln1. With GluD2, shank-2, homer-3, and GluA2 clustered in Purkinje cells around the beads coated with HA-Cbln1. The clustering of PSD components is absent in neurons of GluD2 KO mice.. Experimental description: 20/11/2017 Pim\n- Overexpressed protein is of rat species: \"Rat cDNAs encoding GluD1, GluD2 and GluK2 were gifts from Dr. J. Boulter \"\n- Cell culures were of mouse species: \"Mixed cerebellar cultures were prepared from embryonic day 17 to day-of-birth ICR, GluD2-null (ho5J) or cbln1-null mice \"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-9681-3318" , "https://orcid.org/0000-0002-9880-1214" , "https://orcid.org/0000-0002-0269-0311" ;
        dc:date           "2017-12-05" ;
        dc:title          "SYNGO_BP_1932" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

