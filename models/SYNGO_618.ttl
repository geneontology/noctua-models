gomodel:SYNGO_618  a      owl:Ontology ;
        rdfs:comment      "Rationale: 374 different proteins that copurify with a PSD fraction where identfied by LC-MS/MS.\nRL18_RAT was found among these proteins.\nFor proteins coming from datasets derived from PSD (detergent-resistant synaptic junctions) preparations without defined selection / enrichment of the pre- or postsynaptic compartment we cannot assign these proteins to excitatory and/or inhibitory nor to the presynapse or / and postsynapse without further information.. Experimental description: \"PSD fractions were prepared from rat forebrains largely as previously described (4, 9).\" p. 21004" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-0269-0311" , "https://orcid.org/0000-0002-9681-3318" , "https://orcid.org/0000-0002-9880-1214" ;
        dc:date           "2017-08-08" ;
        dc:title          "SYNGO_CC_618" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

