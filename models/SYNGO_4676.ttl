gomodel:SYNGO_4676  a     owl:Ontology ;
        rdfs:comment      "Rationale: fig 1: shRNA-mediated depletion of KIF5B (but not KIF5A) reduced the number of mature mushroom shaped spines (while increasing the number of filopodia. Spontaneous (mini) EPSC frequency was reduced while amplitude was unaffected.\nFig 2: reduction of spine numbers upon KIF5B depletion can be rescued by KIF5B and by KIF5C, but not KIF5A\nFig 7: spine density was reduced in KIF5B conditional null mutant hippocampus with reduced mini frequency and amplitude.. Experimental description: Key resource table:\nC57/6J WT mice, Kif5bfl/fl mice" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9900-4233" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2022-07-29" ;
        dc:title          "SYNGO_BP_4676" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

