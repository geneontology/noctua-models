lego:evidence  a  owl:AnnotationProperty .

gomodel:SYNGO_3991  a     owl:Ontology ;
        rdfs:comment      "Rationale: Immunocytochemical and immunohistochemical stainings of endogeneous and GFP-labelled ROGDI shows localisation of ROGDI at presynaptic sites via preferential localisation of ROGDI on axons and presynaptic markers including Bassoon, synapsin, synaptotagmin-1.. Experimental description: Primary cultured hippocampal rat neurons were obtained from embryonic day 19 rat brains as described in Dresbach et al." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-5615-1014" ;
        dc:date           "2020-07-24" ;
        dc:title          "SYNGO_CC_3991" ;
