gomodel:SYNGO_305  a      owl:Ontology ;
        rdfs:comment      "Rationale: tagged versions of GLUT4 are shown to translocate to the presynaptic plasma membrane during electrical activity. Preventing this from happening (by genetic ablation of GLUT4) blocks synaptic vesicle endocytosis in a way that is almost identical to simply removing extracellular glucose. The defect in vesicle endocytosis can be rescued by re-expressing intact GLUT4 in the KD neurons but not by re-expressing a mutant GLUT4 that can not transport glucose. Experimental description: Hippocampal CA1-CA3 neurons were isolated from 1- to 3-day-old rats of mixed gender" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-7480-0826" , "https://orcid.org/0000-0003-4022-8707" , "https://orcid.org/0000-0003-2533-9548" , "https://orcid.org/0000-0002-5648-066X" , "https://orcid.org/0000-0002-1212-5623" ;
        dc:date           "2017-09-15" ;
        dc:title          "SYNGO_BP_305" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

