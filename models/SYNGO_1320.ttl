gomodel:SYNGO_1320  a     owl:Ontology ;
        rdfs:comment      "Rationale: Authors show that STAT3 and phospho STAT3 translocates from the cytoplasm to the nucleus upon treatment with NMDA, accumulating in the nucleus over time. Pharmacological blockade of JAK2 by using AG490 completely prevents the NMDA-induced accumulation of STAT3 and pSTAT3 in the nucleus, suggesting a key role in the regulation of this process.. Experimental description: Experiments were performed in rat organotypic hippocampal slices." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0575-6950" , "https://orcid.org/0000-0002-1585-539X" ;
        dc:date           "2018-05-30" ;
        dc:title          "SYNGO_BP_1320" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

