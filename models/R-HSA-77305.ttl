:R-HSA-77305  a             owl:NamedIndividual , obo:GO_0006635 ;
        rdfs:comment        "This first pass through the beta-oxidation spiral starts with the saturated fatty acid palmitoyl-CoA and produces myristoyl-CoA. Four enzymatic steps are required, starting with VLCAD CoA dehydrogenase (Very Long Chain) activity, followed by three enzymatic steps, enoyl-CoA hydratase, 3-hydroxyacyl-CoA dehydrogenase, and ketoacyl-CoA thiolase activities, all present in the mitochondrial membrane associated trifunctional protein." ;
        rdfs:label          "Beta oxidation of palmitoyl-CoA to myristoyl-CoA" ;
        dc:contributor      "Authored: Gillespie, ME, 2003-09-19 00:00:00" , "Edited: Gillespie, ME, 0000-00-00 00:00:00" , "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-77305" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-77286/R-HSA-77286> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

