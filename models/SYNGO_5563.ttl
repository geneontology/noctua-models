gomodel:SYNGO_5563  a     owl:Ontology ;
        rdfs:comment      "Rationale: Cultured hippocampal neurons were immunostained for endogenous Cnnm2, pre-synaptic marker protein synaptophysin (SYP) and postsynaptic marker PSD95 (DLG4). Confocal microscopy confirmed synaptic localization for Cnnm2 by partial co-localization with both marker proteins. The data does not support a more specific annotation to either pre- or post-synaptic compartments.\n\n---\n\nThe experimental data annotated here will be included in an upcoming manuscript (by the SynGO consortium) that describes the SynGO 1.2 update, when a PMID is available this annotation will be updated with the respective reference.. Experimental description: Microscopy experiments were performed in cultured hippocampal mouse neurons.\n\nantibody: ThermoFisher, PA5-102013, Rabbit, poly" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2023-11-28" ;
        dc:title          "SYNGO_CC_5563" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

