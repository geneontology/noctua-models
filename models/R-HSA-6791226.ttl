<http://model.geneontology.org/R-HSA-6791509_R-HSA-6791223>
        a       <http://identifiers.org/uniprot/Q9NRX1> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
        <http://www.w3.org/2000/01/rdf-schema#comment>
                "located_in cytosol" , "Original Reactome ID: UniProt_Q9NRX1" ;
        <http://www.w3.org/2000/01/rdf-schema#label>
