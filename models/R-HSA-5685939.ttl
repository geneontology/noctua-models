gomodel:R-HSA-5687468_R-HSA-5687464
        a                   <http://purl.obolibrary.org/obo/go/extensions/reacto.owl#REACTO_R-HSA-5687468> , owl:NamedIndividual ;
        rdfs:comment        "Original Reactome ID: R-HSA-5687468" , "located_in nucleoplasm" ;
        rdfs:label          "DNA DSB:MRN:RBBP8" ;
        dc:contributor      "GOC:reactome_curators" ;
