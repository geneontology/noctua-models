        <http://purl.obolibrary.org/obo/BFO_0000066>
                <http://model.geneontology.org/reaction_R-HSA-210404_location_lociGO_0005886> ;
        <http://purl.obolibrary.org/obo/RO_0002233>
                <http://model.geneontology.org/R-ALL-210382_extracellular_region> , <http://model.geneontology.org/R-ALL-29804_cytosol> , <http://model.geneontology.org/R-ALL-351626_R-HSA-210404> , <http://model.geneontology.org/R-ALL-74113_extracellular_region> ;
        <http://purl.obolibrary.org/obo/RO_0002234>
                <http://model.geneontology.org/R-ALL-70106_R-HSA-210404> , <http://model.geneontology.org/R-ALL-83910_cytosol> , <http://model.geneontology.org/R-ALL-29404_cytosol> , <http://model.geneontology.org/R-ALL-74126_extracellular_region> ;
