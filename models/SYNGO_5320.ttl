gomodel:SYNGO_5320  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 4b-e: immunofluorescence imaging of Sema7A in cultured thalamic neurons showed partial co-localization with GAD67 (inhibitory synapse marker protein) but not VGLUT2 (excitatory synapse marker protein).\n\nFigure 4f,g: immunogold EM confirmed presynaptic localization of Sema7a.. Experimental description: M&M: \"EM. P9 mice were perfused with 2% paraformaldehyde and 2% glutaraldehyde; L4 in S1 was dissected and processed for postembedding immunogold EM using a freeze substitution protocol\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2023-03-11" ;
        dc:title          "SYNGO_CC_5320" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

