gomodel:SYNGO_3042  a     owl:Ontology ;
        rdfs:comment      "Rationale: In Fig. 1C postembedding immunogold EM localizes endogenous C1ql2 in WT MF-CA3 synapses to the synaptic cleft and the presynaptic membrane. In Fig 1D Super-resolution structured illumination (SIM) microscopy is used to localize C1ql2 between presynaptic Bassoon and postsynaptic PSD-95 immunoreactivities.. Experimental description: Endogenous C1ql2, C1ql3, and GluK2/3 immunoreactivities in WT hippocampus. Arrows indicate CA3 stratum lucidum. Insets show immunoreactivity in mice\nlacking a corresponding gene to confirm antibody specificity. (Legend Fig. 1A, p. 754)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9880-1214" , "https://orcid.org/0000-0002-9681-3318" , "https://orcid.org/0000-0002-0269-0311" , "https://orcid.org/0000-0001-9377-7414" ;
        dc:date           "2018-04-20" ;
        dc:title          "SYNGO_CC_3042" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

