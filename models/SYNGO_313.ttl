gomodel:SYNGO_313  a      owl:Ontology ;
        rdfs:comment      "Rationale: Using electron microscopy it is shown that Piccolo/Aczonin is present at the active zone of conventional synapses (figure 1), and at the ribbon of photoreceptor ribbon synapses (figure 2). No knockout control is available, but the authors used multiple antibodies against Piccolo that essentially show the same staining pattern.. Experimental description: Adult Sprague-Dawley rats were deeply anesthetized and fixed by transcardiac perfusion." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-7620-2704" , "https://orcid.org/0000-0002-1558-1958" ;
        dc:date           "2017-04-05" ;
        dc:title          "SYNGO_CC_313" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

