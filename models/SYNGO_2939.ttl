gomodel:SYNGO_2939  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.1: \"TAOK2 Localizes to Dendritic Spines and Its Kinase Activity Is Required for Spine Maturation\"\n- \"Our immunofluorescence analysis using an antibody that recognizes both isoforms of TAOK2 revealed that, in mature DIV18 hippocampal neurons, TAOK2 was present throughout the neuronal cytoplasm and also localized to the actin-rich dendritic spines and dendritic shaft (Figures 1A and S1A).\". Experimental description: - \"Neuronal Cultures and Transfection: Hippocampi were obtained from E18 Sprague-Dawley rat (Harlan Lab) embryos...\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2018-03-21" ;
        dc:title          "SYNGO_CC_2939" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

