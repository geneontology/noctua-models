:R-HSA-9034864  a           owl:NamedIndividual , obo:GO_0046579 ;
        rdfs:comment        "Upon activation by NTF3 (NT-3), the receptor tyrosine kinase NTRK3 (TRKC) triggers RAS signaling through adaptor proteins SHC1 and GRB2 (Marsh and Palfrey 1996, Gunn-Moore et al. 1997, Yuen and Mobley 1999). ERK activation downstream of NTRK3 may increase cell motility through WAVE. The mechanism is not known (Gromnitza et al. 2018)." ;
        rdfs:label          "Activated NTRK3 signals through RAS" ;
        dc:contributor      "Reviewed: Tsoulfas, Pantelis, 2018-05-09" , "Authored: Orlic-Milacic, Marija, 2018-01-02" , "GOC:reactome_curators" , "Edited: Orlic-Milacic, Marija, 2018-05-09" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-9034864" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-9034015/R-HSA-9034015> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

