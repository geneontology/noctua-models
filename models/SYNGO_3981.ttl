gomodel:SYNGO_3981  a     owl:Ontology ;
        rdfs:comment      "Rationale: Immunocytochemistry shows localisation of PRA1 with Piccolo and Synaptotagmin puncta in hippocampal neurons.\n\nBrain fractionation shows that RABAC1 (PRA1) are present in synaptosomes (synaptic plasma membranes, synaptic supernatant, and pellet following Triton X-100 extraction of extracted synaptic plasma membrane fractions).. Experimental description: The isolation of synaptosome, synaptic plasma membrane, and synaptic junctional preparations was performed as described (Cases-Langhoff et al., 1996). The Cases-Langhoff study was done on rat." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-5615-1014" ;
        dc:date           "2020-08-10" ;
        dc:title          "SYNGO_CC_3981" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

