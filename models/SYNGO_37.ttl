dc:source  a    owl:AnnotationProperty .

gomodel:SYNGO_37  a       owl:Ontology ;
        rdfs:comment      "Rationale: SNAP-23 is enriched at excitatory synapses on dendritic spines co-localizing with PSD-95 and Shank. Surface NMDA receptors are reduced in SNAP-23+/- mice. Knockdown of SNAP-23 causes a reduction in NMDA-evoked currents and NMDA EPSCs in CA1 pyramidal neurons. Experimental description: M&M Fig2A-E :\"Primary hippocampal neurons were prepared from E18 Sprague-Dawley **rats** ..\"\nM&M Fig2F : \"Postembedding immunogold labeling utilized established methods41-44. Briefly, **rats** were perfused \"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9900-4233" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2017-03-21" ;
        dc:title          "SYNGO_CC_37" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

<http://identifiers.org/rgd/620221>
