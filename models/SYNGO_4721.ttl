obo:GO_0003674  a  owl:Class .

obo:BFO_0000066  a  owl:ObjectProperty .

gomodel:SYNGO_4721  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 1c,d,e: Super-resolution imaging of hippocampal neuronal cultures showed anti-mGluR7 (GRM7) co-localized with Bassoon (BSN).\n\nFigure 2,S2: Fluorescence recovery after photobleaching (FRAP) experiments showed surface-expressed mGluR7 was immobile and enriched in presynaptic boutons.\n\nA model for mGluRs 2 and 7 is proposed in Figure 6. Based on the known transmembrane topology of the protein, the \"integral component of ... membrane\" term was chosen.. Experimental description: M&M: \"Dissociated hippocampal cultures from embryonic day 18 (E18) Wistar rat (Janvier Labs) brains of both genders were prepared as described previously\"\n\nantibody:\nrabbit anti-mGluR7 (1:100 dilution, Merck Millipore, #07-239, RRID AB_310459)" , "Automated change 2024-03-14: GO:0099059 replaced by GO:0048787" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_4721" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

