dc:date  a      owl:AnnotationProperty .

gomodel:SYNGO_4868  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 8: Gαi1 (GNAI1) is present in synaptic biochemical subfractions and co-localizes with a polyclonal antibody against PSD proteins (PSD-95, PSD-93, SAP97) in cultured hippocampal neurons. A pulldown of GDP-bound Gαi (pan antibody) yields postsynaptic proteins NR2B, NR1, SAP102 (DLG3), and over-expression of Gαi1 decreased trafficking of NR2B. Taken together, this implies postsynaptic localization of Gαi1.. Experimental description: Results, Figure 8: \"Characterization of cellular compartments containing Gαi1 and Gαipan in P2 rat brain\"\n\nantibody:\nanti-Gαi1 (Santa Cruz, Santa Cruz, CA)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2022-09-09" ;
        dc:title          "SYNGO_CC_4868" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

