pav:providedBy  a  owl:AnnotationProperty .

gomodel:SYNGO_3687  a     owl:Ontology ;
        rdfs:comment      "Rationale: 9/10/2017 Pim\n- BAIAP2 is shown to influence spine density via OE and shRNA KD. BAIAP2 is a known regulator of actin structure signaling via WAVE2. Actin remodelling is shown to be involved via the WAVE2 protein in Fig.9.. Experimental description: - Cultured hippocampal neurons were prepared from embryonic day 18 (E18) rat brain as described previously.\n- Overexpressed BAIUP2 is of human species: \"Human IRSp53 cDNAs (NM_017450; full length aa 1-521 and aa 1-517, which lacks the last four residues) were subcloned into the BamHI-EcoRI site of pcDNA3.1-HA...\" Only annotation made against rat." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4419-210X" , "https://orcid.org/0000-0002-1190-4481" , "https://orcid.org/0000-0002-9848-0262" , "https://orcid.org/0000-0002-2094-7491" ;
        dc:date           "2018-05-29" ;
        dc:title          "SYNGO_BP_3687" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

