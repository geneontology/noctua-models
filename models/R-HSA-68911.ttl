:R-HSA-68911  a             owl:NamedIndividual , obo:GO_0007346 ;
        rdfs:comment        "This is one of two 'gap' phases in the standard eukaryotic mitotic cell cycle. It is the interval between the completion of DNA synthesis and the beginning of mitosis. Protein synthesis occurs in this phase, following DNA replication in the S phase. This is the time when the cell stockpiles on the cytoplasmic contents, before mitosis and cytokinesis occur (Mitchison 2003, Kaldis 2016)." ;
        rdfs:label          "G2 Phase" ;
        dc:contributor      "GOC:reactome_curators" , "Edited: Orlic-Milacic, Marija, 2017-03-24" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-68911" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-453274/R-HSA-453274> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

