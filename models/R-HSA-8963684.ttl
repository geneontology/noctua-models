:R-HSA-8963684  a           owl:NamedIndividual , obo:GO_0006572 ;
        rdfs:comment        "Cytosolic tyrosine is transaminated to form 3-(4-hydroxyphenyl)pyruvate which in four further reactions is converted to fumarate and acetoacetate. Tyrosine is thus both a glucogenic (fumarate) and a ketogenic (acetoacetate) amino acid. Defects in any of the steps lead to metabolic diseases with accumulation of tyrosine (tyrosinemia) (Mitchell et al. 2001; Held, 2006)." ;
        rdfs:label          "Tyrosine catabolism" ;
        dc:contributor      "Edited: D'Eustachio, Peter, 2017-03-21" , "GOC:reactome_curators" , "Authored: Jassal, Bijay, 2017-02-10" , "Reviewed: D'Eustachio, Peter, 2025-11-07" , "Reviewed: D'Eustachio, Peter, 2025-11-14" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-8963684" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-8963691/R-HSA-8963691> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

