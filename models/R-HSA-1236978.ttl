:R-HSA-1236978  a           owl:NamedIndividual , obo:GO_0002479 ;
        rdfs:comment        "Exogenous soluble antigens are cross-presented by dendritic cells, albeit with lower efficiency than for particulate substrates. Soluble antigens destined for cross-presentation are taken up by distinct endocytosis mechanisms which route them into stable early endosomes and then to the cytoplasm for proteasomal degradation and peptide loading." ;
        rdfs:label          "Cross-presentation of soluble exogenous antigens (endosomes)" ;
        dc:contributor      "Edited: Garapati, P V, 2011-03-28" , "Reviewed: Desjardins, M, English, L, 2011-05-13" , "Reviewed: Matthews, Lisa, 2025-02-28" , "Authored: Garapati, P V, 2011-03-28" , "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-1236978" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-1236975/R-HSA-1236975> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

