gomodel:SYNGO_90  a       owl:Ontology ;
        rdfs:comment      "Rationale: PMCA4 is enriched in docked vesicles/active zone membrane fraction.\nIt is 1.6-fold enriched in glutamatergic vs. GABAergic synapses.\n\n26/01/2017 Pim Note\n- Because enriched in AZ and not in free SV AT2B1 is presumably localized to the AZ membrane, not in SVs.\n- Uniprot: transmembrane. Experimental description: Results: \"To isolate docking complexes from **rat brain**, we first prepared synaptosomes and subjected them to limited proteolysis to dissociate pre- and postsynaptic membranes (Figure 1A).\" p. 286" , "Automated change 2024-03-14: GO:0099059 replaced by GO:0048787" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-9880-1214" , "https://orcid.org/0000-0002-0269-0311" , "https://orcid.org/0000-0002-9681-3318" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_90" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

