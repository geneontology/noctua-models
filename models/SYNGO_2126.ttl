gomodel:SYNGO_2126  a     owl:Ontology ;
        rdfs:comment      "Rationale: HIP1 immunolabeling demonstrated a preferential distribution for the postsynaptic compartment and is found three-fold more in the postsynapse compared to the pre synapse. There is currently no way to express this in GO.\n\n11/12/2017 Pim:\n- Fig.3: \"HIP1 immunoreactivity is found in the postsynaptic profiles more often than in the presynaptic profiles\"\n- Fig.5: \"HIP1 immunolabeling, like epsin1, was frequently found to be close to, or even physically associated with, the plasma membrane (Fig. 5)\"....\"HIP1 immunolabeling is concentrated at the plasma membrane of the postsynaptic profiles but is distributed evenly in the presynaptic profiles.\". Experimental description: \"This study focused on the CA1 stratum radiatum of the hippocampus. Sections from all three rats were used for analysis.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-4973-5732" ;
        dc:date           "2017-12-11" ;
        dc:title          "SYNGO_CC_2126" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

