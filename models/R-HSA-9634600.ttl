:R-HSA-9634600  a           owl:NamedIndividual , obo:GO_0006110 ;
        rdfs:comment        "The committed step of glycolysis is the phosphorylation of D-fructose 6-phosphate (Fru(6)P) to form D-fructose 1,6-bisphosphate, catalyzed by phosphofructokinase 1 (PFK) tetramer. PFK can be allosterically activated by D-fructose 2,6-bisphosphate whose levels are increased in response to insulin signaling and decreased in response to glucagon signaling, through the reactions annotated here (Pilkis et al. 1995)." ;
        rdfs:label          "Regulation of glycolysis by fructose 2,6-bisphosphate metabolism" ;
        dc:contributor      "Reviewed: Harris, RA, 2008-09-10 18:47:12" , "Edited: D'Eustachio, Peter, 2019-01-11" , "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-9634600" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-70171/R-HSA-70171> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

