obo:RO_0002333  a  owl:ObjectProperty .

gomodel:SYNGO_4731  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 4: Confocal imaging of hippocampal neuronal cultures with co-staining for Homer1c-mCherry and FCHO1-pmCherryC1 show this protein is localized at the postsynapse.\n\nFigure 5: time-lapse experiments on neurons co-expressing Homer1c and fluorophore-tagged FCHO1 showed transient association with endocytic zones near the PSD, i.e. its average lifetime at perisynaptic sites was significantly lower compared to the average lifetime of CLCa.. Experimental description: M&M: \"Hippocampal cultures were prepared from brain of embryonic day 18 (E18) Wistar rats (both genders) as described before (Scheefhals et al., 2019)\"\n\nFCHO1-pmCherryC1 (Addgene plasmid #27690)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" ;
        dc:date           "2022-08-01" ;
        dc:title          "SYNGO_CC_4731" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

