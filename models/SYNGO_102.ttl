gomodel:SYNGO_102  a      owl:Ontology ;
        rdfs:comment      "Rationale: Localizing Piccolo/Aczonin using multiple antibodies covering the entire length of Piccolo/Aczonin by Immunogold technology to the active zone of cerebellar synapses. The paper describes the orientation relative to the synaptic membrane and compares it to the localization of other proteins including Bassoon, ELKS/CAST, RIM and Munc13.\nSupporting evidence shows the localization of the protein to other glutamatergic synapses in the hippocampus as well as retinal photoreceptor ribbon synapses.. Experimental description: Adult Sprague-Dawley rats were deeply anesthetized and fixed by transcardiac perfusion. p. 8 of 10" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-9880-1214" , "https://orcid.org/0000-0002-9681-3318" , "https://orcid.org/0000-0002-0269-0311" ;
        dc:date           "2017-03-21" ;
        dc:title          "SYNGO_CC_102" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

