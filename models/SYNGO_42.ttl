gomodel:SYNGO_42  a       owl:Ontology ;
        rdfs:comment      "Rationale: Immunolabeling of highly purified synaptic vesicles with antibodies selective for Rab26 by immuno electron microscopy and immunoblotting indicates the presence of this GTPase in synaptic vesicles. Fluorescence microscopy with anti-Rab26 antibodies further indicate the localisation of endogenous Rab26 to presynaptic compartments via colocalisation with synaptotagmin 1.\n\nUniprot: Lipidation 253/254 S-geranylgeranyl cysteine. Experimental description: Sequencing of cDNA encoded by plasmid. Not mentioned in the paper.\n\n19/01/2017 Pim\nNote: please note that the expert that created this annotation is part of the lab that created this publication. The species information is therefore derived from direct communication with the authors." , "Automated change 2024-03-14: GO:0098993 replaced by GO:0030672" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-5615-1014" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_42" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_9606" .

