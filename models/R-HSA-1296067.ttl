:R-HSA-1296067  a           obo:GO_0071805 , owl:NamedIndividual ;
        rdfs:comment        "Inwardly rectifying potassium transport are tetrameric channels that are found in kidney in the nephron. Kir 1.1 works as a homotetramer, however, Kir 4.1 and 5.1 work as heterotetramers. These channels transport K+ from cytosol to the lumen of the tubules." ;
        rdfs:label          "Potassium transport channels" ;
        dc:contributor      "Reviewed: Jassal, Bijay, 2010-09-23" , "GOC:reactome_curators" , "Authored: Mahajan, SS, 2011-05-18" , "Edited: Mahajan, SS, 2011-05-22" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-1296067" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-1296065/R-HSA-1296065> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

