obo:BFO_0000050  a  owl:ObjectProperty .

gomodel:SYNGO_4040  a     owl:Ontology ;
        rdfs:comment      "Rationale: GNAI2 was detected in Liquid chromatography-mass spectrometry results of LDCVs.\nFigure1: Subcellular fractionation shows immunoblotting of GNAI2 in LDCVs fraction.\nFigure 2A: Double immunofluorescence staining shows the distribution of GNAI2(green) with Substance P positive LDCV (red).\nFigure 2B: Post-embedding immunogold (inset) staining against GNAI2 displays localisation on the surface of LDCV.\n\n18/01/2021 Dnyanada: The paper does not provide any information on the specificity of the antibody used.. Experimental description: Mice were used for EM and immunostaining experiments, while rats were used for subcellular fractionation and MS. No mention of mouse strain used ...Authors were contacted for retrieving this information (15/05/2020 Dnyanada, xu.zhang@ion.ac.cn)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0003-2916-7616" ;
        dc:date           "2021-01-18" ;
        dc:title          "SYNGO_CC_4040" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

