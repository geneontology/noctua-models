<http://model.geneontology.org/UniProtKB_Q9BYK8_R-HSA-381367_R-HSA-560517_component>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://identifiers.org/uniprot/Q9BYK8> ;
