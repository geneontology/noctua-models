:R-HSA-6787639  a           obo:GO_0042350 , owl:NamedIndividual ;
        rdfs:comment        "Fucose-containing glycans play important roles in immunity and signalling. Fucosylated glycans are created by fucosyltransferases, which require the high-energy donor substrate GDP-fucose. Two pathways for the synthesis of GDP-fucose exist in mammalian cells; the GDP-mannose-dependent de novo pathway provides the majority of GDP-fucose whereas a minor contribution comes from the free fucose-dependent salvage pathway (Becker & Lowe 2003)." ;
        rdfs:label          "GDP-fucose biosynthesis" ;
        dc:contributor      "GOC:reactome_curators" , "Reviewed: D'Eustachio, Peter, 2015-09-14" , "Authored: Jassal, Bijay, 2015-07-15" , "Edited: Jassal, Bijay, 2015-07-15" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-6787639" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-446219/R-HSA-446219> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

