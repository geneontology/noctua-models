:R-HSA-9032759  a           owl:NamedIndividual , obo:GO_0008150 ;
        rdfs:comment        "DOCK3-mediated activation of RAC1 downstream of BDNF-induced signaling by NTRK2 (TRKB) plays a role in axonal growth and regeneration. DOCK3 can be recruited to the plasma membrane to activate RAC1 by binding to NTRK-associated FYN (Namekata et al. 2010). Alternatively, DOCK3 can, upon poorly elucidated RHOG activation by the BDNF:NTRK2 complex, bind to the RHOG:GTP complex and activate RAC1 in an ELMO1-dependent manner (Namekata et al. 2012)." ;
        rdfs:label          "NTRK2 activates RAC1" ;
        dc:contributor      "Edited: Orlic-Milacic, Marija, 2018-02-20" , "GOC:reactome_curators" , "Reviewed: Antila, Hanna, 2018-02-13" , "Reviewed: Castrén, Eero, 2018-02-13" , "Authored: Orlic-Milacic, Marija, 2018-01-05" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-9032759" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-9032500/R-HSA-9032500> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

