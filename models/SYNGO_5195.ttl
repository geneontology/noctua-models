obo:BFO_0000050  a  owl:ObjectProperty .

gomodel:SYNGO_5195  a    owl:Ontology ;
        rdfs:comment     "Rationale: Figure 1: RPS23RG1 knockout mice exhibit learning and memory deficits and synaptic plasticity impairment.\n\nFigure 2: postsynapse maturation and synapse density was impaired in RPS23RG1 knockout mice.\n\nFigure 3, 4: RPS23RG1 knockout enhanced PSD93 (DLG2) and PSD95 (DLG4) turnover.\n\nFigure 4c, S7, S7: pulldown of endogenous RPS23RG1 in wildtype and RPS23RG1-knockout mice showed interaction with PSD93 (DLG2) and PSD95 (DLG4), competing for binding with MDM2 and thus attenuating ubiquitination.\n\nFigure 4d: confocal imaging of overexpressed human HA-tagged RPS23RG1 in mouse primary neuronal cultures showed partial co-localization with PSD93 (DLG2) and PSD95 (DLG4).. Experimental description: annotated the confocal localization evidence in Figure 4d; \"HA-tagged human RR1 was transfected into WT mouse primary neurons at DIV4.\"" ;
        lego:modelstate  "production" ;
        dc:contributor   "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date          "2023-03-01" ;
        dc:title         "SYNGO_BP_5195" ;
        pav:providedBy   "https://syngo.vu.nl" .
