gomodel:SYNGO_1983  a     owl:Ontology ;
        rdfs:comment      "Rationale: This paper investigates the motorneuron-Renshaw cell (MN-RC) synapse, a cholinergic synapse in the spinal cord.\n\nFig.1+2: Sensitivity to DHβE of nicotinic EPSCs in Renshaw cells of various knockout mice are investigated. The most striking changes in DHβE-sensitivity were obtained for mice in which either the β2 or the β4 subunit had been deleted.. Experimental description: -Tissues are of mouse species: \"The mice used were either wild type C57BL/6J mice (Janvier), or knockout lines for one of the following nAChR subunits: α7-/-[20], α2-/-[21][22], β2-/-[23], β4-/-[24] or for the membrane anchor of acetylcholinesterase (PRiMA-/- mice, [25])\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0003-0593-3443" ;
        dc:date           "2017-12-24" ;
        dc:title          "SYNGO_MF_1983" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

