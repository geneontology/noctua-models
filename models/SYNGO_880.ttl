gomodel:SYNGO_880  a      owl:Ontology ;
        rdfs:comment      "Rationale: Confocal images of neurons stained with antibodies against APBB1/Fe65 and synaptophysin shows colocalisation of both proteins in a synaptic staining pattern. Live-imaging experiments further illustrate punctate colocalisation of APBB1-EGFP and with synaptobrevin-DsRed puncta in axons.. Experimental description: Materials and Methods. \"Primary neuronal cultures were prepared from cortices of embryonic day (E) 17 or postnatal day (P) 1 rats.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-5615-1014" ;
