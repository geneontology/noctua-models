<http://model.geneontology.org/ev_w_id_R-HSA-191422_RO_0002233_R-ALL-113592_cytosol_Reactome_R-HSA-191422>
        a       <http://purl.obolibrary.org/obo/ECO_0000313> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
