obo:BFO_0000066  a  owl:ObjectProperty .

gomodel:SYNGO_4107  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig 2D: High-frequency stimulation (10 Hz for 10 min) provokes a marked synaptic depression at the Vps29 mutant in NMJ indicating a role in synaptic vesicle recycling.\nFig 2E: Larval preparations were stimulated with potassium chloride in the presence of extracellular buffer containing the fluorescent dye FM 1-43, permitting quantification of endocytic flux. In control animals, FM 1-43 dye was rapidly internalized at the presynaptic membrane. However, NMJs from Vps29 mutant animals significantly reduced FM dye uptake indicating impaired synaptic vesicle endocytosis. As Vps29 mutant does not completely abolish endocytosis, \"regulation of..\" was chosen.. Experimental description: The Vps291 null allele was generated using CRISPR/Cas9-mediated gene replacement, as previously described (Li-Kroeger et al., 2018)." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0003-2916-7616" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2021-01-20" ;
        dc:title          "SYNGO_BP_4107" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_7227" .

