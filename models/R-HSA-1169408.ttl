<http://model.geneontology.org/ev_w_id_R-HSA-157689_R-HSA-1176059_controller_BFO_0000051_REACTO_R-HSA-157712_R-HSA-157689_R-HSA-1176059_component_Reactome_R-HSA-1169408>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/ECO_0000313> ;
