obo:BFO_0000066  a  owl:ObjectProperty .

gomodel:SYNGO_1124  a     owl:Ontology ;
        rdfs:comment      "Rationale: The equilibrative nucleoside transporter (ENT)1 is expressed at synapses. Pre-embedding immunoperoxidase and -immunogold labelling demonstrates the presence of ENT1 immunoreactivity in some presynaptic terminals (Fig 3H).\n\nThe specificity of the antibody used (anti-rENT1227-290) was tested by ELISA, Western Blotting and IHC (Fig. 1).. Experimental description: Wistar rats (bred in-house) were given a lethal dose of Sagatal" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-0755-5899" , "https://orcid.org/0000-0003-0938-8534" , "https://orcid.org/0000-0001-7351-8706" , "https://orcid.org/0000-0003-3185-5709" ;
        dc:date           "2017-08-17" ;
        dc:title          "SYNGO_CC_1124" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

