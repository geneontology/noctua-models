obo:BFO_0000066  a  owl:ObjectProperty .

gomodel:SYNGO_585  a      owl:Ontology ;
        rdfs:comment      "Rationale: Pre-embedding immuno-EM indicates immunoreactivity for Complexin-2 in dendrites and dendritic spines in different synapse types and brain regions. EM localization indicates that a larger proportion of the protein may be associated to membranes (in comparison to the subcellular fractionation, where most of the synaphins are in the soluble, cytosolic fraction - Referenced to SynGO annotation #577).\n\nmonoclonal antibodies (mAbs) specific to synaphin 1 (12C5) were generated in the study. No KO control.\n\n31/5/2017 Pim\n- Authors state: \"In the dendrites of immunoreactive neurons, labeling was present along microtubules and the plasma membrane including the postsynaptic densities at the dendritic spines and shafts (Fig. 3B).\". Experimental description: Wistar female rats at the age of two months were anesthetized..." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-3185-5709" , "https://orcid.org/0000-0003-0938-8534" , "https://orcid.org/0000-0002-0755-5899" , "https://orcid.org/0000-0001-7351-8706" ;
        dc:date           "2017-06-06" ;
        dc:title          "SYNGO_CC_585" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

