lego:evidence  a  owl:AnnotationProperty .

dc:date  a      owl:AnnotationProperty .

gomodel:SYNGO_204  a      owl:Ontology ;
        rdfs:comment      "Rationale: Analyses of highly purified synaptic vesicles by mass spectrometry and immunobloting with Rab7-specific antbodies indicate the presence of Rab7 on these vesicles. Nevertheless, microscopic analyses of Rab7 and synaptophysin co-staining in hippocampal neurons indicate only partial colocalisation of Rab7-positive puncta with synaptic vesicles in these cells.. Experimental description: Legend to Figure 2 \"Enrichment profiles of Rab GTPases on purified SVs isolated from rat brain homogenates, determined by quantitative\nimmunoblotting\"\n\n27/3/2017 Pim:\n- Personal communication with the authors (John Chua of, at that time, the Jahn Lab) informed us that the species of the pEGFP-Rab7 construct was Canis Lupus (wolf).\n- Based on the data presented in Fig.1 on SV localizaton annotation is made against the rat species." , "Automated change 2024-03-14: GO:0098993 replaced by GO:0030672" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-5615-1014" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_204" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

