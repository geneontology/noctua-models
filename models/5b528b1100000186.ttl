obo:GO_0036498  a  owl:Class .

[ a                      owl:Axiom ;
  rdfs:comment           "Supporting evidence statement (PMID:25366321): We assessed XBP1/xbp-1 function in RtcB mutants using a Phsp-4::GFP reporter that is dependent on the IRE1/XBP1 branch of the UPR [5,6]. ER stress induced by tunicamycin resulted in upregulation of GFP in control RtcB heterozygous animals, but expression was eliminated in homozygous RtcB mutants (Fig 2A). Expression of rtcb-1 cDNA specifically in the\nintestine restored GFP only in that tissue, indicating that RtcB is\nrequired cell-autonomously for XBP-1 function in vivo." ;
  lego:evidence          :5fa76ad400000179 ;
  dc:contributor         "https://orcid.org/0000-0002-1706-4196" ;
  dc:date                "2020-11-10" ;
  pav:providedBy         "http://www.wormbase.org" ;
  owl:annotatedProperty  obo:RO_0002233 ;
  owl:annotatedSource    :5ce58dde00001438 ;
  owl:annotatedTarget    :5fa76ad400000017
] .

