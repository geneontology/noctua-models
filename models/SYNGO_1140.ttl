gomodel:SYNGO_1140  a     owl:Ontology ;
        rdfs:comment      "Rationale: This figures shows the immuno-EM localisation of brain-specific spectrin(240/235) (also called fodrin or calspectrin, that was later renamed to Spectrin beta II). The antibody labels axons (Fig4A,B) and axon terminals (Fig4D,E) specifically with little labelling of dendrites or spines. Preimmune serum does not show positive signal (Fig4F).. Experimental description: \"Figure 4. Electron micrograph of the cerebellar cortex of adult mouse.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0001-5259-4945" ;
        dc:date           "2018-01-25" ;
        dc:title          "SYNGO_CC_1140" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

