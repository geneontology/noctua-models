obo:RO_0002233  a  owl:ObjectProperty .

:R-HSA-9024909  a           owl:NamedIndividual , obo:GO_0051388 ;
        rdfs:comment        "Signaling by the neurotrophin receptor tyrosine kinase NTRK2 (TRKB) can be activated by binding to brain-derived neurotrophic factor (BDNF), which functions as a ligand for NTRK2 (Soppet et al. 1991, Klein et al. 1991). Binding to BDNF triggers NTRK2 dimerization (Ohira et al. 2001) and trans-autophosphorylation of NTRK2 dimers on conserved tyrosine residues in the cytoplasmic tail of the receptor (Guiton et al. 1994, Minichiello et al. 1998, McCarty and Feinstein 1999). Phosphorylated tyrosine residues subsequently serve as docking sites for recruitment of effector proteins that trigger downstream signaling cascades." ;
        rdfs:label          "BDNF activates NTRK2 (TRKB) signaling" ;
        dc:contributor      "Reviewed: Antila, Hanna, 2018-02-13" , "Edited: Orlic-Milacic, Marija, 2018-02-20" , "Authored: Orlic-Milacic, Marija, 2018-01-05" , "GOC:reactome_curators" , "Reviewed: Castrén, Eero, 2018-02-13" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-9024909" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-9006115/R-HSA-9006115> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

