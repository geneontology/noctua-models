<http://model.geneontology.org/R-ALL-113581_mitochondrial_matrix>
        a       <http://purl.obolibrary.org/obo/CHEBI_456216> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
        <http://www.w3.org/2000/01/rdf-schema#comment>
                "located_in mitochondrial matrix" , "Original Reactome ID: CHEBI_456216" ;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "ADP" ;
        <http://purl.org/dc/elements/1.1/contributor>
                "GOC:reactome_curators" ;
