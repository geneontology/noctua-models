lego:evidence  a  owl:AnnotationProperty .

gomodel:SYNGO_103  a      owl:Ontology ;
        rdfs:comment      "Rationale: The paper summarizes the evidence from many original reports. It describes all the interaction partners known so far and describes the function and the role in organizing the synaptic vesicle recycling and the localization of the Ca-channels and in regulating Actin-dynamics and endocytosis as well as its role in regulating synaptic maintenance and integrity.. Experimental description: The paper reviews data from mouse and rat synapses. Table 1 provides species information. Mouse was selected because the function of Pclo has also been shown in KO mice.\n\n21/3/2017 Pim\nThis paper is a review paper that integrates data from mouse and rat studies. I have agreed with annotating against the mouse protein because of KO data." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9681-3318" , "https://orcid.org/0000-0002-9880-1214" , "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-0269-0311" ;
        dc:date           "2017-03-21" ;
        dc:title          "SYNGO_MF_103" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

