<http://model.geneontology.org/ev_w_id_R-HSA-420818_RO_0002234_R-HSA-420817_R-HSA-420818_Reactome_R-HSA-420818>
        a       <http://purl.obolibrary.org/obo/ECO_0000313> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
