obo:UBERON_0002435  a  owl:Class .

gomodel:SYNGO_3064  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.7: \"High-resolution light and electron microscopic localization of beta-ARK immunoreactivity in rat brain\"\n- \"Ultrastructurally, betaARK1 and betaARK2 immunoreactivities were present both in association with postsynaptic densities and, presynaptically, within axon terminals (Fig. 7). Postsynaptic and presynaptic localizations of betaARK1 and betaARK2 are both found in various brain regions, with postsynaptic distributions generally predominating. Subcellular distributions within the stiaturn are illustrated to emphasize that the betaARK isozymes may be presynaptic as well as postsynaptic.\". Experimental description: - \"High-resolution light and electron microscopic localization of @ARK immunoreactivity in rat brain. \"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0003-0593-3443" ;
        dc:date           "2018-03-29" ;
        dc:title          "SYNGO_CC_3064" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

