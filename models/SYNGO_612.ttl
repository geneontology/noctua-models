gomodel:SYNGO_612  a      owl:Ontology ;
        rdfs:comment      "Rationale: Supplemental table S1 contains 492 proteins of the PSD fraction identified either by 2D gel electrophoresis followed by MS/MS or by LC-MS/MS.\nRL3_RAT was found together with multiple other ribosomal proteins.\nFor proteins coming from datasets derived from PSD (detergent-resistant synaptic junctions) preparations without defined selection / enrichment of the pre- or postsynaptic compartment we cannot assign these proteins to excitatory and/or inhibitory nor to the presynapse or / and postsynapse without further information.. Experimental description: \"The PSD was purified from rat forebrain as described previously (Yoshimura and Yamauchi 1997).\" p. 760" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-0269-0311" , "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-9681-3318" , "https://orcid.org/0000-0002-9880-1214" ;
        dc:date           "2017-08-15" ;
        dc:title          "SYNGO_CC_612" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

