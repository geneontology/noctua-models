<http://model.geneontology.org/R-HSA-177689_R-HSA-177692>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/go/extensions/reacto.owl#REACTO_R-HSA-177689> ;
        <http://www.w3.org/2000/01/rdf-schema#comment>
                "Original Reactome ID: R-HSA-177689" , "located_in endosome membrane" ;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "viral dsRNA:TLR3:TRIF:polyUb-TRAF6:TAK1:TAB1:TAB2/TAB3: free polyUb chain" ;
        <http://purl.org/dc/elements/1.1/contributor>
                "GOC:reactome_curators" ;
        <http://purl.org/dc/elements/1.1/date>
