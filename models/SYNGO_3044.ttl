gomodel:SYNGO_3044  a     owl:Ontology ;
        rdfs:comment      "Rationale: C1ql2 and C1ql3 Determine Postsynaptic KAR Localization at MF-CA3 Synapses (Fig. 3) via signaling through Nrx3 -> C1ql2/3 -> Kainate receptor (Fig. 5).. Experimental description: Endogenous C1ql2, C1ql3, and GluK2/3 immunoreactivities in WT hippocampus. Arrows indicate CA3 stratum lucidum. Insets show immunoreactivity in mice\nlacking a corresponding gene to confirm antibody specificity. (Legend Fig. 1A, p. 754)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-9681-3318" , "https://orcid.org/0000-0002-9880-1214" , "https://orcid.org/0000-0002-0269-0311" ;
        dc:date           "2018-04-30" ;
        dc:title          "SYNGO_BP_3044" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

