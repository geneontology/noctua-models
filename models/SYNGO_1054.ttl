gomodel:SYNGO_1054  a     owl:Ontology ;
        rdfs:comment      "Rationale: IQ-ArfGEF/BRAG1/IQSEC2 is present in retinal photoreceptor terminals and localizes to synaptic ribbons, which are electron-dense structures that tether synaptic vesicles in these synapses in proximity to release sites. Immunohistochemical analysis demonstrates co-localization of immunoreactivity for RIBEYE (the structural component of synaptic ribbons) and bassoon, which is present at the ribbon base, but not PSD-95 (Fig. 2), indicating a presynaptic localization of IQSEC2 in this synapse type. The presence of immunoreactivity at synaptic ribbons at photoreceptor terminals was confirmed by pre-embedding immunoperoxidase and -gold labelling (Fig. 3).. Experimental description: Ten mice were used for light immunohistochemical analysis and six for immunoelectron microscopic observation." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0938-8534" , "https://orcid.org/0000-0002-0755-5899" , "https://orcid.org/0000-0001-7351-8706" , "https://orcid.org/0000-0003-3185-5709" ;
        dc:date           "2017-08-21" ;
        dc:title          "SYNGO_CC_1054" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .
