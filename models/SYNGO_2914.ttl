obo:ECO_0005589  a  owl:Class .

gomodel:SYNGO_2914  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.2: \"Knockout of Thorase Increases AMPAR Surface Expression and AMPAR Currents\"\n\nFig.3: \"Deficits in Homeostatic Synaptic Scaling and Endocytosis of AMPARs in Thorase KO neurons\"\n\nFig.4: \"NMDA-induced AMPAR Internalization is Reduced in an ATPase-Dependent Manner in Thorase KO Neurons\"\n\nFig.6: \"Thorase Deficiency Enhances AMPAR Currents and LTP and Impairs LTD Without Affecting Basal Synaptic Transmission at CA1 Hippocampal Synapses\"\n\nDiscussion: \"In contrast, Thorase acts at GluR2-GRIP1 complexes to control the endocytosis and removal of AMPARs from the postsynaptic membrane. The identification of Thorase as a major regulator of AMPAR trafficking offers new opportunities to enhance the understanding and to identify additional regulators of AMPAR turnover.\". Experimental description: - \"Conditional Thorase knockout (KO) mice were generated...\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2018-03-15" ;
        dc:title          "SYNGO_BP_2914" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

