gomodel:SYNGO_884  a      owl:Ontology ;
        rdfs:comment      "Rationale: The paper describes the synaptic connectivity of interneuronal subpopulations in the rat basolateral amygdalar nucleus.\nFigures 3, 4 and 5 show that immunoperoxidase reactivity labelling calbindin is diffused and found in presynaptic terminals.\n\n2/7/2017 Pim\n- Cytosol localization derived from the diffuse, non-localized staining.. Experimental description: For electron microscopy, two rats were perfused with 4.0% paraformaldehyde-0.2% glutaraldehyde in PB and post-fixed in 4.0% paraformaldehyde for 4-6 hours at 4°C, and three rats were perfused with 2.0% paraformaldehyde-3.75% acrolein and post-fixed in 2% paraformaldehyde for 3 hours." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-3185-5709" , "https://orcid.org/0000-0001-7351-8706" , "https://orcid.org/0000-0002-0755-5899" , "https://orcid.org/0000-0003-0938-8534" ;
        dc:date           "2017-07-02" ;
        dc:title          "SYNGO_CC_884" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

