obo:GO_0098978  a  owl:Class .

gomodel:SYNGO_5230  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 4c: confocal imaging of immunofluorescence labeling for DEAD box 3 (DDX3X), surface-GluR1 (GRIA1) and PSD-95 (DLG4) in cultured hippocampal neurons showed localization of DEAD box 3 to the postsynaptic density.. Experimental description: M&M: \"Hippocampal sandwich cultures with glial feeders were used. Briefly, hippocampi were dissected from E18 rat embryos and dissociated using trypsin (0.25%) and trituration.\"\n\nantibody:\n\"the anti-Dead Box 3 antibody was a gift from Dr. Wayne Sossin (McGill University, Montreal, Canada)\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2023-03-04" ;
        dc:title          "SYNGO_CC_5230" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

