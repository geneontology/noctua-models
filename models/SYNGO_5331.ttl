gomodel:SYNGO_5331  a     owl:Ontology ;
        rdfs:comment      "Automated change 2024-03-14: GO:0099055 replaced by GO:0045211" , "Rationale: Figure 5: confocal imaging of immunofluorescence labeling for FLRT2, vGLUT1 and PSD-95 (DLG4) in mouse hippocampal neurons showed partial co-localization with both the presynaptic (vGLUT1; 30.6%) and postsynaptic (PSD95; 15.7%) markers.\n\nBased on the known transmembrane topology of this protein, \"integral component of ... membrane\" term was selected.. Experimental description: Results, Figure 5 legend: \"Synaptic localization of FLRT2 in the CA1 of adult mice.\"\n\nantibody:\ngoat anti-FLRT2 (1:350; R&D Systems, Minneapolis, MN, United States)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_5331" ;
        pav:providedBy    "https://syngo.vu.nl" ;
