obo:BFO_0000066  a  owl:ObjectProperty .

gomodel:SYNGO_2310  a     owl:Ontology ;
        rdfs:comment      "Rationale: PTPRT was enriched in postsynaptic density fractions.\nPTPRT co-localized to neuronal synapses stained with synaptophysin and PSD-95.\nPTPRT co-localized to excitatory synapses with PSD-95 and vGLUT or to inhibitory synapses with gephyrin and vGAT.. Experimental description: Figure legend\nFigure 1E. Distribution pattern of PTPRT in biochemical rat brain fractions.\n\nMaterials and methods\nCell culture and transfection\nPrimary hippocampal neuronal cultures were as described earlier (Lee et al, 2003)\nNeuron Culture, Transfection, and Immunostaining-Primary hippocampal neuronal cultures were prepared from rat embryonic brain (embryonic day 18)" , "Automated change 2024-03-14: GO:0099061 replaced by GO:0098839" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-5518-6584" , "https://orcid.org/0000-0001-6194-9648" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_2310" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

