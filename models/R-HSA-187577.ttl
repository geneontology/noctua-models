  <http://geneontology.org/lego/evidence>
          <http://model.geneontology.org/ev_w_id_R-HSA-187552_RO_0002233_R-HSA-187522_R-HSA-187552_Reactome_R-HSA-187552> , <http://model.geneontology.org/ev_w_id_R-HSA-187552_RO_0002233_R-HSA-187522_R-HSA-187552_Reactome_R-HSA-187577> ;
