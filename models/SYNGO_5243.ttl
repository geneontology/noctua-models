gomodel:SYNGO_5243  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 1: overexpression of a syt-17-pHluorin construct in 3DIV hippocampal neurons showed synaptotagmin-17 (SYT17) at dendritic puncta, co-localized with endosomal marker GFP-RAB5 (marker for early endosomes).\n\nFigure 7: to establish synaptic localization of SYT17, higher-resolution immunofluorescence labeling in 14 14DIV hippocampal neurons showed postsynaptic co-localization of endogenous AMPA receptors with overexpressed RAB5 and SYT17.. Experimental description: the cultured neurons were mice; \"Primary hippocampal neurons (CA subfields) were harvested from newborn (P0) mice of both sexes and cultured\" but the overexpressed construct was human. Doesn't matter much, mouse and human SYT17 proteins are nearly identical." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" ;
        dc:date           "2023-03-08" ;
        dc:title          "SYNGO_CC_5243" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_9606" .

