gomodel:SYNGO_3865  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.6: \"LPA induces GABAAergic STD and GABAAγ2 dephosphorylation via postsynaptic LPA1-RhoA/ROCK-CaN signaling\"\n- \"Multiple immunolabeling confocal images of the HN from P7 rats showing colocalization between LPA1-ir and gephyrin-ir (top). 3-D reconstruction (bottom) showing that LPA1-ir colocalizes with gephyrin in a SMI32-ir HMN.\"\n\nFig.7: \"LPA induces dephosphorylation and internalization of the GABAAγ2 subunit in a ROCK/CaN-dependent manner\". Experimental description: - \"Multiple immunolabeling confocal images of the HN from P7 rats showing a close relationship between LPA1-ir patches and structures expressing the nonphosphorylated form of neurofilament H\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0003-0593-3443" ;
        dc:date           "2018-07-09" ;
        dc:title          "SYNGO_BP_3865" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

