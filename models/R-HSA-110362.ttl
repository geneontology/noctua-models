:R-HSA-110362  a            obo:GO_0008150 , owl:NamedIndividual ;
        rdfs:comment        "During POLB-dependent long patch base excision repair (BER), PARP1 and/or PARP2 is recruited to the BER site along with flap endonuclease FEN1. PARP1 and/or PARP2 and FEN1 facilitate POLB-mediated strand displacement synthesis which involves incorporation of 2-10 nucleotides at the 3' end of the APEX1-created single strand break (SSB). After the DNA strand displacement synthesis is completed and the displaced strand is cleaved, POLB recruits DNA ligase I (LIG1) to ligate the SSB (Klungland and Lindahl 1997, Dimitriadis et al. 1998, Prasad et al. 2001, Lavrik et al. 2001, Tomkinson et al. 2001, Ranalli et al. 2002, Cistulli et al. 2004, Liu et al. 2005)." ;
        rdfs:label          "POLB-Dependent Long Patch Base Excision Repair" ;
        dc:contributor      "Edited: Orlic-Milacic, Marija, 2014-12-03" , "Authored: Matthews, L, 2004-02-03 00:30:00" , "Edited: Matthews, L, 2004-02-03 00:30:00" , "Reviewed: Borowiec, James, 2014-12-22" , "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-110362" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-110373/R-HSA-110373> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

