obo:ECO_0007695  a  owl:Class .

lego:evidence  a  owl:AnnotationProperty .

gomodel:SYNGO_1212  a     owl:Ontology ;
        rdfs:comment      "Rationale: Characterisation of GluR2 subunit in out-side out patches of oocytes overexpressing GluR2.\n\nrule: NAS_MFCC-BP\nrationale:\nProtein has ligand-gated ion channel receptor activity and is localized in the presynaptic membrane (shown with high-resolution technique). The inference to term ligand-gated ion channel activity involved in regulation of presynaptic membrane potential (GO:0099507) is trivial and non-controversial.\nPinf_CC:\n[P19491] SyNGO ID 1194 (PMID:28057533, EM)\n[P19491] SyNGO ID 1206 (PMID:15610164, EM). Experimental description: The rat wild-type GluR2 flip and GluR2 flop cDNAs were kind gifts from Drs. Jim Boulter, Stephan F. Heinemann, and Michael Hollmann (Salk Institute, La Jolla, CA)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0001-9425-2935" ;
        dc:date           "2018-06-29" ;
        dc:title          "SYNGO_MF_1212" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

