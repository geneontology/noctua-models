gomodel:SYNGO_4043  a     owl:Ontology ;
        rdfs:comment      "Rationale: P2RX2 was detected in Liquid chromatography-mass spectrometry results of LDCVs\nFigure 2A: Double immunofluorescence staining shows the distribution of P2RX2(green) with Substance P positive LDCV (red).\nFigure 2B: Post-embedding immunogold (inset) staining against P2RX2 displays localisation on the surface of LDCV.\n\n18/01/2021 Dnyanada: The paper does not provide any information on the specificity of the antibody used.. Experimental description: No mention of mouse strain used ...Authors were contacted for retrieving this information (15/05/2020 Dnyanada, xu.zhang@ion.ac.cn)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0003-2916-7616" ;
