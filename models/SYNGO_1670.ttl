gomodel:SYNGO_1670  a     owl:Ontology ;
        rdfs:comment      "Rationale: Immunolocalization data of EM suggest that Eps8 is closely associated with the postsynaptic apparatus. Immunostaining of the PSDs was evident in both granule cell and unipolar brush cells (UBCs) dendrites in cerebellum.. Experimental description: Young (26 day-old) Wistar albino males and adult (200-250g of body weight) Sprague-Dawley rats of both sex were purchased from a commercial breeder (Harlan, Indianapolis, IN) and processed according to approved guidelines." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0912-1514" , "https://orcid.org/0000-0002-3670-7863" ;
        dc:date           "2017-10-12" ;
        dc:title          "SYNGO_CC_1670" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

