obo:BFO_0000066  a  owl:ObjectProperty .

gomodel:SYNGO_1956  a     owl:Ontology ;
        rdfs:comment      "Rationale: Kainate receptor subunit Glur6 (=GRIK2)\n\n22/11/2017 Pim\nFig.1: \"GluR7-Containing Presynaptic KARs Facilitate MF Short-Term Synaptic Plasticity\"\nPPF is significantly reduced in GluR7-/- mice. PPF is a presynaptic phenomenon.\nFig.2: \"Long-Term Potentiation (LTP) Is Impaired in GluR7-/- Mice\"\nFig.3: \"Subcellular localization and association of GluR6 and GluR7 subunits\"\nFig.4: \"Properties of recombinant and native GluR7-containing KARs\"\n\n- Based on integration of in vivo, PPI and heterologous expression data, the authors conclude that presynaptic modulation of SV release is mediated by GluR6/Glur7 heteromers.\n- The GluR6 KO animal has been demonstrated to display both pre and postsynaptic defects which overlaps with the conclusion of the primary paper of this ticket.. Experimental description: \"Experiments were performed on parasaggital hippocampal slices from 14- to 21-day-old WT and GluR7-/- mice by using standard techniques (45).\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0001-9425-2935" ;
        dc:date           "2018-06-07" ;
        dc:title          "SYNGO_MF_1956" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

dc:contributor  a  owl:AnnotationProperty .

