:R-HSA-181429  a            obo:GO_0006836 , owl:NamedIndividual ;
        rdfs:comment        "Serotonin is synthesized in the serotonergic neurons in the central nervous system and the enterochrommaffin cells of the gastroinetstinal system. Serotonin is loaded into the clathrin sculpted monoamine transport vesicles. The vesicles are docked, primed and release after the change in the membrane potential that activates voltage gated calcium channels and the reponse by several proetins to the changes in intracellular Ca2+ increase leads to fusion of the vesicle and release of serotonin into the synapse." ;
        rdfs:label          "Serotonin Neurotransmitter Release Cycle" ;
        dc:contributor      "Reviewed: Kavalali, E, 2008-04-24 16:31:34" , "Authored: Mahajan, SS, 2008-01-14 16:01:52" , "GOC:reactome_curators" , "Edited: Mahajan, SS, 2008-11-18 00:03:09" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-181429" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-112310/R-HSA-112310> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

