<http://model.geneontology.org/R-HSA-181429/R-HSA-181429>
        a       <http://purl.obolibrary.org/obo/GO_0006836> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
        <http://www.w3.org/2000/01/rdf-schema#comment>
                "Serotonin is synthesized in the serotonergic neurons in the central nervous system and the enterochrommaffin cells of the gastroinetstinal system. Serotonin is loaded into the clathrin sculpted monoamine transport vesicles. The vesicles are docked, primed and release after the change in the membrane potential that activates voltage gated calcium channels and the reponse by several proetins to the changes in intracellular Ca2+ increase leads to fusion of the vesicle and release of serotonin into the synapse." ;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Serotonin Neurotransmitter Release Cycle" ;
        <http://purl.org/dc/elements/1.1/contributor>
                "Reviewed: Kavalali, E, 2008-04-24 16:31:34" , "Authored: Mahajan, SS, 2008-01-14 16:01:52" , "GOC:reactome_curators" , "Edited: Mahajan, SS, 2008-11-18 00:03:09" ;
        <http://purl.org/dc/elements/1.1/date>
                "2026-02-25" ;
        <http://purl.org/pav/providedBy>
                "https://reactome.org" ;
        <http://www.geneontology.org/formats/oboInOwl#hasDbXref>
                "R-HSA-181429" ;
