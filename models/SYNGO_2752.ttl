gomodel:SYNGO_2752  a     owl:Ontology ;
        rdfs:comment      "Rationale: Note: NLGN-2: Neuroligin 2 is classically known to be located in the postsynaptic speciallization of GABAergic synapses. This publication shows that the postsynapse of dopaminergic synapses has a GABAergic signature, including NLGN-2: Neuroligin 2 presence.\n\nFig.3: \"GABAergic postsynaptic phenotype at striatal dopamine synapses\"\nFig.S3: \"Expression of GABAergic, but not glutamatergic, postsynaptic proteins at dopamine synapses\". Experimental description: - \"The dorsolateral portion of the striatum in adult male C57BL/6N, NL2-KO (Jackson Laboratory), CAST-KO (43), D1R-KO (44), and D2R-KO (45) mice (1-3 mo of age) was analyzed\"" , "Automated change 2024-03-14: GO:0099060 replaced by GO:0099634" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0003-0593-3443" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_2752" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

