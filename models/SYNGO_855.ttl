obo:ECO_0006013  a  owl:Class .

gomodel:SYNGO_855  a      owl:Ontology ;
        rdfs:comment      "Rationale: mSec7-1 is a guanine nucleotide exchange factor (GEF). Overexpression of rat msec7-1 in Xenopus neuromuscular junctions causes and increase in the frequency of spontaneous synaptic currents (Fig. 3), without a change in the number of synaptic terminals (data not shown), indicating the the presence of a larger readily releasable pool (Fig. 3). Overexpression of msec7-1 caused an increase in amplitude of the the initial action-potential evoked EPSC. These data indicate a function of msec7-1 in regulating synaptic vesicle exocytosis.. Experimental description: Expression vectors for full length rat msec7-1 were generated" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-7351-8706" , "https://orcid.org/0000-0002-0755-5899" , "https://orcid.org/0000-0003-3185-5709" , "https://orcid.org/0000-0003-0938-8534" ;
        dc:date           "2018-03-19" ;
        dc:title          "SYNGO_BP_855" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

