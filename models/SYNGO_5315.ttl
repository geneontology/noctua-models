gomodel:SYNGO_5315  a     owl:Ontology ;
        rdfs:comment      "Rationale: \"SPHK1-GFP is targeted to presynaptic terminals in cultured hippocampal neurons as shown by colocalization with immunoreactivity for Bassoon, a marker of pre-synaptic nerve terminals.\"\n\n\"SPHK1 is selectively enriched at the presynaptic terminal of photoreceptor cells in mouse retina\". Experimental description: M&M: \"Fibroblasts and hippocampal neuronal cultures were electroporated with Amaxa Nucleofector using solution R/program A-24 and mouse neuron solution/program O-03 (Lonza, Basel, Switzerland).\"\n\nPlasmids:\n\"human SPHK1 (clone ID 5213270)\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" ;
        dc:date           "2023-03-11" ;
        dc:title          "SYNGO_CC_5315" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_9606" .

