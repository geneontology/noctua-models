gomodel:SYNGO_3990  a     owl:Ontology ;
        rdfs:comment      "Rationale: Activation of NMDAR causes activation of RalA which in turn binds and translocates RalBP1 to dendritic spines. This causes endocytosis of the GluR2 subunit of the AMPAR complex and subsequent LTD state.\n\nAdditionally, RalA itself is involved in maintaining basal levels of AMPAR by inhibiting basal AMPAR endocytosis in a GTP-independent manner.. Experimental description: Cultured hippocampal neurons were prepared from embryonic day 18 rat brain." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-5615-1014" ;
        dc:date           "2020-07-24" ;
        dc:title          "SYNGO_BP_3990" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

