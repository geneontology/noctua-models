:R-HSA-399956  a            obo:GO_0008150 , owl:NamedIndividual ;
        rdfs:comment        "CRMPs are a small family of plexinA-interacting cytosolic phosphoproteins identified as mediators of Sema3A signaling and neuronal differentiation. After Sema3A activation Plexin-A bound CRMP's undergo phosphorylation by Cdk5, GSK3beta and Fes kinases. Phosphorylation of CRMPs by these kinases blocks the ability of CRMP to bind to tubulin dimers, subsequently induces depolymerization of F-actin, and ultimately leads to growth cone collapse." ;
        rdfs:label          "CRMPs in Sema3A signaling" ;
        dc:contributor      "GOC:reactome_curators" , "Reviewed: Kumanogoh, A, Kikutani, H, 2009-09-01" , "Authored: Garapati, P V, 2009-03-23 09:59:28" , "Edited: Garapati, P V, 2009-03-23 10:00:38" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-399956" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-373755/R-HSA-373755> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

