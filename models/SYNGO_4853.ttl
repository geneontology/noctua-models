gomodel:SYNGO_4853  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 3, 4: Rab17 co-localizes with Syntaxin-4 (STX4) in the soma, dendritic shaft, tip, and spine.\n\nFigure 5,6: Rab17 is required for polarized trafficking of Syntaxin-4 to the dendrite.\n\nFigure 2,7: Rab17 is required for surface expression of GluK2 (GRIK2) without affecting its trafficking.\n\nTaken together, Rab17 was shown to transport Syntaxin-4 from cell soma to dendrites and postsynapses in mouse hippocampal neurons, thereby regulating surface expression of GluK2.. Experimental description: - \"At 8 DIV, mouse hippocampal neurons were co-transfected w...\"\n- Overexpressed Rab17 is of mouse species (traced back via blast analsysis of primer sequence ATGGCGCAGGCTGCTGG)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-4973-5732" ;
        dc:date           "2022-09-07" ;
        dc:title          "SYNGO_BP_4853" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

