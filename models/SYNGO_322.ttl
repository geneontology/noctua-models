gomodel:SYNGO_322  a      owl:Ontology ;
        rdfs:comment      "Rationale: Subcellular fractionation from synaptosomes is used to study the localization of adenylyl cyclases. It is shown that adenylyl cyclase 8 is present in the presynaptic fraction. AC8 was not detected in the postsynaptic fraction.\n\nThe antibody used against AC8 was verified with a knockout control.\n\n13/10/2017 Pim\n- Based on the known transmembrane topology of the protein, the \"integral component of ... membrane\" term was chosen.. Experimental description: Individual forebrain regions (containing hippocampus and cortex) were freshly isolated from WT, AC1KO and AC8KO male mice killed by CO2 inhalation." , "Automated change 2024-03-14: GO:0099056 replaced by GO:0042734" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-7620-2704" , "https://orcid.org/0000-0002-1558-1958" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_322" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

