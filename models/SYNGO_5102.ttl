gomodel:SYNGO_5102  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 5: Hippocampal neurons (DIV 3) were transduced with lentivirus expressing shRNAs against TRIM47 along with mCherry. Prior to transduction, CAG-GFP was transfected in hippocampal neurons (DIV 2) to visualize the dendritic spine. Confocal imaging at DIV21 showed that knockdown of TRIM47 led to a significant increase of total dendritic spine density.. Experimental description: Results, Figure 3 legend: \"Synaptoneurosome is prepared from rat hippocampus ... Rat brain sections at P14 and P60 are immunostained for TRIM47 ...\"\n\nantibody:\nTRIM47 (1:500; Bethyl Laboratories, #A301-194A)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2023-02-24" ;
        dc:title          "SYNGO_BP_5102" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

