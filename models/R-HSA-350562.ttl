<http://model.geneontology.org/ev_w_id_REACTO_R-HSA-9907994_R-HSA-9907993_R-HSA-353125_component_BFO_0000051_UniProtKB_P51665_R-HSA-9907994_R-HSA-353125_component_Reactome_R-HSA-350562>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/ECO_0000313> ;
