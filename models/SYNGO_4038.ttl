gomodel:SYNGO_4038  a     owl:Ontology ;
        rdfs:comment      "Rationale: ADRB2 was detected in Liquid chromatography-mass spectrometry results of LDCVs.\nFigure 1: Subcellular fractionation shows immunoblotting of ADRB2 in LDCVs fraction.\nFigure 2A: Double immunofluorescence staining shows the distribution of ADRB2(green) with Substance P positive LDCV (red).\nFigure 2B: Post-embedding immunogold (inset) staining against ADRB2 displays localisation on the surface of LDCV.\nFigure S3 C: Pre-embedding immunogold-silver labelling with Myc antibodies shows localization of ADRB2-Myc in LDCVs in PC12 cells. This is to further validate for the specificity of LDCV localisation.. Experimental description: Mice were used for EM and immunostaining experiments, while rats were used for subcellular fractionation and MS. No mention of mouse strain used ...Authors were contacted for retrieving this information (15/05/2020 Dnyanada, xu.zhang@ion.ac.cn)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0003-2916-7616" ;
        dc:date           "2021-01-12" ;
        dc:title          "SYNGO_CC_4038" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

