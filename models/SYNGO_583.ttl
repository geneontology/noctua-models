gomodel:SYNGO_583  a      owl:Ontology ;
        rdfs:comment      "Rationale: Pre-embedding immuno-EM indicates immunoreactivity for Complexin-1 in dendrites and dendritic spines in different synapse types and brain regions. EM localization indicates that a larger proportion of the protein may be associated to membranes (in comparison to the subcellular fractionation, where most of the synaphins are in the soluble, cytosolic fraction - Referenced to SynGO annotation #577).\n\nmonoclonal antibodies (mAbs) specific to synaphin 2 (7B8) were generated in the study. No KO control.\n\n31/5/2017 Pim\n- Authors state: \" Postsynaptic densities at the spines and dendritic shafts occasionally disclosed intense labeling.\". Experimental description: Wistar female rats at the age of two months were anesthetized..." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-7351-8706" , "https://orcid.org/0000-0003-0938-8534" , "https://orcid.org/0000-0002-0755-5899" , "https://orcid.org/0000-0003-3185-5709" ;
        dc:date           "2017-05-31" ;
        dc:title          "SYNGO_CC_583" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

