gomodel:reaction_R-HSA-9853385_location_lociGO_0005829
        a               owl:NamedIndividual , obo:GO_0005829 ;
        dc:contributor  "GOC:reactome_curators" ;
        dc:date         "2026-06-29" ;
        pav:providedBy  "https://reactome.org" .

:R-HSA-2500257  a           owl:NamedIndividual , obo:GO_0000070 ;
        rdfs:comment        "The resolution of sister chromatids in mitotic prometaphase involves removal of cohesin complexes from chromosomal arms, with preservation of cohesion at centromeres (Losada et al. 1998, Hauf et al. 2001, Hauf et al. 2005).<br><br>CDK1-mediated phosphorylation of cohesin-bound CDCA5 (Sororin) at threonine T159 provides a docking site for PLK1, enabling PLK1-mediated phosphorylation of cohesin subunits STAG2 (SA2) and RAD21 (Hauf et al. 2005, Dreier et al. 2011, Zhang et al. 2011). Further phosphorylation of CDCA5 by CDK1 results in dissociation of CDCA5 from cohesin complex, which restores the activity of WAPAL in removing STAG2-phosphorylated cohesin from chromosomal arms (Hauf et al. 2005, Gandhi et al. 2006, Kueng et al. 2006, Shintomi and Hirano 2006, Nishiyama et al. 2010, Zhang et al. 2011).<br><br>At centromeres, kinetochore proteins shugoshins (SGOL1 and SGOL2) enable PP2A-B56 (also a kinetochore constituent) to dephosphorylate the STAG2 subunit of centromeric cohesin. Dephosphorylation of STAG2 enables maintenance of centromeric cohesion, thus preventing separation of sister chromatids until anaphase (Salic et al. 2004, Kitajima et al. 2004, Kitajima et al. 2005, Kitajima et al. 2006)." ;
        rdfs:label          "Resolution of Sister Chromatid Cohesion" ;
        dc:contributor      "Reviewed: Orthwein, Alexandre, 2024-04-26" , "Reviewed: Zhang, Nenggang, 2012-10-22" , "Edited: Gillespie, ME, 2012-10-05" , "Edited: Matthews, L, 2012-10-05" , "Reviewed: Yao, Xuebiao, 2024-03-01" , "GOC:reactome_curators" , "Reviewed: Tanno, Yuji, 2012-11-20" , "Reviewed: Liu, Xing, 2024-03-01" , "Reviewed: Watanabe, Yoshinori, 2012-11-20" , "Authored: Orlic-Milacic, M, 2012-10-02" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-2500257" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-68877/R-HSA-68877> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

