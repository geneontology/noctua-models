gomodel:SYNGO_3645  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig 1: SNAP-29 was associated with synaptosomal membranes, it was present predominantly in the synaptic vesicle fraction and to a lesser extent in the plasma membrane fraction. Isolated synaptic vesicles by using anti-synaptotagmin-1-conjugated Sepharose beads showed prominent staining for SNAP29. Fig 2: SNAP-29 and synaptophysin, a marker for synaptic vesicles, were to a large extent colocalized along the entire processes of hippocampal neurons.. Experimental description: M&M: Rat brain synaptosomes" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9900-4233" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2018-06-19" ;
        dc:title          "SYNGO_CC_3645" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

