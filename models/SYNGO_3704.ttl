obo:BFO_0000066  a  owl:ObjectProperty .

gomodel:SYNGO_3704  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.1: \"Spatiotemporal dynamics of RhoA activation during long-term structural plasticity induced in single spines\"\n\nFig.3: \"Spatial profile of RhoA and Cdc42 activities\"\n\nRhoA becomes activated in dendritic spines upon local glutamate uncaging, and spine becomes enlarged.. Experimental description: - Tissue slices were of rat species: \"Hippocampal cultured slices were prepared from postnatal day 6-7 rats as described\"\n- Over-expressed protein is of human species: \"Monomeric enhanced green fluorescent protein fused RhoA (mEGFP-RhoA) and mEGFP-Cdc42 were prepared by inserting human RhoA and Cdc42 coding sequences into the pEGFP-C1 vector (Clontech) containing the A206K monomeric mutation in EGFP\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-1542-3498" , "https://orcid.org/0000-0002-3898-5197" , "https://orcid.org/0000-0002-0808-7003" ;
        dc:date           "2018-05-29" ;
        dc:title          "SYNGO_BP_3704" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_9606" .

