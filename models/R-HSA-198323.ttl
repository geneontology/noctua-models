:R-HSA-198323  a            obo:GO_0043491 , owl:NamedIndividual ;
        rdfs:comment        "Following activation, AKT can phosphorylate an array of target proteins in the cytoplasm, many of which are involved in cell survival control. Phosphorylation of TSC2 feeds positively to the TOR kinase, which, in turn, contributes to AKT activation (positive feedback loop)." ;
        rdfs:label          "AKT phosphorylates targets in the cytosol" ;
        dc:contributor      "Reviewed: Greene, LA, 2007-11-08 15:39:37" , "Edited: Jassal, B, 2011-05-11" , "Authored: Nasi, Sergio, Annibali, D, 2006-10-10" , "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-198323" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-1257604/R-HSA-1257604> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

