lego:evidence  a  owl:AnnotationProperty .

gomodel:SYNGO_33  a       owl:Ontology ;
        rdfs:comment      "Rationale: FSN-1 is expressed specifically in the nervous system in the nerve processes. At the synapse, FSN-1 is excluded from the active zone because it does not localize with active-zone protein UNC-10. It is present at some periactive zones because it resides adjacent to the vesicle region and partly overlaps with RPM-1, which is restricted to periactive zones. At GABAergic NMJs, FSN-1 is absent from the postsynaptic terminal.. Experimental description: In C.elegans" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9900-4233" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2017-03-21" ;
        dc:title          "SYNGO_CC_33" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_6239" .

