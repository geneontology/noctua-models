obo:ECO_0005589  a  owl:Class .

gomodel:SYNGO_5319  a     owl:Ontology ;
        rdfs:comment      "Automated change 2024-03-14: GO:0099055 replaced by GO:0045211" , "Rationale: Figure 1: confocal imaging of immunofluorescence labeling for Plexin B1 and PSD-95 (DLG4) in cultured hippocampal neurons showed postsynaptic localization.\n\nBased on the known transmembrane topology of this protein, \"integral component of ... membrane\" term was selected.. Experimental description: \"Hippocampal neurons were cultured as described by Banker and Goslin [2] with modifications. In brief, the hippocampal tissues were dissociated from Sprague-Dawley rat embryos of embryonic day 18 (E18) (SLC),\"\n\nantibody:\n\"Polyclonal antibodies to plexin-B1 were raised by immunizing rabbits with maltose binding protein (MBP)-fused-mouse plexin-B1 (amino acid, 1216-1521, NM_17725). The specificity of the antibodies was confirmed by Western blot analysis.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_5319" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

