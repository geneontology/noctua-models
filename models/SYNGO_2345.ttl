obo:ECO_0000314  a  owl:Class .

gomodel:SYNGO_2345  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 1; Shisa7 is a type-I transmembrane protein interacting with AMPA-type receptors\nFigure 2; Shisa7 effects on AMPAR desensitization rate and recovery from desensitization\nFigure 3; Shisa7 prolongs synaptic AMPAR currents\nFigure 6; Deletion of Shisa7 slows down initiation and decreases maintenance of LTP\n\nBoth analyses compare Shisa7 KO mice to WT littermates. Experimental description: \"All electrophysiological recordings on CA1 neurons, as well as behavioral analyses, were performed on 8-12 week old male littermates. Male Shisa7 KO and WT littermates were single-housed when adult (>8 weeks),~2 weeks prior to behavioral analysis; behavior was carried out with mice 10-12 weeks\"\n\n24/01/2018 Pim\n- Overexpressed Shisa7 is of mouse species: \"The full-length coding DNA for exon4-containing mouse Shisa7 (reference NP_766325.3)\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2018-01-24" ;
        dc:title          "SYNGO_BP_2345" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

