obo:GO_0098839  a  owl:Class .

gomodel:SYNGO_5038  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 6: immunoprecipitation assays in HEK293 cells showed Apoer2 (LRP8) can interact with proteins PSD-95 (DLG4) and NR2A.\n\nFigure 7a: Apoer2 is enriched in PSD biochemical fractions similar to PSD-95 from rat brains.\n\nFigure 7b-g: Apoer2 and PSD-95 co-localize in cultured (rat) hippocampal neurons.\n\nFigure 7h,i: Immunogold EM showed Apoer2 is localized to the PSD in CA1 hippocampi\n\nBased on the known transmembrane topology of this protein, \"integral component of ... membrane\" term was selected.. Experimental description: M&M: \"Electron Microscopy Adult - Apoer2 ICD mutant mice ...\"\n\nantibody:\n\"We thank Johannes Nimpf for Apoer2 antibodies\"" , "Automated change 2024-03-14: GO:0099061 replaced by GO:0098839" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_5038" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

