:R-HSA-1483191  a           obo:GO_0006656 , owl:NamedIndividual ;
        rdfs:comment        "<i>De novo</i> (Kennedy pathway) synthesis of phosphatidylcholine (PC) involves phosphorylation of choline (Cho) to phosphocholine (PCho) followed by condensing with cytidine triphosphate (CTP) to form CDP-choline (CDP-Cho). Diacylglycerol (DAG) and CDP-ETA together then form PC. Alternatively, PC is formed when phosphatidylethanolamine (PE) is methylated by phosphatidylethanolamine N-methyltransferase (PEMT) (Henneberry et al. 2002; Wright & McMaster 2002)." ;
        rdfs:label          "Synthesis of PC" ;
        dc:contributor      "GOC:reactome_curators" , "Reviewed: D'Eustachio, Peter, 2025-08-13" , "Reviewed: Wakelam, Michael, 2012-05-14" , "Authored: Williams, MG, 2011-09-14" , "Edited: Williams, MG, 2011-08-12" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-1483191" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-1483206/R-HSA-1483206> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

