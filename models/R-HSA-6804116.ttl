<http://model.geneontology.org/R-HSA-182558_R-HSA-69562_controller>
        a       <http://purl.obolibrary.org/obo/go/extensions/reacto.owl#REACTO_R-HSA-182558> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
