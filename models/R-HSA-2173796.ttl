<http://model.geneontology.org/ev_w_id_R-HSA-2186785_RO_0002233_R-HSA-68524_R-HSA-2186785_Reactome_R-HSA-2186785>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/ECO_0000313> ;
