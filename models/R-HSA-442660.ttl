:R-HSA-442660  a            obo:GO_0006836 , owl:NamedIndividual ;
        rdfs:comment        "The SLC6 gene family encodes proteins that mediate neurotransmitter uptake thus terminating a synaptic signal. The proteins mediate transport of GABA (gamma-aminobutyric acid), norepinephrine, dopamine, serotonin, glycine, taurine, L-proline, creatine and betaine. These transporters are mainly present in the CNS and PNS (Chen NH et al, 2004)." ;
        rdfs:label          "SLC-mediated transport of neurotransmitters" ;
        dc:contributor      "Authored: Jassal, Bijay, 2009-09-29" , "GOC:reactome_curators" , "Reviewed: He, Lei, 2009-11-12" , "Reviewed: D'Eustachio, Peter, 2025-08-21" , "Edited: Jassal, Bijay, 2009-09-29" , "Reviewed: D'Eustachio, Peter, 2025-08-26" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-442660" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-425407/R-HSA-425407> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

