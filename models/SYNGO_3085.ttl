obo:GO_0003674  a  owl:Class .

gomodel:SYNGO_3085  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.2: \"The ABD of βI-spectrin specifically enlarges dendritic spine heads\"\n\nFig.3: \"The ABD of βI-spectrin prevents actin depolymerization\"\n\nFig.4: \"The ABD of βI-spectrin prevents acute actin depolymerization\"\n\nFig.5: \"The ABD of βI-spectrin decreases the morphological plasticity of dendritic spines\"\n\nFig.6: \"Expression of the ABD of βI-spectrin increases the size of the PSD\"\n\nFig.7: \"The ABD of βI-spectrin enhances single spine AMPAR-mediated synaptic responses\". Experimental description: From M&M section:\n\n\"Organotypic hippocampal slice cultures were prepared with the roller tube method [31]. Briefly, hippocampi were dissected from 5-7 day-old rat pups and cut into 400 um-thick slices with a chopper, under sterile conditions.\"\n\n9/4/2018 Pim\n- Overexpression of a human BetaI spectrin; Spectrin beta chain, erythrocytic cDNA was used (accession NM_000347)." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-6893-6177" , "https://orcid.org/0000-0002-5265-6306" ;
        dc:date           "2018-04-09" ;
        dc:title          "SYNGO_BP_3085" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_9606" .

