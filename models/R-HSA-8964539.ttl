	a <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/GO_0072590> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "N-acetylaspartylglutamate synthase A ligates NAA, L-Glu forming NAAG" ;
	<http://www.w3.org/2004/02/skos/core#exactMatch> <http://www.reactome.org/biopax/84/48887#BiochemicalReaction13220> ;
