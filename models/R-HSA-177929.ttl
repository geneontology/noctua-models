gomodel:ev_w_id_R-HSA-177934_RO_0002333_R-HSA-177934_UniProt_P00533_Reactome_R-HSA-177934
        a               owl:NamedIndividual , obo:ECO_0000313 ;
        dc:contributor  "GOC:reactome_curators" ;
