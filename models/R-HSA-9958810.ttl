<http://model.geneontology.org/R-HSA-9934398_R-HSA-9958889>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/go/extensions/reacto.owl#REACTO_R-HSA-9934398> ;
        <http://www.w3.org/2000/01/rdf-schema#comment>
                "located_in plasma membrane" , "Original Reactome ID: R-HSA-9934398" ;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Man,Man9GlucNAc2,p-3S-CDH1:CTNNB1,JUP:CTNNA1:CTNND1" ;
