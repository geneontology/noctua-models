obo:GO_0099173  a  owl:Class .

gomodel:SYNGO_3714  a     owl:Ontology ;
        rdfs:comment      "Rationale: Knockdown of ARP2/3 results in a lower spine density.\n\n8/2/2018 Pim\n- Data looks at cocalization of PSD95 and SV2 spots as a readout for synapse formation. Authors show that ACTR3 is located at the postsynaptic side. ACTR3 is a known actin remodeling protein part of the Arp2/3 complex.. Experimental description: Cell Culture and Transfection-Hippocampal low density cultures were prepared as described previously (18). Reference 18 is entitled: Rat Hippocampal Neurons in Low-density Culture (Banker, G., and Goslin, K., eds) pp. 339-370, MIT Press, Cambridge, MA" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-4022-8707" , "https://orcid.org/0000-0001-7480-0826" , "https://orcid.org/0000-0002-5648-066X" , "https://orcid.org/0000-0002-1212-5623" , "https://orcid.org/0000-0003-2533-9548" ;
        dc:date           "2018-05-31" ;
        dc:title          "SYNGO_BP_3714" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

