gomodel:SYNGO_3088  a     owl:Ontology ;
        rdfs:comment      "Rationale: [Fig.2: \"The Wnt5a-evoked inhibition of K+ currents is mediated by nitric oxide\"]\n[Fig.3: \"Wnt5a requires nNOS activity to induce an increase in fEPSPs in hippocampal slices\"]\n\nFig.4: \"ROR2 is required for the Wnt5a-dependent inhibition of the voltage-gated potassium current\". Experimental description: From M&M section:\n\"The experiments were performed on Sprague-Dawley rat fetuses (embryonic day 18, E18).\"\n\"Hippocampi were dissected from Sprague-Dawley rats at E18, and primary rat hippocampal cultures were prepared.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-6893-6177" , "https://orcid.org/0000-0002-5265-6306" ;
        dc:date           "2018-04-09" ;
        dc:title          "SYNGO_BP_3088" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

