gomodel:SYNGO_3786  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.4: \"Immunoelectron microscopic localization of annexin V in intact rat central nervous tissue\"\n- \"\n\nFig.5: \"Rat brain synaptosomes immunolabeled with annexin V antibodies\"\n- \"\n\nFig.6: \"Electron micrographs of purified rat synaptic vesicles\"\n- \"\n\nFig.7: \"Electron microscopic profiles of purified human annexin V and synaptic vesicles\"\n\n- \"Judging from the immunolabeling using synaptosomal fraction, annexin V is expected to be specifically associated with synaptic vesicles...we found that the result of immunolabeling for annexin V was similar to that for synaptophysin. Immunogold particles indicating annexin V preferentially labeled synaptic vesicles (Fig. 6c). \". Experimental description: - \"Rats (Wistar, 200-250 g) anesthetized with chloral hydrate...\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0003-0593-3443" ;
        dc:date           "2018-06-28" ;
        dc:title          "SYNGO_CC_3786" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

