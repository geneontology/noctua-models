obo:ECO_0006067  a  owl:Class .

gomodel:SYNGO_1624  a     owl:Ontology ;
        rdfs:comment      "Rationale: Prior knowledge (PMID:12176979): IMPA1 (myo-inositol monophosphatase, IMPase) is an enzyme of the inositol-1,4,5-trisphosphate signaling cascade that is activated by the Ca2+-binding protein calbindin D28k (CB).\n\nUsing FRAP technique the paper shows that the CB interacts with IMPase in dendritic spines of cerebellar Purkinje, implying that both proteins localise there.\n\n09/10/2017 Pim\n- In in order to track CB translocaltion. this protein is of rat species (\"Rat recombinant CB expressed ...\").. Experimental description: CB protein is of rat species (\"Rat recombinant CB expressed ...\")." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2094-7491" , "https://orcid.org/0000-0002-1190-4481" , "https://orcid.org/0000-0002-4419-210X" , "https://orcid.org/0000-0002-9848-0262" ;
        dc:date           "2017-10-09" ;
        dc:title          "SYNGO_CC_1624" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

