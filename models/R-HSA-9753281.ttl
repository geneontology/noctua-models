<http://model.geneontology.org/ev_w_id_R-HSA-9753676_RO_0002234_R-ALL-76194_cytosol_Reactome_R-HSA-9753281>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/ECO_0000313> ;
