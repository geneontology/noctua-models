gomodel:SYNGO_954  a      owl:Ontology ;
        rdfs:comment      "Rationale: The authors use a co-culture assay to observe VGLut1 co-localizing patches of a synaptophysin-GFP reporter protein This assay measures the recruitment of SVs. Fig. 2B shows that overexpression of a truncated syntenin-1 construct that presumably acts as a dominant negative protein blocks the ability of EphB2 to mediate a trans-synaptic synaptogenic effect. Using a knock-dwon approach, Fig. 2C shows that syntenin-1 is required in presynaptic neurons so that postsynaptic EphB2 can mediate. Experimental description: \"Primary dissociated cortical neurons were prepared from embryonic day 17 (E17) to E18 rats\"\n\n22/6/2017 Pim\nSyntenin dom neg. protein expressed in neurons was traced back to PMID:16421316 and is of *rat* species. Literal: \" Rat syntenin-1 was subcloned into pFLAG-CMV2...\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0912-1514" , "https://orcid.org/0000-0002-3670-7863" ;
        dc:date           "2017-06-23" ;
        dc:title          "SYNGO_BP_954" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

dc:source  a    owl:AnnotationProperty .

