<http://purl.obolibrary.org/obo/GO_0004175>
        a       <http://www.w3.org/2002/07/owl#Class> .

<http://model.geneontology.org/ev_w_id_R-HSA-1504193_RO_0002333_R-HSA-68819_R-HSA-1504193_controller_Reactome_R-HSA-4641258>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/ECO_0000313> ;
        <http://purl.org/dc/elements/1.1/contributor>
