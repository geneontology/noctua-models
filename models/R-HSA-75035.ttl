obo:GO_0004674  a  owl:Class .

:R-HSA-75035  a             obo:GO_0008150 , owl:NamedIndividual ;
        rdfs:comment        "DNA damage induced activation of the checkpoint kinases Chk1/Chk2(Cds1) results in the conversion and/or maintenance of CyclinB:Cdc2 complex in its Tyrosine 15 phosphorylated (inactive) state. Cdc2 activity is regulated by a balance between the phosphorylation and dephosphorylation by the Wee1/Myt1 kinase and Cdc25 phosphatase. Inactivation of the Cyclin B:Cdc2 complex likely involves both inactivation of Cdc25 and/or stimulation of Wee1/Myt1 kinase activity." ;
        rdfs:label          "Chk1/Chk2(Cds1) mediated inactivation of Cyclin B:Cdk1 complex" ;
        dc:contributor      "Authored: Matthews, L, 2003-08-05 01:10:00" , "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-75035" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-69473/R-HSA-69473> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

