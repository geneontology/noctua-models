<http://model.geneontology.org/R-HSA-2316344_R-HSA-2316352>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/go/extensions/reacto.owl#REACTO_R-HSA-2316344> ;
        <http://www.w3.org/2000/01/rdf-schema#comment>
                "located_in cytoplasmic vesicle membrane" , "Original Reactome ID: R-HSA-2316344" ;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "GGC-RALA:GTP:MYO1C:Calmodulin:F-actin" ;
