gomodel:SYNGO_2442653c6e43-feb8-4c9e-afc7-ab77c8ae8449
        a               owl:NamedIndividual , obo:ECO_0006006 ;
        dc:contributor  "https://orcid.org/0000-0002-5676-366X" , "https://orcid.org/0000-0001-9783-5183" ;
