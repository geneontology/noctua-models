        rdfs:label          "TNF-α:TNFR1:TRADD:K63polyUb-RIPK1:BIRC2,3,4" ;
        dc:contributor      "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "Reactome:R-HSA-5357756" ;
