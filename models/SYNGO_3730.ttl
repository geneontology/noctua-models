gomodel:SYNGO_3730  a     owl:Ontology ;
        rdfs:comment      "Rationale: Crk-L is a postsynaptic protein which plays a crucial role in NMJ synapse formation concomitantly with CrkI/II, by directly interacting with Dok-7.\n\nFig.3: \"Dok-7 tyrosine phosphorylation plays a critical role in AChR clustering\"\n- \"(A,B) Overexpression of wild-type Dok-7 stimulated AChR clustering (~50-fold), independently of Agrin. Mutation of either Y396 or Y406 impaired AChR clustering, and mutation of both residues reduced AChR clustering still further\". Experimental description: - \"Murine Dok-7 (GenBank: BAE96740) cDNA was isolated by PCR from C2 muscle c\" --> mouse" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0575-6950" , "https://orcid.org/0000-0002-1585-539X" ;
        dc:date           "2018-06-06" ;
        dc:title          "SYNGO_BP_3730" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

