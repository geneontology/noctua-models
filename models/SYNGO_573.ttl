obo:GO_0003674  a  owl:Class .

gomodel:SYNGO_573  a      owl:Ontology ;
        rdfs:comment      "Rationale: Immunoblotting analysis of subcellular fractions from rat brain with antibodies to SCAMPs 1 and 5, and to the NMDA receptor as control.\n\nThe sub fractionation allows to enrich crude synaptic vesicles (LP2 fraction), and from these, a highly purified synaptic vesicles fraction (SV fraction) can be obtained. Figure 6 demonstrates a massive enrichment of SCAMP1 in both the LP2 and SV samples, suggesting that the protein is localized to synaptic vesicles.. Experimental description: Immunoblotting analysis of subcellular fractions from rat brain." , "Automated change 2024-03-14: GO:0030285 replaced by GO:0030672" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-3185-5709" , "https://orcid.org/0000-0002-0755-5899" , "https://orcid.org/0000-0001-7351-8706" , "https://orcid.org/0000-0003-0938-8534" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_573" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

