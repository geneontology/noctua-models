gomodel:SYNGO_2647  a     owl:Ontology ;
        rdfs:comment      "Rationale: Lack of PTPRA impairs LTP in hippocampal slices.. Experimental description: Materials and methods\nGene targeting\nBriefly, a IRES/β-geo cassette was inserted under the control of the endogenous Ptpra promoter; this left no detectable RPTPα protein expressed. The mutation was propagated on a mixed 129SvEv × 129SvJ background, and for electrophysiological and behavioral studies was also backcrossed five times into C57/Bl6." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-6194-9648" , "https://orcid.org/0000-0001-5518-6584" ;
        dc:date           "2018-03-02" ;
        dc:title          "SYNGO_BP_2647" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

