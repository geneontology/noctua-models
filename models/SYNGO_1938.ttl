gomodel:SYNGO_1938  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.7: \"Cbln1 and Cbln2 serve as a presynaptic organizer in hippocampal neurons\"\n\"Immunocytochemical analyses showed that HEK293 cells expressing GluD2 but not those expressing GluD2ΔNTD accumulated synaptophysin-positive presynaptic terminals of hippocampal neurons only when recombinant HA-Cbln1 protein was added to the culture medium (Fig. 7A).\". Experimental description: \"Mixed cerebellar cultures were prepared from embryonic day 17 to day-of-birth ICR or cbln1-null mice as previously described (Matsuda et al., 2009).\" p. 1448\n\n20/11/2017 Pim\n- Overexpressed protein is of rat species: \"Rat cDNA encoding GluD2 was a gift from Dr J. Boulter ....\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-0269-0311" , "https://orcid.org/0000-0001-9377-7414" , "https://orcid.org/0000-0002-9681-3318" , "https://orcid.org/0000-0002-9880-1214" ;
        dc:date           "2017-11-20" ;
        dc:title          "SYNGO_BP_1938" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

