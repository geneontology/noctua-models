:R-HSA-112310  a            owl:NamedIndividual , obo:GO_0007269 ;
        rdfs:comment        "Neurotransmitter is stored in the synaptic vesicle in the pre-synaptic terminal prior to its release in the synaptic cleft upon depolarization of the pre-synaptic membrane. The release of the neurotransmitter is a multi-step process that is controlled by electrical signals passing through the axons in form of action potential. Neurotransmitters include glutamate, acetylcholine, nor-epinephrine, dopamine and seratonin. Each of the neurotransmitter cycle is independently described." ;
        rdfs:label          "Neurotransmitter release cycle" ;
        dc:contributor      "Edited: Mahajan, SS, 2008-01-14 16:01:52" , "GOC:reactome_curators" , "Reviewed: Restituito, S, Kavalali, E, 2008-12-02 04:33:19" , "Authored: Mahajan, SS, 2008-01-14 16:01:52" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-112310" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-112315/R-HSA-112315> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

