gomodel:SYNGO_5398  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 7: confocal imaging of THY1 labeled with a fluorescent protein in transgenic mice showed labeling was confined to neurons, and YFP labeled neurons in their entirety, including somata, nuclei, axons, dendrites, and dendritic spines.\n\nNote that THY1 fill presynaptic terminals as well, though not highlighted with zoom-in in Figure 7. Figure 1 shows presynaptic THY1 in adult neuromuscular junctions. PMID:15601941 is an example of GFP-THY1 fill of axons and giant mossy fiber boutons.. Experimental description: M&M: Thy1-YFP mice, Feng et al., 2000, PMID:11086982" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2023-03-15" ;
        dc:title          "SYNGO_CC_5398" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

