<http://model.geneontology.org/67c10cc400002026> a owl:Ontology ;
    ns2:modelstate "production"^^xsd:string ;
    dc:contributor "https://orcid.org/0000-0001-6330-7526"^^xsd:string,
        "https://orcid.org/0009-0003-9059-1333"^^xsd:string ;
    dc:date "2025-11-29"^^xsd:string ;
    dc:title "biotin import across plasma membrane (GO:1905135),  biotin biosynthetic process (GO:0009102),  protein maturation (GO:0051604) - biotinylated proteins"^^xsd:string ;
    ns1:providedBy "http://www.pombase.org"^^xsd:string ;
    rdfs:comment "These pathway holes are working on the assumption that the location of biotin synthase is correct, but this seems unlikely, especially since the substrates are both cytosolic. Maybe there is aun undiscovered biotinylated protein in the mitochondrion?"^^xsd:string ;
    ns4:in_taxon ns3:NCBITaxon_4896 .

