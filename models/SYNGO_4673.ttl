gomodel:SYNGO_4673  a     owl:Ontology ;
        rdfs:comment      "Rationale: TrkB is localized by immunostaining at presynaptic terminals as visualized by confocal and STED microscopy using a presynaptic marker (Synaptophysin or Bassoon).. Experimental description: The protein was detected by immunostaining in rat hippocampal neurons. Antibody used is goat anti-TrkB (cys32-His429) from R&D Systems." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0575-6950" , "https://orcid.org/0000-0002-1585-539X" ;
