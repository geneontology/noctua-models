obo:GO_0030552  a  owl:Class .

:R-HSA-164378  a            owl:NamedIndividual , obo:GO_0071377 ;
        rdfs:comment        "Adenylate cyclase catalyses the synthesis of cyclic AMP (cAMP) from ATP. In the absence of cAMP, protein kinase A (PKA) exists as inactive tetramers of two catalytic subunits and two regulatory subunits. cAMP binding to PKA tetramers causes them to dissociate and release their catalytic subunits as active monomers. Four isoforms of the regulatory subunit are known, that differ in their tissue specificity and functional characteristics, but the specific isoform activated in response to glucagon signaling has not yet been identified." ;
        rdfs:label          "PKA activation in glucagon signalling" ;
        dc:contributor      "Authored: Gopinathrao, G, D'Eustachio, P, 2005-05-19 14:01:31" , "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-164378" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-163359/R-HSA-163359> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

