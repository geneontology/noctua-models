:R-HSA-2029482  a           owl:NamedIndividual , obo:GO_0008150 ;
        rdfs:comment        "The actin cytoskeleton is fundamental for phagocytosis and members of the Rho family GTPases RAC and CDC42 are involved in actin cytoskeletal regulation leading to pseudopod extension. Active RAC and CDC42 exert their action through the members of WASP family proteins (WASP/N-WASP/WAVE) and ARP2/3 complex. Actin filaments move from the bottom toward the top of the phagocytic cup during pseudopod extension." ;
        rdfs:label          "Regulation of actin dynamics for phagocytic cup formation" ;
        dc:contributor      "Reviewed: Rosales, C, 2012-05-14" , "Authored: Garapati, P V, 2012-01-04" , "Edited: Garapati, P V, 2012-01-04" , "GOC:reactome_curators" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-2029482" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-2029480/R-HSA-2029480> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

