gomodel:SYNGO_4538  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure S1A-B: Primary hippocampal neurons stained with anti-DPP6 antibody show localisation in the dendritic spines. Majority of the anti-DPP6 puncta colocalises with postsynaptic density marker PSD95.\nFigure S1C: The lack of anti-DPP6 staining in DPP6 KO neurons is indicative of the antibody's specificity.\n\nThe term \"synapse\" was chosen as the annotated microscopic data doesn't have sufficient resolution for a specific term.. Experimental description: Primary hippocampal neuron cultures from E18-19 WT mice were prepared as described in PMID:17582333." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-2916-7616" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2022-04-29" ;
        dc:title          "SYNGO_CC_4538" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

