:R-HSA-432720  a            obo:GO_0008150 , owl:NamedIndividual ;
        rdfs:comment        "Proteins that have been synthesized, processed and sorted eventually reach the final steps of the secretory pathway. This pathway is responsible not only for proteins that are secreted from the cell but also enzymes and other resident proteins in the lumen of the ER, Golgi, and lysosomes as well as integral proteins transported in the vesicle membranes. Here the proteins in this secretory pathway are ultimately found in lysososmes." ;
        rdfs:label          "Lysosome Vesicle Biogenesis" ;
        dc:contributor      "GOC:reactome_curators" , "Reviewed: Simpson, Jeremy C, 2009-08-27" , "Edited: Gillespie, ME, 2009-08-12" , "Authored: Gillespie, ME, 2009-08-27" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-432720" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-199992/R-HSA-199992> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

