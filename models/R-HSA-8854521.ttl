pav:providedBy  a  owl:AnnotationProperty .

:R-HSA-8854521  a           obo:GO_0008150 , owl:NamedIndividual ;
        rdfs:comment        "PHLDA1 (TDAG51), the product of a gene involved in breast cancer progression, interacts with aurora kinase A (AURKA). While unphosphorylated PHLDA1 promotes AURKA ubiquitination and degradation, AURKA-mediated phosphorylation of PHLDA1 results in down-regulation of PHLDA1 protein levels. Ectopic expression of PHLDA1 strongly antagonizes AURKA-triggered oncogenic phenotypes, suggesting PHLDA1 downregulation as one of the key mechanisms by which AURKA promotes breast cancer (Johnson et al. 2011)." ;
        rdfs:label          "Interaction between PHLDA1 and AURKA" ;
        dc:contributor      "Authored: Orlic-Milacic, Marija, 2016-01-29" , "Edited: Orlic-Milacic, Marija, 2016-01-29" , "GOC:reactome_curators" , "Reviewed: Shah, Kavita, 2016-02-04" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-8854521" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-69275/R-HSA-69275> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

