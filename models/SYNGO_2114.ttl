obo:GO_0098921  a  owl:Class .

gomodel:SYNGO_2114  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.2: \"Endocannabinoid-Mediated Retrograde Suppression Is Absent in the Cerebellum of α-KO Mice\"\n\nFig.3: \"Endocannabinoid-Mediated Retrograde Suppression Is Absent in the Hippocampus and Striatum of α-KO Mice\"\n\nNote1: the retrograde aspect of the effect is demonstrated by the effect of depolarization of the postsynaptic cell that has effects on the presynaptic release of neurotransmitter.\nNote2: The effect is shown to be on GABAergic and Glutamatergic synaptic currents in the hippocampus and striatum. I did not have sufficient space in the menus to accomodate this combinatorial complexity.. Experimental description: \"Mice were decapitated following CO2 anesthesia, a...\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-4973-5732" ;
        dc:date           "2023-02-26" ;
        dc:title          "SYNGO_BP_2114" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

