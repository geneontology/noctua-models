pav:providedBy  a  owl:AnnotationProperty .

gomodel:SYNGO_1436  a     owl:Ontology ;
        rdfs:comment      "Rationale: Adult rat forebrains were isolated, homogenized and then centrifuged multiple times (including one spin with a sucrose gradient) to yield postsynaptic densities (PSDs). PSDs were then separated on a 1D SDS gel and 14 gel slices were cut from this gel. The slices were trypsinzied and then separated using LC-MS/MS. MS/MS spectra were then compared to the NCBI database using the Sequest algorithm to identify peptides. 374 proteins were found in the PSD.. Experimental description: Paper just specifies rat with no reference to strain in this paper or the cited papers about the protocol." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-1212-5623" , "https://orcid.org/0000-0003-2533-9548" , "https://orcid.org/0000-0002-5648-066X" , "https://orcid.org/0000-0001-7480-0826" , "https://orcid.org/0000-0003-4022-8707" ;
        dc:date           "2017-11-21" ;
        dc:title          "SYNGO_CC_1436" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

