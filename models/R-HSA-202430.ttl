gomodel:R-HSA-202430  a   owl:Ontology ;
        rdfs:comment      "http://www.reactome.org" , "Imported from Reactome: https://reactome.org/content/detail/R-HSA-202430" , "For logical inference, import the integrated tbox ontology http://purl.obolibrary.org/obo/go/extensions/go-lego-reacto.owl" ;
        lego:modelstate   "development" ;
        dc:contributor    "GOC:reactome_curators" ;
        dc:date           "2026-06-29" ;
        dc:title          "Translocation of ZAP-70 to Immunological synapse - imported from: Reactome" ;
        pav:providedBy    "https://reactome.org" ;
        biolink:in_taxon  obo:NCBITaxon_9606 .

:R-HSA-202430  a            obo:GO_0008150 , owl:NamedIndividual ;
        rdfs:comment        "The dual phosphorylated ITAMs recruit SYK kinase ZAP70 via their tandem SH2 domains (step 8). ZAP70 subsequently undergoes phosphorylation on multiple tyrosine residues for further activation. ZAP70 includes both positive and negative regulatory sites. Tyrosine 493 is a conserved regulatory site found within the activation loop of the kinase domain. This site has shown to be a positive regulatory site required for ZAP70 kinase activity and is phosphorylated by LCK (step 9). This phosphorylation contributes to the active conformation of the catalytic domain. Later ZAP70 undergoes trans-autophosphorylation at Y315 and Y319 (step 10). These sites appear to be positive regulatory sites. ZAP70 achieves its full activation after the trans-autophosphorylation. Activated ZAP70 along with LCK phosphorylates the multiple tyrosine residues in the adaptor protein LAT (step 11). PTPN22 can dephosphorylate and inhibit ZAP70 activity to downregulate TCR signaling (step 12)." ;
        rdfs:label          "Translocation of ZAP-70 to Immunological synapse" ;
        dc:contributor      "GOC:reactome_curators" , "Reviewed: Trowsdale, J, 2008-02-26 12:02:59" , "Authored: Rudd, C.E., de Bono, B, Garapati, P V, 2008-01-24 15:53:10" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-202430" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-202403/R-HSA-202403> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

[ a                      owl:Axiom ;
  rdfs:comment           "Imported from Reactome: https://reactome.org/content/detail/R-HSA-202430" , "Entity Regulation Rule 3. The relation 'Phosphorylation of ZAP-70 by Lck' 'null' 'Activation of ZAP-70' was inferred because:\n reaction1 has an output that is the enabler of reaction 2." ;
  lego:evidence          gomodel:ev_w_id_R-HSA-202168_RO_0002629_R-HSA-202174_Reactome_R-HSA-202430 ;
  dc:contributor         "GOC:reactome_curators" ;
