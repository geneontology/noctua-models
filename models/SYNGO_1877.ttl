gomodel:SYNGO_1877  a     owl:Ontology ;
        rdfs:comment      "Rationale: PSDs were isolated from the forebrains of 30 days old untreated rats and analysed by mass spectrometry.\n\n\"Poly(rC)-binding protein 1\" is listed in table 1 as NCBI protein gi|6754994\n\nfrom https://www.ncbi.nlm.nih.gov/protein/6754994 this maps to MGI:1345635 = uniprot identifier P60335. This is a mouse protein, so it appears the original publication used a multi-species database (which was not uncommon at time of publication). The matching identifier in rat genome database is RGD:1561319 and NCBI gene ID 500242.. Experimental description: 30-days-old rats; subspecies not specified." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-9848-0262" , "https://orcid.org/0000-0002-2094-7491" , "https://orcid.org/0000-0002-4419-210X" , "https://orcid.org/0000-0002-1190-4481" ;
        dc:date           "2023-11-08" ;
        dc:title          "SYNGO_CC_1877" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

