gomodel:SYNGO_2198  a     owl:Ontology ;
        rdfs:comment      "Rationale: fig4:reserve pool replenishment inhibited.\nfig6:exocytosis not affected.\nfig7:bulk endocytosis not affected.\n\nrat primary neuronal cultures, rat cerebellar granule neurons. Antibody Anti-AP-1-gamma from BD Biosciences.\n\n11/12/2017 Pim\nThe AP-3D shRNA's (ACAAAGTGTTCCTCAAGTA, CTATCATCCTGGAGAATCA) were traced back to rat Ap3d1 gene via blast analysis.. Experimental description: \"Preparation, transfections, and immunofluorescence studies of rat cerebellar granule neurons (prepared from 7-d-old pups of either sex) were carried out according to previously described protocols (Tan et al., 2003; Clayton et al., 2009).\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2017-12-11" ;
        dc:title          "SYNGO_BP_2198" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

