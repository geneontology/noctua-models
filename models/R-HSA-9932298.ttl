<http://model.geneontology.org/R-HSA-9932868_R-HSA-9932859>
        a       <http://purl.obolibrary.org/obo/go/extensions/reacto.owl#REACTO_R-HSA-9932868> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
        <http://www.w3.org/2000/01/rdf-schema#comment>
                "located_in cytosol" , "Original Reactome ID: R-HSA-9932868" ;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "K48polyUb-K107,p-S-CRY1;K48polyUb-K126,p-S-CRY2" ;
        <http://purl.org/dc/elements/1.1/contributor>
