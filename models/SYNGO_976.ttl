gomodel:SYNGO_976  a      owl:Ontology ;
        rdfs:comment      "Rationale: The localization of Aldolase C (Zebrin II) was examined using immunogold labelling for electron microscopy. Gold particles were abundant in spines and dendrites, and, according to the paper: 'zebrin appeared to be located mainly over cytoplasmic matrix.' Zebrin immunostaining was present only in the dendrites and spines of Purkinje cells.. Experimental description: 'Animals. Wistar rats from Møllegaard Hansen were kept in the animal\nfacility at the Institute of Basic Medical Sciences.'" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-3185-5709" , "https://orcid.org/0000-0003-0938-8534" , "https://orcid.org/0000-0001-7351-8706" , "https://orcid.org/0000-0002-0755-5899" ;
        dc:date           "2017-07-03" ;
        dc:title          "SYNGO_CC_976" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

