lego:iuphar_id  a  owl:AnnotationProperty .

:5a7e68a100001514  a    obo:GO_0035195 , owl:NamedIndividual ;
        rdfs:comment    "\" The Ddx5 mRNA and protein levels were significantly down-regulated by miR-462 mimics but increased by the miR-462 inhibitor (Fig. 3D, E). Additionally, in contrast to Hif-1α and miR-462/miR-731 cluster, the endogenous Ddx5 protein level was significantly reduced in cells treated with CoCl2 in a time-dependent manner (Fig. 2E). These results indicated that Ddx5 is a bona fide target of miR-462 and can be effectively regulated under hypoxic stress.\"" , "The paper shows correlation between miR-462 and ddx5 levels but no causal link between the two observations. - PG " ;
        layout:x        "696" ;
        layout:y        "21" ;
        obo:RO_0004046  :5a7e68a100001521 ;
        dc:contributor  "https://orcid.org/0000-0002-1706-4196" , "https://orcid.org/0000-0003-1813-6857" ;
        dc:date         "2018-05-11" ;
        pav:providedBy  "http://geneontology.org" , "http://www.wormbase.org" .

