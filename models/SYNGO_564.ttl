gomodel:SYNGO_564  a      owl:Ontology ;
        rdfs:comment      "Rationale: Figure 1b demonstrates a reduction in the uptake of the neurotransmitter glutamate in synaptosomes from VGLUT1 knockout mice in comparison to controls, with no changes observed in seratonin uptake.\n\n16/8/2017 Pim\nLiteral: \"Synaptic vesicle-enriched membrane fractions from VGLUT1-/- animals also exhibited a reduction in glutamate but not serotonin uptake\" (Fig.1B). Experimental description: To examine the role of the different VGLUT isoforms in vivo, we inactivated mouse\nVGLUT1 by deleting the first two transmembrane domains through homologous recombination in embryonic stem cells (fig. S1)." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0938-8534" , "https://orcid.org/0000-0002-0755-5899" , "https://orcid.org/0000-0003-3185-5709" , "https://orcid.org/0000-0001-7351-8706" ;
        dc:date           "2018-01-25" ;
        dc:title          "SYNGO_BP_564" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

