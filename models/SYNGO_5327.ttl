gomodel:SYNGO_5327  a     owl:Ontology ;
        rdfs:comment      "Automated change 2024-03-14: GO:0099699 replaced by GO:0097060" , "Rationale: Figure 4: proximity labeling of synaptic cleft proteins identified PCDH9.\n\nFigure 5: immunofluorescence labeling of overexpressed PCDH9 showed partial co-localization with VGLUT1 and Bassoon in cortical neuron cultures from rat brain.. Experimental description: species of the overexpressed protein is not listed, annotating against the identified protein in the proximity labeling assay.\n\n\"We therefore opted to use dissociated neuron culture, rather than intact brain tissue, to allow for rapid delivery and washout of biotin-phenol, H2O2, and subsequent peroxidase quenchers. At DIV19 (19 days in vitro), our embryonic rat cortical neuron cultures displayed abundant staining of synapse markers ...\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_5327" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

