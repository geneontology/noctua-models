:R-HSA-9969901  a           obo:GO_0006695 , owl:NamedIndividual ;
        rdfs:comment        "Tracer studies in intact mice and human and mouse cell lines showed little flux through the complete KR pathway in any tissue. Instead, a modified form of the pathway was observed, in which delta(24)-sterol reductase (DHCR24) reduced zymosterol (ZYMOL), a Bloch pathway intermediate, to zymostenol (ZYMSTNL), a KR intermediate, which was then metabolized via the last three steps of the KR pathway to form cholesterol. Usage of this pathway was observed in skin, preputial glands and brain (Mitsche et al. 2015)." ;
        rdfs:label          "Cholesterol biosynthesis from zymosterol (modified Kandutsch-Russell pathway)" ;
        dc:contributor      "GOC:reactome_curators" , "Edited: D'Eustachio, Peter, 2025-10-24" , "Authored: D'Eustachio, Peter, 2025-10-24" , "Reviewed: Hill, David P, 2025-10-24" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-9969901" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-191273/R-HSA-191273> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

