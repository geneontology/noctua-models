gomodel:SYNGO_3816  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.4: \"Panels D-F show the presence of the terminal ending of a single neuron (arrow) and its axon (arrowhead) present in the dermis and labeled strongly for both integrin α2 (D) as well as for peripherin (E). Superimposed D and E images are shown in F, and indicate stronger co-localization of integrin α2 and peripherin at the receptive ending than at the axon of this neuron.\". Experimental description: \"Skin specimens were obtained from the medial thigh of the opposite hindlimbs of the rats used in the neurophysiological experiments.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2018-06-27" ;
        dc:title          "SYNGO_CC_3816" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

