dc:source  a    owl:AnnotationProperty .

gomodel:SYNGO_4750  a     owl:Ontology ;
        rdfs:comment      "Rationale: AP1M1 was detected in synaptosomal and synaptic vesicle biochemical fractions from both mouse cerebellum and cortex.\n\nSynaptic localization is further supported by the observation that 1) AP-1 complexes play a role in synaptic CCV recycling (PMID:20203623), and 2) AP-1 complexes contain a mu-subunit (PMID:15377783) and this can only be AP1M1, as AP1M2 expression in brain is very low.. Experimental description: \"Adult (>3.5 months old) wild-type male mice (C57BL/6JRj) were purchased from Janvier Labs (Germany).\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" ;
        dc:date           "2022-08-04" ;
        dc:title          "SYNGO_CC_4750" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

