gomodel:SYNGO_734  a      owl:Ontology ;
        rdfs:comment      "Rationale: Fig 2 uses immunofluorescence analysis to demonstrate that PIP kinase Igamma is localized in the presynaptic compartment. Fig 6 uses immunogold electron microscopy to demonstrate that PIP kinase Igamma is localized to the presynaptic plasma membrane as well as the cytososl and coated endocytic intermediates. In figure 6C, the authors report a strikingly selective localization of PIPKIγ immunoreactivity on membrane regions directly adjacent to clathrin-coated buds while synaptic vesicles were consistently unlabelled.. Experimental description: From results, \"Immunofluorescence of rat brain sections taken from the brain stem and stained with anti-PIPKIγ antibodies...\"." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-7806-5662" ;
        dc:date           "2017-08-14" ;
        dc:title          "SYNGO_CC_734" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

pav:providedBy  a  owl:AnnotationProperty .

