obo:ECO_0006003  a  owl:Class .

obo:RO_0002333  a  owl:ObjectProperty .

gomodel:SYNGO_2196  a     owl:Ontology ;
        rdfs:comment      "Rationale: EFA6A was enriched in postsynaptic density fractions.\nEFA6A was localized in dendrites and dendritic spines.\nImmunogold particles for EFA6A were deposited preferentially on the post-synaptic side and distributed inside and near the PSD in the dendritic spine, with the highest density located between 60 and 90 nm from the post-synaptic plasma membrane.. Experimental description: Materials and methods\nImmunohistochemistry\nUnder deep pentobarbital anesthesia (100 mg/kg of body weight, i.p.), four wild-type eight-week-old male C57BL/6N mice were perfused.\nSubcellular fractionation\nForebrains from five adult male C57BL/6N mice were homogenized." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0001-6194-9648" , "https://orcid.org/0000-0001-5518-6584" ;
        dc:date           "2018-01-15" ;
        dc:title          "SYNGO_CC_2196" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

