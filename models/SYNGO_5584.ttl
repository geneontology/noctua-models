gomodel:SYNGO_5584  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 6: immunofluorescence microscopy showed 5-HT4R (gene HTR4, Serotonin receptor 4) localized to postsynapses in the dorsal striatum (that specifically received input from thalamic glutamatergic presynapses). Localization to dendritic spines was approx 30%. Experimental description: M&M:\n\"Postsynaptic localization of 5-HT4R in dSPNs\nLabeling of cortical and thalamic afferents\nTo identify cortical afferents, VGLUT1-Venus knockin mice were used and no injections were required\"\n\nantibody:\nRabbit anti-5-HT4R, AbCam, Cat# ab60359, RRID: AB_2122438" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2023-11-29" ;
        dc:title          "SYNGO_CC_5584" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

