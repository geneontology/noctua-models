gomodel:SYNGO_2150  a     owl:Ontology ;
        rdfs:comment      "Rationale: Local activation GTPase shown with OE of mEGFP-tagged Rac1 (FRET assay with Raichu probes).\n\nFig.3: \"Rich2 selectively regulates Rac1\"\n- Literal: \"We found that transfected Rich2 decreased, whereas Rich2 si-RNA increased the FRET signal of the pRAICHU-Rac1 probes in spines.\". Experimental description: - Species of over-expressed rac1, Cdc42, RhoA Raichu probes is not explicitly stated in the paper. Species traced back to Matsuda lab. Matsuda lab was contacted for species information (matsudam@lif.kyoto-u.ac.jp; laurent.fagni@igf.cnrs.fr , dd. 12/12/2017)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-1542-3498" , "https://orcid.org/0000-0002-0808-7003" , "https://orcid.org/0000-0002-3898-5197" ;
        dc:date           "2018-02-07" ;
        dc:title          "SYNGO_CC_2150" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_9606" .

