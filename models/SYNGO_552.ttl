gomodel:SYNGO_552  a      owl:Ontology ;
        rdfs:comment      "Rationale: Electrophysiological evidences show that in mIPSC recordings from WT and Baiap3 KO hypothalamus slices cultured in the presence of diazepam or vehicle control, Baiap3 WT mIPSC amplitudes were significantly smaller than in KO slices, and WT mIPSC rise times were longer than in KO slices.\nBaiap3 WT slices showed an increase in AP frequency in response to diazepam withdrawal and IPSC amplitudes and IPSC frequencies were increased in Baiap3 WT slices under diazepam withdrawal compared with DMSO-treated WT slices.. Experimental description: Baiap3 mutant mice of mixed 129/Ola;C57BL/6N background were backcrossed for seven more generations to C57BL/6N; all experiments were done with WT and KO littermates of the resulting generation 8" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-1190-4481" , "https://orcid.org/0000-0002-9848-0262" , "https://orcid.org/0000-0002-4419-210X" , "https://orcid.org/0000-0002-2094-7491" ;
        dc:date           "2017-10-09" ;
        dc:title          "SYNGO_BP_552" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

