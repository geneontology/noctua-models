obo:ECO_0005589  a  owl:Class .

gomodel:SYNGO_5262  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 1: SRPX2 overexpression in cultured cortical neurons increased excitatory, but not inhibitory, synapse density.\n\nFigure 2: SRPX2 knockdown and secretion of dominant negative SRPX2 decrease excitatory synaptic density in cultured cortical neurons.\n\nFigure 4: In vivo assay. \"Neurons transfected with SRXP2-directed shRNA showed a decrease in the density of dendritic spines on the apical dendrite of layer V/VI neurons (Fig. 4, B and C), an effect that is reversed by cotransfection of the shRNA-resistant SRPX2 construct.\". Experimental description: Results, Figure 2 legend: \"Rat cortical neurons were cotransfected with BFP and scrambled shRNA, SRPX2 shRNA, or SRPX2 shRNA and rescue construct (SRPX2 rescue) and then stained for excitatory or inhibitory synaptic markers.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-4973-5732" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2023-03-09" ;
        dc:title          "SYNGO_BP_5262" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

