gomodel:SYNGO_985  a      owl:Ontology ;
        rdfs:comment      "Rationale: Myosin Vb was highly enriched in dendritic spines and localized near glutamatergic synapses labeled by PSD-95 (Figure 1B).\n\n3/11/2017 Pim\n- Myo5b is a known actin-based motor protein that has been shown to bind F-actin.. Experimental description: M&M:\nHippocampal neuron cultures were prepared from E18 rat embryos\nco-IPs of endogenous proteins were done from whole rat brains\nElectrophysiology was done in brain slices from MyoVb Y119G transgenic mice or wild type FVB mice (Charles River)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-6153-3586" , "https://orcid.org/0000-0002-2666-0758" ;
        dc:date           "2018-05-31" ;
        dc:title          "SYNGO_CC_985" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

