obo:ECO_0006063  a  owl:Class .

pav:providedBy  a  owl:AnnotationProperty .

gomodel:SYNGO_301  a      owl:Ontology ;
        rdfs:comment      "Rationale: Known ligands (ephrin-A1, ephrin-A3 and ephrin-B2) for EphA4 induce its phosphorylation. Adding a dimerized Fc fusion of the extracellular domain of ephrin-A3 caused spine length retraction, whereas EphA4 Fc moderately reduced spine width presumably due to a dominant-negative effect on endogenous EphA4 interactions (Fig. 2). Dendritic spines of CA1 pyramidal neurons are longer in P19-P21 EphA4 knockout mice, while spine density is normal (Fig. 4). Cells transfected with kinase-inactive EphA4 have longer spines in pyramidal neurons in slices (Fig. 6).. Experimental description: \"slices from each mouse were divided among media\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0912-1514" , "https://orcid.org/0000-0002-3670-7863" ;
        dc:date           "2018-05-30" ;
        dc:title          "SYNGO_BP_301" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

