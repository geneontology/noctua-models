gomodel:SYNGO_4985  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure S2B: Lnx1 was detected in PSD biochemical fractions from mouse hippocampi. The antibody shows an unspecific band, the other band (presumably Lnx1) is abolished in controls using Lnx1 -/- mice.\n\nFigure S2C: confocal imaging of Thy1-GFP-M, synapsin1 and overexpressed Flag-Lnx1 in cultured hippocampal neurons showed localization to dendritic spines.. Experimental description: Supplementary Figure S2 legend: \"(A) Specific postnatal expression of Lnx1 in hippocampus was identified with quantitatively immunoprecipitated (IP) β-gal protein in hippocampal lysates from Lnx1 +/+ or Lnx1 -/- mice during development.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-4973-5732" ;
        dc:date           "2023-02-08" ;
        dc:title          "SYNGO_CC_4985" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

