gomodel:SYNGO_4798  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 1B: superresolution microscopy (3D-STORM) showed that Frizzled3 (FZD3) colocalized with presynaptic marker Bassoon but not with postsynaptic marker PSD-95.\n\nBased on the known transmembrane topology of this protein, \"integral component of ... membrane\" term was selected. As also depicted by authors in Figure 1C.. Experimental description: M&M: \"Hippocampi were dissected from E18.5 mice, and hippocampal neuron culture was performed as previously described\"\n\nantibody:\nanti-Frizzled3 (R&D Systems)" , "Automated change 2024-03-14: GO:0099059 replaced by GO:0048787" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-4973-5732" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_4798" ;
        pav:providedBy    "https://syngo.vu.nl" ;
