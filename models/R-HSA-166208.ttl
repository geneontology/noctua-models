  <http://geneontology.org/lego/evidence>
          <http://model.geneontology.org/ev_w_id_REACTO_R-HSA-377400_R-HSA-5653972_R-HSA-165692_component_BFO_0000051_UniProtKB_Q8N122_R-HSA-377400_R-HSA-165692_component_Reactome_R-HSA-166208> , <http://model.geneontology.org/ev_w_id_REACTO_R-HSA-377400_R-HSA-5653972_R-HSA-165692_component_BFO_0000051_UniProtKB_Q8N122_R-HSA-377400_R-HSA-165692_component_Reactome_R-HSA-377400> ;
