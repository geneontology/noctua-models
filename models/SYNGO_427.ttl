gomodel:SYNGO_427  a      owl:Ontology ;
        rdfs:comment      "Rationale: Fig. 4: biochemical purification of postsynaptic density (PSD) fraction indicates that DRP2 is associated to PSD.\nFig 6: Costaining of DRP2 and PSD-95 on brain slices indicates that DRP2 colocalize with PSD-95.. Experimental description: PSD preparation was made by rat brain. This experiment if featured in Fig. 4. Costaining of DRP2 and PSD-95 on brain slices was made in rat brain. This experiment if featured in Fig. 6.\n\nLiteral from M&M\n\"Subcellular Fractionation and Western Blotting\nFractionation of rat brain homogenates was as previously described\"\n\"Immunohistochemistry\nAdult rat brains were fixed by perfusion with 4%\nparaformaldehyde followed by postfixing overnight.\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-2949-9725" , "https://orcid.org/0000-0003-0662-9523" ;
        dc:date           "2017-05-17" ;
        dc:title          "SYNGO_CC_427" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

