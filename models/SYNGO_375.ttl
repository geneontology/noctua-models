obo:GO_0098978  a  owl:Class .

gomodel:SYNGO_375  a      owl:Ontology ;
        rdfs:comment      "Rationale: Fig 1 shows that knock-down of ephrin-B1 in cultured cortical neurons reduced ephB2-dependent syn-GFP (synaptophysin-GFP) accumulation on co-cultured HEK293 cells expressing EphB2. This supports a pre- and trans-synaptic role for ephrin-B1 in synapse assembly.\n\nFig 4 shows that knock-down of ephrin-B1 in cultured DIV21-23 cortical neurons results in reduced number of presynaptic puncta (syn-GFP), and of colocalized pre- and postsynaptic puncta.. Experimental description: Primary dissociated cortical neurons were prepared from embryonic day 17 (E17) to E18 rats" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0912-1514" , "https://orcid.org/0000-0002-3670-7863" ;
        dc:date           "2018-03-07" ;
        dc:title          "SYNGO_BP_375" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

