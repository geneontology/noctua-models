obo:GO_0036455  a  owl:Class .

:R-HSA-2564830  a           owl:NamedIndividual , obo:GO_0016226 ;
        rdfs:comment        "Iron-sulfur clusters containing 4 atoms of iron and 4 atoms of sulfur (4Fe-4S clusters) are assembled in the cytosol on a heterotetrameric scaffold composed of NUBP2 and NUBP1 subunits (reviewed in Lill et al. 2012, Rouault et al. 2012, Sharma et al. 2010, Lill and Muhlenhoff 2006). The sources of iron and sulfur are uncertain but the process requires a sulfur-containing compound exported from mitochondria via ABCB7 (ABC7). Newly synthesized 4Fe-4S are transferred to apoproteins such as XPD and POLD1 via the CIA targeting complex, composed of NARFL, CIAO1, FAM96B, and MMS19." ;
        rdfs:label          "Cytosolic iron-sulfur cluster assembly" ;
        dc:contributor      "Authored: Lill, Roland, 2012-11-07" , "Edited: May, B, 2012-11-07" , "GOC:reactome_curators" , "Reviewed: Hill, David P, 2025-03-26" , "Reviewed: Uringa, Evert-Jan, 2013-02-05" ;
        dc:date             "2026-06-29" ;
        pav:providedBy      "https://reactome.org" ;
        oboInOwl:hasDbXref  "R-HSA-2564830" ;
        skos:narrower       <http://model.geneontology.org/R-HSA-1430728/R-HSA-1430728> ;
        skos:note           "org.biopax.paxtools.model.level3.Pathway" .

