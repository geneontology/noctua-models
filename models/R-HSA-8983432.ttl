<http://model.geneontology.org/ev_w_id_REACTO_R-HSA-9009701_R-HSA-8983118_R-HSA-8983371_component_BFO_0000051_UniProtKB_P14784_R-HSA-9009701_R-HSA-8983371_component_Reactome_R-HSA-9009701>
        a       <http://purl.obolibrary.org/obo/ECO_0000313> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
