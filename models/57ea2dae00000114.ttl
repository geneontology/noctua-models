ns1:ECO_0000315 a owl:Class .

[] a owl:Axiom ;
    ns2:evidence <http://model.geneontology.org/57ea2dae00000114/57ea2dae00000163> ;
    dc:contributor "https://orcid.org/0000-0002-1706-4196"^^xsd:string ;
    dc:date "2016-09-28"^^xsd:string ;
    rdfs:comment "ES (PMID:11580895): Transgenic animals carrying this fusion gene expressed GFP in the bilateral AFD neurons as well as in the nine pharyngeal marginal cells (Figure 3A). The TTX-1-GFP-tagged pro- tein is localized to the nuclei of all cells."^^xsd:string ;
    owl:annotatedProperty ns1:BFO_0000066 ;
    owl:annotatedSource <http://model.geneontology.org/57ea2dae00000114/57ea2dae00000119> ;
    owl:annotatedTarget <http://model.geneontology.org/57ea2dae00000114/57ea2dae00000116> .

[] a owl:Axiom ;
    dc:contributor "https://orcid.org/0000-0002-1706-4196"^^xsd:string ;
    dc:date "2016-09-28"^^xsd:string ;
    owl:annotatedProperty ns1:RO_0002333 ;
    owl:annotatedSource <http://model.geneontology.org/57ea2dae00000114/57ea2dae00000119> ;
    owl:annotatedTarget <http://model.geneontology.org/57ea2dae00000114/57ea2dae00000120> .

[] a owl:Axiom ;
    ns2:evidence <http://model.geneontology.org/57ea2dae00000114/57ea2dae00000145>,
        <http://model.geneontology.org/57ea2dae00000114/57ea2dae00000154> ;
    dc:contributor "https://orcid.org/0000-0002-1706-4196"^^xsd:string ;
    dc:date "2016-09-28"^^xsd:string ;
    rdfs:comment """ES (PMID:11580895): We found that, consistent with previous reports, in most animals examined, the sensory endings of the AFD neurons were grossly abnormal, with complete loss of the finger-like projections and extension of the cilia (Figure 1D). This defect was evident even in
young larvae, indicating that TTX-1 function may be required throughout development for correct morphogenesis of the AFD sensory endings."""^^xsd:string,
        "ES (PMID:2428682): The fingers of the AFD neurons in the cryophilic mutant ttx-1 (p767; formerly EH67, Hedgecock and Russell, 1975) are entirely missing.  Instead, a fingerless sack of membrane protrudes from the dendrites just below the cilia (Fig. 32)."^^xsd:string ;
    owl:annotatedProperty ns1:RO_0002411 ;
    owl:annotatedSource <http://model.geneontology.org/57ea2dae00000114/57ea2dae00000115> ;
    owl:annotatedTarget <http://model.geneontology.org/57ea2dae00000114/57ea2dae00000136> .

[] a owl:Axiom ;
    ns2:derived "true"^^xsd:string ;
    owl:annotatedProperty rdfs:label ;
    owl:annotatedSource <http://identifiers.org/wormbase/WBGene00006652> ;
    owl:annotatedTarget "ttx-1 Cele"^^xsd:string .

[] a owl:Axiom ;
    dc:contributor "https://orcid.org/0000-0002-1706-4196"^^xsd:string ;
    dc:date "2016-09-28"^^xsd:string ;
    owl:annotatedProperty ns1:RO_0002213 ;
    owl:annotatedSource <http://model.geneontology.org/57ea2dae00000114/57ea2dae00000119> ;
    owl:annotatedTarget <http://model.geneontology.org/57ea2dae00000114/57ea2dae00000121> .

