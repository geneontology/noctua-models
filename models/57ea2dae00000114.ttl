:57ea2dae00000120  a    owl:NamedIndividual , <http://identifiers.org/wormbase/WBGene00006652> ;
        dc:contributor  "https://orcid.org/0000-0002-1706-4196" ;
        dc:date         "2016-09-28" .

[ a                      owl:Axiom ;
  rdfs:comment           "ES (PMID:11580895): Transgenic animals carrying this fusion gene expressed GFP in the bilateral AFD neurons as well as in the nine pharyngeal marginal cells (Figure 3A). The TTX-1-GFP-tagged pro-\ntein is localized to the nuclei of all cells." ;
  lego:evidence          :57ea2dae00000162 ;
  dc:contributor         "https://orcid.org/0000-0002-1706-4196" ;
  dc:date                "2016-09-28" ;
  owl:annotatedProperty  obo:BFO_0000066 ;
  owl:annotatedSource    :57ea2dae00000119 ;
  owl:annotatedTarget    :57ea2dae00000161
] .

:57ea2dae00000161  a     owl:NamedIndividual , obo:GO_0005634 ;
        layout:x         "392.7500457763672" ;
        layout:y         "8" ;
        obo:BFO_0000050  :57ea2dae00000116 ;
        dc:contributor   "https://orcid.org/0000-0002-1706-4196" ;
        dc:date          "2016-09-28" .

[ a                      owl:Axiom ;
  rdfs:comment           "ES (PMID:11580895): We found that, consistent with previous reports, in most animals examined, the sensory endings of the AFD neurons were grossly abnormal, with complete loss of the finger-like projections and extension of the cilia (Figure 1D). This defect was evident even in\nyoung larvae, indicating that TTX-1 function may be required throughout development for correct morphogenesis of the AFD sensory endings." , "ES (PMID:2428682): The fingers of the AFD neurons in the cryophilic mutant ttx-1 (p767; formerly EH67, Hedgecock and Russell, 1975) are entirely missing.  Instead, a fingerless sack of membrane protrudes from the dendrites just below the cilia (Fig. 32)." ;
  lego:evidence          :57ea2dae00000145 , :57ea2dae00000154 ;
  dc:contributor         "https://orcid.org/0000-0002-1706-4196" ;
  dc:date                "2016-09-28" ;
  owl:annotatedProperty  obo:RO_0002411 ;
  owl:annotatedSource    :57ea2dae00000115 ;
  owl:annotatedTarget    :57ea2dae00000136
] .

