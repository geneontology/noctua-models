    dc:contributor "https://orcid.org/0000-0002-1706-4196"^^xsd:string ;
    dc:date "2016-09-28"^^xsd:string ;
    owl:annotatedProperty ns1:BFO_0000050 ;
    owl:annotatedSource <http://model.geneontology.org/57ea2dae00000114/57ea2dae00000121> ;
