<http://model.geneontology.org/ev_w_id_R-HSA-9960175_RO_0002234_R-HSA-9960159_R-HSA-9960175_Reactome_R-HSA-9927418>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/ECO_0000313> ;
