obo:BFO_0000066  a  owl:ObjectProperty .

gomodel:SYNGO_1234  a     owl:Ontology ;
        rdfs:comment      "Rationale: Figure 5: SV2B is enriched in the synaptic vesicle fraction\n\n24/10/2017 Pim\n- Authors note; \"Proteins with an iTRAQ ratio of more than 2.5 are considered to be significantly enriched in the docked synaptic vesicle fraction.\" The ratio for this protein is 1.\n- Based on the known transmembrane topology of the protein, the \"integral component of ... membrane\" term was chosen.\n\n19/01/2021 Dnyanada: PMID: 31959215 added to this annotation uses immunoEM data to demonstrate localisation of SV2 to synaptic vesicles. The anti-SV2 antibody used in the study is not isoform-specific and was added to the additional literature field for all SV2 CC annotations.. Experimental description: Result section, First sentence: To isolate docking complexes from RAT brain, we first prepared synaptosomes and subjected them to limited proteolysis to dissociate pre- and postsynaptic membranes" , "Automated change 2024-03-14: GO:0030285 replaced by GO:0030672" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-2514-0216" , "https://orcid.org/0000-0002-9900-4233" ;
        dc:date           "2024-03-14" ;
        dc:title          "SYNGO_CC_1234" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

