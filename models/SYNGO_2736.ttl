obo:ECO_0006004  a  owl:Class .

gomodel:SYNGO_2736  a     owl:Ontology ;
        rdfs:comment      "Rationale: Wong et.al. use STED microscopy to demonstrate that ELKS2 is present at the active zone. An ELKS2-specific antibody resulted in signal overlapping with Bassoon, an established active zone marker.\n\nThe antibody is characterized with knockout controls in Held et.al.. Experimental description: Primary mouse hippocampal cultures were generated from newborns as previously described (20), and all analyses were performed at DIV 14-17." ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0002-7620-2704" , "https://orcid.org/0000-0002-1558-1958" ;
        dc:date           "2018-03-06" ;
        dc:title          "SYNGO_CC_2736" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

