obo:GO_0003674  a  owl:Class .

gomodel:SYNGO_4783  a     owl:Ontology ;
        rdfs:comment      "Rationale: The HIP14-/- mouse has a loss of synapses in striatum (Figure 2) and the hippocampus (Figure 3). In addition figures 2B,C,G (presynaptic) and H (postsynaptic) suggest disruption of synaptic function. Figure 4E and 4F show structural changes and a loss of plasticity relative to wt control.\n\nThe data is consistent with lipidation of synaptic constituents effecting targeting. Both pre and post are impacted. And the failure to lipidate constituents impacts synaptic structure (synapses disappear in an ill-defined way). Experimental description: Experiments were conducted on the same Hip14-/- mouse line that was previously characterized (PMID21775500)" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-3185-5709" ;
        dc:date           "2022-08-22" ;
        dc:title          "SYNGO_BP_4783" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10090" .

<http://identifiers.org/mgi/MGI:2445110>
