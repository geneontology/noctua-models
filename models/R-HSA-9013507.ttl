<http://model.geneontology.org/R-HSA-9021521_R-HSA-9021523>
        a       <http://purl.obolibrary.org/obo/go/extensions/reacto.owl#REACTO_R-HSA-9021521> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
        <http://www.w3.org/2000/01/rdf-schema#comment>
                "located_in cytosol" , "Original Reactome ID: R-HSA-9021521" ;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "NEXT3,NICD3:WWP2" ;
        <http://purl.org/dc/elements/1.1/contributor>
