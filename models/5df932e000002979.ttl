skos:note  a    owl:AnnotationProperty .

gomodel:5df932e000002979
        a                owl:Ontology ;
        rdfs:comment     "Transducin is the G-alpha subunit (enabling the G protein activity), which activates the breakdown of cGMP, causing the closure of cGMP-gated sodium channels. This, in turn, causes hyperpolarization of the cell from ongoing potassium efflux, causing voltage gated calcium channels to close, calcium levels to drop, decreasing release of glutamate by synaptic vesicles. Glutamate serves as an inhibitory signal for other cells." , "Automated change 2023-03-16: RO:0002213 replaced by RO:0002629" , "Automated change 2023-03-16: RO:0002212 replaced by RO:0002630" ;
        lego:modelstate  "development" ;
        dc:contributor   "https://orcid.org/0000-0002-9074-3507" ;
        dc:date          "2026-04-23" ;
        dc:title         "GPCR opsin signaling (through transducin)" ;
        pav:providedBy   "http://geneontology.org" .

