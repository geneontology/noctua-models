gomodel:SYNGO_2912  a     owl:Ontology ;
        rdfs:comment      "Rationale: Fig.6: \"Overexpression of Hsc70 decreases gephyrin clustering at synapses\"\n- \"We found that overexpressed VeHsc70 significantly decreased the intensity of gephyrin clusters compared with control neurons transfected with EGFP \"\n\nFig.7: \"Hsc70 inhibition induces gephyrin clustering at synapses\"\n- \"CA treatment increased the fluorescence intensity of gephyrin clusters by 27 ± 5% compared with that measured in parallel control experiments\". Experimental description: - \"Adult homozygous knock-in mice were deeply anesthetized...\"\n- \"The Venus-tagged version of Hsc70 was obtained by fusing rat Hsc70 to the Venus-yellow fluorescent protein (YFP)\"" ;
        lego:modelstate   "production" ;
        dc:contributor    "https://orcid.org/0000-0003-0593-3443" , "https://orcid.org/0000-0002-2286-1587" , "https://orcid.org/0000-0002-2514-0216" ;
        dc:date           "2018-03-15" ;
        dc:title          "SYNGO_BP_2912" ;
        pav:providedBy    "https://syngo.vu.nl" ;
        biolink:in_taxon  "http://purl.obolibrary.org/obo/NCBITaxon_10116" .

